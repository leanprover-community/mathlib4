-- test that we can translate between structures, reordering the arguments of the fields
class SemilatticeInf (őĪ : Type) extends PartialOrder őĪ, Min őĪ where
  le_inf : ‚ąÄ a b c : őĪ, a ‚Č§ b ‚Üí a ‚Č§ c ‚Üí a ‚Č§ b ‚äď c

class SemilatticeSup (őĪ : Type) extends PartialOrder őĪ, Max őĪ where
  protected sup_le : ‚ąÄ a b c : őĪ, a ‚Č§ c ‚Üí b ‚Č§ c ‚Üí a ‚äĒ b ‚Č§ c

attribute [to_dual] SemilatticeInf
attribute [to_dual existing] SemilatticeSup.sup_le

@[to_dual]
lemma SemilatticeInf.le_inf' {őĪ : Type} [SemilatticeInf őĪ] (a b c : őĪ) : a ‚Č§ b ‚Üí a ‚Č§ c ‚Üí a ‚Č§ b ‚äď c :=
  SemilatticeInf.le_inf a b c

@[to_dual]
lemma SemilatticeSup.sup_le' {őĪ : Type} [SemilatticeSup őĪ] (a b c : őĪ) : a ‚Č§ c ‚Üí b ‚Č§ c ‚Üí a ‚äĒ b ‚Č§ c :=
  SemilatticeSup.sup_le a b c

structure Lattice (őĪ : Type) extends SemilatticeInf őĪ, SemilatticeSup őĪ

attribute [to_dual existing] Lattice.toSemilatticeInf

