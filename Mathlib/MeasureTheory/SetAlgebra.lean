/-!
# Algebra of sets

In this file we define the notion of algebra of sets and give its basic properties. An algebra
of sets is a family of sets containing the empty set and closed by complement and binary union.
It is therefore similar to a `╧Г`-algebra, except that it is not necessarily closed
by countable unions.

We also define the algebra of sets generated by a family of sets and give its basic properties,
and we prove that it is countable when it is generated by a countable family. We prove that
the `╧Г`-algebra generated by a family of sets `ЁЭТЬ` is the same as the one generated by the algebra
of sets generated by `ЁЭТЬ`.

## Main definitions

* `MeasureTheory.IsSetAlgebra`: property of being an algebra of sets.
* `MeasureTheory.generateSetAlgebra`: the algebra of sets generated by a family of sets.

## Main statements

* `MeasureTheory.mem_generateSetAlgebra_elim`: If a set `s` belongs to the algebra of sets
  generated by `ЁЭТЬ`, then it can be written as a finite union of finite intersections of sets which
  are in `ЁЭТЬ` or have their complement in `ЁЭТЬ`.
* `MeasureTheory.countable_generateSetAlgebra`: If a family of sets is countable then so is
  the algebra of sets generated by it.

## References

* <https://en.wikipedia.org/wiki/Field_of_sets>

## Tags

algebra of sets, generated algebra of sets
-/

public section

open MeasurableSpace Set

namespace MeasureTheory

variable {╬▒ : Type*} {ЁЭТЬ : Set (Set ╬▒)} {s t : Set ╬▒}

/-! ### Definition and basic properties of an algebra of sets -/

/-- An algebra of sets is a family of sets containing the empty set and closed by complement and
union. Consequently it is also closed by difference (see `IsSetAlgebra.diff_mem`) and intersection
(see `IsSetAlgebra.inter_mem`). -/
structure IsSetAlgebra (ЁЭТЬ : Set (Set ╬▒)) : Prop where
  empty_mem : тИЕ тИИ ЁЭТЬ
  compl_mem : тИА тжГsтжД, s тИИ ЁЭТЬ тЖТ sс╢Ь тИИ ЁЭТЬ
  union_mem : тИА тжГs tтжД, s тИИ ЁЭТЬ тЖТ t тИИ ЁЭТЬ тЖТ s тИк t тИИ ЁЭТЬ

namespace IsSetAlgebra

/-- An algebra of sets contains the whole set. -/
theorem univ_mem (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) : univ тИИ ЁЭТЬ :=
  compl_empty тЦ╕ hЁЭТЬ.compl_mem hЁЭТЬ.empty_mem

/-- An algebra of sets is closed by intersection. -/
theorem inter_mem (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) (s_mem : s тИИ ЁЭТЬ) (t_mem : t тИИ ЁЭТЬ) :
    s тИй t тИИ ЁЭТЬ :=
  inter_eq_compl_compl_union_compl .. тЦ╕
    hЁЭТЬ.compl_mem (hЁЭТЬ.union_mem (hЁЭТЬ.compl_mem s_mem) (hЁЭТЬ.compl_mem t_mem))

/-- An algebra of sets is closed by difference. -/
theorem diff_mem (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) (s_mem : s тИИ ЁЭТЬ) (t_mem : t тИИ ЁЭТЬ) :
    s \ t тИИ ЁЭТЬ := hЁЭТЬ.inter_mem s_mem (hЁЭТЬ.compl_mem t_mem)

/-- An algebra of sets is a ring of sets. -/
theorem isSetRing (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) : IsSetRing ЁЭТЬ where
  empty_mem := hЁЭТЬ.empty_mem
  union_mem := hЁЭТЬ.union_mem
  diff_mem := fun _ _ тЖж hЁЭТЬ.diff_mem

/-- An algebra of sets is closed by finite unions. -/
theorem biUnion_mem {╬╣ : Type*} (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) {s : ╬╣ тЖТ Set ╬▒} (S : Finset ╬╣)
    (hs : тИА i тИИ S, s i тИИ ЁЭТЬ) : тЛГ i тИИ S, s i тИИ ЁЭТЬ := hЁЭТЬ.isSetRing.biUnion_mem S hs

/-- An algebra of sets is closed by finite intersections. -/
theorem biInter_mem {╬╣ : Type*} (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) {s : ╬╣ тЖТ Set ╬▒} (S : Finset ╬╣)
    (hs : тИА i тИИ S, s i тИИ ЁЭТЬ) : тЛВ i тИИ S, s i тИИ ЁЭТЬ := by
  by_cases! h : S = тИЕ
  ┬╖ rw [h, тЖР Finset.set_biInter_coe, Finset.coe_empty, biInter_empty]
    exact hЁЭТЬ.univ_mem
  ┬╖ exact hЁЭТЬ.isSetRing.biInter_mem S h hs

end IsSetAlgebra

section generateSetAlgebra

/-! ### Definition and properties of the algebra of sets generated by some family -/

/-- `generateSetAlgebra ЁЭТЬ` is the smallest algebra of sets containing `ЁЭТЬ`. -/
inductive generateSetAlgebra {╬▒ : Type*} (ЁЭТЬ : Set (Set ╬▒)) : Set (Set ╬▒)
  | base (s : Set ╬▒) (s_mem : s тИИ ЁЭТЬ) : generateSetAlgebra ЁЭТЬ s
  | empty : generateSetAlgebra ЁЭТЬ тИЕ
  | compl (s : Set ╬▒) (hs : generateSetAlgebra ЁЭТЬ s) : generateSetAlgebra ЁЭТЬ sс╢Ь
  | union (s t : Set ╬▒) (hs : generateSetAlgebra ЁЭТЬ s) (ht : generateSetAlgebra ЁЭТЬ t) :
      generateSetAlgebra ЁЭТЬ (s тИк t)

/-- The algebra of sets generated by a family of sets is an algebra of sets. -/
theorem isSetAlgebra_generateSetAlgebra :
    IsSetAlgebra (generateSetAlgebra ЁЭТЬ) where
  empty_mem := generateSetAlgebra.empty
  compl_mem := fun _ hs тЖж generateSetAlgebra.compl _ hs
  union_mem := fun _ _ hs ht тЖж generateSetAlgebra.union _ _ hs ht

/-- The algebra of sets generated by `ЁЭТЬ` contains `ЁЭТЬ`. -/
theorem self_subset_generateSetAlgebra : ЁЭТЬ тКЖ generateSetAlgebra ЁЭТЬ :=
  fun _ тЖж generateSetAlgebra.base _

/-- The measurable space generated by a family of sets `ЁЭТЬ` is the same as the one generated
by the algebra of sets generated by `ЁЭТЬ`. -/
@[simp]
theorem generateFrom_generateSetAlgebra_eq :
    generateFrom (generateSetAlgebra ЁЭТЬ) = generateFrom ЁЭТЬ := by
  refine le_antisymm (fun s ms тЖж ?_) (generateFrom_mono self_subset_generateSetAlgebra)
  induction s, ms using generateFrom_induction with
  | hC t ht h =>
    clear h
    induction ht with
    | base u u_mem => exact measurableSet_generateFrom u_mem
    | empty => exact @MeasurableSet.empty _ (generateFrom ЁЭТЬ)
    | compl u _ mu => exact mu.compl
    | union u v _ _ mu mv => exact MeasurableSet.union mu mv
  | empty => exact MeasurableSpace.measurableSet_empty _
  | compl t _ ht => exact ht.compl
  | iUnion t _ ht => exact .iUnion ht

/-- If a family of sets `ЁЭТЬ` is contained in `тДм`, then the algebra of sets generated by `ЁЭТЬ`
is contained in the one generated by `тДм`. -/
theorem generateSetAlgebra_mono {тДм : Set (Set ╬▒)} (h : ЁЭТЬ тКЖ тДм) :
    generateSetAlgebra ЁЭТЬ тКЖ generateSetAlgebra тДм := by
  intro s hs
  induction hs with
  | base t t_mem => exact self_subset_generateSetAlgebra (h t_mem)
  | empty => exact isSetAlgebra_generateSetAlgebra.empty_mem
  | compl t _ t_mem => exact isSetAlgebra_generateSetAlgebra.compl_mem t_mem
  | union t u _ _ t_mem u_mem => exact isSetAlgebra_generateSetAlgebra.union_mem t_mem u_mem

namespace IsSetAlgebra

/-- If a family of sets `ЁЭТЬ` is contained in an algebra of sets `тДм`, then so is the algebra of sets
generated by `ЁЭТЬ`. -/
theorem generateSetAlgebra_subset {тДм : Set (Set ╬▒)} (h : ЁЭТЬ тКЖ тДм)
    (hтДм : IsSetAlgebra тДм) : generateSetAlgebra ЁЭТЬ тКЖ тДм := by
  intro s hs
  induction hs with
  | base t t_mem => exact h t_mem
  | empty => exact hтДм.empty_mem
  | compl t _ t_mem => exact hтДм.compl_mem t_mem
  | union t u _ _ t_mem u_mem => exact hтДм.union_mem t_mem u_mem

/-- If `ЁЭТЬ` is an algebra of sets, then it contains the algebra generated by itself. -/
theorem generateSetAlgebra_subset_self (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) :
    generateSetAlgebra ЁЭТЬ тКЖ ЁЭТЬ := hЁЭТЬ.generateSetAlgebra_subset subset_rfl

/-- If `ЁЭТЬ` is an algebra of sets, then it is equal to the algebra generated by itself. -/
theorem generateSetAlgebra_eq (hЁЭТЬ : IsSetAlgebra ЁЭТЬ) : generateSetAlgebra ЁЭТЬ = ЁЭТЬ :=
  Subset.antisymm hЁЭТЬ.generateSetAlgebra_subset_self self_subset_generateSetAlgebra

end IsSetAlgebra

/-- If a set belongs to the algebra of sets generated by `ЁЭТЬ` then it can be written as a finite
union of finite intersections of sets which are in `ЁЭТЬ` or have their complement in `ЁЭТЬ`. -/
theorem mem_generateSetAlgebra_elim (s_mem : s тИИ generateSetAlgebra ЁЭТЬ) :
    тИГ A : Set (Set (Set ╬▒)), A.Finite тИз (тИА a тИИ A, a.Finite) тИз
    (тИАс╡Й (a тИИ A) (t тИИ a), t тИИ ЁЭТЬ тИи tс╢Ь тИИ ЁЭТЬ) тИз s = тЛГ a тИИ A, тЛВ t тИИ a, t := by
  induction s_mem with
  | base u u_mem =>
    refine тЯи{{u}}, finite_singleton {u},
      fun a ha тЖж eq_of_mem_singleton ha тЦ╕ finite_singleton u,
      fun a ha t ht тЖж ?_, by simpтЯй
    rw [eq_of_mem_singleton ha, ha, eq_of_mem_singleton ht, ht] at *
    exact Or.inl u_mem
  | empty => exact тЯитИЕ, finite_empty, fun _ h тЖж (notMem_empty _ h).elim,
    fun _ ha _ _ тЖж (notMem_empty _ ha).elim, by simpтЯй
  | compl u _ u_ind =>
    rcases u_ind with тЯиA, A_fin, mem_A, hA, u_eqтЯй
    have := finite_coe_iff.2 A_fin
    have := fun a : A тЖж finite_coe_iff.2 <| mem_A a.1 a.2
    refine тЯи{{(f a).1с╢Ь | a : A} | f : (╬а a : A, тЖСa)}, finite_coe_iff.1 inferInstance,
      fun a тЯиf, hfтЯй тЖж hf тЦ╕ finite_coe_iff.1 inferInstance, fun a ha t ht тЖж ?_, ?_тЯй
    ┬╖ rcases ha with тЯиf, rflтЯй
      rcases ht with тЯиa, rflтЯй
      rw [compl_compl, or_comm]
      exact hA a.1 a.2 (f a).1 (f a).2
    ┬╖ ext x
      simp only [u_eq, compl_iUnion, compl_iInter, mem_iInter, mem_iUnion, mem_compl_iff,
        exists_prop, Subtype.exists, mem_setOf_eq, iUnion_exists, iUnion_iUnion_eq',
        iInter_exists]
      constructor <;> intro hx
      ┬╖ choose f hf using hx
        exact тЯиfun тЯиa, haтЯй тЖж тЯиf a ha, (hf a ha).1тЯй, fun _ a ha h тЖж by rw [тЖР h]; exact (hf a ha).2тЯй
      ┬╖ rcases hx with тЯиf, hfтЯй
        exact fun a ha тЖж тЯиf тЯиa, haтЯй, (f тЯиa, haтЯй).2, hf (f тЯиa, haтЯй)с╢Ь a ha rflтЯй
  | union u v _ _ u_ind v_ind =>
    rcases u_ind with тЯиAu, Au_fin, mem_Au, hAu, u_eqтЯй
    rcases v_ind with тЯиAv, Av_fin, mem_Av, hAv, v_eqтЯй
    refine тЯиAu тИк Av, Au_fin.union Av_fin, ?_, ?_, by rw [u_eq, v_eq, тЖР biUnion_union]тЯй
    ┬╖ rintro a (ha | ha)
      ┬╖ exact mem_Au a ha
      ┬╖ exact mem_Av a ha
    ┬╖ rintro a (ha | ha) t ht
      ┬╖ exact hAu a ha t ht
      ┬╖ exact hAv a ha t ht

/-- If a family of sets is countable then so is the algebra of sets generated by it. -/
theorem countable_generateSetAlgebra (h : ЁЭТЬ.Countable) :
    (generateSetAlgebra ЁЭТЬ).Countable := by
  let тДм := {s | s тИИ ЁЭТЬ} тИк {s | sс╢Ь тИИ ЁЭТЬ}
  have count_тДм : тДм.Countable := by
    apply h.union
    have : compl '' ЁЭТЬ = {s | sс╢Ь тИИ ЁЭТЬ} := by
      ext s
      simpa using тЯиfun тЯиx, x_mem, hxтЯй тЖж by simp [тЖР hx, x_mem], fun hs тЖж тЯиsс╢Ь, hs, by simpтЯйтЯй
    exact this тЦ╕ h.image compl
  let f : Set (Set (Set ╬▒)) тЖТ Set ╬▒ := fun A тЖж тЛГ a тИИ A, тЛВ t тИИ a, t
  let ЁЭТЮ := {a | a.Finite тИз a тКЖ тДм}
  have count_ЁЭТЮ : ЁЭТЮ.Countable := countable_setOf_finite_subset (countable_coe_iff.1 count_тДм)
  let ЁЭТЯ := {A | A.Finite тИз A тКЖ ЁЭТЮ}
  have count_ЁЭТЯ : ЁЭТЯ.Countable := countable_setOf_finite_subset (countable_coe_iff.1 count_ЁЭТЮ)
  have : generateSetAlgebra ЁЭТЬ тКЖ f '' ЁЭТЯ := by
    intro s s_mem
    rcases mem_generateSetAlgebra_elim s_mem with тЯиA, A_fin, mem_A, hA, rflтЯй
    exact тЯиA, тЯиA_fin, fun a ha тЖж тЯиmem_A a ha, hA a haтЯйтЯй, rflтЯй
  exact (count_ЁЭТЯ.image f).mono this

end generateSetAlgebra

end MeasureTheory
