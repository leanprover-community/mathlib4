variable {ő≤ : Type*} {mő≤ : MeasurableSpace ő≤} {őĹ : Measure ő≤} [SFinite őĹ]

theorem prod_withDensity_left‚āÄ {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : AEMeasurable f őľ) :
    (őľ.withDensity f).prod őĹ = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ f z.1) := by
  refine ext_of_lintegral _ fun ŌÜ hŌÜ ‚Ü¶ ?_
  rw [lintegral_prod _ hŌÜ.aemeasurable, lintegral_withDensity_eq_lintegral_mul‚āÄ hf,
    lintegral_withDensity_eq_lintegral_mul‚āÄ _ hŌÜ.aemeasurable, lintegral_prod]
  ¬∑ refine lintegral_congr (fun x ‚Ü¶ ?_)
    rw [Pi.mul_apply, ‚Üź lintegral_const_mul'' _ (by fun_prop)]
    simp
  all_goals fun_prop (disch := intro _ hs; simp [hs])

theorem prod_withDensity_left {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) :
    (őľ.withDensity f).prod őĹ = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ f z.1) :=
  prod_withDensity_left‚āÄ hf.aemeasurable

theorem prod_withDensity_right‚āÄ {g : ő≤ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : AEMeasurable g őĹ) :
    őľ.prod (őĹ.withDensity g) = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ g z.2) := by
  refine ext_of_lintegral _ fun ŌÜ hŌÜ ‚Ü¶ ?_
  rw [lintegral_prod _ hŌÜ.aemeasurable, lintegral_withDensity_eq_lintegral_mul‚āÄ _ hŌÜ.aemeasurable,
    lintegral_prod]
  ¬∑ refine lintegral_congr (fun x ‚Ü¶ ?_)
    rw [lintegral_withDensity_eq_lintegral_mul‚āÄ hg (by fun_prop)]
    simp
  all_goals fun_prop (disch := intro _ hs; simp [hs])

theorem prod_withDensity_right {g : ő≤ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : Measurable g) :
    őľ.prod (őĹ.withDensity g) = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ g z.2) :=
  prod_withDensity_right‚āÄ hg.aemeasurable

theorem prod_withDensity‚āÄ {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : ő≤ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (hg : AEMeasurable g őĹ) :
    (őľ.withDensity f).prod (őĹ.withDensity g) = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ f z.1 * g z.2) := by
  rw [prod_withDensity_left‚āÄ hf, prod_withDensity_right‚āÄ hg, ‚Üź withDensity_mul‚āÄ, mul_comm]
  ¬∑ rfl
  all_goals fun_prop (disch := intro _ hs; simp [hs])

theorem prod_withDensity {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : ő≤ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) (hg : Measurable g) :
    (őľ.withDensity f).prod (őĹ.withDensity g) = (őľ.prod őĹ).withDensity (fun z ‚Ü¶ f z.1 * g z.2) :=
  prod_withDensity‚āÄ hf.aemeasurable hg.aemeasurable

-- `prod_smul_left` is in the `Prod` file. This lemma is here because this is the file in which
-- we prove the instance that gives `SFinite (c ‚ÄĘ őĹ)`.
lemma Measure.prod_smul_right (c : ‚ĄĚ‚Č•0‚ąě) : őľ.prod (c ‚ÄĘ őĹ) = c ‚ÄĘ (őľ.prod őĹ) := by
  ext s hs
