/-!
# Measure with a given density with respect to another measure

For a measure `őľ` on `őĪ` and a function `f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě`, we define a new measure `őľ.withDensity f`.
On a measurable set `s`, that measure has value `‚ąę‚ĀĽ a in s, f a ‚ąāőľ`.

An important result about `withDensity` is the Radon-Nikodym theorem. It states that, given measures
`őľ, őĹ`, if `HaveLebesgueDecomposition őľ őĹ` then `őľ` is absolutely continuous with respect to
`őĹ` if and only if there exists a measurable function `f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě` such that
`őľ = őĹ.withDensity f`.
See `MeasureTheory.Measure.absolutelyContinuous_iff_withDensity_rnDeriv_eq`.

-/

@[expose] public section

open Set hiding restrict restrict_apply

open Filter ENNReal NNReal MeasureTheory.Measure

namespace MeasureTheory

variable {őĪ : Type*} {m0 : MeasurableSpace őĪ} {őľ : Measure őĪ}

/-- Given a measure `őľ : Measure őĪ` and a function `f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě`, `őľ.withDensity f` is the
measure such that for a measurable set `s` we have `őľ.withDensity f s = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ`. -/
noncomputable
def Measure.withDensity {m : MeasurableSpace őĪ} (őľ : Measure őĪ) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) : Measure őĪ :=
  Measure.ofMeasurable (fun s _ => ‚ąę‚ĀĽ a in s, f a ‚ąāőľ) (by simp) fun _ hs hd =>
    lintegral_iUnion hs hd _

@[simp]
theorem withDensity_apply (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) {s : Set őĪ} (hs : MeasurableSet s) :
    őľ.withDensity f s = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ :=
  Measure.ofMeasurable_apply s hs

theorem withDensity_apply_le (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) (s : Set őĪ) :
    ‚ąę‚ĀĽ a in s, f a ‚ąāőľ ‚Č§ őľ.withDensity f s := by
  let t := toMeasurable (őľ.withDensity f) s
  calc
  ‚ąę‚ĀĽ a in s, f a ‚ąāőľ ‚Č§ ‚ąę‚ĀĽ a in t, f a ‚ąāőľ :=
    lintegral_mono_set (subset_toMeasurable (withDensity őľ f) s)
  _ = őľ.withDensity f t :=
    (withDensity_apply f (measurableSet_toMeasurable (withDensity őľ f) s)).symm
  _ = őľ.withDensity f s := measure_toMeasurable s


/-! In the next theorem, the s-finiteness assumption is necessary. Here is a counterexample
without this assumption. Let `őĪ` be an uncountable space, let `x‚āÄ` be some fixed point, and consider
the ŌÉ-algebra made of those sets which are countable and do not contain `x‚āÄ`, and of their
complements. This is the ŌÉ-algebra generated by the sets `{x}` for `x ‚Č† x‚āÄ`. Define a measure equal
to `+‚ąě` on nonempty sets. Let `s = {x‚āÄ}` and `f` the indicator of `sŠ∂ú`. Then
* `‚ąę‚ĀĽ a in s, f a ‚ąāőľ = 0`. Indeed, consider a simple function `g ‚Č§ f`. It vanishes on `s`. Then
  `‚ąę‚ĀĽ a in s, g a ‚ąāőľ = 0`. Taking the supremum over `g` gives the claim.
* `őľ.withDensity f s = +‚ąě`. Indeed, this is the infimum of `őľ.withDensity f t` over measurable sets
  `t` containing `s`. As `s` is not measurable, such a set `t` contains a point `x ‚Č† x‚āÄ`. Then
  `őľ.withDensity f t ‚Č• őľ.withDensity f {x} = ‚ąę‚ĀĽ a in {x}, f a ‚ąāőľ = őľ {x} = +‚ąě`.

One checks that `őľ.withDensity f = őľ`, while `őľ.restrict s` gives zero mass to sets not
containing `x‚āÄ`, and infinite mass to those that contain it. -/

theorem withDensity_apply' [SFinite őľ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) (s : Set őĪ) :
    őľ.withDensity f s = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ := by
  apply le_antisymm ?_ (withDensity_apply_le f s)
  let t := toMeasurable őľ s
  calc
  őľ.withDensity f s ‚Č§ őľ.withDensity f t := measure_mono (subset_toMeasurable őľ s)
  _ = ‚ąę‚ĀĽ a in t, f a ‚ąāőľ := withDensity_apply f (measurableSet_toMeasurable őľ s)
  _ = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ := by congr 1; exact restrict_toMeasurable_of_sFinite s

@[simp]
lemma withDensity_zero_left (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) : (0 : Measure őĪ).withDensity f = 0 := by
  ext s hs
  rw [withDensity_apply _ hs]
  simp

theorem withDensity_congr_ae {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (h : f =ŠĶź[őľ] g) :
    őľ.withDensity f = őľ.withDensity g := by
  refine Measure.ext fun s hs => ?_
  rw [withDensity_apply _ hs, withDensity_apply _ hs]
  exact lintegral_congr_ae (ae_restrict_of_ae h)

lemma withDensity_mono {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hfg : f ‚Č§ŠĶź[őľ] g) :
    őľ.withDensity f ‚Č§ őľ.withDensity g := by
  refine le_iff.2 fun s hs ‚Ü¶ ?_
  rw [withDensity_apply _ hs, withDensity_apply _ hs]
  refine setLIntegral_mono_ae' hs ?_
  filter_upwards [hfg] with x h_le using fun _ ‚Ü¶ h_le

theorem withDensity_add_left {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    őľ.withDensity (f + g) = őľ.withDensity f + őľ.withDensity g := by
  refine Measure.ext fun s hs => ?_
  rw [withDensity_apply _ hs, Measure.add_apply, withDensity_apply _ hs, withDensity_apply _ hs,
    ‚Üź lintegral_add_left hf]
  simp only [Pi.add_apply]

theorem withDensity_add_right (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : Measurable g) :
    őľ.withDensity (f + g) = őľ.withDensity f + őľ.withDensity g := by
  simpa only [add_comm] using withDensity_add_left hg f

theorem withDensity_add_measure {m : MeasurableSpace őĪ} (őľ őĹ : Measure őĪ) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    (őľ + őĹ).withDensity f = őľ.withDensity f + őĹ.withDensity f := by
  ext1 s hs
  simp only [withDensity_apply f hs, restrict_add, lintegral_add_measure, Measure.add_apply]

theorem withDensity_sum {őĻ : Type*} {m : MeasurableSpace őĪ} (őľ : őĻ ‚Üí Measure őĪ) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    (sum őľ).withDensity f = sum fun n => (őľ n).withDensity f := by
  ext1 s hs
  simp_rw [sum_apply _ hs, withDensity_apply f hs, restrict_sum őľ hs, lintegral_sum_measure]

theorem withDensity_smul (r : ‚ĄĚ‚Č•0‚ąě) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) :
    őľ.withDensity (r ‚ÄĘ f) = r ‚ÄĘ őľ.withDensity f := by
  refine Measure.ext fun s hs => ?_
  rw [withDensity_apply _ hs, Measure.coe_smul, Pi.smul_apply, withDensity_apply _ hs,
    smul_eq_mul, ‚Üź lintegral_const_mul r hf]
  simp only [Pi.smul_apply, smul_eq_mul]

theorem withDensity_smul' (r : ‚ĄĚ‚Č•0‚ąě) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) (hr : r ‚Č† ‚ąě) :
    őľ.withDensity (r ‚ÄĘ f) = r ‚ÄĘ őľ.withDensity f := by
  refine Measure.ext fun s hs => ?_
  rw [withDensity_apply _ hs, Measure.coe_smul, Pi.smul_apply, withDensity_apply _ hs,
    smul_eq_mul, ‚Üź lintegral_const_mul' r f hr]
  simp only [Pi.smul_apply, smul_eq_mul]

theorem withDensity_smul_measure (r : ‚ĄĚ‚Č•0‚ąě) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    (r ‚ÄĘ őľ).withDensity f = r ‚ÄĘ őľ.withDensity f := by
  ext s hs
  simp [withDensity_apply, hs]

theorem isFiniteMeasure_withDensity {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : ‚ąę‚ĀĽ a, f a ‚ąāőľ ‚Č† ‚ąě) :
    IsFiniteMeasure (őľ.withDensity f) :=
  { measure_univ_lt_top := by
      rwa [withDensity_apply _ MeasurableSet.univ, Measure.restrict_univ, lt_top_iff_ne_top] }

theorem withDensity_absolutelyContinuous {m : MeasurableSpace őĪ} (őľ : Measure őĪ) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    őľ.withDensity f ‚Č™ őľ := by
  refine AbsolutelyContinuous.mk fun s hs‚āĀ hs‚āā => ?_
  rw [withDensity_apply _ hs‚āĀ]
  exact setLIntegral_measure_zero _ _ hs‚āā

theorem withDensity_apply‚āÄ (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) {s : Set őĪ} (hs : NullMeasurableSet s őľ) :
    őľ.withDensity f s = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ := by
  let t := toMeasurable őľ s
  have A : ‚ąę‚ĀĽ a in t, f a ‚ąāőľ = ‚ąę‚ĀĽ a in s, f a ‚ąāőľ :=
    setLIntegral_congr hs.toMeasurable_ae_eq
  have B : őľ.withDensity f t = őľ.withDensity f s :=
    measure_congr (withDensity_absolutelyContinuous őľ f hs.toMeasurable_ae_eq)
  rw [‚Üź A, ‚Üź B]
  exact withDensity_apply _ (measurableSet_toMeasurable őľ s)

instance noAtoms_withDensity [NoAtoms őľ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) : NoAtoms (őľ.withDensity f) where
  measure_singleton _ := withDensity_absolutelyContinuous őľ f (measure_singleton _)

@[simp]
theorem withDensity_zero : őľ.withDensity 0 = 0 := by
  ext1 s hs
  simp [withDensity_apply _ hs]

@[simp]
theorem withDensity_one : őľ.withDensity 1 = őľ := by
  ext1 s hs
  simp [withDensity_apply _ hs]

@[simp]
theorem withDensity_const (c : ‚ĄĚ‚Č•0‚ąě) : őľ.withDensity (fun _ ‚Ü¶ c) = c ‚ÄĘ őľ := by
  ext1 s hs
  simp [withDensity_apply _ hs]

theorem withDensity_tsum {őĻ : Type*} [Countable őĻ] {f : őĻ ‚Üí őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (h : ‚ąÄ i, Measurable (f i)) :
    őľ.withDensity (‚ąĎ' n, f n) = sum fun n => őľ.withDensity (f n) := by
  ext1 s hs
  simp_rw [sum_apply _ hs, withDensity_apply _ hs]
  change ‚ąę‚ĀĽ x in s, (‚ąĎ' n, f n) x ‚ąāőľ = ‚ąĎ' i, ‚ąę‚ĀĽ x, f i x ‚ąāőľ.restrict s
  rw [‚Üź lintegral_tsum fun i => (h i).aemeasurable]
  exact lintegral_congr fun x => tsum_apply (Pi.summable.2 fun _ => ENNReal.summable)

theorem withDensity_indicator {s : Set őĪ} (hs : MeasurableSet s) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    őľ.withDensity (s.indicator f) = (őľ.restrict s).withDensity f := by
  ext1 t ht
  rw [withDensity_apply _ ht, lintegral_indicator hs, restrict_comm hs, ‚Üź
    withDensity_apply _ ht]

theorem withDensity_indicator_one {s : Set őĪ} (hs : MeasurableSet s) :
    őľ.withDensity (s.indicator 1) = őľ.restrict s := by
  rw [withDensity_indicator hs, withDensity_one]

theorem withDensity_ofReal_mutuallySingular {f : őĪ ‚Üí ‚ĄĚ} (hf : Measurable f) :
    (őľ.withDensity fun x => ENNReal.ofReal <| f x) ‚üā‚āė
      őľ.withDensity fun x => ENNReal.ofReal <| -f x := by
  set S : Set őĪ := { x | f x < 0 }
  have hS : MeasurableSet S := measurableSet_lt hf measurable_const
  refine ‚ü®S, hS, ?_, ?_‚ü©
  ¬∑ rw [withDensity_apply _ hS, lintegral_eq_zero_iff hf.ennreal_ofReal, EventuallyEq]
    exact (ae_restrict_mem hS).mono fun x hx => ENNReal.ofReal_eq_zero.2 (le_of_lt hx)
  ¬∑ rw [withDensity_apply _ hS.compl, lintegral_eq_zero_iff hf.neg.ennreal_ofReal, EventuallyEq]
    exact
      (ae_restrict_mem hS.compl).mono fun x hx =>
        ENNReal.ofReal_eq_zero.2 (not_lt.1 <| mt neg_pos.1 hx)

theorem restrict_withDensity {s : Set őĪ} (hs : MeasurableSet s) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    (őľ.withDensity f).restrict s = (őľ.restrict s).withDensity f := by
  ext1 t ht
  rw [restrict_apply ht, withDensity_apply _ ht, withDensity_apply _ (ht.inter hs),
    restrict_restrict ht]

theorem restrict_withDensity' [SFinite őľ] (s : Set őĪ) (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    (őľ.withDensity f).restrict s = (őľ.restrict s).withDensity f := by
  ext1 t ht
  rw [restrict_apply ht, withDensity_apply _ ht, withDensity_apply' _ (t ‚ą© s),
    restrict_restrict ht]

lemma trim_withDensity {m m0 : MeasurableSpace őĪ} {őľ : Measure őĪ}
    (hm : m ‚Č§ m0) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable[m] f) :
    (őľ.withDensity f).trim hm = (őľ.trim hm).withDensity f := by
  refine @Measure.ext _ m _ _ (fun s hs ‚Ü¶ ?_)
  rw [withDensity_apply _ hs, restrict_trim _ _ hs, lintegral_trim _ hf, trim_measurableSet_eq _ hs,
    withDensity_apply _ (hm s hs)]

lemma Measure.MutuallySingular.withDensity {őĹ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (h : őľ ‚üā‚āė őĹ) :
    őľ.withDensity f ‚üā‚āė őĹ :=
  MutuallySingular.mono_ac h (withDensity_absolutelyContinuous _ _) AbsolutelyContinuous.rfl

@[simp]
theorem withDensity_eq_zero_iff {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : AEMeasurable f őľ) :
    őľ.withDensity f = 0 ‚ÜĒ f =ŠĶź[őľ] 0 := by
  rw [‚Üź measure_univ_eq_zero, withDensity_apply _ .univ, restrict_univ, lintegral_eq_zero_iff' hf]

alias ‚ü®withDensity_eq_zero, _‚ü© := withDensity_eq_zero_iff

theorem withDensity_apply_eq_zero' {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {s : Set őĪ} (hf : AEMeasurable f őľ) :
    őľ.withDensity f s = 0 ‚ÜĒ őľ ({ x | f x ‚Č† 0 } ‚ą© s) = 0 := by
  constructor
  ¬∑ intro hs
    let t := toMeasurable (őľ.withDensity f) s
    apply measure_mono_null (inter_subset_inter_right _ (subset_toMeasurable (őľ.withDensity f) s))
    have A : őľ.withDensity f t = 0 := by rw [measure_toMeasurable, hs]
    rw [withDensity_apply f (measurableSet_toMeasurable _ s),
      lintegral_eq_zero_iff' (AEMeasurable.restrict hf),
      EventuallyEq, ae_restrict_iff'‚āÄ, ae_iff] at A
    swap
    ¬∑ simp only [measurableSet_toMeasurable, MeasurableSet.nullMeasurableSet]
    simp only [Pi.zero_apply] at A
    convert A using 2
    ext x
    simp only [and_comm, exists_prop, mem_inter_iff, mem_setOf_eq,
      not_forall]
  ¬∑ intro hs
    let t := toMeasurable őľ ({ x | f x ‚Č† 0 } ‚ą© s)
    have A : s ‚äÜ t ‚ą™ { x | f x = 0 } := by
      intro x hx
      rcases eq_or_ne (f x) 0 with (fx | fx)
      ¬∑ simp only [fx, mem_union, mem_setOf_eq, or_true]
      ¬∑ left
        apply subset_toMeasurable _ _
        exact ‚ü®fx, hx‚ü©
    apply measure_mono_null A (measure_union_null _ _)
    ¬∑ apply withDensity_absolutelyContinuous
      rwa [measure_toMeasurable]
    rcases hf with ‚ü®g, hg, hfg‚ü©
    have t : {x | f x = 0} =ŠĶź[őľ.withDensity f] {x | g x = 0} := by
      apply withDensity_absolutelyContinuous
      filter_upwards [hfg] with a ha
      rw [eq_iff_iff]
      exact ‚ü®fun h ‚Ü¶ by rw [h] at ha; exact ha.symm,
             fun h ‚Ü¶ by rw [h] at ha; exact ha‚ü©
    rw [measure_congr t, withDensity_congr_ae hfg]
    have M : MeasurableSet { x : őĪ | g x = 0 } := hg (measurableSet_singleton _)
    rw [withDensity_apply _ M, lintegral_eq_zero_iff hg]
    filter_upwards [ae_restrict_mem M]
    simp only [imp_self, Pi.zero_apply, imp_true_iff]

theorem withDensity_apply_eq_zero {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {s : Set őĪ} (hf : Measurable f) :
    őľ.withDensity f s = 0 ‚ÜĒ őľ ({ x | f x ‚Č† 0 } ‚ą© s) = 0 :=
  withDensity_apply_eq_zero' <| hf.aemeasurable

theorem ae_withDensity_iff' {p : őĪ ‚Üí Prop} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : AEMeasurable f őľ) :
    (‚ąÄŠĶź x ‚ąāőľ.withDensity f, p x) ‚ÜĒ ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† 0 ‚Üí p x := by
  rw [ae_iff, ae_iff, withDensity_apply_eq_zero' hf, iff_iff_eq]
  congr
  ext x
  simp only [exists_prop, mem_inter_iff, mem_setOf_eq, not_forall]

theorem ae_withDensity_iff {p : őĪ ‚Üí Prop} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) :
    (‚ąÄŠĶź x ‚ąāőľ.withDensity f, p x) ‚ÜĒ ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† 0 ‚Üí p x :=
  ae_withDensity_iff' <| hf.aemeasurable

theorem ae_withDensity_iff_ae_restrict' {p : őĪ ‚Üí Prop} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) :
    (‚ąÄŠĶź x ‚ąāőľ.withDensity f, p x) ‚ÜĒ ‚ąÄŠĶź x ‚ąāőľ.restrict { x | f x ‚Č† 0 }, p x := by
  rw [ae_withDensity_iff' hf, ae_restrict_iff'‚āÄ]
  ¬∑ simp only [mem_setOf]
  ¬∑ rcases hf with ‚ü®g, hg, hfg‚ü©
    have nonneg_eq_ae : {x | g x ‚Č† 0} =ŠĶź[őľ] {x | f x ‚Č† 0} := by
      filter_upwards [hfg] with a ha
      simp only [eq_iff_iff]
      exact ‚ü®fun (h : g a ‚Č† 0) ‚Ü¶ by rwa [‚Üź ha] at h,
             fun (h : f a ‚Č† 0) ‚Ü¶ by rwa [ha] at h‚ü©
    exact NullMeasurableSet.congr
      (MeasurableSet.nullMeasurableSet
        <| hg (measurableSet_singleton _)).compl
      nonneg_eq_ae

theorem ae_withDensity_iff_ae_restrict {p : őĪ ‚Üí Prop} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) :
    (‚ąÄŠĶź x ‚ąāőľ.withDensity f, p x) ‚ÜĒ ‚ąÄŠĶź x ‚ąāőľ.restrict { x | f x ‚Č† 0 }, p x :=
  ae_withDensity_iff_ae_restrict' <| hf.aemeasurable

theorem aemeasurable_withDensity_ennreal_iff' {f : őĪ ‚Üí ‚ĄĚ‚Č•0}
    (hf : AEMeasurable f őľ) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} :
    AEMeasurable g (őľ.withDensity fun x => (f x : ‚ĄĚ‚Č•0‚ąě)) ‚ÜĒ
      AEMeasurable (fun x => (f x : ‚ĄĚ‚Č•0‚ąě) * g x) őľ := by
  have t : ‚ąÉ f', Measurable f' ‚ąß f =ŠĶź[őľ] f' := hf
  rcases t with ‚ü®f', hf'_m, hf'_ae‚ü©
  constructor
  ¬∑ rintro ‚ü®g', g'meas, hg'‚ü©
    have A : MeasurableSet {x | f' x ‚Č† 0} := hf'_m (measurableSet_singleton _).compl
    refine ‚ü®fun x => f' x * g' x, hf'_m.coe_nnreal_ennreal.smul g'meas, ?_‚ü©
    apply ae_of_ae_restrict_of_ae_restrict_compl { x | f' x ‚Č† 0 }
    ¬∑ rw [EventuallyEq, ae_withDensity_iff' hf.coe_nnreal_ennreal] at hg'
      rw [ae_restrict_iff' A]
      filter_upwards [hg', hf'_ae] with a ha h'a h_a_nonneg
      have : (f' a : ‚ĄĚ‚Č•0‚ąě) ‚Č† 0 := by simpa only [Ne, ENNReal.coe_eq_zero] using h_a_nonneg
      rw [‚Üź h'a] at this ‚äĘ
      rw [ha this]
    ¬∑ rw [ae_restrict_iff' A.compl]
      filter_upwards [hf'_ae] with a ha ha_null
      have ha_null : f' a = 0 := Function.notMem_support.mp ha_null
      rw [ha_null] at ha ‚äĘ
      rw [ha]
      simp only [ENNReal.coe_zero, zero_mul]
  ¬∑ rintro ‚ü®g', g'meas, hg'‚ü©
    refine ‚ü®fun x => ((f' x)‚ĀĽ¬Ļ : ‚ĄĚ‚Č•0‚ąě) * g' x, hf'_m.coe_nnreal_ennreal.inv.smul g'meas, ?_‚ü©
    rw [EventuallyEq, ae_withDensity_iff' hf.coe_nnreal_ennreal]
    filter_upwards [hg', hf'_ae] with a hfga hff'a h'a
    rw [hff'a] at hfga h'a
    rw [‚Üź hfga, ‚Üź mul_assoc, ENNReal.inv_mul_cancel h'a ENNReal.coe_ne_top, one_mul]

theorem aemeasurable_withDensity_ennreal_iff {f : őĪ ‚Üí ‚ĄĚ‚Č•0} (hf : Measurable f) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} :
    AEMeasurable g (őľ.withDensity fun x => (f x : ‚ĄĚ‚Č•0‚ąě)) ‚ÜĒ
      AEMeasurable (fun x => (f x : ‚ĄĚ‚Č•0‚ąě) * g x) őľ :=
  aemeasurable_withDensity_ennreal_iff' <| hf.aemeasurable

theorem dirac_withDensity' {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) (a : őĪ) :
    (dirac a).withDensity f = f a ‚ÄĘ dirac a := by
  ext s hs
  classical
  simp [withDensity_apply f hs, setLIntegral_dirac' hf hs, dirac_apply' _ hs,
    Set.indicator]

theorem dirac_withDensity [MeasurableSingletonClass őĪ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) (a : őĪ) :
    (dirac a).withDensity f = f a ‚ÄĘ dirac a := by
  ext s hs
  classical
  simp [withDensity_apply f hs, setLIntegral_dirac, Set.indicator]

theorem count_withDensity' {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) :
    count.withDensity f = sum (fun a ‚Ü¶ f a ‚ÄĘ dirac a) := by
  simp [count, withDensity_sum, dirac_withDensity' hf _]

theorem count_withDensity [MeasurableSingletonClass őĪ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    count.withDensity f = sum (fun a ‚Ü¶ f a ‚ÄĘ dirac a) := by
  simp [count, withDensity_sum, dirac_withDensity]

open MeasureTheory.SimpleFunc

/-- This is Exercise 1.2.1 from [tao2010]. It allows you to express integration of a measurable
function with respect to `(őľ.withDensity f)` as an integral with respect to `őľ`, called the base
measure. `őľ` is often the Lebesgue measure, and in this circumstance `f` is the probability density
function, and `(őľ.withDensity f)` represents any continuous random variable as a
probability measure, such as the uniform distribution between 0 and 1, the Gaussian distribution,
the exponential distribution, the Beta distribution, or the Cauchy distribution (see Section 2.4
of [wasserman2004]). Thus, this method shows how to one can calculate expectations, variances,
and other moments as a function of the probability density function.
-/
theorem lintegral_withDensity_eq_lintegral_mul (őľ : Measure őĪ) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (h_mf : Measurable f) :
    ‚ąÄ {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}, Measurable g ‚Üí ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
  apply Measurable.ennreal_induction
  ¬∑ intro c s h_ms
    simp [*, mul_comm _ c, ‚Üź indicator_mul_right]
  ¬∑ intro g h _ h_mea_g _ h_ind_g h_ind_h
    simp [mul_add, *, Measurable.mul]
  ¬∑ intro g h_mea_g h_mono_g h_ind
    have : Monotone fun n a => f a * g n a := fun m n hmn x => by dsimp; grw [h_mono_g hmn x]
    simp [lintegral_iSup, ENNReal.mul_iSup, h_mf.mul (h_mea_g _), *]

theorem setLIntegral_withDensity_eq_setLIntegral_mul (őľ : Measure őĪ) {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : Measurable f) (hg : Measurable g) {s : Set őĪ} (hs : MeasurableSet s) :
    ‚ąę‚ĀĽ x in s, g x ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ x in s, (f * g) x ‚ąāőľ := by
  rw [restrict_withDensity hs, lintegral_withDensity_eq_lintegral_mul _ hf hg]

/-- The Lebesgue integral of `g` with respect to the measure `őľ.withDensity f` coincides with
the integral of `f * g`. This version assumes that `g` is almost everywhere measurable. For a
version without conditions on `g` but requiring that `f` is almost everywhere finite, see
`lintegral_withDensity_eq_lintegral_mul_non_measurable` -/
theorem lintegral_withDensity_eq_lintegral_mul‚āÄ' {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : AEMeasurable g (őľ.withDensity f)) :
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
  let f' := hf.mk f
  have : őľ.withDensity f = őľ.withDensity f' := withDensity_congr_ae hf.ae_eq_mk
  rw [this] at hg ‚äĘ
  let g' := hg.mk g
  calc
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f' = ‚ąę‚ĀĽ a, g' a ‚ąāőľ.withDensity f' := lintegral_congr_ae hg.ae_eq_mk
    _ = ‚ąę‚ĀĽ a, (f' * g') a ‚ąāőľ :=
      (lintegral_withDensity_eq_lintegral_mul _ hf.measurable_mk hg.measurable_mk)
    _ = ‚ąę‚ĀĽ a, (f' * g) a ‚ąāőľ := by
      apply lintegral_congr_ae
      apply ae_of_ae_restrict_of_ae_restrict_compl { x | f' x ‚Č† 0 }
      ¬∑ have Z := hg.ae_eq_mk
        rw [EventuallyEq, ae_withDensity_iff_ae_restrict hf.measurable_mk] at Z
        filter_upwards [Z]
        intro x hx
        simp only [g', hx, Pi.mul_apply]
      ¬∑ have M : MeasurableSet { x : őĪ | f' x ‚Č† 0 }Š∂ú :=
          (hf.measurable_mk (measurableSet_singleton 0).compl).compl
        filter_upwards [ae_restrict_mem M]
        intro x hx
        simp only [Classical.not_not, mem_setOf_eq, mem_compl_iff] at hx
        simp only [hx, zero_mul, Pi.mul_apply]
    _ = ‚ąę‚ĀĽ a : őĪ, (f * g) a ‚ąāőľ := by
      apply lintegral_congr_ae
      filter_upwards [hf.ae_eq_mk]
      intro x hx
      simp only [f', hx, Pi.mul_apply]

lemma setLIntegral_withDensity_eq_lintegral_mul‚āÄ' {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : AEMeasurable g (őľ.withDensity f))
    {s : Set őĪ} (hs : MeasurableSet s) :
    ‚ąę‚ĀĽ a in s, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a in s, (f * g) a ‚ąāőľ := by
  rw [restrict_withDensity hs, lintegral_withDensity_eq_lintegral_mul‚āÄ' hf.restrict]
  rw [‚Üź restrict_withDensity hs]
  exact hg.restrict

theorem lintegral_withDensity_eq_lintegral_mul‚āÄ {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : AEMeasurable g őľ) :
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ :=
  lintegral_withDensity_eq_lintegral_mul‚āÄ' hf (hg.mono' (withDensity_absolutelyContinuous őľ f))

lemma setLIntegral_withDensity_eq_lintegral_mul‚āÄ {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hg : AEMeasurable g őľ)
    {s : Set őĪ} (hs : MeasurableSet s) :
    ‚ąę‚ĀĽ a in s, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a in s, (f * g) a ‚ąāőľ :=
  setLIntegral_withDensity_eq_lintegral_mul‚āÄ' hf
    (hg.mono' (MeasureTheory.withDensity_absolutelyContinuous őľ f)) hs

theorem lintegral_withDensity_le_lintegral_mul (őľ : Measure őĪ) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (f_meas : Measurable f) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) : (‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f) ‚Č§ ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
  rw [‚Üź iSup_lintegral_measurable_le_eq_lintegral, ‚Üź iSup_lintegral_measurable_le_eq_lintegral]
  refine iSup‚āā_le fun i i_meas => iSup_le fun hi => ?_
  rw [lintegral_withDensity_eq_lintegral_mul _ f_meas i_meas]
  exact le_iSup‚āā_of_le (f * i) (f_meas.mul i_meas) <| le_iSup_of_le (by grw [hi]) le_rfl

theorem lintegral_withDensity_eq_lintegral_mul_non_measurable (őľ : Measure őĪ) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (f_meas : Measurable f) (hf : ‚ąÄŠĶź x ‚ąāőľ, f x < ‚ąě) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
  refine le_antisymm (lintegral_withDensity_le_lintegral_mul őľ f_meas g) ?_
  rw [‚Üź iSup_lintegral_measurable_le_eq_lintegral, ‚Üź iSup_lintegral_measurable_le_eq_lintegral]
  refine iSup‚āā_le fun i i_meas => iSup_le fun hi => ?_
  have A : (fun x => (f x)‚ĀĽ¬Ļ * i x) ‚Č§ g := by
    intro x
    dsimp
    rw [mul_comm, ‚Üź div_eq_mul_inv]
    exact div_le_of_le_mul' (hi x)
  refine le_iSup_of_le (fun x => (f x)‚ĀĽ¬Ļ * i x) (le_iSup_of_le (f_meas.inv.mul i_meas) ?_)
  refine le_iSup_of_le A ?_
  rw [lintegral_withDensity_eq_lintegral_mul _ f_meas (f_meas.inv.mul i_meas)]
  apply lintegral_mono_ae
  filter_upwards [hf]
  intro x h'x
  rcases eq_or_ne (f x) 0 with (hx | hx)
  ¬∑ have := hi x
    simp only [hx, zero_mul, Pi.mul_apply, nonpos_iff_eq_zero] at this
    simp [this]
  ¬∑ apply le_of_eq _
    dsimp
    rw [‚Üź mul_assoc, ENNReal.mul_inv_cancel hx h'x.ne, one_mul]

theorem setLIntegral_withDensity_eq_setLIntegral_mul_non_measurable (őľ : Measure őĪ) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (f_meas : Measurable f) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) {s : Set őĪ} (hs : MeasurableSet s)
    (hf : ‚ąÄŠĶź x ‚ąāőľ.restrict s, f x < ‚ąě) :
    ‚ąę‚ĀĽ a in s, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a in s, (f * g) a ‚ąāőľ := by
  rw [restrict_withDensity hs, lintegral_withDensity_eq_lintegral_mul_non_measurable _ f_meas hf]

theorem lintegral_withDensity_eq_lintegral_mul_non_measurable‚āÄ (őľ : Measure őĪ) {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (h'f : ‚ąÄŠĶź x ‚ąāőľ, f x < ‚ąě) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
  let f' := hf.mk f
  calc
    ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a, g a ‚ąāőľ.withDensity f' := by
      rw [withDensity_congr_ae hf.ae_eq_mk]
    _ = ‚ąę‚ĀĽ a, (f' * g) a ‚ąāőľ := by
      apply lintegral_withDensity_eq_lintegral_mul_non_measurable _ hf.measurable_mk
      filter_upwards [h'f, hf.ae_eq_mk]
      intro x hx h'x
      rwa [‚Üź h'x]
    _ = ‚ąę‚ĀĽ a, (f * g) a ‚ąāőľ := by
      apply lintegral_congr_ae
      filter_upwards [hf.ae_eq_mk]
      intro x hx
      simp only [f', hx, Pi.mul_apply]

theorem setLIntegral_withDensity_eq_setLIntegral_mul_non_measurable‚āÄ (őľ : Measure őĪ)
    {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {s : Set őĪ} (hf : AEMeasurable f (őľ.restrict s)) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě)
    (hs : MeasurableSet s) (h'f : ‚ąÄŠĶź x ‚ąāőľ.restrict s, f x < ‚ąě) :
    ‚ąę‚ĀĽ a in s, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a in s, (f * g) a ‚ąāőľ := by
  rw [restrict_withDensity hs, lintegral_withDensity_eq_lintegral_mul_non_measurable‚āÄ _ hf h'f]

theorem setLIntegral_withDensity_eq_setLIntegral_mul_non_measurable‚āÄ' (őľ : Measure őĪ) [SFinite őľ]
    {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (s : Set őĪ) (hf : AEMeasurable f (őľ.restrict s)) (g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě)
    (h'f : ‚ąÄŠĶź x ‚ąāőľ.restrict s, f x < ‚ąě) :
    ‚ąę‚ĀĽ a in s, g a ‚ąāőľ.withDensity f = ‚ąę‚ĀĽ a in s, (f * g) a ‚ąāőľ := by
  rw [restrict_withDensity' s, lintegral_withDensity_eq_lintegral_mul_non_measurable‚āÄ _ hf h'f]

theorem withDensity_mul‚āÄ {őľ : Measure őĪ} {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (hg : AEMeasurable g őľ) :
    őľ.withDensity (f * g) = (őľ.withDensity f).withDensity g := by
  ext1 s hs
  rw [withDensity_apply _ hs, withDensity_apply _ hs, restrict_withDensity hs,
    lintegral_withDensity_eq_lintegral_mul‚āÄ hf.restrict hg.restrict]

theorem withDensity_mul (őľ : Measure őĪ) {f g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : Measurable f) (hg : Measurable g) :
    őľ.withDensity (f * g) = (őľ.withDensity f).withDensity g :=
  withDensity_mul‚āÄ hf.aemeasurable hg.aemeasurable

lemma withDensity_inv_same_le {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : AEMeasurable f őľ) :
    (őľ.withDensity f).withDensity f‚ĀĽ¬Ļ ‚Č§ őľ := by
  change (őľ.withDensity f).withDensity (fun x ‚Ü¶ (f x)‚ĀĽ¬Ļ) ‚Č§ őľ
  rw [‚Üź withDensity_mul‚āÄ hf hf.inv]
  suffices (f * fun x ‚Ü¶ (f x)‚ĀĽ¬Ļ) ‚Č§ŠĶź[őľ] 1 by
    refine (withDensity_mono this).trans ?_
    rw [withDensity_one]
  filter_upwards with x
  simp

lemma withDensity_inv_same‚āÄ {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (hf_ne_zero : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† 0) (hf_ne_top : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† ‚ąě) :
    (őľ.withDensity f).withDensity (fun x ‚Ü¶ (f x)‚ĀĽ¬Ļ) = őľ := by
  rw [‚Üź withDensity_mul‚āÄ hf hf.inv]
  suffices (f * fun x ‚Ü¶ (f x)‚ĀĽ¬Ļ) =ŠĶź[őľ] 1 by
    rw [withDensity_congr_ae this, withDensity_one]
  filter_upwards [hf_ne_zero, hf_ne_top] with x hf_ne_zero hf_ne_top
  simp only [Pi.mul_apply]
  rw [ENNReal.mul_inv_cancel hf_ne_zero hf_ne_top, Pi.one_apply]

lemma withDensity_inv_same {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : Measurable f) (hf_ne_zero : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† 0) (hf_ne_top : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† ‚ąě) :
    (őľ.withDensity f).withDensity (fun x ‚Ü¶ (f x)‚ĀĽ¬Ļ) = őľ :=
  withDensity_inv_same‚āÄ hf.aemeasurable hf_ne_zero hf_ne_top

/-- If `f` is almost everywhere positive, then `őľ ‚Č™ őľ.withDensity f`. See also
`withDensity_absolutelyContinuous` for the reverse direction, which always holds. -/
lemma withDensity_absolutelyContinuous' {őľ : Measure őĪ} {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (hf_ne_zero : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† 0) :
    őľ ‚Č™ őľ.withDensity f := by
  refine Measure.AbsolutelyContinuous.mk (fun s hs hőľs ‚Ü¶ ?_)
  rw [withDensity_apply _ hs, lintegral_eq_zero_iff' hf.restrict,
    ae_eq_restrict_iff_indicator_ae_eq hs, Set.indicator_zero', Filter.EventuallyEq, ae_iff] at hőľs
  simp only [ae_iff, ne_eq, not_not] at hf_ne_zero
  simp only [Pi.zero_apply, Set.indicator_apply_eq_zero, not_forall, exists_prop] at hőľs
  have hle : s ‚äÜ {a | a ‚ąą s ‚ąß ¬¨f a = 0} ‚ą™ {a | f a = 0} :=
    fun x hx ‚Ü¶ or_iff_not_imp_right.mpr <| fun hnx ‚Ü¶ ‚ü®hx, hnx‚ü©
  exact measure_mono_null hle <| nonpos_iff_eq_zero.1 <| le_trans (measure_union_le _ _)
    <| hőľs.symm ‚Ėł zero_add _ |>.symm ‚Ėł hf_ne_zero.le

theorem withDensity_ae_eq {ő≤ : Type*} {f g : őĪ ‚Üí ő≤} {d : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hd : AEMeasurable d őľ) (h_ae_nonneg : ‚ąÄŠĶź x ‚ąāőľ, d x ‚Č† 0) :
    f =ŠĶź[őľ.withDensity d] g ‚ÜĒ f =ŠĶź[őľ] g :=
  Iff.intro
  (fun h ‚Ü¶ Measure.AbsolutelyContinuous.ae_eq
    (withDensity_absolutelyContinuous' hd h_ae_nonneg) h)
  (fun h ‚Ü¶ Measure.AbsolutelyContinuous.ae_eq
    (withDensity_absolutelyContinuous őľ d) h)

/-- If `őľ` is a ŌÉ-finite measure, then so is `őľ.withDensity fun x ‚Ü¶ f x`
for any `‚ĄĚ‚Č•0`-valued function `f`. -/
protected instance SigmaFinite.withDensity [SigmaFinite őľ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0) :
    SigmaFinite (őľ.withDensity (fun x ‚Ü¶ f x)) := by
  refine ‚ü®‚ü®‚ü®fun n ‚Ü¶ spanningSets őľ n ‚ą© f ‚ĀĽ¬Ļ' (Iic n), fun _ ‚Ü¶ trivial, fun n ‚Ü¶ ?_, ?_‚ü©‚ü©‚ü©
  ¬∑ rw [withDensity_apply']
    apply setLIntegral_lt_top_of_bddAbove
    ¬∑ exact ((measure_mono inter_subset_left).trans_lt (measure_spanningSets_lt_top őľ n)).ne
    ¬∑ exact ‚ü®n, forall_mem_image.2 fun x hx ‚Ü¶ hx.2‚ü©
  ¬∑ rw [iUnion_eq_univ_iff]
    refine fun x ‚Ü¶ ‚ü®max (spanningSetsIndex őľ x) ‚Ćąf x‚ĆČ‚āä, ?_, ?_‚ü©
    ¬∑ exact mem_spanningSets_of_index_le _ _ (le_max_left ..)
    ¬∑ simp [Nat.le_ceil]

lemma SigmaFinite.withDensity_of_ne_top [SigmaFinite őľ] {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf_ne_top : ‚ąÄŠĶź x ‚ąāőľ, f x ‚Č† ‚ąě) : SigmaFinite (őľ.withDensity f) := by
  have : f =ŠĶź[őľ] fun x ‚Ü¶ (f x).toNNReal := hf_ne_top.mono fun x hx ‚Ü¶ (ENNReal.coe_toNNReal hx).symm
  rw [withDensity_congr_ae this]
  infer_instance

lemma SigmaFinite.withDensity_of_ne_top' [SigmaFinite őľ] {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf_ne_top : ‚ąÄ x, f x ‚Č† ‚ąě) :
    SigmaFinite (őľ.withDensity f) :=
  SigmaFinite.withDensity_of_ne_top <| ae_of_all _ hf_ne_top

instance SigmaFinite.withDensity_ofReal [SigmaFinite őľ] (f : őĪ ‚Üí ‚ĄĚ) :
    SigmaFinite (őľ.withDensity (fun x ‚Ü¶ ENNReal.ofReal (f x))) :=
  .withDensity _

section SFinite

variable (őľ) in
theorem exists_measurable_le_withDensity_eq [SFinite őľ] (f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě) :
    ‚ąÉ g, Measurable g ‚ąß g ‚Č§ f ‚ąß őľ.withDensity g = őľ.withDensity f := by
  obtain ‚ü®g, hgm, hgf, hint‚ü© := exists_measurable_le_forall_setLIntegral_eq őľ f
  use g, hgm, hgf
  ext s hs
  simp only [hint, withDensity_apply _ hs]

/-- If `őľ` is an `s`-finite measure, then so is `őľ.withDensity f`. -/
instance Measure.withDensity.instSFinite [SFinite őľ] {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} :
    SFinite (őľ.withDensity f) := by
  wlog hfm : Measurable f generalizing f
  ¬∑ rcases exists_measurable_le_withDensity_eq őľ f with ‚ü®g, hgm, -, h‚ü©
    exact h ‚Ėł this hgm
  wlog hőľ : IsFiniteMeasure őľ generalizing őľ
  ¬∑ rw [‚Üź sum_sfiniteSeq őľ, withDensity_sum]
    have (n : ‚Ąē) : SFinite ((sfiniteSeq őľ n).withDensity f) := this inferInstance
    infer_instance
  set s := {x | f x = ‚ąě}
  have hs : MeasurableSet s := hfm (measurableSet_singleton _)
  have key := calc
    őľ.withDensity f = őľ.withDensity (sŠ∂ú.indicator f) + őľ.withDensity (s.indicator f) := by
      simp (disch := measurability) [withDensity_indicator, ‚Üź restrict_withDensity]
    _ = őľ.withDensity (sŠ∂ú.indicator f) + .sum fun _ : ‚Ąē ‚Ü¶ őľ.withDensity (s.indicator 1) := by
      rw [‚Üź withDensity_tsum (by measurability)]
      congr 2 with x
      rw [ENNReal.tsum_apply]
      if hx : x ‚ąą s then simpa [hx, ENNReal.tsum_const_eq_top_of_ne_zero]
      else simp [hx]
  have : SigmaFinite (őľ.withDensity (sŠ∂ú.indicator f)) := by
    refine SigmaFinite.withDensity_of_ne_top <| ae_of_all _ fun x hx ‚Ü¶ ?_
    simp [indicator_apply, ite_eq_iff, s] at hx
  have : SigmaFinite (őľ.withDensity (s.indicator 1)) := by
    rw [withDensity_indicator hs]
    exact SigmaFinite.withDensity 1
  rw [key]
  infer_instance

instance [SFinite őľ] (c : ‚ĄĚ‚Č•0‚ąě) : SFinite (c ‚ÄĘ őľ) := by
  rw [‚Üź withDensity_const]
  infer_instance

/-- If `őľ ‚Č™ őĹ` and `őĹ` is s-finite, then `őľ` is s-finite. -/
theorem sFinite_of_absolutelyContinuous {őĹ : Measure őĪ} [SFinite őĹ] (hőľőĹ : őľ ‚Č™ őĹ) :
    SFinite őľ := by
  rw [‚Üź Measure.restrict_add_restrict_compl (őľ := őľ) measurableSet_sigmaFiniteSetWRT,
    restrict_compl_sigmaFiniteSetWRT hőľőĹ]
  infer_instance

/-- In a countable space, every measure is s-finite. -/
instance [Countable őĪ] : SFinite őľ := by
  obtain ‚ü®s, h‚ü© := exists_sum_smul_dirac őľ
  rw [h]
  infer_instance

end SFinite

