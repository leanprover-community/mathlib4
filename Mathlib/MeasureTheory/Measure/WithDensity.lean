@[to_additive]
theorem mconv_withDensity_eq_mlconvolution‚āÄ {f g : G ‚Üí ‚ĄĚ‚Č•0‚ąě}
    (hf : AEMeasurable f őľ) (hg : AEMeasurable g őľ) :
    őľ.withDensity f ‚ąó‚āė őľ.withDensity g = őľ.withDensity (f ‚čÜ‚āė‚āó[őľ] g) := by
  refine ext_of_lintegral _ fun ŌÜ hŌÜ ‚Ü¶ ?_
  rw [lintegral_mconv_eq_lintegral_prod hŌÜ, prod_withDensity‚āÄ hf hg,
    lintegral_withDensity_eq_lintegral_mul‚āÄ,
    lintegral_withDensity_eq_lintegral_mul‚āÄ, lintegral_prod,
    lintegral_congr (fun x ‚Ü¶ by apply (lintegral_mul_left_eq_self _ x‚ĀĽ¬Ļ).symm),
    lintegral_lintegral_swap]
  ¬∑ simp only [Pi.mul_apply, mul_inv_cancel_left, mlconvolution_def]
    conv in (‚ąę‚ĀĽ _, _ ‚ąāőľ) * ŌÜ _ => rw [(lintegral_mul_const'' _ (by fun_prop)).symm]
  all_goals first | fun_prop | dsimp; fun_prop

