section BorelSpace

variable [TopologicalSpace őĪ] [MeasurableSpace őĪ] [BorelSpace őĪ] [TopologicalSpace ő≤]
  [MeasurableSpace ő≤] [BorelSpace ő≤] [TopologicalSpace ő≥] [MeasurableSpace ő≥] [BorelSpace ő≥]
  [MeasurableSpace őī]

theorem pi_le_borel_pi {őĻ : Type*} {ŌÄ : őĻ ‚Üí Type*} [‚ąÄ i, TopologicalSpace (ŌÄ i)]
    [‚ąÄ i, MeasurableSpace (ŌÄ i)] [‚ąÄ i, BorelSpace (ŌÄ i)] :
      MeasurableSpace.pi ‚Č§ borel (‚ąÄ i, ŌÄ i) := by
  have : ‚ÄĻ‚ąÄ i, MeasurableSpace (ŌÄ i)‚Äļ = fun i => borel (ŌÄ i) :=
    funext fun i => BorelSpace.measurable_eq
  rw [this]
  exact iSup_le fun i => comap_le_iff_le_map.2 <| (continuous_apply i).borel_measurable

theorem prod_le_borel_prod : Prod.instMeasurableSpace ‚Č§ borel (őĪ √ó ő≤) := by
  rw [‚ÄĻBorelSpace őĪ‚Äļ.measurable_eq, ‚ÄĻBorelSpace ő≤‚Äļ.measurable_eq]
  refine sup_le ?_ ?_
  ¬∑ exact comap_le_iff_le_map.mpr continuous_fst.borel_measurable
  ¬∑ exact comap_le_iff_le_map.mpr continuous_snd.borel_measurable

instance Pi.borelSpace {őĻ : Type*} {ŌÄ : őĻ ‚Üí Type*} [Countable őĻ] [‚ąÄ i, TopologicalSpace (ŌÄ i)]
    [‚ąÄ i, MeasurableSpace (ŌÄ i)] [‚ąÄ i, SecondCountableTopology (ŌÄ i)] [‚ąÄ i, BorelSpace (ŌÄ i)] :
    BorelSpace (‚ąÄ i, ŌÄ i) :=
  ‚ü®le_antisymm pi_le_borel_pi OpensMeasurableSpace.borel_le‚ü©

instance Prod.borelSpace [SecondCountableTopologyEither őĪ ő≤] :
    BorelSpace (őĪ √ó ő≤) :=
  ‚ü®le_antisymm prod_le_borel_prod OpensMeasurableSpace.borel_le‚ü©

/-- Given a measurable embedding to a Borel space which is also a topological embedding, then the
source space is also a Borel space. -/
lemma MeasurableEmbedding.borelSpace {őĪ ő≤ : Type*} [MeasurableSpace őĪ] [TopologicalSpace őĪ]
    [MeasurableSpace ő≤] [TopologicalSpace ő≤] [hő≤ : BorelSpace ő≤] {e : őĪ ‚Üí ő≤}
    (h'e : MeasurableEmbedding e) (h''e : IsInducing e) :
    BorelSpace őĪ := by
  constructor
  have : MeasurableSpace.comap e (borel ő≤) = ‚ÄĻ_‚Äļ := by simpa [hő≤.measurable_eq] using h'e.comap_eq
  rw [‚Üź this, ‚Üź borel_comap, h''e.eq_induced]

instance _root_.ULift.instBorelSpace : BorelSpace (ULift őĪ) :=
  MeasurableEquiv.ulift.measurableEmbedding.borelSpace Homeomorph.ulift.isInducing

instance DiscreteMeasurableSpace.toBorelSpace {őĪ : Type*} [TopologicalSpace őĪ] [DiscreteTopology őĪ]
    [MeasurableSpace őĪ] [DiscreteMeasurableSpace őĪ] : BorelSpace őĪ := by
  constructor; ext; simp [MeasurableSpace.measurableSet_generateFrom, MeasurableSet.of_discrete]

protected theorem Topology.IsEmbedding.measurableEmbedding {f : őĪ ‚Üí ő≤} (h‚āĀ : IsEmbedding f)
