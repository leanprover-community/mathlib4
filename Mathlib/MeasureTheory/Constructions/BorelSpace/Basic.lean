/-!
# Borel (measurable) space

## Main definitions

* `borel őĪ` : the least `ŌÉ`-algebra that contains all open sets;
* `class BorelSpace` : a space with `TopologicalSpace` and `MeasurableSpace` structures
  such that `‚ÄĻMeasurableSpace őĪ‚Äļ = borel őĪ`;
* `class OpensMeasurableSpace` : a space with `TopologicalSpace` and `MeasurableSpace`
  structures such that all open sets are measurable; equivalently, `borel őĪ ‚Č§ ‚ÄĻMeasurableSpace őĪ‚Äļ`.
* `BorelSpace` instances on `Empty`, `Unit`, `Bool`, `Nat`, `Int`, `Rat`;
* `MeasurableSpace` and `BorelSpace` instances on `‚ĄĚ`, `‚ĄĚ‚Č•0`, `‚ĄĚ‚Č•0‚ąě`.

## Main statements

* `IsOpen.measurableSet`, `IsClosed.measurableSet`: open and closed sets are measurable;
* `Continuous.measurable` : a continuous function is measurable;
* `Continuous.measurable2` : if `f : őĪ ‚Üí ő≤` and `g : őĪ ‚Üí ő≥` are measurable and `op : ő≤ √ó ő≥ ‚Üí őī`
  is continuous, then `fun x => op (f x, g y)` is measurable;
* `Measurable.add` etc : dot notation for arithmetic operations on `Measurable` predicates,
  and similarly for `dist` and `edist`;
* `AEMeasurable.add` : similar dot notation for almost everywhere measurable functions;
-/


noncomputable section

open Filter MeasureTheory Set Topology
open scoped NNReal ENNReal MeasureTheory

universe u v w x y

variable {őĪ ő≤ ő≥ ő≥‚āā őī : Type*} {őĻ : Sort y} {s t u : Set őĪ}

open MeasurableSpace TopologicalSpace

/-- `MeasurableSpace` structure generated by `TopologicalSpace`. -/
def borel (őĪ : Type u) [TopologicalSpace őĪ] : MeasurableSpace őĪ :=
  generateFrom { s : Set őĪ | IsOpen s }

theorem borel_anti : Antitone (@borel őĪ) := fun _ _ h =>
  MeasurableSpace.generateFrom_le fun _ hs => .basic _ (h _ hs)

theorem borel_eq_top_of_discrete [TopologicalSpace őĪ] [DiscreteTopology őĪ] : borel őĪ = ‚ä§ :=
  top_le_iff.1 fun s _ => GenerateMeasurable.basic s (isOpen_discrete s)

theorem borel_eq_generateFrom_of_subbasis {s : Set (Set őĪ)} [t : TopologicalSpace őĪ]
    [SecondCountableTopology őĪ] (hs : t = .generateFrom s) : borel őĪ = .generateFrom s :=
  le_antisymm
    (generateFrom_le fun u (hu : t.IsOpen u) => by
      rw [hs] at hu
      induction hu with
      | basic u hu => exact GenerateMeasurable.basic u hu
      | univ => exact @MeasurableSet.univ őĪ (generateFrom s)
      | inter s‚āĀ s‚āā _ _ hs‚āĀ hs‚āā => exact @MeasurableSet.inter őĪ (generateFrom s) _ _ hs‚āĀ hs‚āā
      | sUnion f hf ih =>
        rcases isOpen_sUnion_countable f (by rwa [hs]) with ‚ü®v, hv, vf, vu‚ü©
        rw [‚Üź vu]
        exact @MeasurableSet.sUnion őĪ (generateFrom s) _ hv fun x xv => ih _ (vf xv))
    (generateFrom_le fun u hu =>
      GenerateMeasurable.basic _ <| show t.IsOpen u by rw [hs]; exact GenerateOpen.basic _ hu)

theorem TopologicalSpace.IsTopologicalBasis.borel_eq_generateFrom [TopologicalSpace őĪ]
    [SecondCountableTopology őĪ] {s : Set (Set őĪ)} (hs : IsTopologicalBasis s) :
    borel őĪ = .generateFrom s :=
  borel_eq_generateFrom_of_subbasis hs.eq_generateFrom

theorem isPiSystem_isOpen [TopologicalSpace őĪ] : IsPiSystem ({s : Set őĪ | IsOpen s}) :=
  fun _s hs _t ht _ => IsOpen.inter hs ht

lemma isPiSystem_isClosed [TopologicalSpace őĪ] : IsPiSystem ({s : Set őĪ | IsClosed s}) :=
  fun _s hs _t ht _ ‚Ü¶ IsClosed.inter hs ht

theorem borel_eq_generateFrom_isClosed [TopologicalSpace őĪ] :
    borel őĪ = .generateFrom { s | IsClosed s } :=
  le_antisymm
    (generateFrom_le fun _t ht =>
      @MeasurableSet.of_compl őĪ _ (generateFrom { s | IsClosed s })
        (GenerateMeasurable.basic _ <| isClosed_compl_iff.2 ht))
    (generateFrom_le fun _t ht =>
      @MeasurableSet.of_compl őĪ _ (borel őĪ) (GenerateMeasurable.basic _ <| isOpen_compl_iff.2 ht))

theorem borel_comap {f : őĪ ‚Üí ő≤} {t : TopologicalSpace ő≤} :
    @borel őĪ (t.induced f) = (@borel ő≤ t).comap f :=
  comap_generateFrom.symm

theorem Continuous.borel_measurable [TopologicalSpace őĪ] [TopologicalSpace ő≤] {f : őĪ ‚Üí ő≤}
    (hf : Continuous f) : @Measurable őĪ ő≤ (borel őĪ) (borel ő≤) f :=
  Measurable.of_le_map <|
    generateFrom_le fun s hs => GenerateMeasurable.basic (f ‚ĀĽ¬Ļ' s) (hs.preimage hf)

/-- A space with `MeasurableSpace` and `TopologicalSpace` structures such that
all open sets are measurable. -/
class OpensMeasurableSpace (őĪ : Type*) [TopologicalSpace őĪ] [h : MeasurableSpace őĪ] : Prop where
  /-- Borel-measurable sets are measurable. -/
  borel_le : borel őĪ ‚Č§ h

/-- A space with `MeasurableSpace` and `TopologicalSpace` structures such that
the `ŌÉ`-algebra of measurable sets is exactly the `ŌÉ`-algebra generated by open sets. -/
class BorelSpace (őĪ : Type*) [TopologicalSpace őĪ] [MeasurableSpace őĪ] : Prop where
  /-- The measurable sets are exactly the Borel-measurable sets. -/
  measurable_eq : ‚ÄĻMeasurableSpace őĪ‚Äļ = borel őĪ

namespace Mathlib.Tactic.Borelize

open Lean Elab Term Tactic Meta

/-- The behaviour of `borelize őĪ` depends on the existing assumptions on `őĪ`.

- if `őĪ` is a topological space with instances `[MeasurableSpace őĪ] [BorelSpace őĪ]`, then
  `borelize őĪ` replaces the former instance by `borel őĪ`;
- otherwise, `borelize őĪ` adds instances `borel őĪ : MeasurableSpace őĪ` and `‚ü®rfl‚ü© : BorelSpace őĪ`.

Finally, `borelize őĪ ő≤ ő≥` runs `borelize őĪ; borelize ő≤; borelize ő≥`.
-/
syntax "borelize" (ppSpace colGt term:max)* : tactic

/-- Add instances `borel e : MeasurableSpace e` and `‚ü®rfl‚ü© : BorelSpace e`. -/
def addBorelInstance (e : Expr) : TacticM Unit := do
  let t ‚Üź Lean.Elab.Term.exprToSyntax e
  evalTactic <| ‚Üź `(tactic|
    refine_lift
      letI : MeasurableSpace $t := borel $t
      haveI : BorelSpace $t := ‚ü®rfl‚ü©
      ?_)

/-- Given a type `e`, an assumption `i : MeasurableSpace e`, and an instance `[BorelSpace e]`,
replace `i` with `borel e`. -/
def borelToRefl (e : Expr) (i : FVarId) : TacticM Unit := do
  let te ‚Üź Lean.Elab.Term.exprToSyntax e
  evalTactic <| ‚Üź `(tactic|
    have := @BorelSpace.measurable_eq $te _ _ _)
  try
    liftMetaTactic fun m => return [‚Üź subst m i]
  catch _ =>
    let et ‚Üź synthInstance (‚Üź mkAppOptM ``TopologicalSpace #[e])
    throwError m!"\
      `‚ÄĻTopologicalSpace {e}‚Äļ := {et}\n\
      depends on\n\
      {Expr.fvar i} : MeasurableSpace {e}`\n\
      so `borelize` isn't available"
  evalTactic <| ‚Üź `(tactic|
    refine_lift
      letI : MeasurableSpace $te := borel $te
      ?_)

/-- Given a type `$t`, if there is an assumption `[i : MeasurableSpace $t]`, then try to prove
`[BorelSpace $t]` and replace `i` with `borel $t`. Otherwise, add instances
`borel $t : MeasurableSpace $t` and `‚ü®rfl‚ü© : BorelSpace $t`. -/
def borelize (t : Term) : TacticM Unit := withMainContext <| do
  let u ‚Üź mkFreshLevelMVar
  let e ‚Üź withoutRecover <| Tactic.elabTermEnsuringType t (mkSort (mkLevelSucc u))
  let i? ‚Üź findLocalDeclWithType? (‚Üź mkAppOptM ``MeasurableSpace #[e])
  i?.elim (addBorelInstance e) (borelToRefl e)

elab_rules : tactic
  | `(tactic| borelize $[$t:term]*) => t.forM borelize

end Mathlib.Tactic.Borelize

instance (priority := 100) OrderDual.opensMeasurableSpace {őĪ : Type*} [TopologicalSpace őĪ]
    [MeasurableSpace őĪ] [h : OpensMeasurableSpace őĪ] : OpensMeasurableSpace őĪŠĶíŠĶą where
  borel_le := h.borel_le

instance (priority := 100) OrderDual.borelSpace {őĪ : Type*} [TopologicalSpace őĪ]
    [MeasurableSpace őĪ] [h : BorelSpace őĪ] : BorelSpace őĪŠĶíŠĶą where
  measurable_eq := h.measurable_eq

/-- In a `BorelSpace` all open sets are measurable. -/
instance (priority := 100) BorelSpace.opensMeasurable {őĪ : Type*} [TopologicalSpace őĪ]
    [MeasurableSpace őĪ] [BorelSpace őĪ] : OpensMeasurableSpace őĪ :=
  ‚ü®ge_of_eq <| BorelSpace.measurable_eq‚ü©

instance Subtype.borelSpace {őĪ : Type*} [TopologicalSpace őĪ] [MeasurableSpace őĪ]
    [hőĪ : BorelSpace őĪ] (s : Set őĪ) : BorelSpace s :=
  ‚ü®by borelize őĪ; symm; apply borel_comap‚ü©

instance Countable.instBorelSpace [Countable őĪ] [MeasurableSpace őĪ] [MeasurableSingletonClass őĪ]
    [TopologicalSpace őĪ] [DiscreteTopology őĪ] : BorelSpace őĪ := by
  have : ‚ąÄ s, @MeasurableSet őĪ inferInstance s := fun s ‚Ü¶ s.to_countable.measurableSet
  have : ‚ąÄ s, @MeasurableSet őĪ (borel őĪ) s := fun s ‚Ü¶ measurableSet_generateFrom (isOpen_discrete s)
  exact ‚ü®by aesop‚ü©

instance Subtype.opensMeasurableSpace {őĪ : Type*} [TopologicalSpace őĪ] [MeasurableSpace őĪ]
    [h : OpensMeasurableSpace őĪ] (s : Set őĪ) : OpensMeasurableSpace s :=
  ‚ü®by
    rw [borel_comap]
    exact comap_mono h.1‚ü©

lemma opensMeasurableSpace_iff_forall_measurableSet
    [TopologicalSpace őĪ] [MeasurableSpace őĪ] :
    OpensMeasurableSpace őĪ ‚ÜĒ  (‚ąÄ (s : Set őĪ), IsOpen s ‚Üí MeasurableSet s) := by
  refine ‚ü®fun h s hs ‚Ü¶ ?_, fun h ‚Ü¶ ‚ü®generateFrom_le h‚ü©‚ü©
  exact OpensMeasurableSpace.borel_le _ <| GenerateMeasurable.basic _ hs

instance (priority := 100) BorelSpace.countablyGenerated {őĪ : Type*} [TopologicalSpace őĪ]
    [MeasurableSpace őĪ] [BorelSpace őĪ] [SecondCountableTopology őĪ] : CountablyGenerated őĪ := by
  obtain ‚ü®b, bct, -, hb‚ü© := exists_countable_basis őĪ
  refine ‚ü®‚ü®b, bct, ?_‚ü©‚ü©
  borelize őĪ
  exact hb.borel_eq_generateFrom

theorem MeasurableSet.induction_on_open [TopologicalSpace őĪ] [MeasurableSpace őĪ] [BorelSpace őĪ]
    {C : Set őĪ ‚Üí Prop} (h_open : ‚ąÄ U, IsOpen U ‚Üí C U)
    (h_compl : ‚ąÄ t, MeasurableSet t ‚Üí C t ‚Üí C tŠ∂ú)
    (h_union :
      ‚ąÄ f : ‚Ąē ‚Üí Set őĪ,
        Pairwise (Disjoint on f) ‚Üí (‚ąÄ i, MeasurableSet (f i)) ‚Üí (‚ąÄ i, C (f i)) ‚Üí C (‚čÉ i, f i)) :
    ‚ąÄ ‚¶Ét‚¶Ą, MeasurableSet t ‚Üí C t :=
  MeasurableSpace.induction_on_inter BorelSpace.measurable_eq isPiSystem_isOpen
    (h_open _ isOpen_empty) h_open h_compl h_union

section

variable [TopologicalSpace őĪ] [MeasurableSpace őĪ] [OpensMeasurableSpace őĪ] [TopologicalSpace ő≤]
  [MeasurableSpace ő≤] [OpensMeasurableSpace ő≤] [TopologicalSpace ő≥] [MeasurableSpace ő≥]
  [BorelSpace ő≥] [TopologicalSpace ő≥‚āā] [MeasurableSpace ő≥‚āā] [BorelSpace ő≥‚āā] [MeasurableSpace őī]

theorem IsOpen.measurableSet (h : IsOpen s) : MeasurableSet s :=
  OpensMeasurableSpace.borel_le _ <| GenerateMeasurable.basic _ h

theorem IsOpen.nullMeasurableSet {őľ} (h : IsOpen s) : NullMeasurableSet s őľ :=
  h.measurableSet.nullMeasurableSet

instance (priority := 1000) {s : Set őĪ} [h : HasCountableSeparatingOn őĪ IsOpen s] :
    CountablySeparated s := by
  rw [CountablySeparated.subtype_iff]
  exact .mono (fun _ ‚Ü¶ IsOpen.measurableSet) Subset.rfl

@[measurability]
theorem measurableSet_interior : MeasurableSet (interior s) :=
  isOpen_interior.measurableSet

theorem IsGőī.measurableSet (h : IsGőī s) : MeasurableSet s := by
  rcases h with ‚ü®S, hSo, hSc, rfl‚ü©
  exact MeasurableSet.sInter hSc fun t ht => (hSo t ht).measurableSet

theorem measurableSet_of_continuousAt {ő≤} [EMetricSpace ő≤] (f : őĪ ‚Üí ő≤) :
    MeasurableSet { x | ContinuousAt f x } :=
  (IsGőī.setOf_continuousAt f).measurableSet

theorem IsClosed.measurableSet (h : IsClosed s) : MeasurableSet s :=
  h.isOpen_compl.measurableSet.of_compl

theorem IsClosed.nullMeasurableSet {őľ} (h : IsClosed s) : NullMeasurableSet s őľ :=
  h.measurableSet.nullMeasurableSet

theorem IsCompact.measurableSet [T2Space őĪ] (h : IsCompact s) : MeasurableSet s :=
  h.isClosed.measurableSet

theorem IsCompact.nullMeasurableSet [T2Space őĪ] {őľ} (h : IsCompact s) : NullMeasurableSet s őľ :=
  h.isClosed.nullMeasurableSet

/-- If two points are topologically inseparable,
then they can't be separated by a Borel measurable set. -/
theorem Inseparable.mem_measurableSet_iff {x y : ő≥} (h : Inseparable x y) {s : Set ő≥}
    (hs : MeasurableSet s) : x ‚ąą s ‚ÜĒ y ‚ąą s :=
  hs.induction_on_open (C := fun s ‚Ü¶ (x ‚ąą s ‚ÜĒ y ‚ąą s)) (fun _ ‚Ü¶ h.mem_open_iff) (fun _ _ ‚Ü¶ Iff.not)
    fun _ _ _ h ‚Ü¶ by simp [h]

/-- If `K` is a compact set in an R‚āĀ space and `s ‚äá K` is a Borel measurable superset,
then `s` includes the closure of `K` as well. -/
theorem IsCompact.closure_subset_measurableSet [R1Space ő≥] {K s : Set ő≥} (hK : IsCompact K)
    (hs : MeasurableSet s) (hKs : K ‚äÜ s) : closure K ‚äÜ s := by
  rw [hK.closure_eq_biUnion_inseparable, iUnion‚āā_subset_iff]
  exact fun x hx y hy ‚Ü¶ (hy.mem_measurableSet_iff hs).1 (hKs hx)

/-- In an R‚āĀ topological space with Borel measure `őľ`,
the measure of the closure of a compact set `K` is equal to the measure of `K`.

See also `MeasureTheory.Measure.OuterRegular.measure_closure_eq_of_isCompact`
for a version that assumes `őľ` to be outer regular
but does not assume the `ŌÉ`-algebra to be Borel. -/
theorem IsCompact.measure_closure [R1Space ő≥] {K : Set ő≥} (hK : IsCompact K) (őľ : Measure ő≥) :
    őľ (closure K) = őľ K := by
  refine le_antisymm ?_ (measure_mono subset_closure)
  calc
    őľ (closure K) ‚Č§ őľ (toMeasurable őľ K) := measure_mono <|
      hK.closure_subset_measurableSet (measurableSet_toMeasurable ..) (subset_toMeasurable ..)
    _ = őľ K := measure_toMeasurable ..

@[measurability]
theorem measurableSet_closure : MeasurableSet (closure s) :=
  isClosed_closure.measurableSet

theorem measurable_of_isOpen {f : őī ‚Üí ő≥} (hf : ‚ąÄ s, IsOpen s ‚Üí MeasurableSet (f ‚ĀĽ¬Ļ' s)) :
    Measurable f := by
  rw [‚ÄĻBorelSpace ő≥‚Äļ.measurable_eq]
  exact measurable_generateFrom hf

theorem measurable_of_isClosed {f : őī ‚Üí ő≥} (hf : ‚ąÄ s, IsClosed s ‚Üí MeasurableSet (f ‚ĀĽ¬Ļ' s)) :
    Measurable f := by
  apply measurable_of_isOpen; intro s hs
  rw [‚Üź MeasurableSet.compl_iff, ‚Üź preimage_compl]; apply hf; rw [isClosed_compl_iff]; exact hs

theorem measurable_of_isClosed' {f : őī ‚Üí ő≥}
    (hf : ‚ąÄ s, IsClosed s ‚Üí s.Nonempty ‚Üí s ‚Č† univ ‚Üí MeasurableSet (f ‚ĀĽ¬Ļ' s)) : Measurable f := by
  apply measurable_of_isClosed; intro s hs
  rcases eq_empty_or_nonempty s with h1 | h1
  ¬∑ simp [h1]
  by_cases h2 : s = univ
  ¬∑ simp [h2]
  exact hf s hs h1 h2

instance nhds_isMeasurablyGenerated (a : őĪ) : (ūĚďĚ a).IsMeasurablyGenerated := by
  rw [nhds, iInf_subtype']
  refine @Filter.iInf_isMeasurablyGenerated őĪ _ _ _ fun i => ?_
  exact i.2.2.measurableSet.principal_isMeasurablyGenerated

/-- If `s` is a measurable set, then `ūĚďĚ[s] a` is a measurably generated filter for
each `a`. This cannot be an `instance` because it depends on a non-instance `hs : MeasurableSet s`.
-/
theorem MeasurableSet.nhdsWithin_isMeasurablyGenerated {s : Set őĪ} (hs : MeasurableSet s) (a : őĪ) :
    (ūĚďĚ[s] a).IsMeasurablyGenerated :=
  haveI := hs.principal_isMeasurablyGenerated
  Filter.inf_isMeasurablyGenerated _ _

instance (priority := 100) OpensMeasurableSpace.separatesPoints [T0Space őĪ] :
    SeparatesPoints őĪ := by
  rw [separatesPoints_iff]
  intro x y hxy
  apply Inseparable.eq
  rw [inseparable_iff_forall_open]
  exact fun s hs => hxy _ hs.measurableSet

theorem borel_eq_top_of_countable {őĪ : Type*} [TopologicalSpace őĪ] [T0Space őĪ] [Countable őĪ] :
    borel őĪ = ‚ä§ := by
  refine top_unique fun s _ ‚Ü¶ ?_
  borelize őĪ
  exact .of_discrete

-- see Note [lower instance priority]
instance (priority := 100) OpensMeasurableSpace.toMeasurableSingletonClass [T1Space őĪ] :
    MeasurableSingletonClass őĪ :=
  ‚ü®fun _ => isClosed_singleton.measurableSet‚ü©

instance Pi.opensMeasurableSpace {őĻ : Type*} {ŌÄ : őĻ ‚Üí Type*} [Countable őĻ]
    [t' : ‚ąÄ i, TopologicalSpace (ŌÄ i)] [‚ąÄ i, MeasurableSpace (ŌÄ i)]
    [‚ąÄ i, SecondCountableTopology (ŌÄ i)] [‚ąÄ i, OpensMeasurableSpace (ŌÄ i)] :
    OpensMeasurableSpace (‚ąÄ i, ŌÄ i) := by
  constructor
  have : Pi.topologicalSpace = .generateFrom { t | ‚ąÉ (s : ‚ąÄ a, Set (ŌÄ a)) (i : Finset őĻ),
      (‚ąÄ a ‚ąą i, s a ‚ąą countableBasis (ŌÄ a)) ‚ąß t = pi (‚ÜĎi) s } := by
    simp only [funext fun a => @eq_generateFrom_countableBasis (ŌÄ a) _ _, pi_generateFrom_eq]
  rw [borel_eq_generateFrom_of_subbasis this]
  apply generateFrom_le
  rintro _ ‚ü®s, i, hi, rfl‚ü©
  refine MeasurableSet.pi i.countable_toSet fun a ha => IsOpen.measurableSet ?_
  rw [eq_generateFrom_countableBasis (ŌÄ a)]
  exact .basic _ (hi a ha)

/-- The typeclass `SecondCountableTopologyEither őĪ ő≤` registers the fact that at least one of
the two spaces has second countable topology. This is the right assumption to ensure that continuous
maps from `őĪ` to `ő≤` are strongly measurable. -/
class SecondCountableTopologyEither (őĪ ő≤ : Type*) [TopologicalSpace őĪ] [TopologicalSpace ő≤] :
  Prop where
  /-- The projection out of `SecondCountableTopologyEither` -/
  out : SecondCountableTopology őĪ ‚ą® SecondCountableTopology ő≤

instance (priority := 100) secondCountableTopologyEither_of_left (őĪ ő≤ : Type*) [TopologicalSpace őĪ]
    [TopologicalSpace ő≤] [SecondCountableTopology őĪ] : SecondCountableTopologyEither őĪ ő≤ where
  out := Or.inl (by infer_instance)

instance (priority := 100) secondCountableTopologyEither_of_right (őĪ ő≤ : Type*)
    [TopologicalSpace őĪ] [TopologicalSpace ő≤] [SecondCountableTopology ő≤] :
    SecondCountableTopologyEither őĪ ő≤ where
  out := Or.inr (by infer_instance)

/-- If either `őĪ` or `ő≤` has second-countable topology, then the open sets in `őĪ √ó ő≤` belong to the
product sigma-algebra. -/
instance Prod.opensMeasurableSpace [h : SecondCountableTopologyEither őĪ ő≤] :
    OpensMeasurableSpace (őĪ √ó ő≤) := by
  apply opensMeasurableSpace_iff_forall_measurableSet.2 (fun s hs ‚Ü¶ ?_)
  rcases h.out with hőĪ|hő≤
  ¬∑ let F : Set őĪ ‚Üí Set ő≤ := fun a ‚Ü¶ {y | ‚ąÉ b, IsOpen b ‚ąß y ‚ąą b ‚ąß a √óňĘ b ‚äÜ s}
    have A : ‚ąÄ a, IsOpen (F a) := by
      intro a
      apply isOpen_iff_forall_mem_open.2
      rintro y ‚ü®b, b_open, yb, hb‚ü©
      exact ‚ü®b, fun z zb ‚Ü¶ ‚ü®b, b_open, zb, hb‚ü©, b_open, yb‚ü©
    have : s = ‚čÉ a ‚ąą countableBasis őĪ, a √óňĘ F a := by
      apply Subset.antisymm
      ¬∑ rintro ‚ü®y1, y2‚ü© hy
        rcases isOpen_prod_iff.1 hs y1 y2 hy with ‚ü®u, v, u_open, v_open, yu, yv, huv‚ü©
        obtain ‚ü®a, ha, ya, au‚ü© : ‚ąÉ a ‚ąą countableBasis őĪ, y1 ‚ąą a ‚ąß a ‚äÜ u :=
          IsTopologicalBasis.exists_subset_of_mem_open (isBasis_countableBasis őĪ) yu u_open
        simp only [mem_iUnion, mem_prod, mem_setOf_eq, exists_and_left, exists_prop]
        exact ‚ü®a, ya, ha, v, v_open, yv, (Set.prod_mono_left au).trans huv‚ü©
      ¬∑ rintro ‚ü®y1, y2‚ü© hy
        simp only [mem_iUnion, mem_prod, mem_setOf_eq, exists_and_left, exists_prop] at hy
        rcases hy with ‚ü®a, ya, -, b, -, yb, hb‚ü©
        exact hb (mem_prod.2 ‚ü®ya, yb‚ü©)
    rw [this]
    apply MeasurableSet.biUnion (countable_countableBasis őĪ) (fun a ha ‚Ü¶ ?_)
    exact (isOpen_of_mem_countableBasis ha).measurableSet.prod (A a).measurableSet
  ¬∑ let F : Set ő≤ ‚Üí Set őĪ := fun a ‚Ü¶ {y | ‚ąÉ b, IsOpen b ‚ąß y ‚ąą b ‚ąß b √óňĘ a ‚äÜ s}
    have A : ‚ąÄ a, IsOpen (F a) := by
      intro a
      apply isOpen_iff_forall_mem_open.2
      rintro y ‚ü®b, b_open, yb, hb‚ü©
      exact ‚ü®b, fun z zb ‚Ü¶ ‚ü®b, b_open, zb, hb‚ü©, b_open, yb‚ü©
    have : s = ‚čÉ a ‚ąą countableBasis ő≤, F a √óňĘ a := by
      apply Subset.antisymm
      ¬∑ rintro ‚ü®y1, y2‚ü© hy
        rcases isOpen_prod_iff.1 hs y1 y2 hy with ‚ü®u, v, u_open, v_open, yu, yv, huv‚ü©
        obtain ‚ü®a, ha, ya, au‚ü© : ‚ąÉ a ‚ąą countableBasis ő≤, y2 ‚ąą a ‚ąß a ‚äÜ v :=
          IsTopologicalBasis.exists_subset_of_mem_open (isBasis_countableBasis ő≤) yv v_open
        simp only [mem_iUnion, mem_prod, mem_setOf_eq, exists_and_left, exists_prop]
        exact ‚ü®a, ‚ü®u, u_open, yu, (Set.prod_mono_right au).trans huv‚ü©, ha, ya‚ü©
      ¬∑ rintro ‚ü®y1, y2‚ü© hy
        simp only [mem_iUnion, mem_prod, mem_setOf_eq, exists_and_left, exists_prop] at hy
        rcases hy with ‚ü®a, ‚ü®b, -, yb, hb‚ü©, -, ya‚ü©
        exact hb (mem_prod.2 ‚ü®yb, ya‚ü©)
    rw [this]
    apply MeasurableSet.biUnion (countable_countableBasis ő≤) (fun a ha ‚Ü¶ ?_)
    exact (A a).measurableSet.prod (isOpen_of_mem_countableBasis ha).measurableSet

variable {őĪ' : Type*} [TopologicalSpace őĪ'] [MeasurableSpace őĪ']

theorem interior_ae_eq_of_null_frontier {őľ : Measure őĪ'} {s : Set őĪ'} (h : őľ (frontier s) = 0) :
    interior s =ŠĶź[őľ] s :=
  interior_subset.eventuallyLE.antisymm <| subset_closure.eventuallyLE.trans (ae_le_set.2 h)

theorem measure_interior_of_null_frontier {őľ : Measure őĪ'} {s : Set őĪ'} (h : őľ (frontier s) = 0) :
    őľ (interior s) = őľ s :=
  measure_congr (interior_ae_eq_of_null_frontier h)

theorem nullMeasurableSet_of_null_frontier {s : Set őĪ} {őľ : Measure őĪ} (h : őľ (frontier s) = 0) :
    NullMeasurableSet s őľ :=
  ‚ü®interior s, isOpen_interior.measurableSet, (interior_ae_eq_of_null_frontier h).symm‚ü©

theorem closure_ae_eq_of_null_frontier {őľ : Measure őĪ'} {s : Set őĪ'} (h : őľ (frontier s) = 0) :
    closure s =ŠĶź[őľ] s :=
  ((ae_le_set.2 h).trans interior_subset.eventuallyLE).antisymm <| subset_closure.eventuallyLE

theorem measure_closure_of_null_frontier {őľ : Measure őĪ'} {s : Set őĪ'} (h : őľ (frontier s) = 0) :
    őľ (closure s) = őľ s :=
  measure_congr (closure_ae_eq_of_null_frontier h)

instance separatesPointsOfOpensMeasurableSpaceOfT0Space [T0Space őĪ] :
    MeasurableSpace.SeparatesPoints őĪ where
  separates x y := by
    contrapose!
    intro x_ne_y
    obtain ‚ü®U, U_open, mem_U‚ü© := exists_isOpen_xor'_mem x_ne_y
    by_cases x_in_U : x ‚ąą U
    ¬∑ refine ‚ü®U, U_open.measurableSet, x_in_U, ?_‚ü©
      simp_all only [ne_eq, xor_true, not_false_eq_true]
    ¬∑ refine ‚ü®UŠ∂ú, U_open.isClosed_compl.measurableSet, x_in_U, ?_‚ü©
      simp_all only [ne_eq, xor_false, id_eq, mem_compl_iff, not_true_eq_false, not_false_eq_true]

/-- A continuous function from an `OpensMeasurableSpace` to a `BorelSpace`
is measurable. -/
@[fun_prop]
theorem Continuous.measurable {f : őĪ ‚Üí ő≥} (hf : Continuous f) : Measurable f :=
  hf.borel_measurable.mono OpensMeasurableSpace.borel_le (le_of_eq <| BorelSpace.measurable_eq)

/-- A continuous function from an `OpensMeasurableSpace` to a `BorelSpace`
is ae-measurable. -/
@[fun_prop]
theorem Continuous.aemeasurable {f : őĪ ‚Üí ő≥} (h : Continuous f) {őľ : Measure őĪ} : AEMeasurable f őľ :=
  h.measurable.aemeasurable

theorem IsClosedEmbedding.measurable {f : őĪ ‚Üí ő≥} (hf : IsClosedEmbedding f) : Measurable f :=
  hf.continuous.measurable

/-- If a function is defined piecewise in terms of functions which are continuous on their
respective pieces, then it is measurable. -/
theorem ContinuousOn.measurable_piecewise {f g : őĪ ‚Üí ő≥} {s : Set őĪ} [‚ąÄ j : őĪ, Decidable (j ‚ąą s)]
    (hf : ContinuousOn f s) (hg : ContinuousOn g sŠ∂ú) (hs : MeasurableSet s) :
    Measurable (s.piecewise f g) := by
  refine measurable_of_isOpen fun t ht => ?_
  rw [piecewise_preimage, Set.ite]
  apply MeasurableSet.union
  ¬∑ rcases _root_.continuousOn_iff'.1 hf t ht with ‚ü®u, u_open, hu‚ü©
    rw [hu]
    exact u_open.measurableSet.inter hs
  ¬∑ rcases _root_.continuousOn_iff'.1 hg t ht with ‚ü®u, u_open, hu‚ü©
    rw [diff_eq_compl_inter, inter_comm, hu]
    exact u_open.measurableSet.inter hs.compl

