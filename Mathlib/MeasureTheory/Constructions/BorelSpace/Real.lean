lemma tendsto_measure_Icc_nhdsWithin_right (b : ‚Ñù) :
    Tendsto (fun Œ¥ ‚Ü¶ Œº (Icc (b - Œ¥) (b + Œ¥))) (ùìù[‚â•] (0 : ‚Ñù)) (ùìù (Œº {b})) := by
  simp only [‚Üê nhdsGT_sup_nhdsWithin_singleton, nhdsWithin_singleton, tendsto_sup,
    tendsto_measure_Icc_nhdsWithin_right' Œº b, true_and, tendsto_pure_left]
