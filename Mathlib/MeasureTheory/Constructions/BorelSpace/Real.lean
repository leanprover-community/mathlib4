namespace Real

theorem borel_eq_generateFrom_Ioo_rat :
    borel в„қ = .generateFrom (вӢғ (a : в„ҡ) (b : в„ҡ) (_ : a < b), {Ioo (a : в„қ) (b : в„қ)}) :=
  isTopologicalBasis_Ioo_rat.borel_eq_generateFrom

theorem borel_eq_generateFrom_Iio_rat : borel в„қ = .generateFrom (вӢғ a : в„ҡ, {Iio (a : в„қ)}) := by
  rw [borel_eq_generateFrom_Iio]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q вҶҰ singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ вҹЁa, rflвҹ©
  have : IsLUB (range ((вҶ‘) : в„ҡ вҶ’ в„қ) вҲ© Iio a) a := by
    simp [isLUB_iff_le_iff, mem_upperBounds, вҶҗ le_iff_forall_rat_lt_imp_le]
  rw [вҶҗ this.biUnion_Iio_eq, вҶҗ image_univ, вҶҗ image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Iio (b : в„қ)) (by simp)

theorem borel_eq_generateFrom_Ioi_rat : borel в„қ = .generateFrom (вӢғ a : в„ҡ, {Ioi (a : в„қ)}) := by
  rw [borel_eq_generateFrom_Ioi]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q вҶҰ singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ вҹЁa, rflвҹ©
  have : IsGLB (range ((вҶ‘) : в„ҡ вҶ’ в„қ) вҲ© Ioi a) a := by
    simp [isGLB_iff_le_iff, mem_lowerBounds, вҶҗ le_iff_forall_lt_rat_imp_le]
  rw [вҶҗ this.biUnion_Ioi_eq, вҶҗ image_univ, вҶҗ image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Ioi (b : в„қ)) (by simp)

theorem borel_eq_generateFrom_Iic_rat : borel в„қ = .generateFrom (вӢғ a : в„ҡ, {Iic (a : в„қ)}) := by
  rw [borel_eq_generateFrom_Ioi_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ вҹЁq, rflвҹ© <;>
  dsimp only <;>
  [rw [вҶҗ compl_Iic]; rw [вҶҗ compl_Ioi]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem borel_eq_generateFrom_Ici_rat : borel в„қ = .generateFrom (вӢғ a : в„ҡ, {Ici (a : в„қ)}) := by
  rw [borel_eq_generateFrom_Iio_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ вҹЁq, rflвҹ© <;>
  dsimp only <;>
  [rw [вҶҗ compl_Ici]; rw [вҶҗ compl_Iio]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem isPiSystem_Ioo_rat :
    IsPiSystem (вӢғ (a : в„ҡ) (b : в„ҡ) (_ : a < b), {Ioo (a : в„қ) (b : в„қ)}) := by
  convert isPiSystem_Ioo ((вҶ‘) : в„ҡ вҶ’ в„қ) ((вҶ‘) : в„ҡ вҶ’ в„қ)
  ext x
  simp [eq_comm]

theorem isPiSystem_Iio_rat : IsPiSystem (вӢғ a : в„ҡ, {Iio (a : в„қ)}) := by
  convert isPiSystem_image_Iio (((вҶ‘) : в„ҡ вҶ’ в„қ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ioi_rat : IsPiSystem (вӢғ a : в„ҡ, {Ioi (a : в„қ)}) := by
  convert isPiSystem_image_Ioi (((вҶ‘) : в„ҡ вҶ’ в„қ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Iic_rat : IsPiSystem (вӢғ a : в„ҡ, {Iic (a : в„қ)}) := by
  convert isPiSystem_image_Iic (((вҶ‘) : в„ҡ вҶ’ в„қ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ici_rat : IsPiSystem (вӢғ a : в„ҡ, {Ici (a : в„қ)}) := by
  convert isPiSystem_image_Ici (((вҶ‘) : в„ҡ вҶ’ в„қ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

/-- The intervals `(-(n + 1), (n + 1))` form a finite spanning set in the set of open intervals
with rational endpoints for a locally finite measure `Ој` on `в„қ`. -/
def finiteSpanningSetsInIooRat (Ој : Measure в„қ) [IsLocallyFiniteMeasure Ој] :
    Ој.FiniteSpanningSetsIn (вӢғ (a : в„ҡ) (b : в„ҡ) (_ : a < b), {Ioo (a : в„қ) (b : в„қ)}) where
  set n := Ioo (-(n + 1)) (n + 1)
  set_mem n := by
    simp only [mem_iUnion, mem_singleton_iff]
    refine вҹЁ-(n + 1 : в„•), n + 1, ?_, by simpвҹ©
    -- TODO: norm_cast fails here?
    push_cast
    exact neg_lt_self n.cast_add_one_pos
  finite _ := measure_Ioo_lt_top
  spanning :=
    iUnion_eq_univ_iff.2 fun x =>
      вҹЁвҢҠ|x|вҢӢвӮҠ, neg_lt.1 ((neg_le_abs x).trans_lt (Nat.lt_floor_add_one _)),
        (le_abs_self x).trans_lt (Nat.lt_floor_add_one _)вҹ©

theorem measure_ext_Ioo_rat {Ој ОҪ : Measure в„қ} [IsLocallyFiniteMeasure Ој]
    (h : вҲҖ a b : в„ҡ, Ој (Ioo a b) = ОҪ (Ioo a b)) : Ој = ОҪ :=
  (finiteSpanningSetsInIooRat Ој).ext borel_eq_generateFrom_Ioo_rat isPiSystem_Ioo_rat <| by
    simp only [mem_iUnion, mem_singleton_iff]
    rintro _ вҹЁa, b, -, rflвҹ©
    apply h

