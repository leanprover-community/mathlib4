lemma tendsto_measure_Icc [NoAtoms őľ] (b : ‚ĄĚ) :
    Tendsto (fun őī ‚Ü¶ őľ (Icc (b - őī) (b + őī))) (ūĚďĚ (0 : ‚ĄĚ)) (ūĚďĚ 0) := by
