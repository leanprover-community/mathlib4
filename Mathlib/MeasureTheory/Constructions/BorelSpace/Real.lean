/-- If a function `f : ╬▒ Рєњ РёЮРЅЦ0` is measurable and the measure is ¤Ѓ-finite, then there exists
spanning measurable sets with finite measure on which `f` is bounded.
See also `StronglyMeasurable.exists_spanning_measurableSet_norm_le` for functions into normed
groups. -/
theorem exists_spanning_measurableSet_le {f : ╬▒ Рєњ РёЮРЅЦ0} (hf : Measurable f) (╬╝ : Measure ╬▒)
    [SigmaFinite ╬╝] :
    РѕЃ s : РёЋ Рєњ Set ╬▒,
      (Рѕђ n, MeasurableSet (s n) РѕД ╬╝ (s n) < Рѕъ РѕД Рѕђ x Рѕѕ s n, f x РЅц n) РѕД
      РІЃ i, s i = Set.univ := by
  let sigma_finite_sets := spanningSets ╬╝
  let norm_sets := fun n : РёЋ => { x | f x РЅц n }
  have norm_sets_spanning : РІЃ n, norm_sets n = Set.univ := by
    ext1 x
    simp only [Set.mem_iUnion, Set.mem_univ, iff_true]
    exact exists_nat_ge (f x)
  let sets n := sigma_finite_sets n РѕЕ norm_sets n
  have h_meas : Рѕђ n, MeasurableSet (sets n) := by
    refine fun n => MeasurableSet.inter ?_ ?_
    ┬и exact measurableSet_spanningSets ╬╝ n
    ┬и exact hf measurableSet_Iic
  have h_finite : Рѕђ n, ╬╝ (sets n) < Рѕъ := by
    refine fun n => (measure_mono Set.inter_subset_left).trans_lt ?_
    exact measure_spanningSets_lt_top ╬╝ n
  refine РЪеsets, fun n => РЪеh_meas n, h_finite n, ?_РЪЕ, ?_РЪЕ
  ┬и exact fun x hx => hx.2
  ┬и have :
      РІЃ i, sigma_finite_sets i РѕЕ norm_sets i = (РІЃ i, sigma_finite_sets i) РѕЕ РІЃ i, norm_sets i := by
      refine Set.iUnion_inter_of_monotone (monotone_spanningSets ╬╝) fun i j hij x => ?_
      simp only [norm_sets, Set.mem_setOf_eq]
      refine fun hif => hif.trans ?_
      exact mod_cast hij
    rw [this, norm_sets_spanning, iUnion_spanningSets ╬╝, Set.inter_univ]

variable (╬╝ : Measure РёЮ) [IsFiniteMeasureOnCompacts ╬╝]

lemma tendsto_measure_Icc_nhdsWithin_right' (b : РёЮ) :
    Tendsto (fun ╬┤ Рєд ╬╝ (Icc (b - ╬┤) (b + ╬┤))) (­ЮЊЮ[>] (0 : РёЮ)) (­ЮЊЮ (╬╝ {b})) := by
  rw [Real.singleton_eq_inter_Icc]
  apply tendsto_measure_biInter_gt (fun r hr Рєд nullMeasurableSet_Icc)
  ┬и intro r s _rpos hrs
    exact Icc_subset_Icc (by linarith) (by linarith)
  ┬и exact РЪе1, zero_lt_one, isCompact_Icc.measure_ne_topРЪЕ

lemma tendsto_measure_Icc_nhdsWithin_right (b : РёЮ) :
    Tendsto (fun ╬┤ Рєд ╬╝ (Icc (b - ╬┤) (b + ╬┤))) (­ЮЊЮ[РЅЦ] (0 : РёЮ)) (­ЮЊЮ (╬╝ {b})) := by
  simp only [Рєљ nhdsGT_sup_nhdsWithin_singleton, nhdsWithin_singleton, tendsto_sup,
    tendsto_measure_Icc_nhdsWithin_right' ╬╝ b, true_and, tendsto_pure_left]
  intro s hs
  simpa using mem_of_mem_nhds hs

lemma tendsto_measure_Icc [NoAtoms ╬╝] (b : РёЮ) :
    Tendsto (fun ╬┤ Рєд ╬╝ (Icc (b - ╬┤) (b + ╬┤))) (­ЮЊЮ (0 : РёЮ)) (­ЮЊЮ 0) := by
  rw [Рєљ nhdsLT_sup_nhdsGE, tendsto_sup]
  constructor
  ┬и apply tendsto_const_nhds.congr'
    filter_upwards [self_mem_nhdsWithin] with r (hr : r < 0)
    rw [Icc_eq_empty (by linarith), measure_empty]
  ┬и simpa only [measure_singleton] using tendsto_measure_Icc_nhdsWithin_right ╬╝ b
