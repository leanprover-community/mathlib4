lemma measurable_of_real_real {f : EReal Г— EReal вҶ’ ОІ}
    (h_real : Measurable fun p : в„қ Г— в„қ вҶҰ f (p.1, p.2))
    (h_bot_left : Measurable fun r : в„қ вҶҰ f (вҠҘ, r))
    (h_top_left : Measurable fun r : в„қ вҶҰ f (вҠӨ, r))
    (h_bot_right : Measurable fun r : в„қ вҶҰ f (r, вҠҘ))
    (h_top_right : Measurable fun r : в„қ вҶҰ f (r, вҠӨ)) :
    Measurable f := by
  refine measurable_of_real_prod ?_ ?_ ?_
  В· refine measurable_swap_iff.mp <| measurable_of_real_prod ?_ h_bot_right h_top_right
    exact h_real.comp measurable_swap
  В· exact measurable_of_measurable_real h_bot_left
  В· exact measurable_of_measurable_real h_top_left

private lemma measurable_const_mul (c : EReal) : Measurable fun (x : EReal) вҶҰ c * x := by
  refine measurable_of_measurable_real ?_
  have h1 : (fun (p : в„қ) вҶҰ (вҠҘ : EReal) * p)
      = fun p вҶҰ if p = 0 then (0 : EReal) else (if p < 0 then вҠӨ else вҠҘ) := by
    ext p
    split_ifs with h1 h2
    В· simp [h1]
    В· rw [bot_mul_coe_of_neg h2]
    В· rw [bot_mul_coe_of_pos]
      exact lt_of_le_of_ne (not_lt.mp h2) (Ne.symm h1)
  have h2 : Measurable fun (p : в„қ) вҶҰ if p = 0 then (0 : EReal) else if p < 0 then вҠӨ else вҠҘ := by
    refine Measurable.piecewise (measurableSet_singleton _) measurable_const ?_
    exact Measurable.piecewise measurableSet_Iio measurable_const measurable_const
  induction c with
  | bot => rwa [h1]
  | coe c => exact (measurable_id.const_mul _).coe_real_ereal
  | top =>
    simp_rw [вҶҗ neg_bot, neg_mul]
    apply Measurable.neg
    rwa [h1]

instance : MeasurableMulвӮӮ EReal := by
  refine вҹЁmeasurable_of_real_real ?_ ?_ ?_ ?_ ?_вҹ©
  В· exact (measurable_fst.mul measurable_snd).coe_real_ereal
  В· exact (measurable_const_mul _).comp measurable_coe_real_ereal
  В· exact (measurable_const_mul _).comp measurable_coe_real_ereal
  В· simp_rw [mul_comm _ вҠҘ]
    exact (measurable_const_mul _).comp measurable_coe_real_ereal
  В· simp_rw [mul_comm _ вҠӨ]
    exact (measurable_const_mul _).comp measurable_coe_real_ereal

