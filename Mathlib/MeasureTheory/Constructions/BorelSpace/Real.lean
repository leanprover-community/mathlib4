    Measurable g := by
  simp_rw [вҶҗ measurable_coe_nnreal_ennreal_iff] at hf вҠў
  refine ENNReal.measurable_of_tendsto' u hf ?_
  rw [tendsto_pi_nhds] at lim вҠў
  exact fun x => (ENNReal.continuous_coe.tendsto (g x)).comp (lim x)

/-- A sequential limit of measurable `в„қвүҘ0`-valued functions is measurable. -/
theorem measurable_of_tendsto {f : в„• вҶ’ Оұ вҶ’ в„қвүҘ0} {g : Оұ вҶ’ в„қвүҘ0} (hf : вҲҖ i, Measurable (f i))
    (lim : Tendsto f atTop (рқ“қ g)) : Measurable g :=
  measurable_of_tendsto' atTop hf lim

