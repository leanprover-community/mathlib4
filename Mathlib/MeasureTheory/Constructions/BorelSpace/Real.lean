    exact measurable_coe_nnreal_ennreal.mul_const _

/-- A limit (over a general filter) of measurable `в„қвүҘ0вҲһ`-valued functions is measurable. -/
theorem measurable_of_tendsto' {О№ : Type*} {f : О№ вҶ’ Оұ вҶ’ в„қвүҘ0вҲһ} {g : Оұ вҶ’ в„қвүҘ0вҲһ} (u : Filter О№)
    [NeBot u] [IsCountablyGenerated u] (hf : вҲҖ i, Measurable (f i)) (lim : Tendsto f u (рқ“қ g)) :
    Measurable g := by
  rcases u.exists_seq_tendsto with вҹЁx, hxвҹ©
  rw [tendsto_pi_nhds] at lim
  have : (fun y => liminf (fun n => (f (x n) y : в„қвүҘ0вҲһ)) atTop) = g := by
    ext1 y
    exact ((lim y).comp hx).liminf_eq
  rw [вҶҗ this]
  change Measurable fun y => liminf (fun n => (f (x n) y : в„қвүҘ0вҲһ)) atTop
  exact .liminf fun n => hf (x n)

/-- A sequential limit of measurable `в„қвүҘ0вҲһ`-valued functions is measurable. -/
theorem measurable_of_tendsto {f : в„• вҶ’ Оұ вҶ’ в„қвүҘ0вҲһ} {g : Оұ вҶ’ в„қвүҘ0вҲһ} (hf : вҲҖ i, Measurable (f i))
    (lim : Tendsto f atTop (рқ“қ g)) : Measurable g :=
  measurable_of_tendsto' atTop hf lim

/-- A limit (over a general filter) of a.e.-measurable `в„қвүҘ0вҲһ`-valued functions is
a.e.-measurable. -/
lemma aemeasurable_of_tendsto' {О№ : Type*} {f : О№ вҶ’ Оұ вҶ’ в„қвүҘ0вҲһ} {g : Оұ вҶ’ в„қвүҘ0вҲһ}
    {Ој : Measure Оұ} (u : Filter О№) [NeBot u] [IsCountablyGenerated u]
    (hf : вҲҖ i, AEMeasurable (f i) Ој) (hlim : вҲҖбөҗ a вҲӮОј, Tendsto (fun i вҶҰ f i a) u (рқ“қ (g a))) :
    AEMeasurable g Ој := by
  rcases u.exists_seq_tendsto with вҹЁv, hvвҹ©
  have h'f : вҲҖ n, AEMeasurable (f (v n)) Ој := fun n вҶҰ hf (v n)
  set p : Оұ вҶ’ (в„• вҶ’ в„қвүҘ0вҲһ) вҶ’ Prop := fun x f' вҶҰ Tendsto f' atTop (рқ“қ (g x))
  have hp : вҲҖбөҗ x вҲӮОј, p x fun n вҶҰ f (v n) x := by
    filter_upwards [hlim] with x hx using hx.comp hv
  classical
  set aeSeqLim := fun x вҶҰ ite (x вҲҲ aeSeqSet h'f p) (g x) (вҹЁf (v 0) xвҹ© : Nonempty в„қвүҘ0вҲһ).some
  refine вҹЁaeSeqLim, measurable_of_tendsto' atTop (aeSeq.measurable h'f p)
    (tendsto_pi_nhds.mpr fun x вҶҰ ?_), ?_вҹ©
  В· unfold aeSeqLim
    simp_rw [aeSeq]
    split_ifs with hx
    В· simp_rw [aeSeq.mk_eq_fun_of_mem_aeSeqSet h'f hx]
      exact aeSeq.fun_prop_of_mem_aeSeqSet h'f hx
    В· exact tendsto_const_nhds
  В· exact (ite_ae_eq_of_measure_compl_zero g (fun x вҶҰ (вҹЁf (v 0) xвҹ© : Nonempty в„қвүҘ0вҲһ).some)
      (aeSeqSet h'f p) (aeSeq.measure_compl_aeSeqSet_eq_zero h'f hp)).symm

/-- A limit of a.e.-measurable `в„қвүҘ0вҲһ`-valued functions is a.e.-measurable. -/
