theorem borel_eq_generateFrom_Ioo_rat :
    borel РёЮ = .generateFrom (РІЃ (a : Рёџ) (b : Рёџ) (_ : a < b), {Ioo (a : РёЮ) (b : РёЮ)}) :=
  isTopologicalBasis_Ioo_rat.borel_eq_generateFrom

theorem borel_eq_generateFrom_Iio_rat : borel РёЮ = .generateFrom (РІЃ a : Рёџ, {Iio (a : РёЮ)}) := by
  rw [borel_eq_generateFrom_Iio]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q Рєд singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ РЪеa, rflРЪЕ
  have : IsLUB (range ((РєЉ) : Рёџ Рєњ РёЮ) РѕЕ Iio a) a := by
    simp [isLUB_iff_le_iff, mem_upperBounds, Рєљ le_iff_forall_rat_lt_imp_le]
  rw [Рєљ this.biUnion_Iio_eq, Рєљ image_univ, Рєљ image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Iio (b : РёЮ)) (by simp)

theorem borel_eq_generateFrom_Ioi_rat : borel РёЮ = .generateFrom (РІЃ a : Рёџ, {Ioi (a : РёЮ)}) := by
  rw [borel_eq_generateFrom_Ioi]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q Рєд singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ РЪеa, rflРЪЕ
  have : IsGLB (range ((РєЉ) : Рёџ Рєњ РёЮ) РѕЕ Ioi a) a := by
    simp [isGLB_iff_le_iff, mem_lowerBounds, Рєљ le_iff_forall_lt_rat_imp_le]
  rw [Рєљ this.biUnion_Ioi_eq, Рєљ image_univ, Рєљ image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Ioi (b : РёЮ)) (by simp)

theorem borel_eq_generateFrom_Iic_rat : borel РёЮ = .generateFrom (РІЃ a : Рёџ, {Iic (a : РёЮ)}) := by
  rw [borel_eq_generateFrom_Ioi_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ РЪеq, rflРЪЕ <;>
  dsimp only <;>
  [rw [Рєљ compl_Iic]; rw [Рєљ compl_Ioi]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem borel_eq_generateFrom_Ici_rat : borel РёЮ = .generateFrom (РІЃ a : Рёџ, {Ici (a : РёЮ)}) := by
  rw [borel_eq_generateFrom_Iio_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ РЪеq, rflРЪЕ <;>
  dsimp only <;>
  [rw [Рєљ compl_Ici]; rw [Рєљ compl_Iio]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem isPiSystem_Ioo_rat :
    IsPiSystem (РІЃ (a : Рёџ) (b : Рёџ) (_ : a < b), {Ioo (a : РёЮ) (b : РёЮ)}) := by
  convert isPiSystem_Ioo ((РєЉ) : Рёџ Рєњ РёЮ) ((РєЉ) : Рёџ Рєњ РёЮ)
  ext x
  simp [eq_comm]

theorem isPiSystem_Iio_rat : IsPiSystem (РІЃ a : Рёџ, {Iio (a : РёЮ)}) := by
  convert isPiSystem_image_Iio (((РєЉ) : Рёџ Рєњ РёЮ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ioi_rat : IsPiSystem (РІЃ a : Рёџ, {Ioi (a : РёЮ)}) := by
  convert isPiSystem_image_Ioi (((РєЉ) : Рёџ Рєњ РёЮ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Iic_rat : IsPiSystem (РІЃ a : Рёџ, {Iic (a : РёЮ)}) := by
  convert isPiSystem_image_Iic (((РєЉ) : Рёџ Рєњ РёЮ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ici_rat : IsPiSystem (РІЃ a : Рёџ, {Ici (a : РёЮ)}) := by
  convert isPiSystem_image_Ici (((РєЉ) : Рёџ Рєњ РёЮ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

/-- The intervals `(-(n + 1), (n + 1))` form a finite spanning set in the set of open intervals
with rational endpoints for a locally finite measure `╬╝` on `РёЮ`. -/
def finiteSpanningSetsInIooRat (╬╝ : Measure РёЮ) [IsLocallyFiniteMeasure ╬╝] :
    ╬╝.FiniteSpanningSetsIn (РІЃ (a : Рёџ) (b : Рёџ) (_ : a < b), {Ioo (a : РёЮ) (b : РёЮ)}) where
  set n := Ioo (-(n + 1)) (n + 1)
  set_mem n := by
    simp only [mem_iUnion, mem_singleton_iff]
    refine РЪе-(n + 1 : РёЋ), n + 1, ?_, by simpРЪЕ
    -- TODO: norm_cast fails here?
    push_cast
    exact neg_lt_self n.cast_add_one_pos
  finite _ := measure_Ioo_lt_top
  spanning :=
    iUnion_eq_univ_iff.2 fun x =>
      РЪеРїі|x|РїІРѓі, neg_lt.1 ((neg_le_abs x).trans_lt (Nat.lt_floor_add_one _)),
        (le_abs_self x).trans_lt (Nat.lt_floor_add_one _)РЪЕ

theorem measure_ext_Ioo_rat {╬╝ ╬й : Measure РёЮ} [IsLocallyFiniteMeasure ╬╝]
    (h : Рѕђ a b : Рёџ, ╬╝ (Ioo a b) = ╬й (Ioo a b)) : ╬╝ = ╬й :=
  (finiteSpanningSetsInIooRat ╬╝).ext borel_eq_generateFrom_Ioo_rat isPiSystem_Ioo_rat <| by
    simp only [mem_iUnion, mem_singleton_iff]
    rintro _ РЪеa, b, -, rflРЪЕ
    apply h

