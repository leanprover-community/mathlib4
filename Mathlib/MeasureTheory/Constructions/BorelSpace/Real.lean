/-- A limit (over a general filter) of measurable `‚ĄĚ‚Č•0‚ąě` valued functions is measurable. -/
theorem measurable_of_tendsto' {őĻ : Type*} {f : őĻ ‚Üí őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (u : Filter őĻ)
    [NeBot u] [IsCountablyGenerated u] (hf : ‚ąÄ i, Measurable (f i)) (lim : Tendsto f u (ūĚďĚ g)) :
    Measurable g := by
  rcases u.exists_seq_tendsto with ‚ü®x, hx‚ü©
  rw [tendsto_pi_nhds] at lim
  have : (fun y => liminf (fun n => (f (x n) y : ‚ĄĚ‚Č•0‚ąě)) atTop) = g := by
    ext1 y
    exact ((lim y).comp hx).liminf_eq
  rw [‚Üź this]
  show Measurable fun y => liminf (fun n => (f (x n) y : ‚ĄĚ‚Č•0‚ąě)) atTop
  exact .liminf fun n => hf (x n)

/-- A sequential limit of measurable `‚ĄĚ‚Č•0‚ąě` valued functions is measurable. -/
theorem measurable_of_tendsto {f : ‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : ‚ąÄ i, Measurable (f i))
    (lim : Tendsto f atTop (ūĚďĚ g)) : Measurable g :=
  measurable_of_tendsto' atTop hf lim

/-- A limit (over a general filter) of a.e.-measurable `‚ĄĚ‚Č•0‚ąě` valued functions is
a.e.-measurable. -/
lemma aemeasurable_of_tendsto' {őĻ : Type*} {f : őĻ ‚Üí őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
    {őľ : Measure őĪ} (u : Filter őĻ) [NeBot u] [IsCountablyGenerated u]
    (hf : ‚ąÄ i, AEMeasurable (f i) őľ) (hlim : ‚ąÄŠĶź a ‚ąāőľ, Tendsto (fun i ‚Ü¶ f i a) u (ūĚďĚ (g a))) :
    AEMeasurable g őľ := by
  rcases u.exists_seq_tendsto with ‚ü®v, hv‚ü©
  have h'f : ‚ąÄ n, AEMeasurable (f (v n)) őľ := fun n ‚Ü¶ hf (v n)
  set p : őĪ ‚Üí (‚Ąē ‚Üí ‚ĄĚ‚Č•0‚ąě) ‚Üí Prop := fun x f' ‚Ü¶ Tendsto f' atTop (ūĚďĚ (g x))
  have hp : ‚ąÄŠĶź x ‚ąāőľ, p x fun n ‚Ü¶ f (v n) x := by
    filter_upwards [hlim] with x hx using hx.comp hv
  classical
  set aeSeqLim := fun x ‚Ü¶ ite (x ‚ąą aeSeqSet h'f p) (g x) (‚ü®f (v 0) x‚ü© : Nonempty ‚ĄĚ‚Č•0‚ąě).some
  refine ‚ü®aeSeqLim, measurable_of_tendsto' atTop (aeSeq.measurable h'f p)
    (tendsto_pi_nhds.mpr fun x ‚Ü¶ ?_), ?_‚ü©
  ¬∑ unfold aeSeqLim
    simp_rw [aeSeq]
    split_ifs with hx
    ¬∑ simp_rw [aeSeq.mk_eq_fun_of_mem_aeSeqSet h'f hx]
      exact aeSeq.fun_prop_of_mem_aeSeqSet h'f hx
    ¬∑ exact tendsto_const_nhds
  ¬∑ exact (ite_ae_eq_of_measure_compl_zero g (fun x ‚Ü¶ (‚ü®f (v 0) x‚ü© : Nonempty ‚ĄĚ‚Č•0‚ąě).some)
      (aeSeqSet h'f p) (aeSeq.measure_compl_aeSeqSet_eq_zero h'f hp)).symm

/-- A limit of a.e.-measurable `‚ĄĚ‚Č•0‚ąě` valued functions is a.e.-measurable. -/
lemma aemeasurable_of_tendsto {f : ‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {g : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {őľ : Measure őĪ}
    (hf : ‚ąÄ i, AEMeasurable (f i) őľ) (hlim : ‚ąÄŠĶź a ‚ąāőľ, Tendsto (fun i ‚Ü¶ f i a) atTop (ūĚďĚ (g a))) :
    AEMeasurable g őľ :=
  aemeasurable_of_tendsto' atTop hf hlim

