instance instMeasurableMul‚āā : MeasurableMul‚āā ‚ĄĚ‚Č•0‚ąě := by
  refine ‚ü®measurable_of_measurable_nnreal_nnreal ?_ ?_ ?_‚ü©
  ¬∑ simp only [‚Üź ENNReal.coe_mul, measurable_mul.coe_nnreal_ennreal]
  ¬∑ simp only [ENNReal.top_mul', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const
  ¬∑ simp only [ENNReal.mul_top', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const

instance instMeasurableSub‚āā : MeasurableSub‚āā ‚ĄĚ‚Č•0‚ąě :=
  ‚ü®by
    apply measurable_of_measurable_nnreal_nnreal <;>
      simp [‚Üź WithTop.coe_sub, tsub_eq_zero_of_le];
        exact continuous_sub.measurable.coe_nnreal_ennreal‚ü©

