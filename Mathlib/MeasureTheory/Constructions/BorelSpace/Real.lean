namespace ENNReal

theorem measurable_of_measurable_nnreal {f : в„қвүҘ0вҲһ вҶ’ Оұ} (h : Measurable fun p : в„қвүҘ0 => f p) :
    Measurable f :=
  measurable_of_measurable_on_compl_singleton вҲһ
    (MeasurableEquiv.ennrealEquivNNReal.symm.measurable_comp_iff.1 h)

/-- `в„қвүҘ0вҲһ` is `MeasurableEquiv` to `в„қвүҘ0 вҠ• Unit`. -/
def ennrealEquivSum : в„қвүҘ0вҲһ вүғбөҗ в„қвүҘ0 вҠ• Unit :=
  { Equiv.optionEquivSumPUnit в„қвүҘ0 with
    measurable_toFun := measurable_of_measurable_nnreal measurable_inl
    measurable_invFun :=
      measurable_fun_sum measurable_coe_nnreal_ennreal (@measurable_const в„қвүҘ0вҲһ Unit _ _ вҲһ) }

open Function (uncurry)

theorem measurable_of_measurable_nnreal_prod {_ : MeasurableSpace ОІ} {_ : MeasurableSpace Оі}
    {f : в„қвүҘ0вҲһ Г— ОІ вҶ’ Оі} (HвӮҒ : Measurable fun p : в„қвүҘ0 Г— ОІ => f (p.1, p.2))
    (HвӮӮ : Measurable fun x => f (вҲһ, x)) : Measurable f :=
  let e : в„қвүҘ0вҲһ Г— ОІ вүғбөҗ (в„қвүҘ0 Г— ОІ) вҠ• (Unit Г— ОІ) :=
    (ennrealEquivSum.prodCongr (MeasurableEquiv.refl ОІ)).trans
      (MeasurableEquiv.sumProdDistrib _ _ _)
  e.symm.measurable_comp_iff.1 <| measurable_fun_sum HвӮҒ (HвӮӮ.comp measurable_id.snd)

theorem measurable_of_measurable_nnreal_nnreal {_ : MeasurableSpace ОІ} {f : в„қвүҘ0вҲһ Г— в„қвүҘ0вҲһ вҶ’ ОІ}
    (hвӮҒ : Measurable fun p : в„қвүҘ0 Г— в„қвүҘ0 => f (p.1, p.2)) (hвӮӮ : Measurable fun r : в„қвүҘ0 => f (вҲһ, r))
    (hвӮғ : Measurable fun r : в„қвүҘ0 => f (r, вҲһ)) : Measurable f :=
  measurable_of_measurable_nnreal_prod
    (measurable_swap_iff.1 <| measurable_of_measurable_nnreal_prod (hвӮҒ.comp measurable_swap) hвӮғ)
    (measurable_of_measurable_nnreal hвӮӮ)

theorem measurable_ofReal : Measurable ENNReal.ofReal :=
  ENNReal.continuous_ofReal.measurable

theorem measurable_toReal : Measurable ENNReal.toReal :=
  ENNReal.measurable_of_measurable_nnreal measurable_coe_nnreal_real

theorem measurable_toNNReal : Measurable ENNReal.toNNReal :=
  ENNReal.measurable_of_measurable_nnreal measurable_id

instance instMeasurableMulвӮӮ : MeasurableMulвӮӮ в„қвүҘ0вҲһ := by
  refine вҹЁmeasurable_of_measurable_nnreal_nnreal ?_ ?_ ?_вҹ©
  В· simp only [вҶҗ ENNReal.coe_mul, measurable_mul.coe_nnreal_ennreal]
  В· simp only [ENNReal.top_mul', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const
  В· simp only [ENNReal.mul_top', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const

instance instMeasurableSubвӮӮ : MeasurableSubвӮӮ в„қвүҘ0вҲһ :=
  вҹЁmeasurable_of_measurable_nnreal_nnreal measurable_sub.coe_nnreal_ennreal (by simp) (by simp)вҹ©

instance instMeasurableInv : MeasurableInv в„қвүҘ0вҲһ :=
