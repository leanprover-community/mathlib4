lemma tendsto_measure_Icc_nhdsWithin_right' (b : в„қ) :
    Tendsto (fun Оҙ вҶҰ Ој (Icc (b - Оҙ) (b + Оҙ))) (рқ“қ[>] (0 : в„қ)) (рқ“қ (Ој {b})) := by
