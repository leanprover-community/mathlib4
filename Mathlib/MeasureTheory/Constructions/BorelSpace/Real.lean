    (MeasurableEquiv.ennrealEquivNNReal.symm.measurable_comp_iff.1 h)

/-- `‚ĄĚ‚Č•0‚ąě` is `MeasurableEquiv` to `‚ĄĚ‚Č•0 ‚äē Unit`. -/
def ennrealEquivSum : ‚ĄĚ‚Č•0‚ąě ‚ČÉŠĶź ‚ĄĚ‚Č•0 ‚äē Unit :=
  { Equiv.optionEquivSumPUnit ‚ĄĚ‚Č•0 with
    measurable_toFun := measurable_of_measurable_nnreal measurable_inl
    measurable_invFun :=
      measurable_fun_sum measurable_coe_nnreal_ennreal (@measurable_const ‚ĄĚ‚Č•0‚ąě Unit _ _ ‚ąě) }

open Function (uncurry)

theorem measurable_of_measurable_nnreal_prod {_ : MeasurableSpace ő≤} {_ : MeasurableSpace ő≥}
    {f : ‚ĄĚ‚Č•0‚ąě √ó ő≤ ‚Üí ő≥} (H‚āĀ : Measurable fun p : ‚ĄĚ‚Č•0 √ó ő≤ => f (p.1, p.2))
    (H‚āā : Measurable fun x => f (‚ąě, x)) : Measurable f :=
  let e : ‚ĄĚ‚Č•0‚ąě √ó ő≤ ‚ČÉŠĶź (‚ĄĚ‚Č•0 √ó ő≤) ‚äē (Unit √ó ő≤) :=
    (ennrealEquivSum.prodCongr (MeasurableEquiv.refl ő≤)).trans
      (MeasurableEquiv.sumProdDistrib _ _ _)
  e.symm.measurable_comp_iff.1 <| measurable_fun_sum H‚āĀ (H‚āā.comp measurable_id.snd)

theorem measurable_of_measurable_nnreal_nnreal {_ : MeasurableSpace ő≤} {f : ‚ĄĚ‚Č•0‚ąě √ó ‚ĄĚ‚Č•0‚ąě ‚Üí ő≤}
    (h‚āĀ : Measurable fun p : ‚ĄĚ‚Č•0 √ó ‚ĄĚ‚Č•0 => f (p.1, p.2)) (h‚āā : Measurable fun r : ‚ĄĚ‚Č•0 => f (‚ąě, r))
    (h‚āÉ : Measurable fun r : ‚ĄĚ‚Č•0 => f (r, ‚ąě)) : Measurable f :=
  measurable_of_measurable_nnreal_prod
    (measurable_swap_iff.1 <| measurable_of_measurable_nnreal_prod (h‚āĀ.comp measurable_swap) h‚āÉ)
    (measurable_of_measurable_nnreal h‚āā)

