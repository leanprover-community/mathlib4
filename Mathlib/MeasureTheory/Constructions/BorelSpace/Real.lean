namespace Real

theorem borel_eq_generateFrom_Ioo_rat :
    borel ‚ĄĚ = .generateFrom (‚čÉ (a : ‚Ąö) (b : ‚Ąö) (_ : a < b), {Ioo (a : ‚ĄĚ) (b : ‚ĄĚ)}) :=
  isTopologicalBasis_Ioo_rat.borel_eq_generateFrom

theorem borel_eq_generateFrom_Iio_rat : borel ‚ĄĚ = .generateFrom (‚čÉ a : ‚Ąö, {Iio (a : ‚ĄĚ)}) := by
  rw [borel_eq_generateFrom_Iio]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q ‚Ü¶ singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ ‚ü®a, rfl‚ü©
  have : IsLUB (range ((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) ‚ą© Iio a) a := by
    simp [isLUB_iff_le_iff, mem_upperBounds, ‚Üź le_iff_forall_rat_lt_imp_le]
  rw [‚Üź this.biUnion_Iio_eq, ‚Üź image_univ, ‚Üź image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Iio (b : ‚ĄĚ)) (by simp)

theorem borel_eq_generateFrom_Ioi_rat : borel ‚ĄĚ = .generateFrom (‚čÉ a : ‚Ąö, {Ioi (a : ‚ĄĚ)}) := by
  rw [borel_eq_generateFrom_Ioi]
  refine le_antisymm
    (generateFrom_le ?_)
    (generateFrom_mono <| iUnion_subset fun q ‚Ü¶ singleton_subset_iff.mpr <| mem_range_self _)
  rintro _ ‚ü®a, rfl‚ü©
  have : IsGLB (range ((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) ‚ą© Ioi a) a := by
    simp [isGLB_iff_le_iff, mem_lowerBounds, ‚Üź le_iff_forall_lt_rat_imp_le]
  rw [‚Üź this.biUnion_Ioi_eq, ‚Üź image_univ, ‚Üź image_inter_preimage, univ_inter, biUnion_image]
  exact MeasurableSet.biUnion (to_countable _)
    fun b _ => GenerateMeasurable.basic (Ioi (b : ‚ĄĚ)) (by simp)

theorem borel_eq_generateFrom_Iic_rat : borel ‚ĄĚ = .generateFrom (‚čÉ a : ‚Ąö, {Iic (a : ‚ĄĚ)}) := by
  rw [borel_eq_generateFrom_Ioi_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ ‚ü®q, rfl‚ü© <;>
  dsimp only <;>
  [rw [‚Üź compl_Iic]; rw [‚Üź compl_Ioi]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem borel_eq_generateFrom_Ici_rat : borel ‚ĄĚ = .generateFrom (‚čÉ a : ‚Ąö, {Ici (a : ‚ĄĚ)}) := by
  rw [borel_eq_generateFrom_Iio_rat, iUnion_singleton_eq_range, iUnion_singleton_eq_range]
  refine le_antisymm (generateFrom_le ?_) (generateFrom_le ?_) <;>
  rintro _ ‚ü®q, rfl‚ü© <;>
  dsimp only <;>
  [rw [‚Üź compl_Ici]; rw [‚Üź compl_Iio]] <;>
  exact MeasurableSet.compl (GenerateMeasurable.basic _ (mem_range_self q))

theorem isPiSystem_Ioo_rat :
    IsPiSystem (‚čÉ (a : ‚Ąö) (b : ‚Ąö) (_ : a < b), {Ioo (a : ‚ĄĚ) (b : ‚ĄĚ)}) := by
  convert isPiSystem_Ioo ((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) ((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ)
  ext x
  simp [eq_comm]

theorem isPiSystem_Iio_rat : IsPiSystem (‚čÉ a : ‚Ąö, {Iio (a : ‚ĄĚ)}) := by
  convert isPiSystem_image_Iio (((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ioi_rat : IsPiSystem (‚čÉ a : ‚Ąö, {Ioi (a : ‚ĄĚ)}) := by
  convert isPiSystem_image_Ioi (((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Iic_rat : IsPiSystem (‚čÉ a : ‚Ąö, {Iic (a : ‚ĄĚ)}) := by
  convert isPiSystem_image_Iic (((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

theorem isPiSystem_Ici_rat : IsPiSystem (‚čÉ a : ‚Ąö, {Ici (a : ‚ĄĚ)}) := by
  convert isPiSystem_image_Ici (((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ) '' univ)
  ext x
  simp only [iUnion_singleton_eq_range, mem_range, image_univ, mem_image, exists_exists_eq_and]

/-- The intervals `(-(n + 1), (n + 1))` form a finite spanning sets in the set of open intervals
with rational endpoints for a locally finite measure `őľ` on `‚ĄĚ`. -/
def finiteSpanningSetsInIooRat (őľ : Measure ‚ĄĚ) [IsLocallyFiniteMeasure őľ] :
    őľ.FiniteSpanningSetsIn (‚čÉ (a : ‚Ąö) (b : ‚Ąö) (_ : a < b), {Ioo (a : ‚ĄĚ) (b : ‚ĄĚ)}) where
  set n := Ioo (-(n + 1)) (n + 1)
  set_mem n := by
    simp only [mem_iUnion, mem_singleton_iff]
    refine ‚ü®-(n + 1 : ‚Ąē), n + 1, ?_, by simp‚ü©
    -- TODO: norm_cast fails here?
    push_cast
    exact neg_lt_self n.cast_add_one_pos
  finite _ := measure_Ioo_lt_top
  spanning :=
    iUnion_eq_univ_iff.2 fun x =>
      ‚ü®‚Ćä|x|‚Ćč‚āä, neg_lt.1 ((neg_le_abs x).trans_lt (Nat.lt_floor_add_one _)),
        (le_abs_self x).trans_lt (Nat.lt_floor_add_one _)‚ü©

theorem measure_ext_Ioo_rat {őľ őĹ : Measure ‚ĄĚ} [IsLocallyFiniteMeasure őľ]
    (h : ‚ąÄ a b : ‚Ąö, őľ (Ioo a b) = őĹ (Ioo a b)) : őľ = őĹ :=
  (finiteSpanningSetsInIooRat őľ).ext borel_eq_generateFrom_Ioo_rat isPiSystem_Ioo_rat <| by
    simp only [mem_iUnion, mem_singleton_iff]
    rintro _ ‚ü®a, b, -, rfl‚ü©
    apply h

