theorem measurable_of_measurable_nnreal {f : РёЮРЅЦ0Рѕъ Рєњ ╬▒} (h : Measurable fun p : РёЮРЅЦ0 => f p) :
    Measurable f :=
  measurable_of_measurable_on_compl_singleton Рѕъ
    (MeasurableEquiv.ennrealEquivNNReal.symm.measurable_comp_iff.1 h)

/-- `РёЮРЅЦ0Рѕъ` is `MeasurableEquiv` to `РёЮРЅЦ0 РіЋ Unit`. -/
def ennrealEquivSum : РёЮРЅЦ0Рѕъ РЅЃрхљ РёЮРЅЦ0 РіЋ Unit :=
  { Equiv.optionEquivSumPUnit РёЮРЅЦ0 with
    measurable_toFun := measurable_of_measurable_nnreal measurable_inl
    measurable_invFun :=
      measurable_fun_sum measurable_coe_nnreal_ennreal (@measurable_const РёЮРЅЦ0Рѕъ Unit _ _ Рѕъ) }

open Function (uncurry)

theorem measurable_of_measurable_nnreal_prod {_ : MeasurableSpace ╬▓} {_ : MeasurableSpace ╬│}
    {f : РёЮРЅЦ0Рѕъ ├Ќ ╬▓ Рєњ ╬│} (HРѓЂ : Measurable fun p : РёЮРЅЦ0 ├Ќ ╬▓ => f (p.1, p.2))
    (HРѓѓ : Measurable fun x => f (Рѕъ, x)) : Measurable f :=
  let e : РёЮРЅЦ0Рѕъ ├Ќ ╬▓ РЅЃрхљ (РёЮРЅЦ0 ├Ќ ╬▓) РіЋ (Unit ├Ќ ╬▓) :=
    (ennrealEquivSum.prodCongr (MeasurableEquiv.refl ╬▓)).trans
      (MeasurableEquiv.sumProdDistrib _ _ _)
  e.symm.measurable_comp_iff.1 <| measurable_fun_sum HРѓЂ (HРѓѓ.comp measurable_id.snd)

theorem measurable_of_measurable_nnreal_nnreal {_ : MeasurableSpace ╬▓} {f : РёЮРЅЦ0Рѕъ ├Ќ РёЮРЅЦ0Рѕъ Рєњ ╬▓}
    (hРѓЂ : Measurable fun p : РёЮРЅЦ0 ├Ќ РёЮРЅЦ0 => f (p.1, p.2)) (hРѓѓ : Measurable fun r : РёЮРЅЦ0 => f (Рѕъ, r))
    (hРѓЃ : Measurable fun r : РёЮРЅЦ0 => f (r, Рѕъ)) : Measurable f :=
  measurable_of_measurable_nnreal_prod
    (measurable_swap_iff.1 <| measurable_of_measurable_nnreal_prod (hРѓЂ.comp measurable_swap) hРѓЃ)
    (measurable_of_measurable_nnreal hРѓѓ)

theorem measurable_ofReal : Measurable ENNReal.ofReal :=
  ENNReal.continuous_ofReal.measurable

theorem measurable_toReal : Measurable ENNReal.toReal :=
  ENNReal.measurable_of_measurable_nnreal measurable_coe_nnreal_real

theorem measurable_toNNReal : Measurable ENNReal.toNNReal :=
  ENNReal.measurable_of_measurable_nnreal measurable_id

instance instMeasurableMulРѓѓ : MeasurableMulРѓѓ РёЮРЅЦ0Рѕъ := by
  refine РЪеmeasurable_of_measurable_nnreal_nnreal ?_ ?_ ?_РЪЕ
  ┬и simp only [Рєљ ENNReal.coe_mul, measurable_mul.coe_nnreal_ennreal]
  ┬и simp only [ENNReal.top_mul', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const
  ┬и simp only [ENNReal.mul_top', ENNReal.coe_eq_zero]
    exact measurable_const.piecewise (measurableSet_singleton _) measurable_const

instance instMeasurableSubРѓѓ : MeasurableSubРѓѓ РёЮРЅЦ0Рѕъ :=
  РЪеmeasurable_of_measurable_nnreal_nnreal measurable_sub.coe_nnreal_ennreal (by simp) (by simp)РЪЕ

