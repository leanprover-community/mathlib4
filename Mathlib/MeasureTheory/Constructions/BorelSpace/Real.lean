lemma tendsto_measure_Icc [NoAtoms Œº] (b : ‚Ñù) :
    Tendsto (fun Œ¥ ‚Ü¶ Œº (Icc (b - Œ¥) (b + Œ¥))) (ùìù (0 : ‚Ñù)) (ùìù 0) := by
  rw [‚Üê nhdsLT_sup_nhdsGE, tendsto_sup]
