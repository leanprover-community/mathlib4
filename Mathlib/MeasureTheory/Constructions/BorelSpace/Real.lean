/-- A limit (over a general filter) of measurable `РёЮРЅЦ0`-valued functions is measurable. -/
theorem measurable_of_tendsto' {╬╣} {f : ╬╣ Рєњ ╬▒ Рєњ РёЮРЅЦ0} {g : ╬▒ Рєњ РёЮРЅЦ0} (u : Filter ╬╣) [NeBot u]
    [IsCountablyGenerated u] (hf : Рѕђ i, Measurable (f i)) (lim : Tendsto f u (­ЮЊЮ g)) :
    Measurable g := by
  simp_rw [Рєљ measurable_coe_nnreal_ennreal_iff] at hf Ріб
  refine ENNReal.measurable_of_tendsto' u hf ?_
  rw [tendsto_pi_nhds] at lim Ріб
  exact fun x => (ENNReal.continuous_coe.tendsto (g x)).comp (lim x)

/-- A sequential limit of measurable `РёЮРЅЦ0`-valued functions is measurable. -/
theorem measurable_of_tendsto {f : РёЋ Рєњ ╬▒ Рєњ РёЮРЅЦ0} {g : ╬▒ Рєњ РёЮРЅЦ0} (hf : Рѕђ i, Measurable (f i))
    (lim : Tendsto f atTop (­ЮЊЮ g)) : Measurable g :=
  measurable_of_tendsto' atTop hf lim

