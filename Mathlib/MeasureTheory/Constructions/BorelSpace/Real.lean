lemma tendsto_measure_Icc [NoAtoms Ој] (b : в„қ) :
    Tendsto (fun Оҙ вҶҰ Ој (Icc (b - Оҙ) (b + Оҙ))) (рқ“қ (0 : в„қ)) (рқ“қ 0) := by
  rw [вҶҗ nhdsLT_sup_nhdsGE, tendsto_sup]
  constructor
  В· apply tendsto_const_nhds.congr'
    filter_upwards [self_mem_nhdsWithin] with r (hr : r < 0)
