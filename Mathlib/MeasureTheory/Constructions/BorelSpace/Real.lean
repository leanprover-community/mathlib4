lemma tendsto_measure_Icc_nhdsWithin_right' (b : ‚ĄĚ) :
    Tendsto (fun őī ‚Ü¶ őľ (Icc (b - őī) (b + őī))) (ūĚďĚ[>] (0 : ‚ĄĚ)) (ūĚďĚ (őľ {b})) := by
