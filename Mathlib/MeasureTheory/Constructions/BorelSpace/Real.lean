lemma measurable_of_real_prod {f : EReal ├Ќ ╬▓ Рєњ ╬│}
    (h_real : Measurable fun p : РёЮ ├Ќ ╬▓ Рєд f (p.1, p.2))
    (h_bot : Measurable fun x Рєд f (РіЦ, x)) (h_top : Measurable fun x Рєд f (Ріц, x)) : Measurable f :=
  .of_unionРѓЃ_range_cover (measurableEmbedding_prodMk_left _) (measurableEmbedding_prodMk_left _)
    (measurableEmbedding_coe.prodMap .id) (by simp [-univ_subset_iff, subset_def, EReal.forall])
    h_bot h_top h_real

lemma measurable_of_real_real {f : EReal ├Ќ EReal Рєњ ╬▓}
    (h_real : Measurable fun p : РёЮ ├Ќ РёЮ Рєд f (p.1, p.2))
    (h_bot_left : Measurable fun r : РёЮ Рєд f (РіЦ, r))
    (h_top_left : Measurable fun r : РёЮ Рєд f (Ріц, r))
    (h_bot_right : Measurable fun r : РёЮ Рєд f (r, РіЦ))
    (h_top_right : Measurable fun r : РёЮ Рєд f (r, Ріц)) :
    Measurable f := by
  refine measurable_of_real_prod ?_ ?_ ?_
  ┬и refine measurable_swap_iff.mp <| measurable_of_real_prod ?_ h_bot_right h_top_right
    exact h_real.comp measurable_swap
  ┬и exact measurable_of_measurable_real h_bot_left
  ┬и exact measurable_of_measurable_real h_top_left

private lemma measurable_const_mul (c : EReal) : Measurable fun (x : EReal) Рєд c * x := by
  refine measurable_of_measurable_real ?_
  have h1 : (fun (p : РёЮ) Рєд (РіЦ : EReal) * p)
      = fun p Рєд if p = 0 then (0 : EReal) else (if p < 0 then Ріц else РіЦ) := by
    ext p
    split_ifs with h1 h2
    ┬и simp [h1]
    ┬и rw [bot_mul_coe_of_neg h2]
    ┬и rw [bot_mul_coe_of_pos]
      exact lt_of_le_of_ne (not_lt.mp h2) (Ne.symm h1)
  have h2 : Measurable fun (p : РёЮ) Рєд if p = 0 then (0 : EReal) else if p < 0 then Ріц else РіЦ := by
    refine Measurable.piecewise (measurableSet_singleton _) measurable_const ?_
    exact Measurable.piecewise measurableSet_Iio measurable_const measurable_const
  induction c with
  | bot => rwa [h1]
  | coe c => exact (measurable_id.const_mul _).coe_real_ereal
  | top =>
    simp_rw [Рєљ neg_bot, neg_mul]
    apply Measurable.neg
    rwa [h1]

instance : MeasurableMulРѓѓ EReal := by
  refine РЪеmeasurable_of_real_real ?_ ?_ ?_ ?_ ?_РЪЕ
  ┬и exact (measurable_fst.mul measurable_snd).coe_real_ereal
  ┬и exact (measurable_const_mul _).comp measurable_coe_real_ereal
  ┬и exact (measurable_const_mul _).comp measurable_coe_real_ereal
  ┬и simp_rw [mul_comm _ РіЦ]
    exact (measurable_const_mul _).comp measurable_coe_real_ereal
  ┬и simp_rw [mul_comm _ Ріц]
    exact (measurable_const_mul _).comp measurable_coe_real_ereal

end MeasurableMul

