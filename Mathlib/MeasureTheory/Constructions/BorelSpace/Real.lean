/-- A limit (over a general filter) of measurable `РёЮРЅЦ0Рѕъ`-valued functions is measurable. -/
theorem measurable_of_tendsto' {╬╣ : Type*} {f : ╬╣ Рєњ ╬▒ Рєњ РёЮРЅЦ0Рѕъ} {g : ╬▒ Рєњ РёЮРЅЦ0Рѕъ} (u : Filter ╬╣)
    [NeBot u] [IsCountablyGenerated u] (hf : Рѕђ i, Measurable (f i)) (lim : Tendsto f u (­ЮЊЮ g)) :
    Measurable g := by
  rcases u.exists_seq_tendsto with РЪеx, hxРЪЕ
  rw [tendsto_pi_nhds] at lim
  have : (fun y => liminf (fun n => (f (x n) y : РёЮРЅЦ0Рѕъ)) atTop) = g := by
    ext1 y
    exact ((lim y).comp hx).liminf_eq
  rw [Рєљ this]
  change Measurable fun y => liminf (fun n => (f (x n) y : РёЮРЅЦ0Рѕъ)) atTop
  exact .liminf fun n => hf (x n)

/-- A sequential limit of measurable `РёЮРЅЦ0Рѕъ`-valued functions is measurable. -/
theorem measurable_of_tendsto {f : РёЋ Рєњ ╬▒ Рєњ РёЮРЅЦ0Рѕъ} {g : ╬▒ Рєњ РёЮРЅЦ0Рѕъ} (hf : Рѕђ i, Measurable (f i))
    (lim : Tendsto f atTop (­ЮЊЮ g)) : Measurable g :=
  measurable_of_tendsto' atTop hf lim

/-- A limit (over a general filter) of a.e.-measurable `РёЮРЅЦ0Рѕъ`-valued functions is
a.e.-measurable. -/
lemma aemeasurable_of_tendsto' {╬╣ : Type*} {f : ╬╣ Рєњ ╬▒ Рєњ РёЮРЅЦ0Рѕъ} {g : ╬▒ Рєњ РёЮРЅЦ0Рѕъ}
    {╬╝ : Measure ╬▒} (u : Filter ╬╣) [NeBot u] [IsCountablyGenerated u]
    (hf : Рѕђ i, AEMeasurable (f i) ╬╝) (hlim : Рѕђрхљ a Рѕѓ╬╝, Tendsto (fun i Рєд f i a) u (­ЮЊЮ (g a))) :
    AEMeasurable g ╬╝ := by
  rcases u.exists_seq_tendsto with РЪеv, hvРЪЕ
  have h'f : Рѕђ n, AEMeasurable (f (v n)) ╬╝ := fun n Рєд hf (v n)
  set p : ╬▒ Рєњ (РёЋ Рєњ РёЮРЅЦ0Рѕъ) Рєњ Prop := fun x f' Рєд Tendsto f' atTop (­ЮЊЮ (g x))
  have hp : Рѕђрхљ x Рѕѓ╬╝, p x fun n Рєд f (v n) x := by
    filter_upwards [hlim] with x hx using hx.comp hv
  classical
  set aeSeqLim := fun x Рєд ite (x Рѕѕ aeSeqSet h'f p) (g x) (РЪеf (v 0) xРЪЕ : Nonempty РёЮРЅЦ0Рѕъ).some
  refine РЪеaeSeqLim, measurable_of_tendsto' atTop (aeSeq.measurable h'f p)
    (tendsto_pi_nhds.mpr fun x Рєд ?_), ?_РЪЕ
  ┬и unfold aeSeqLim
    simp_rw [aeSeq]
    split_ifs with hx
    ┬и simp_rw [aeSeq.mk_eq_fun_of_mem_aeSeqSet h'f hx]
      exact aeSeq.fun_prop_of_mem_aeSeqSet h'f hx
    ┬и exact tendsto_const_nhds
  ┬и exact (ite_ae_eq_of_measure_compl_zero g (fun x Рєд (РЪеf (v 0) xРЪЕ : Nonempty РёЮРЅЦ0Рѕъ).some)
      (aeSeqSet h'f p) (aeSeq.measure_compl_aeSeqSet_eq_zero h'f hp)).symm

/-- A limit of a.e.-measurable `РёЮРЅЦ0Рѕъ`-valued functions is a.e.-measurable. -/
lemma aemeasurable_of_tendsto {f : РёЋ Рєњ ╬▒ Рєњ РёЮРЅЦ0Рѕъ} {g : ╬▒ Рєњ РёЮРЅЦ0Рѕъ} {╬╝ : Measure ╬▒}
