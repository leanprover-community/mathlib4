/-- If a function `f : őĪ ‚Üí ‚ĄĚ‚Č•0` is measurable and the measure is ŌÉ-finite, then there exists
spanning measurable sets with finite measure on which `f` is bounded.
See also `StronglyMeasurable.exists_spanning_measurableSet_norm_le` for functions into normed
groups. -/
theorem exists_spanning_measurableSet_le {f : őĪ ‚Üí ‚ĄĚ‚Č•0} (hf : Measurable f) (őľ : Measure őĪ)
    [SigmaFinite őľ] :
    ‚ąÉ s : ‚Ąē ‚Üí Set őĪ,
      (‚ąÄ n, MeasurableSet (s n) ‚ąß őľ (s n) < ‚ąě ‚ąß ‚ąÄ x ‚ąą s n, f x ‚Č§ n) ‚ąß
      ‚čÉ i, s i = Set.univ := by
  let sigma_finite_sets := spanningSets őľ
  let norm_sets := fun n : ‚Ąē => { x | f x ‚Č§ n }
  have norm_sets_spanning : ‚čÉ n, norm_sets n = Set.univ := by
    ext1 x
    simp only [Set.mem_iUnion, Set.mem_setOf_eq, Set.mem_univ, iff_true]
    exact exists_nat_ge (f x)
  let sets n := sigma_finite_sets n ‚ą© norm_sets n
  have h_meas : ‚ąÄ n, MeasurableSet (sets n) := by
    refine fun n => MeasurableSet.inter ?_ ?_
    ¬∑ exact measurableSet_spanningSets őľ n
    ¬∑ exact hf measurableSet_Iic
  have h_finite : ‚ąÄ n, őľ (sets n) < ‚ąě := by
    refine fun n => (measure_mono Set.inter_subset_left).trans_lt ?_
    exact measure_spanningSets_lt_top őľ n
  refine ‚ü®sets, fun n => ‚ü®h_meas n, h_finite n, ?_‚ü©, ?_‚ü©
  ¬∑ exact fun x hx => hx.2
  ¬∑ have :
      ‚čÉ i, sigma_finite_sets i ‚ą© norm_sets i = (‚čÉ i, sigma_finite_sets i) ‚ą© ‚čÉ i, norm_sets i := by
      refine Set.iUnion_inter_of_monotone (monotone_spanningSets őľ) fun i j hij x => ?_
      simp only [norm_sets, Set.mem_setOf_eq]
      refine fun hif => hif.trans ?_
      exact mod_cast hij
    rw [this, norm_sets_spanning, iUnion_spanningSets őľ, Set.inter_univ]

