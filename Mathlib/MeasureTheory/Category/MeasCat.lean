module

public import Mathlib.MeasureTheory.Measure.GiryMonad
public import Mathlib.CategoryTheory.Monad.Algebra
public import Mathlib.Topology.Category.TopCat.Basic

/-!
# The category of measurable spaces

Measurable spaces and measurable functions form a (concrete) category `MeasCat`.

## Main definitions

* `Measure : MeasCat ‚•§ MeasCat`: the functor which sends a measurable space `X`
  to the space of measures on `X`; it is a monad (the "Giry monad").

* `Borel : TopCat ‚•§ MeasCat`: sends a topological space `X` to `X` equipped with the
  `ŌÉ`-algebra of Borel sets (the `ŌÉ`-algebra generated by the open subsets of `X`).

## Tags

measurable space, giry monad, borel
-/

@[expose] public section


noncomputable section

open CategoryTheory MeasureTheory

open scoped ENNReal

universe u v


/-- The category of measurable spaces and measurable functions. -/
structure MeasCat : Type (u + 1) where
  /-- Construct a bundled `MeasCat` from the underlying type and the typeclass. -/
  of ::
  /-- The underlying measurable space. -/
  carrier : Type u
  [str : MeasurableSpace carrier]

attribute [instance] MeasCat.str

namespace MeasCat

instance : CoeSort MeasCat Type* :=
  ‚ü®carrier‚ü©

theorem coe_of (X : Type u) [MeasurableSpace X] : (of X : Type u) = X :=
  rfl

instance : LargeCategory MeasCat where
  Hom X Y := { f : X ‚Üí Y // Measurable f }
  id X := ‚ü®id, measurable_id‚ü©
  comp f g := ‚ü®g.1 ‚ąė f.1, g.2.comp f.2‚ü©

instance (X Y : MeasCat) : FunLike ({ f : X ‚Üí Y // Measurable f }) X Y where
  coe f := f
  coe_injective' _ _ := Subtype.ext

instance : ConcreteCategory MeasCat ({ f : ¬∑ ‚Üí ¬∑ // Measurable f }) where
  hom f := f
  ofHom f := f

instance : Inhabited MeasCat :=
  ‚ü®MeasCat.of Empty‚ü©

/-- `Measure X` is the measurable space of measures over the measurable space `X`. It is the
weakest measurable space, s.t. `fun őľ ‚Ü¶ őľ s` is measurable for all measurable sets `s` in `X`. An
important purpose is to assign a monadic structure on it, the Giry monad. In the Giry monad,
the pure values are the Dirac measure, and the bind operation maps to the integral:
`(őľ >>= őĹ) s = ‚ąę x. (őĹ x) s dőľ`.

In probability theory, the `MeasCat`-morphisms `X ‚Üí Prob X` are (sub-)Markov kernels (here `Prob` is
the restriction of `Measure` to (sub-)probability spaces.)
-/
def Measure : MeasCat ‚•§ MeasCat where
  obj X := of (@MeasureTheory.Measure X.1 X.2)
  map f := ‚ü®Measure.map (‚áĎf), Measure.measurable_map f.1 f.2‚ü©
  map_id X := Subtype.ext <| funext fun őľ => @Measure.map_id X.carrier X.str őľ
  map_comp := fun ‚ü®_, hf‚ü© ‚ü®_, hg‚ü© => Subtype.ext <| funext fun _ => (Measure.map_map hg hf).symm

/-- The Giry monad, i.e. the monadic structure associated with `Measure`. -/
def Giry : CategoryTheory.Monad MeasCat where
  toFunctor := Measure
  ő∑ :=
    { app := fun X => ‚ü®@Measure.dirac X.1 X.2, Measure.measurable_dirac‚ü©
      naturality :=
        fun _ _ ‚ü®_, hf‚ü© => Subtype.ext <| funext fun a => (Measure.map_dirac' hf a).symm }
  őľ :=
    { app := fun X => ‚ü®@Measure.join X.1 X.2, Measure.measurable_join‚ü©
      naturality := fun _ _ ‚ü®_, hf‚ü© => Subtype.ext <| funext fun őľ => Measure.join_map_map hf őľ }
  assoc _ := Subtype.ext <| funext fun _ => Measure.join_map_join _
  left_unit _ := Subtype.ext <| funext fun _ => Measure.join_dirac _
  right_unit _ := Subtype.ext <| funext fun _ => Measure.join_map_dirac _

/-- An example of an algebra on `Measure`: the nonnegative Lebesgue integral is a hom, behaving
nicely under the monad operations. -/
def Integral : Giry.Algebra where
  A := MeasCat.of ‚ĄĚ‚Č•0‚ąě
  a := ‚ü®fun m : MeasureTheory.Measure ‚ĄĚ‚Č•0‚ąě ‚Ü¶ ‚ąę‚ĀĽ x, x ‚ąām, Measure.measurable_lintegral measurable_id‚ü©
  unit := Subtype.ext <| funext fun _ : ‚ĄĚ‚Č•0‚ąě => lintegral_dirac' _ measurable_id
  assoc := Subtype.ext <| funext fun őľ : MeasureTheory.Measure (MeasureTheory.Measure ‚ĄĚ‚Č•0‚ąě) ‚Ü¶
    show ‚ąę‚ĀĽ x, x ‚ąāőľ.join = ‚ąę‚ĀĽ x, x ‚ąāMeasure.map (fun m => ‚ąę‚ĀĽ x, x ‚ąām) őľ by
      rw [Measure.lintegral_join, lintegral_map] <;>
        apply_rules [Measurable.aemeasurable, measurable_id, Measure.measurable_lintegral]

end MeasCat

instance TopCat.hasForgetToMeasCat : HasForget‚āā TopCat.{u} MeasCat.{u} where
  forget‚āā.obj X := @MeasCat.of _ (borel X)
  forget‚āā.map f := ‚ü®f.1, f.hom.2.borel_measurable‚ü©

/-- The Borel functor, the canonical embedding of topological spaces into measurable spaces. -/
abbrev Borel : TopCat.{u} ‚•§ MeasCat.{u} :=
  forget‚āā TopCat.{u} MeasCat.{u}
