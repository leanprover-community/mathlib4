/-! # Order topology on `WithTop ╬╣`

When `╬╣` is a topological space with the order topology, we also endow `WithTop ╬╣` with the order
topology. If `╬╣` is second countable, we prove that `WithTop ╬╣` also is.
-/

@[expose] public section

open Set Filter
open scoped Topology

namespace TopologicalSpace

variable {╬╣ : Type*} [Preorder ╬╣]

@[nolint unusedArguments, to_dual]
instance [TopologicalSpace ╬╣] [OrderTopology ╬╣] : TopologicalSpace (WithTop ╬╣) :=
  Preorder.topology _

@[to_dual]
instance [TopologicalSpace ╬╣] [OrderTopology ╬╣] : OrderTopology (WithTop ╬╣) := ÔčĘrflÔčę

instance [ts : TopologicalSpace ╬╣] [ht : OrderTopology ╬╣] [SecondCountableTopology ╬╣] :
    SecondCountableTopology (WithTop ╬╣) := by
  classical
  rcases isEmpty_or_nonempty ╬╣ with h╬╣ | ÔčĘÔčĘxÔéÇÔčęÔčę
  ┬Ě infer_instance
  /- Let `c` be a countable set in `╬╣` such that the topology is generated by the sets `Iio a`
  and `Ioi a` for `a Ôłł c`, by second-countability. Let `c'` be a dense set in `╬╣`, again by
  second-countability. Let `d` in `WithTop ╬╣` be obtained from `c Ôł¬ c'`, by adding `ÔŐĄ` and a point
  `xÔéü : ╬╣` with `Ioi xÔéü = Ôłů` if there is one.
  We will show that the topology on `WithTop ╬╣` is generated by the intervals `Iio a` and `Ioi a`
  for `a Ôłł d`, which will conclude the proof by countability of `d`. -/
  obtain ÔčĘc, c_count, hcÔčę : Ôłâ (c : Set ╬╣), c.Countable Ôłž
      ts = generateFrom { s | Ôłâ a Ôłł c, s = Ioi a ÔłĘ s = Iio a } :=
    exists_countable_generateFrom_Ioi_Iio ╬╣
  obtain ÔčĘc', c'_count, hc'Ôčę : Ôłâ c' : Set ╬╣, c'.Countable Ôłž Dense c' :=
    SeparableSpace.exists_countable_dense
  let xÔéü : ╬╣ := if h : Ôłâ x, Ioi x = Ôłů then h.choose else xÔéÇ
  let d : Set (WithTop ╬╣) := (ÔćĹ) '' c Ôł¬ (ÔćĹ) '' c' Ôł¬ {ÔŐĄ} Ôł¬ {(xÔéü : WithTop ╬╣)}
  suffices H : instWithTopOfOrderTopology
      = generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a} by
    refine ÔčĘ{s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a}, ?_, by rw [ÔćÉ H]Ôčę
    have d_count : d.Countable :=
      (((c_count.image _).union (c'_count.image _)).union (by simp)).union (by simp)
    have : {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a} = Ioi '' d Ôł¬ Iio '' d := by
      #adaptation_note /-- Before leanprover/lean4#13166, this was just `grind`.
      The new canonicalizer using `isDefEq` less,
      and so does not unify as many of the conditions that `grind` wants to case split on.
      Alternatively `ext; simp; grind` work here. -/
      grind (splits := 12)
    rw [this]
    exact (d_count.image _).union (d_count.image _)
  -- We should check the easy direction that all the elements in our generating set are open.
  -- This is trivial as these are all intervals.
  apply le_antisymm
  ┬Ě apply le_generateFrom_iff_subset_isOpen.2
    grind [isOpen_Iio', isOpen_Ioi']
  /- Now, let us check that our sets indeed generates the topology. As the topology is
  generated by the open half-infinite intervals by definition, we should check that open
  half-infinite intervals are covered by finite intersections of our sets. -/
  let basis : Set (Set ╬╣) := {s | Ôłâ (f g : Set ╬╣), f ÔŐć c Ôłž g ÔŐć c Ôłž f.Finite Ôłž g.Finite
      Ôłž s = (Ôőé a Ôłł f, Ioi a) Ôłę (Ôőé a Ôłł g, Iio a)}
  have h_basis : IsTopologicalBasis basis := isTopologicalBasis_biInter_Ioi_Iio_of_generateFrom c hc
  rw [OrderTopology.topology_eq_generate_intervals (╬▒ := WithTop ╬╣)]
  apply le_generateFrom_iff_subset_isOpen.2
  simp only [setOf_subset_setOf, forall_exists_index]
  rintro u a (rfl | rfl)
  -- Consider an interval of the form `Ioi a`. We should cover it by finite intersections of
  -- our sets.
  ┬Ě induction a with
    | top =>
      -- for `a = ÔŐĄ`, this is trivial as `Ioi ÔŐĄ` is in our set by design
      apply isOpen_generateFrom_of_mem
      exact ÔčĘÔŐĄ, by simp [d]Ôčę
    | coe a =>
      -- for `a : ╬╣`, we consider an element `b Ôłł Ioi a`, and seek a finite intersection of our
      -- sets containing it and contained in `Ioi a`.
      rw [@isOpen_iff_forall_mem_open]
      intro b hb
      induction b with
      | top =>
        -- if `b = ÔŐĄ`, then either `Ioi a` is empty in `╬╣` and then we use `Ioi (ÔćĹxÔéü)` which is
        -- in our set and reduced to `ÔŐĄ`
        rcases eq_empty_or_nonempty (Ioi a) with ha | ha
        ┬Ě refine ÔčĘIoi xÔéü, ?_, ?_, by simpÔčę
          ┬Ě have : Ioi xÔéü = Ôłů := by
              have h : Ôłâ x, Ioi x = Ôłů := ÔčĘa, haÔčę
              simp only [xÔéü, h, ÔćôreduceDIte]
              exact h.choose_spec
            simp [WithTop.Ioi_coe, this]
          ┬Ě apply isOpen_generateFrom_of_mem
            simp [d]
        -- If `Ioi a` is not empty in `╬╣`, it contains a point `b` in the dense set `c'`, and then
        -- we use `Ioi (ÔćĹb)` which is in our set, contained in `Ioi (ÔćĹa)` and contains `ÔŐĄ`.
        ┬Ě obtain ÔčĘb, bc', hbÔčę : Ôłâ b Ôłł c', b Ôłł Ioi a := hc'.exists_mem_open (isOpen_Ioi' a) ha
          refine ÔčĘIoi b, ?_, ?_, by simpÔčę
          ┬Ě apply Ioi_subset_Ioi
            simpa using hb.le
          ┬Ě apply isOpen_generateFrom_of_mem
            exact ÔčĘb, by simp [d, bc'], Or.inl rflÔčę
      | coe b =>
        -- if `b` comes from `╬╣`, then in `╬╣` we can find a finite intersection of our sets
        -- containing `b` and contained in `Ioi a`. We lift it to `WithTop ╬╣`.
        simp only [mem_Ioi, WithTop.coe_lt_coe] at hb
        obtain ÔčĘt, ÔčĘf, g, hfc, hgc, f_fin, g_fin, rflÔčę, hb, hfgÔčę :
          Ôłâ t Ôłł basis, b Ôłł t Ôłž t ÔŐć Ioi a := h_basis.isOpen_iff.1 (isOpen_Ioi' a) b hb
        refine ÔčĘ(Ôőé z Ôłł f, Ioi z) Ôłę Ôőé z Ôłł g, Iio z, ?_, ?_, by simpa using hbÔčę
        ┬Ě intro w hw
          induction w with
          | top => simp
          | coe w =>
            simp only [mem_Ioi, WithTop.coe_lt_coe]
            apply hfg
            simpa using hw
        ┬Ě apply @IsOpen.inter _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
          ┬Ě apply @Finite.isOpen_biInter _ _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
            ┬Ě exact f_fin
            ┬Ě intro i hi
              apply isOpen_generateFrom_of_mem
              grind
          ┬Ě apply @Finite.isOpen_biInter _ _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
            ┬Ě exact g_fin
            ┬Ě intro i hi
              apply isOpen_generateFrom_of_mem
              grind
  -- Consider an interval of the form `Iio a`. We should cover it by finite intersections of
  -- our sets.
  ┬Ě induction a with
    | top =>
      -- for `a = ÔŐĄ`, this is trivial as `Iio ÔŐĄ` is in our set by design
      apply isOpen_generateFrom_of_mem
      exact ÔčĘÔŐĄ, by simp [d]Ôčę
    | coe a =>
      -- for `a : ╬╣`, we consider an element `b Ôłł Iio a`, and seek a finite intersection of our
      -- sets containing it and contained in `Iio a`.
      rw [@isOpen_iff_forall_mem_open]
      intro b hb
      induction b with
      | top => simp at hb
      | coe b =>
        -- `b` can not be equal to `ÔŐĄ`, so it comes from `╬╣`. In `╬╣` we can find a finite
        -- intersection of our sets containing `b` and contained in `Iio a`. We lift it
        -- to `WithTop ╬╣`, and intersect with `Iio ÔŐĄ` (which is also in our set) to exclude `ÔŐĄ`.
        simp only [mem_Iio, WithTop.coe_lt_coe] at hb
        obtain ÔčĘt, ÔčĘf, g, hfc, hgc, f_fin, g_fin, rflÔčę, hb, hfgÔčę :
          Ôłâ t Ôłł basis, b Ôłł t Ôłž t ÔŐć Iio a := h_basis.isOpen_iff.1 (isOpen_Iio' a) b hb
        refine ÔčĘ(Ôőé z Ôłł f, Ioi z) Ôłę (Ôőé z Ôłł g, Iio z) Ôłę Iio ÔŐĄ, ?_, ?_, by simpa using hbÔčę
        ┬Ě intro w hw
          induction w with
          | top => simp at hw
          | coe w =>
            simp only [mem_Iio, WithTop.coe_lt_coe]
            apply hfg
            simpa using hw
        ┬Ě apply @IsOpen.inter _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a}); swap
          ┬Ě apply isOpen_generateFrom_of_mem
            simp [d]
          apply @IsOpen.inter _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
          ┬Ě apply @Finite.isOpen_biInter _ _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
            ┬Ě exact f_fin
            ┬Ě intro i hi
              apply isOpen_generateFrom_of_mem
              grind
          ┬Ě apply @Finite.isOpen_biInter _ _ (generateFrom {s | Ôłâ a Ôłł d, s = Ioi a ÔłĘ s = Iio a})
            ┬Ě exact g_fin
            ┬Ě intro i hi
              apply isOpen_generateFrom_of_mem
              grind

end TopologicalSpace

namespace WithTop

variable {╬╣ : Type*} [LinearOrder ╬╣] [TopologicalSpace ╬╣] [OrderTopology ╬╣]

section Coe

@[to_dual]
lemma isEmbedding_coe : Topology.IsEmbedding ((ÔćĹ) : ╬╣ Ôćĺ WithTop ╬╣) := by
  refine WithTop.coe_strictMono.isEmbedding_of_ordConnected (╬▒ := ╬╣) ?_
  rw [WithTop.range_coe]
  exact Set.ordConnected_Iio

@[to_dual]
lemma isOpenEmbedding_coe : Topology.IsOpenEmbedding ((ÔćĹ) : ╬╣ Ôćĺ WithTop ╬╣) :=
  ÔčĘisEmbedding_coe, by rw [WithTop.range_coe]; exact isOpen_IioÔčę

@[to_dual]
lemma nhds_coe {r : ╬╣} : ­ŁôŁ (r : WithTop ╬╣) = (­ŁôŁ r).map (ÔćĹ) :=
  (isOpenEmbedding_coe.map_nhds_eq r).symm

@[fun_prop, continuity, to_dual]
lemma continuous_coe : Continuous ((ÔćĹ) : ╬╣ Ôćĺ WithTop ╬╣) := isEmbedding_coe.continuous

end Coe

section ContinuousUnTop

@[to_dual]
lemma tendsto_untopD (d : ╬╣) {a : WithTop ╬╣} (ha : a Ôëá ÔŐĄ) :
    Tendsto (untopD d) (­ŁôŁ a) (­ŁôŁ (untopD d a)) := by
  lift a to ╬╣ using ha
  rw [nhds_coe, tendsto_map'_iff]
  exact tendsto_id

@[to_dual]
lemma continuousOn_untopD (d : ╬╣) : ContinuousOn (untopD d) { a : WithTop ╬╣ | a Ôëá ÔŐĄ } :=
  fun _a ha ÔćŽ ContinuousAt.continuousWithinAt (tendsto_untopD d ha)

@[to_dual]
lemma tendsto_untopA [Nonempty ╬╣] {a : WithTop ╬╣} (ha : a Ôëá ÔŐĄ) :
    Tendsto untopA (­ŁôŁ a) (­ŁôŁ a.untopA) := tendsto_untopD _ ha

@[to_dual]
lemma continuousOn_untopA [Nonempty ╬╣] : ContinuousOn untopA { a : WithTop ╬╣ | a Ôëá ÔŐĄ } :=
  continuousOn_untopD _

@[to_dual]
lemma tendsto_untop (a : {a : WithTop ╬╣ | a Ôëá ÔŐĄ}) :
    Tendsto (fun x ÔćŽ untop x.1 x.2) (­ŁôŁ a) (­ŁôŁ (untop a.1 a.2)) := by
  have : Nonempty ╬╣ := ÔčĘuntop a.1 a.2Ôčę
  simp only [ÔćÉ untopA_eq_untop, ne_eq, coe_setOf, mem_setOf_eq]
  exact (tendsto_untopA a.2).comp <| tendsto_subtype_rng.mp tendsto_id

@[to_dual]
lemma continuous_untop : Continuous (fun x : {a : WithTop ╬╣ | a Ôëá ÔŐĄ} ÔćŽ untop x.1 x.2) :=
  continuous_iff_continuousAt.mpr tendsto_untop

end ContinuousUnTop

variable (╬╣) in
/-- Homeomorphism between the non-top elements of `WithTop ╬╣` and `╬╣`. -/
@[to_dual /-- Homeomorphism between the non-bot elements of `WithBot ╬╣` and `╬╣`. -/]
noncomputable
def neTopHomeomorph : { a : WithTop ╬╣ | a Ôëá ÔŐĄ } ÔëâÔéť ╬╣ where
  toEquiv := Equiv.withTopSubtypeNe
  continuous_toFun := continuous_untop
  continuous_invFun := continuous_coe.subtype_mk _

variable (╬╣) in
/-- If `╬╣` has a top element, then `WithTop ╬╣` is homeomorphic to `╬╣ ÔŐĽ Unit`. -/
@[to_dual /-- If `╬╣` has a bot element, then `WithBot ╬╣` is homeomorphic to `╬╣ ÔŐĽ Unit`. -/]
noncomputable
def sumHomeomorph [OrderTop ╬╣] : WithTop ╬╣ ÔëâÔéť ╬╣ ÔŐĽ Unit where
  toFun x := if h : x = ÔŐĄ then Sum.inr () else Sum.inl x.untopA
  invFun x := match x with
    | Sum.inl i => (i : WithTop ╬╣)
    | Sum.inr () => ÔŐĄ
  left_inv x := by cases x <;> simp
  right_inv x := by cases x <;> simp
  continuous_toFun := by
    have h_fr : frontier ({ÔŐĄ} : Set (WithTop ╬╣)) = Ôłů := by
      simp only [frontier, Set.finite_singleton, Set.Finite.isClosed, IsClosed.closure_eq]
      suffices interior ({ÔŐĄ} : Set (WithTop ╬╣)) = {ÔŐĄ} by simp [this]
      rw [interior_eq_iff_isOpen]
      have : {ÔŐĄ} = Set.Ioi ((ÔŐĄ : ╬╣) : WithTop ╬╣) := by ext; simp
      rw [this]
      exact isOpen_Ioi
    refine continuous_if' (by simp [h_fr]) (by simp [h_fr]) (by simp) ?_
    exact Continuous.comp_continuousOn (by fun_prop) continuousOn_untopA
  continuous_invFun := continuous_sum_dom.mpr ÔčĘby fun_prop, by fun_propÔčę

@[to_dual]
lemma tendsto_nhds_top_iff {╬▒ : Type*} {f : Filter ╬▒} (x : ╬▒ Ôćĺ WithTop ╬╣) :
    Tendsto x f (­ŁôŁ ÔŐĄ) Ôćö ÔłÇ (i : ╬╣), ÔłÇßÂá (a : ╬▒) in f, i < x a := by
  obtain (h | h) := isEmpty_or_nonempty ╬╣
  ┬Ě simpa using .of_forall fun _ ÔćŽ Subsingleton.elim ..
  refine nhds_top_basis.tendsto_right_iff.trans ?_
  rw [ÔćÉ Set.forall_mem_range (p := (ÔłÇßÂá a in f, ┬Ě < x a)), WithTop.range_coe]
  simp

lemma tendsto_coe_atTop [NoMaxOrder ╬╣] :
    Tendsto ((ÔćĹ) : ╬╣ Ôćĺ WithTop ╬╣) atTop (­ŁôŁ ÔŐĄ) := by
  obtain (h | h) := isEmpty_or_nonempty ╬╣
  ┬Ě simpa using Subsingleton.elim ..
  rw [tendsto_nhds_top_iff]
  intro i
  filter_upwards [atTop_basis_Ioi.mem_of_mem (i := i) trivial]
  simp

end WithTop
