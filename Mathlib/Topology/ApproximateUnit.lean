module

public import Mathlib.Topology.Algebra.Monoid

/-! # Approximate units

An *approximate unit* is a filter `l` such that multiplication on the left (or right) by `m : őĪ`
tends to `ūĚďĚ m` along the filter, and additionally `l ‚Č† ‚ä•`.

Examples of approximate units include:

- The trivial approximate unit `pure 1` in a normed ring.
- `ūĚďĚ 1` or `ūĚďĚ[‚Č†] 1` in a normed ring (note that the latter is disjoint from `pure 1`).
- In a C‚čÜ-algebra, the filter generated by the sections `fun a ‚Ü¶ {x | a ‚Č§ x} ‚ą© closedBall 0 1`,
  where `a` ranges over the positive elements of norm strictly less than 1.
-/
set_option backward.defeqAttrib.useBackward true

@[expose] public section

open Filter Topology

/-- An *approximate unit* is a proper filter (i.e., `‚Č† ‚ä•`) such that multiplication on the left
(and separately on the right) by `m : őĪ` tends to `ūĚďĚ m` along the filter. -/
structure Filter.IsApproximateUnit {őĪ : Type*} [TopologicalSpace őĪ] [Mul őĪ]
    (l : Filter őĪ) : Prop where
  /-- Multiplication on the left by `m` tends to `ūĚďĚ m` along the filter. -/
  tendsto_mul_left m : Tendsto (m * ¬∑) l (ūĚďĚ m)
  /-- Multiplication on the right by `m` tends to `ūĚďĚ m` along the filter. -/
  tendsto_mul_right m : Tendsto (¬∑ * m) l (ūĚďĚ m)
  /-- The filter is not `‚ä•`. -/
  protected [neBot : NeBot l]

namespace Filter.IsApproximateUnit

section TopologicalMonoid

variable {őĪ : Type*} [TopologicalSpace őĪ] [MulOneClass őĪ]

variable (őĪ) in
/-- A unital magma with a topology and bornology has the trivial approximate unit `pure 1`. -/
lemma pure_one : IsApproximateUnit (pure (1 : őĪ)) where
  tendsto_mul_left m := by simpa using tendsto_pure_nhds (m * ¬∑) (1 : őĪ)
  tendsto_mul_right m := by simpa using tendsto_pure_nhds (¬∑ * m) (1 : őĪ)

/-- If `l` is an approximate unit and `‚ä• < l' ‚Č§ l`, then `l'` is also an approximate unit. -/
lemma mono {l l' : Filter őĪ} (hl : l.IsApproximateUnit) (hle : l' ‚Č§ l) [hl' : l'.NeBot] :
    l'.IsApproximateUnit where
  tendsto_mul_left m := hl.tendsto_mul_left m |>.mono_left hle
  tendsto_mul_right m := hl.tendsto_mul_right m |>.mono_left hle

variable (őĪ) in
/-- In a topological unital magma, `ūĚďĚ 1` is an approximate unit. -/
lemma nhds_one [SeparatelyContinuousMul őĪ] : IsApproximateUnit (ūĚďĚ (1 : őĪ)) where
  tendsto_mul_left m := by simpa using tendsto_id (x := ūĚďĚ 1) |>.const_mul m
  tendsto_mul_right m := by simpa using tendsto_id (x := ūĚďĚ 1) |>.mul_const m

/-- In a topological unital magma, `ūĚďĚ 1` is the largest approximate unit. -/
lemma iff_neBot_and_le_nhds_one [SeparatelyContinuousMul őĪ] {l : Filter őĪ} :
    IsApproximateUnit l ‚ÜĒ l.NeBot ‚ąß l ‚Č§ ūĚďĚ 1 :=
  ‚ü®fun hl ‚Ü¶ ‚ü®hl.neBot, by simpa using hl.tendsto_mul_left 1‚ü©,
    And.elim fun _ hl ‚Ü¶ nhds_one őĪ |>.mono hl‚ü©

/-- In a topological unital magma, `ūĚďĚ 1` is the largest approximate unit. -/
lemma iff_le_nhds_one [SeparatelyContinuousMul őĪ] {l : Filter őĪ} [l.NeBot] :
    IsApproximateUnit l ‚ÜĒ l ‚Č§ ūĚďĚ 1 := by
  simpa [iff_neBot_and_le_nhds_one] using fun _ ‚Ü¶ ‚ÄĻ_‚Äļ


end TopologicalMonoid

end Filter.IsApproximateUnit
