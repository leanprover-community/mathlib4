/- This is a lower adjoint to `UniformFun.filter` (see `UniformFun.gc`).
The exact definition of the lower adjoint `l` is not interesting; we will only use that it exists
(in `UniformFun.mono` and `UniformFun.iInf_eq`) and that
`l (Filter.map (Prod.map f f) рқ“•) = Filter.map (Prod.map ((вҲҳ) f) ((вҲҳ) f)) (l рқ“•)` for each
`рқ“• : Filter (Оі Г— Оі)` and `f : Оі вҶ’ Оұ` (in `UniformFun.comap_eq`). -/
local notation "lowerAdjoint" => fun рқ“җ => map (UniformFun.phi Оұ ОІ) (рқ“җ Г—Лў вҠӨ)

/-- The function `UniformFun.filter Оұ ОІ : Filter (ОІ Г— ОІ) вҶ’ Filter ((Оұ вҶ’бөӨ ОІ) Г— (Оұ вҶ’бөӨ ОІ))`
has a lower adjoint `l` (in the sense of `GaloisConnection`). The exact definition of `l` is not
interesting; we will only use that it exists (in `UniformFun.mono` and
`UniformFun.iInf_eq`) and that
`l (Filter.map (Prod.map f f) рқ“•) = Filter.map (Prod.map ((вҲҳ) f) ((вҲҳ) f)) (l рқ“•)` for each
`рқ“• : Filter (Оі Г— Оі)` and `f : Оі вҶ’ Оұ` (in `UniformFun.comap_eq`). -/
protected theorem gc : GaloisConnection lowerAdjoint fun рқ“• => UniformFun.filter Оұ ОІ рқ“• := by
  intro рқ“җ рқ“•
  symm
  calc
    рқ“җ вүӨ UniformFun.filter Оұ ОІ рқ“• вҶ” (UniformFun.basis Оұ ОІ рқ“•).sets вҠҶ рқ“җ.sets := by
      rw [UniformFun.filter, вҶҗ FilterBasis.generate, le_generate_iff]
    _ вҶ” вҲҖ U вҲҲ рқ“•, UniformFun.gen Оұ ОІ U вҲҲ рқ“җ := image_subset_iff
    _ вҶ” вҲҖ U вҲҲ рқ“•,
          { uv | вҲҖ x, (uv, x) вҲҲ { t : ((Оұ вҶ’бөӨ ОІ) Г— (Оұ вҶ’бөӨ ОІ)) Г— Оұ | (t.1.1 t.2, t.1.2 t.2) вҲҲ U } } вҲҲ
            рқ“җ :=
      Iff.rfl
    _ вҶ” вҲҖ U вҲҲ рқ“•,
          { uvx : ((Оұ вҶ’бөӨ ОІ) Г— (Оұ вҶ’бөӨ ОІ)) Г— Оұ | (uvx.1.1 uvx.2, uvx.1.2 uvx.2) вҲҲ U } вҲҲ
            рқ“җ Г—Лў (вҠӨ : Filter Оұ) :=
      forallвӮӮ_congr fun U _hU => mem_prod_top.symm
    _ вҶ” lowerAdjoint рқ“җ вүӨ рқ“• := Iff.rfl

variable [UniformSpace ОІ]

/-- Core of the uniform structure of uniform convergence. -/
protected def uniformCore : UniformSpace.Core (Оұ вҶ’бөӨ ОІ) :=
  UniformSpace.Core.mkOfBasis (UniformFun.basis Оұ ОІ (рқ“Ө ОІ))
    (fun _ вҹЁ_, hV, hVUвҹ© _ => hVU в–ё fun _ => refl_mem_uniformity hV)
    (fun _ вҹЁV, hV, hVUвҹ© =>
      hVU в–ё
        вҹЁUniformFun.gen Оұ ОІ (Prod.swap вҒ»В№' V), вҹЁProd.swap вҒ»В№' V, tendsto_swap_uniformity hV, rflвҹ©,
          fun _ huv x => huv xвҹ©)
    fun _ вҹЁ_, hV, hVUвҹ© =>
    hVU в–ё
      let вҹЁW, hW, hWVвҹ© := comp_mem_uniformity_sets hV
      вҹЁUniformFun.gen Оұ ОІ W, вҹЁW, hW, rflвҹ©, fun _ вҹЁw, huw, hwvвҹ© x => hWV вҹЁw x, вҹЁhuw x, hwv xвҹ©вҹ©вҹ©

/-- Uniform structure of uniform convergence, declared as an instance on `Оұ вҶ’бөӨ ОІ`.
We will denote it `рқ’°(Оұ, ОІ, uОІ)` in the rest of this file. -/
instance uniformSpace : UniformSpace (Оұ вҶ’бөӨ ОІ) :=
  UniformSpace.ofCore (UniformFun.uniformCore Оұ ОІ)

/-- Topology of uniform convergence, declared as an instance on `Оұ вҶ’бөӨ ОІ`. -/
instance topologicalSpace : TopologicalSpace (Оұ вҶ’бөӨ ОІ) :=
  inferInstance

local notation "рқ’°(" Оұ ", " ОІ ", " u ")" => @UniformFun.uniformSpace Оұ ОІ u

/-- By definition, the uniformity of `Оұ вҶ’бөӨ ОІ` admits the family `{(f, g) | вҲҖ x, (f x, g x) вҲҲ V}`
for `V вҲҲ рқ“Ө ОІ` as a filter basis. -/
protected theorem hasBasis_uniformity :
    (рқ“Ө (Оұ вҶ’бөӨ ОІ)).HasBasis (В· вҲҲ рқ“Ө ОІ) (UniformFun.gen Оұ ОІ) :=
  (UniformFun.isBasis_gen Оұ ОІ (рқ“Ө ОІ)).hasBasis

/-- The uniformity of `Оұ вҶ’бөӨ ОІ` admits the family `{(f, g) | вҲҖ x, (f x, g x) вҲҲ V}` for `V вҲҲ рқ“‘` as
a filter basis, for any basis `рқ“‘` of `рқ“Ө ОІ` (in the case `рқ“‘ = (рқ“Ө ОІ).as_basis` this is true by
definition). -/
protected theorem hasBasis_uniformity_of_basis {О№ : Sort*} {p : О№ вҶ’ Prop} {s : О№ вҶ’ Set (ОІ Г— ОІ)}
    (h : (рқ“Ө ОІ).HasBasis p s) : (рқ“Ө (Оұ вҶ’бөӨ ОІ)).HasBasis p (UniformFun.gen Оұ ОІ вҲҳ s) :=
  (UniformFun.hasBasis_uniformity Оұ ОІ).to_hasBasis
    (fun _ hU =>
      let вҹЁi, hi, hiUвҹ© := h.mem_iff.mp hU
      вҹЁi, hi, fun _ huv x => hiU (huv x)вҹ©)
    fun i hi => вҹЁs i, h.mem_of_mem hi, subset_refl _вҹ©

/-- For `f : Оұ вҶ’бөӨ ОІ`, `рқ“қ f` admits the family `{g | вҲҖ x, (f x, g x) вҲҲ V}` for `V вҲҲ рқ“‘` as a filter
basis, for any basis `рқ“‘` of `рқ“Ө ОІ`. -/
protected theorem hasBasis_nhds_of_basis (f) {p : О№ вҶ’ Prop} {s : О№ вҶ’ Set (ОІ Г— ОІ)}
    (h : HasBasis (рқ“Ө ОІ) p s) :
    (рқ“қ f).HasBasis p fun i => { g | (f, g) вҲҲ UniformFun.gen Оұ ОІ (s i) } :=
  nhds_basis_uniformity' (UniformFun.hasBasis_uniformity_of_basis Оұ ОІ h)

/-- For `f : Оұ вҶ’бөӨ ОІ`, `рқ“қ f` admits the family `{g | вҲҖ x, (f x, g x) вҲҲ V}` for `V вҲҲ рқ“Ө ОІ` as a
filter basis. -/
protected theorem hasBasis_nhds (f) :
    (рқ“қ f).HasBasis (fun V => V вҲҲ рқ“Ө ОІ) fun V => { g | (f, g) вҲҲ UniformFun.gen Оұ ОІ V } :=
  UniformFun.hasBasis_nhds_of_basis Оұ ОІ f (Filter.basis_sets _)

variable {Оұ}

/-- Evaluation at a fixed point is uniformly continuous on `Оұ вҶ’бөӨ ОІ`. -/
theorem uniformContinuous_eval (x : Оұ) :
    UniformContinuous (Function.eval x вҲҳ toFun : (Оұ вҶ’бөӨ ОІ) вҶ’ ОІ) := by
  change _ вүӨ _
  rw [map_le_iff_le_comap,
    (UniformFun.hasBasis_uniformity Оұ ОІ).le_basis_iff ((рқ“Ө _).basis_sets.comap _)]
  exact fun U hU => вҹЁU, hU, fun uv huv => huv xвҹ©

variable {ОІ}

@[simp]
protected lemma mem_gen {ОІ} {f g : Оұ вҶ’бөӨ ОІ} {V : Set (ОІ Г— ОІ)} :
    (f, g) вҲҲ UniformFun.gen Оұ ОІ V вҶ” вҲҖ x, (toFun f x, toFun g x) вҲҲ V :=
  .rfl

/-- If `uвӮҒ` and `uвӮӮ` are two uniform structures on `Оі` and `uвӮҒ вүӨ uвӮӮ`, then
`рқ’°(Оұ, Оі, uвӮҒ) вүӨ рқ’°(Оұ, Оі, uвӮӮ)`. -/
protected theorem mono : Monotone (@UniformFun.uniformSpace Оұ Оі) := fun _ _ hu =>
  (UniformFun.gc Оұ Оі).monotone_u hu

/-- If `u` is a family of uniform structures on `Оі`, then
`рқ’°(Оұ, Оі, (вЁ… i, u i)) = вЁ… i, рқ’°(Оұ, Оі, u i)`. -/
protected theorem iInf_eq {u : О№ вҶ’ UniformSpace Оі} : рқ’°(Оұ, Оі, (вЁ… i, u i)) = вЁ… i, рқ’°(Оұ, Оі, u i) := by
  -- This follows directly from the fact that the upper adjoint in a Galois connection maps
  -- infimas to infimas.
  ext : 1
  change UniformFun.filter Оұ Оі рқ“Ө[вЁ… i, u i] = рқ“Ө[вЁ… i, рқ’°(Оұ, Оі, u i)]
  rw [iInf_uniformity, iInf_uniformity]
  exact (UniformFun.gc Оұ Оі).u_iInf

/-- If `uвӮҒ` and `uвӮӮ` are two uniform structures on `Оі`, then
`рқ’°(Оұ, Оі, uвӮҒ вҠ“ uвӮӮ) = рқ’°(Оұ, Оі, uвӮҒ) вҠ“ рқ’°(Оұ, Оі, uвӮӮ)`. -/
protected theorem inf_eq {uвӮҒ uвӮӮ : UniformSpace Оі} :
    рқ’°(Оұ, Оі, uвӮҒ вҠ“ uвӮӮ) = рқ’°(Оұ, Оі, uвӮҒ) вҠ“ рқ’°(Оұ, Оі, uвӮӮ) := by
  -- This follows directly from the fact that the upper adjoint in a Galois connection maps
  -- infimas to infimas.
  rw [inf_eq_iInf, inf_eq_iInf, UniformFun.iInf_eq]
  refine iInf_congr fun i => ?_
  cases i <;> rfl

/-- Post-composition by a uniform inducing function is
a uniform inducing function for the uniform structures of uniform convergence.

More precisely, if `f : Оі вҶ’ ОІ` is uniform inducing,
then `(f вҲҳ В·) : (Оұ вҶ’бөӨ Оі) вҶ’ (Оұ вҶ’бөӨ ОІ)` is uniform inducing. -/
lemma postcomp_isUniformInducing [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : IsUniformInducing f) : IsUniformInducing (ofFun вҲҳ (f вҲҳ В·) вҲҳ toFun : (Оұ вҶ’бөӨ Оі) вҶ’ Оұ вҶ’бөӨ ОІ) :=
  вҹЁ((UniformFun.hasBasis_uniformity _ _).comap _).eq_of_same_basis <|
    UniformFun.hasBasis_uniformity_of_basis _ _ (hf.basis_uniformity (рқ“Ө ОІ).basis_sets)вҹ©

@[deprecated (since := "2024-10-05")]
alias postcomp_uniformInducing := postcomp_isUniformInducing

/-- Post-composition by a uniform embedding is
a uniform embedding for the uniform structures of uniform convergence.

More precisely, if `f : Оі вҶ’ ОІ` is a uniform embedding,
then `(f вҲҳ В·) : (Оұ вҶ’бөӨ Оі) вҶ’ (Оұ вҶ’бөӨ ОІ)` is a uniform embedding. -/
protected theorem postcomp_isUniformEmbedding [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : IsUniformEmbedding f) :
    IsUniformEmbedding (ofFun вҲҳ (f вҲҳ В·) вҲҳ toFun : (Оұ вҶ’бөӨ Оі) вҶ’ Оұ вҶ’бөӨ ОІ) where
  toIsUniformInducing := UniformFun.postcomp_isUniformInducing hf.isUniformInducing
  injective _ _ H := funext fun _ вҶҰ hf.injective (congrFun H _)

@[deprecated (since := "2024-10-01")]
alias postcomp_uniformEmbedding := UniformFun.postcomp_isUniformEmbedding

-- Porting note: had to add a type annotation at `((f вҲҳ В·) : ((Оұ вҶ’ Оі) вҶ’ (Оұ вҶ’ ОІ)))`
/-- If `u` is a uniform structures on `ОІ` and `f : Оі вҶ’ ОІ`, then
`рқ’°(Оұ, Оі, comap f u) = comap (fun g вҶҰ f вҲҳ g) рқ’°(Оұ, Оі, uвӮҒ)`. -/
protected theorem comap_eq {f : Оі вҶ’ ОІ} :
    рқ’°(Оұ, Оі, вҖ№UniformSpace ОІвҖә.comap f) = рқ’°(Оұ, ОІ, _).comap (f вҲҳ В·) := by
  letI : UniformSpace Оі := .comap f вҖ№_вҖә
  exact (UniformFun.postcomp_isUniformInducing (f := f) вҹЁrflвҹ©).comap_uniformSpace.symm

/-- Post-composition by a uniformly continuous function is uniformly continuous on `Оұ вҶ’бөӨ ОІ`.

More precisely, if `f : Оі вҶ’ ОІ` is uniformly continuous, then `(fun g вҶҰ f вҲҳ g) : (Оұ вҶ’бөӨ Оі) вҶ’ (Оұ вҶ’бөӨ ОІ)`
is uniformly continuous. -/
protected theorem postcomp_uniformContinuous [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : UniformContinuous f) :
    UniformContinuous (ofFun вҲҳ (f вҲҳ В·) вҲҳ toFun : (Оұ вҶ’бөӨ Оі) вҶ’ Оұ вҶ’бөӨ ОІ) := by
  -- This is a direct consequence of `UniformFun.comap_eq`
    refine uniformContinuous_iff.mpr ?_
    exact (UniformFun.mono (uniformContinuous_iff.mp hf)).trans_eq UniformFun.comap_eq
    -- Porting note: the original calc proof below gives a deterministic timeout
    --calc
    --  рқ’°(Оұ, Оі, _) вүӨ рқ’°(Оұ, Оі, вҖ№UniformSpace ОІвҖә.comap f) :=
    --    UniformFun.mono (uniformContinuous_iff.mp hf)
    --  _ = рқ’°(Оұ, ОІ, _).comap (f вҲҳ В·) := @UniformFun.comap_eq Оұ ОІ Оі _ f

/-- Turn a uniform isomorphism `Оі вүғбөӨ ОІ` into a uniform isomorphism `(Оұ вҶ’бөӨ Оі) вүғбөӨ (Оұ вҶ’бөӨ ОІ)` by
post-composing. -/
protected def congrRight [UniformSpace Оі] (e : Оі вүғбөӨ ОІ) : (Оұ вҶ’бөӨ Оі) вүғбөӨ (Оұ вҶ’бөӨ ОІ) :=
  { Equiv.piCongrRight fun _ => e.toEquiv with
    uniformContinuous_toFun := UniformFun.postcomp_uniformContinuous e.uniformContinuous
    uniformContinuous_invFun := UniformFun.postcomp_uniformContinuous e.symm.uniformContinuous }

/-- Pre-composition by any function is uniformly continuous for the uniform structures of
uniform convergence.

More precisely, for any `f : Оі вҶ’ Оұ`, the function `(В· вҲҳ f) : (Оұ вҶ’бөӨ ОІ) вҶ’ (Оі вҶ’бөӨ ОІ)` is uniformly
continuous. -/
protected theorem precomp_uniformContinuous {f : Оі вҶ’ Оұ} :
    UniformContinuous fun g : Оұ вҶ’бөӨ ОІ => ofFun (toFun g вҲҳ f) := by
  -- Here we simply go back to filter bases.
  rw [UniformContinuous,
      (UniformFun.hasBasis_uniformity Оұ ОІ).tendsto_iff (UniformFun.hasBasis_uniformity Оі ОІ)]
  exact fun U hU => вҹЁU, hU, fun uv huv x => huv (f x)вҹ©

/-- Turn a bijection `Оі вүғ Оұ` into a uniform isomorphism
`(Оі вҶ’бөӨ ОІ) вүғбөӨ (Оұ вҶ’бөӨ ОІ)` by pre-composing. -/
protected def congrLeft (e : Оі вүғ Оұ) : (Оі вҶ’бөӨ ОІ) вүғбөӨ (Оұ вҶ’бөӨ ОІ) where
  toEquiv := e.arrowCongr (.refl _)
  uniformContinuous_toFun := UniformFun.precomp_uniformContinuous
  uniformContinuous_invFun := UniformFun.precomp_uniformContinuous

/-- The natural map `UniformFun.toFun` from `Оұ вҶ’бөӨ ОІ` to `Оұ вҶ’ ОІ` is uniformly continuous.

In other words, the uniform structure of uniform convergence is finer than that of pointwise
convergence, aka the product uniform structure. -/
protected theorem uniformContinuous_toFun : UniformContinuous (toFun : (Оұ вҶ’бөӨ ОІ) вҶ’ Оұ вҶ’ ОІ) := by
  -- By definition of the product uniform structure, this is just `uniform_continuous_eval`.
  rw [uniformContinuous_pi]
  intro x
  exact uniformContinuous_eval ОІ x

/-- The topology of uniform convergence is TвӮӮ. -/
instance [T2Space ОІ] : T2Space (Оұ вҶ’бөӨ ОІ) :=
  .of_injective_continuous toFun.injective UniformFun.uniformContinuous_toFun.continuous

/-- The topology of uniform convergence indeed gives the same notion of convergence as
`TendstoUniformly`. -/
protected theorem tendsto_iff_tendstoUniformly {F : О№ вҶ’ Оұ вҶ’бөӨ ОІ} {f : Оұ вҶ’бөӨ ОІ} :
    Tendsto F p (рқ“қ f) вҶ” TendstoUniformly (toFun вҲҳ F) (toFun f) p := by
  rw [(UniformFun.hasBasis_nhds Оұ ОІ f).tendsto_right_iff, TendstoUniformly]
  simp only [mem_setOf, UniformFun.gen, Function.comp_def]

/-- The natural bijection between `Оұ вҶ’ ОІ Г— Оі` and `(Оұ вҶ’ ОІ) Г— (Оұ вҶ’ Оі)`, upgraded to a uniform
isomorphism between `Оұ вҶ’бөӨ ОІ Г— Оі` and `(Оұ вҶ’бөӨ ОІ) Г— (Оұ вҶ’бөӨ Оі)`. -/
protected def uniformEquivProdArrow [UniformSpace Оі] : (Оұ вҶ’бөӨ ОІ Г— Оі) вүғбөӨ (Оұ вҶ’бөӨ ОІ) Г— (Оұ вҶ’бөӨ Оі) :=
  -- Denote `ПҶ` this bijection. We want to show that
  -- `comap ПҶ (рқ’°(Оұ, ОІ, uОІ) Г— рқ’°(Оұ, Оі, uОі)) = рқ’°(Оұ, ОІ Г— Оі, uОІ Г— uОі)`.
  -- But `uОІ Г— uОі` is defined as `comap fst uОІ вҠ“ comap snd uОі`, so we just have to apply
  -- `UniformFun.inf_eq` and `UniformFun.comap_eq`, which leaves us to check
  -- that some square commutes.
  Equiv.toUniformEquivOfIsUniformInducing (Equiv.arrowProdEquivProdArrow _ _ _) <| by
    constructor
    change
      comap (Prod.map (Equiv.arrowProdEquivProdArrow _ _ _) (Equiv.arrowProdEquivProdArrow _ _ _))
          _ = _
    simp_rw [UniformFun]
    rw [вҶҗ uniformity_comap]
    congr
    unfold instUniformSpaceProd
    rw [UniformSpace.comap_inf, вҶҗ UniformSpace.comap_comap, вҶҗ UniformSpace.comap_comap]
    have := (@UniformFun.inf_eq Оұ (ОІ Г— Оі)
      (UniformSpace.comap Prod.fst вҖ№_вҖә) (UniformSpace.comap Prod.snd вҖ№_вҖә)).symm
    rwa [UniformFun.comap_eq, UniformFun.comap_eq] at this

-- the relevant diagram commutes by definition
variable (Оұ) (Оҙ : О№ вҶ’ Type*) [вҲҖ i, UniformSpace (Оҙ i)]

/-- The natural bijection between `Оұ вҶ’ О  i, Оҙ i` and `О  i, Оұ вҶ’ Оҙ i`, upgraded to a uniform
isomorphism between `Оұ вҶ’бөӨ (О  i, Оҙ i)` and `О  i, Оұ вҶ’бөӨ Оҙ i`. -/
protected def uniformEquivPiComm : UniformEquiv (Оұ вҶ’бөӨ вҲҖ i, Оҙ i) (вҲҖ i, Оұ вҶ’бөӨ Оҙ i) :=
  -- Denote `ПҶ` this bijection. We want to show that
    -- `comap ПҶ (О  i, рқ’°(Оұ, Оҙ i, uОҙ i)) = рқ’°(Оұ, (О  i, Оҙ i), (О  i, uОҙ i))`.
    -- But `О  i, uОҙ i` is defined as `вЁ… i, comap (eval i) (uОҙ i)`, so we just have to apply
    -- `UniformFun.iInf_eq` and `UniformFun.comap_eq`, which leaves us to check
    -- that some square commutes.
    @Equiv.toUniformEquivOfIsUniformInducing
    _ _ рқ’°(Оұ, вҲҖ i, Оҙ i, Pi.uniformSpace Оҙ)
    (@Pi.uniformSpace О№ (fun i => Оұ вҶ’ Оҙ i) fun i => рқ’°(Оұ, Оҙ i, _)) (Equiv.piComm _) <| by
      refine @IsUniformInducing.mk ?_ ?_ ?_ ?_ ?_ ?_
      change comap (Prod.map Function.swap Function.swap) _ = _
      rw [вҶҗ uniformity_comap]
      congr
      unfold Pi.uniformSpace
      rw [UniformSpace.ofCoreEq_toCore, UniformSpace.ofCoreEq_toCore,
        UniformSpace.comap_iInf, UniformFun.iInf_eq]
      refine iInf_congr fun i => ?_
      rw [вҶҗ UniformSpace.comap_comap, UniformFun.comap_eq]
      rfl

-- Like in the previous lemma, the diagram actually commutes by definition

/-- The set of continuous functions is closed in the uniform convergence topology.
This is a simple wrapper over `TendstoUniformly.continuous`. -/
theorem isClosed_setOf_continuous [TopologicalSpace Оұ] :
    IsClosed {f : Оұ вҶ’бөӨ ОІ | Continuous (toFun f)} := by
  refine isClosed_iff_forall_filter.2 fun f u _ hu huf вҶҰ ?_
  rw [вҶҗ tendsto_id', UniformFun.tendsto_iff_tendstoUniformly] at huf
  exact huf.continuous (le_principal_iff.mp hu)

variable {Оұ} (ОІ) in
theorem uniformSpace_eq_inf_precomp_of_cover {ОҙвӮҒ ОҙвӮӮ : Type*} (ПҶвӮҒ : ОҙвӮҒ вҶ’ Оұ) (ПҶвӮӮ : ОҙвӮӮ вҶ’ Оұ)
    (h_cover : range ПҶвӮҒ вҲӘ range ПҶвӮӮ = univ) :
    рқ’°(Оұ, ОІ, _) =
      .comap (ofFun вҲҳ (В· вҲҳ ПҶвӮҒ) вҲҳ toFun) рқ’°(ОҙвӮҒ, ОІ, _) вҠ“
      .comap (ofFun вҲҳ (В· вҲҳ ПҶвӮӮ) вҲҳ toFun) рқ’°(ОҙвӮӮ, ОІ, _) := by
  ext : 1
  refine le_antisymm (le_inf ?_ ?_) ?_
  В· exact tendsto_iff_comap.mp UniformFun.precomp_uniformContinuous
  В· exact tendsto_iff_comap.mp UniformFun.precomp_uniformContinuous
  В· refine
      (UniformFun.hasBasis_uniformity ОҙвӮҒ ОІ |>.comap _).inf
      (UniformFun.hasBasis_uniformity ОҙвӮӮ ОІ |>.comap _)
        |>.le_basis_iff (UniformFun.hasBasis_uniformity Оұ ОІ) |>.mpr fun U hU вҶҰ
        вҹЁвҹЁU, Uвҹ©, вҹЁhU, hUвҹ©, fun вҹЁf, gвҹ© hfg x вҶҰ ?_вҹ©
    rcases h_cover.ge <| mem_univ x with (вҹЁy, rflвҹ©|вҹЁy, rflвҹ©)
    В· exact hfg.1 y
    В· exact hfg.2 y

variable {Оұ} (ОІ) in
theorem uniformSpace_eq_iInf_precomp_of_cover {Оҙ : О№ вҶ’ Type*} (ПҶ : О  i, Оҙ i вҶ’ Оұ)
    (h_cover : вҲғ I : Set О№, I.Finite вҲ§ вӢғ i вҲҲ I, range (ПҶ i) = univ) :
    рқ’°(Оұ, ОІ, _) = вЁ… i, .comap (ofFun вҲҳ (В· вҲҳ ПҶ i) вҲҳ toFun) рқ’°(Оҙ i, ОІ, _) := by
  ext : 1
  simp_rw [iInf_uniformity, uniformity_comap]
  refine le_antisymm (le_iInf fun i вҶҰ tendsto_iff_comap.mp UniformFun.precomp_uniformContinuous) ?_
  rcases h_cover with вҹЁI, I_finite, I_coverвҹ©
  refine Filter.hasBasis_iInf (fun i : О№ вҶҰ UniformFun.hasBasis_uniformity (Оҙ i) ОІ |>.comap _)
      |>.le_basis_iff (UniformFun.hasBasis_uniformity Оұ ОІ) |>.mpr fun U hU вҶҰ
    вҹЁвҹЁI, fun _ вҶҰ Uвҹ©, вҹЁI_finite, fun _ вҶҰ hUвҹ©, fun вҹЁf, gвҹ© hfg x вҶҰ ?_вҹ©
  rcases mem_iUnionвӮӮ.mp <| I_cover.ge <| mem_univ x with вҹЁi, hi, y, rflвҹ©
  exact mem_iInter.mp hfg вҹЁi, hiвҹ© y

end UniformFun

namespace UniformOnFun

variable {Оұ ОІ : Type*} {Оі О№ : Type*}
variable {s : Set Оұ} {p : Filter О№}

local notation "рқ’°(" Оұ ", " ОІ ", " u ")" => @UniformFun.uniformSpace Оұ ОІ u

/-- Basis sets for the uniformity of `рқ”–`-convergence: for `S : Set Оұ` and `V : Set (ОІ Г— ОІ)`,
`gen рқ”– S V` is the set of pairs `(f, g)` of functions `Оұ вҶ’бөӨ[рқ”–] ОІ` such that
`вҲҖ x вҲҲ S, (f x, g x) вҲҲ V`. Note that the family `рқ”– : Set (Set Оұ)` is only used to specify which
type alias of `Оұ вҶ’ ОІ` to use here. -/
protected def gen (рқ”–) (S : Set Оұ) (V : Set (ОІ Г— ОІ)) : Set ((Оұ вҶ’бөӨ[рқ”–] ОІ) Г— (Оұ вҶ’бөӨ[рқ”–] ОІ)) :=
  { uv : (Оұ вҶ’бөӨ[рқ”–] ОІ) Г— (Оұ вҶ’бөӨ[рқ”–] ОІ) | вҲҖ x вҲҲ S, (toFun рқ”– uv.1 x, toFun рқ”– uv.2 x) вҲҲ V }

/-- For `S : Set Оұ` and `V : Set (ОІ Г— ОІ)`, we have
`UniformOnFun.gen рқ”– S V = (S.restrict Г— S.restrict) вҒ»В№' (UniformFun.gen S ОІ V)`.
This is the crucial fact for proving that the family `UniformOnFun.gen S V` for `S вҲҲ рқ”–` and
`V вҲҲ рқ“Ө ОІ` is indeed a basis for the uniformity `Оұ вҶ’бөӨ[рқ”–] ОІ` endowed with `рқ’ұ(Оұ, ОІ, рқ”–, uОІ)`
the uniform structure of `рқ”–`-convergence, as defined in `UniformOnFun.uniformSpace`. -/
protected theorem gen_eq_preimage_restrict {рқ”–} (S : Set Оұ) (V : Set (ОІ Г— ОІ)) :
    UniformOnFun.gen рқ”– S V =
      Prod.map (S.restrict вҲҳ UniformFun.toFun) (S.restrict вҲҳ UniformFun.toFun) вҒ»В№'
        UniformFun.gen S ОІ V := by
  ext uv
  exact вҹЁfun h вҹЁx, hxвҹ© => h x hx, fun h x hx => h вҹЁx, hxвҹ©вҹ©

/-- `UniformOnFun.gen` is antitone in the first argument and monotone in the second. -/
protected theorem gen_mono {рқ”–} {S S' : Set Оұ} {V V' : Set (ОІ Г— ОІ)} (hS : S' вҠҶ S) (hV : V вҠҶ V') :
    UniformOnFun.gen рқ”– S V вҠҶ UniformOnFun.gen рқ”– S' V' := fun _uv h x hx => hV (h x <| hS hx)

/-- If `рқ”– : Set (Set Оұ)` is nonempty and directed and `рқ“‘` is a filter basis on `ОІ Г— ОІ`, then the
family `UniformOnFun.gen рқ”– S V` for `S вҲҲ рқ”–` and `V вҲҲ рқ“‘` is a filter basis on
`(Оұ вҶ’бөӨ[рқ”–] ОІ) Г— (Оұ вҶ’бөӨ[рқ”–] ОІ)`.
We will show in `has_basis_uniformity_of_basis` that, if `рқ“‘` is a basis for `рқ“Ө ОІ`, then the
corresponding filter is the uniformity of `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
protected theorem isBasis_gen (рқ”– : Set (Set Оұ)) (h : рқ”–.Nonempty) (h' : DirectedOn (В· вҠҶ В·) рқ”–)
    (рқ“‘ : FilterBasis <| ОІ Г— ОІ) :
    IsBasis (fun SV : Set Оұ Г— Set (ОІ Г— ОІ) => SV.1 вҲҲ рқ”– вҲ§ SV.2 вҲҲ рқ“‘) fun SV =>
      UniformOnFun.gen рқ”– SV.1 SV.2 :=
  вҹЁh.prod рқ“‘.nonempty, fun {UвӮҒVвӮҒ UвӮӮVвӮӮ} hвӮҒ hвӮӮ =>
    let вҹЁUвӮғ, hUвӮғ, hUвӮҒвӮғ, hUвӮӮвӮғвҹ© := h' UвӮҒVвӮҒ.1 hвӮҒ.1 UвӮӮVвӮӮ.1 hвӮӮ.1
    let вҹЁVвӮғ, hVвӮғ, hVвӮҒвӮӮвӮғвҹ© := рқ“‘.inter_sets hвӮҒ.2 hвӮӮ.2
    вҹЁвҹЁUвӮғ, VвӮғвҹ©,
      вҹЁвҹЁhUвӮғ, hVвӮғвҹ©, fun _ H =>
        вҹЁfun x hx => (hVвӮҒвӮӮвӮғ <| H x <| hUвӮҒвӮғ hx).1, fun x hx => (hVвӮҒвӮӮвӮғ <| H x <| hUвӮӮвӮғ hx).2вҹ©вҹ©вҹ©вҹ©

variable (Оұ ОІ) [UniformSpace ОІ] (рқ”– : Set (Set Оұ))

/-- Uniform structure of `рқ”–`-convergence, i.e uniform convergence on the elements of `рқ”–`,
declared as an instance on `Оұ вҶ’бөӨ[рқ”–] ОІ`. It is defined as the infimum, for `S вҲҲ рқ”–`, of the pullback
by `S.restrict`, the map of restriction to `S`, of the uniform structure `рқ’°(s, ОІ, uОІ)` on
`вҶҘS вҶ’бөӨ ОІ`. We will denote it `рқ’ұ(Оұ, ОІ, рқ”–, uОІ)`, where `uОІ` is the uniform structure on `ОІ`. -/
instance uniformSpace : UniformSpace (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  вЁ… (s : Set Оұ) (_ : s вҲҲ рқ”–),
    .comap (UniformFun.ofFun вҲҳ s.restrict вҲҳ UniformOnFun.toFun рқ”–) рқ’°(s, ОІ, _)

local notation "рқ’ұ(" Оұ ", " ОІ ", " рқ”– ", " u ")" => @UniformOnFun.uniformSpace Оұ ОІ u рқ”–

/-- Topology of `рқ”–`-convergence, i.e uniform convergence on the elements of `рқ”–`, declared as an
instance on `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
instance topologicalSpace : TopologicalSpace (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  рқ’ұ(Оұ, ОІ, рқ”–, _).toTopologicalSpace

/-- The topology of `рқ”–`-convergence is the infimum, for `S вҲҲ рқ”–`, of topology induced by the map
of `S.restrict : (Оұ вҶ’бөӨ[рқ”–] ОІ) вҶ’ (вҶҘS вҶ’бөӨ ОІ)` of restriction to `S`, where `вҶҘS вҶ’бөӨ ОІ` is endowed with
the topology of uniform convergence. -/
protected theorem topologicalSpace_eq :
    UniformOnFun.topologicalSpace Оұ ОІ рқ”– =
      вЁ… (s : Set Оұ) (_ : s вҲҲ рқ”–), TopologicalSpace.induced
        (UniformFun.ofFun вҲҳ s.restrict вҲҳ toFun рқ”–) (UniformFun.topologicalSpace s ОІ) := by
  simp only [UniformOnFun.topologicalSpace, UniformSpace.toTopologicalSpace_iInf]
  rfl

protected theorem hasBasis_uniformity_of_basis_auxвӮҒ {p : О№ вҶ’ Prop} {s : О№ вҶ’ Set (ОІ Г— ОІ)}
    (hb : HasBasis (рқ“Ө ОІ) p s) (S : Set Оұ) :
    (@uniformity (Оұ вҶ’бөӨ[рқ”–] ОІ) ((UniformFun.uniformSpace S ОІ).comap S.restrict)).HasBasis p fun i =>
      UniformOnFun.gen рқ”– S (s i) := by
  simp_rw [UniformOnFun.gen_eq_preimage_restrict, uniformity_comap]
  exact (UniformFun.hasBasis_uniformity_of_basis S ОІ hb).comap _

protected theorem hasBasis_uniformity_of_basis_auxвӮӮ (h : DirectedOn (В· вҠҶ В·) рқ”–) {p : О№ вҶ’ Prop}
    {s : О№ вҶ’ Set (ОІ Г— ОІ)} (hb : HasBasis (рқ“Ө ОІ) p s) :
    DirectedOn
      ((fun s : Set Оұ => (UniformFun.uniformSpace s ОІ).comap (s.restrict : (Оұ вҶ’бөӨ ОІ) вҶ’ s вҶ’бөӨ ОІ)) вҒ»В№'o
        GE.ge)
      рқ”– :=
  h.mono fun _ _ hst =>
    ((UniformOnFun.hasBasis_uniformity_of_basis_auxвӮҒ Оұ ОІ рқ”– hb _).le_basis_iff
          (UniformOnFun.hasBasis_uniformity_of_basis_auxвӮҒ Оұ ОІ рқ”– hb _)).mpr
      fun V hV => вҹЁV, hV, UniformOnFun.gen_mono hst subset_rflвҹ©

/-- If `рқ”– : Set (Set Оұ)` is nonempty and directed and `рқ“‘` is a filter basis of `рқ“Ө ОІ`, then the
uniformity of `Оұ вҶ’бөӨ[рқ”–] ОІ` admits the family `{(f, g) | вҲҖ x вҲҲ S, (f x, g x) вҲҲ V}` for `S вҲҲ рқ”–` and
`V вҲҲ рқ“‘` as a filter basis. -/
protected theorem hasBasis_uniformity_of_basis (h : рқ”–.Nonempty) (h' : DirectedOn (В· вҠҶ В·) рқ”–)
    {p : О№ вҶ’ Prop} {s : О№ вҶ’ Set (ОІ Г— ОІ)} (hb : HasBasis (рқ“Ө ОІ) p s) :
    (рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ)).HasBasis (fun Si : Set Оұ Г— О№ => Si.1 вҲҲ рқ”– вҲ§ p Si.2) fun Si =>
      UniformOnFun.gen рқ”– Si.1 (s Si.2) := by
  simp only [iInf_uniformity]
  exact
    hasBasis_biInf_of_directed h (fun S => UniformOnFun.gen рқ”– S вҲҳ s) _
      (fun S _hS => UniformOnFun.hasBasis_uniformity_of_basis_auxвӮҒ Оұ ОІ рқ”– hb S)
      (UniformOnFun.hasBasis_uniformity_of_basis_auxвӮӮ Оұ ОІ рқ”– h' hb)

/-- If `рқ”– : Set (Set Оұ)` is nonempty and directed, then the uniformity of `Оұ вҶ’бөӨ[рқ”–] ОІ` admits the
family `{(f, g) | вҲҖ x вҲҲ S, (f x, g x) вҲҲ V}` for `S вҲҲ рқ”–` and `V вҲҲ рқ“Ө ОІ` as a filter basis. -/
protected theorem hasBasis_uniformity (h : рқ”–.Nonempty) (h' : DirectedOn (В· вҠҶ В·) рқ”–) :
    (рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ)).HasBasis (fun SV : Set Оұ Г— Set (ОІ Г— ОІ) => SV.1 вҲҲ рқ”– вҲ§ SV.2 вҲҲ рқ“Ө ОІ) fun SV =>
      UniformOnFun.gen рқ”– SV.1 SV.2 :=
  UniformOnFun.hasBasis_uniformity_of_basis Оұ ОІ рқ”– h h' (рқ“Ө ОІ).basis_sets

variable {Оұ ОІ}

/-- Let `t i` be a nonempty directed subfamily of `рқ”–`
such that every `s вҲҲ рқ”–` is included in some `t i`.
Let `V` bounded by `p` be a basis of entourages of `ОІ`.

Then `UniformOnFun.gen рқ”– (t i) (V j)` bounded by `p j` is a basis of entourages of `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
protected theorem hasBasis_uniformity_of_covering_of_basis {О№ О№' : Type*} [Nonempty О№]
    {t : О№ вҶ’ Set Оұ} {p : О№' вҶ’ Prop} {V : О№' вҶ’ Set (ОІ Г— ОІ)} (ht : вҲҖ i, t i вҲҲ рқ”–)
    (hdir : Directed (В· вҠҶ В·) t) (hex : вҲҖ s вҲҲ рқ”–, вҲғ i, s вҠҶ t i) (hb : HasBasis (рқ“Ө ОІ) p V) :
    (рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ)).HasBasis (fun i : О№ Г— О№' вҶҰ p i.2) fun i вҶҰ
      UniformOnFun.gen рқ”– (t i.1) (V i.2) := by
  have hne : рқ”–.Nonempty := (range_nonempty t).mono (range_subset_iff.2 ht)
  have hd : DirectedOn (В· вҠҶ В·) рқ”– := fun sвӮҒ hsвӮҒ sвӮӮ hsвӮӮ вҶҰ by
    rcases hex sвӮҒ hsвӮҒ, hex sвӮӮ hsвӮӮ with вҹЁвҹЁiвӮҒ, hisвӮҒвҹ©, iвӮӮ, hisвӮӮвҹ©
    rcases hdir iвӮҒ iвӮӮ with вҹЁi, hiвӮҒ, hiвӮӮвҹ©
    exact вҹЁt i, ht _, hisвӮҒ.trans hiвӮҒ, hisвӮӮ.trans hiвӮӮвҹ©
  refine (UniformOnFun.hasBasis_uniformity_of_basis Оұ ОІ рқ”– hne hd hb).to_hasBasis
    (fun вҹЁs, i'вҹ© вҹЁhs, hi'вҹ© вҶҰ ?_) fun вҹЁi, i'вҹ© hi' вҶҰ вҹЁ(t i, i'), вҹЁht i, hi'вҹ©, Subset.rflвҹ©
  rcases hex s hs with вҹЁi, hiвҹ©
  exact вҹЁ(i, i'), hi', UniformOnFun.gen_mono hi Subset.rflвҹ©

/-- If `t n` is a monotone sequence of sets in `рқ”–`
such that each `s вҲҲ рқ”–` is included in some `t n`
and `V n` is an antitone basis of entourages of `ОІ`,
then `UniformOnFun.gen рқ”– (t n) (V n)` is an antitone basis of entourages of `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
protected theorem hasAntitoneBasis_uniformity {О№ : Type*} [Preorder О№] [IsDirected О№ (В· вүӨ В·)]
    {t : О№ вҶ’ Set Оұ} {V : О№ вҶ’ Set (ОІ Г— ОІ)}
    (ht : вҲҖ n, t n вҲҲ рқ”–) (hmono : Monotone t) (hex : вҲҖ s вҲҲ рқ”–, вҲғ n, s вҠҶ t n)
    (hb : HasAntitoneBasis (рқ“Ө ОІ) V) :
    (рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ)).HasAntitoneBasis fun n вҶҰ UniformOnFun.gen рқ”– (t n) (V n) := by
  have := hb.nonempty
  refine вҹЁ(UniformOnFun.hasBasis_uniformity_of_covering_of_basis рқ”–
    ht hmono.directed_le hex hb.1).to_hasBasis ?_ fun i _ вҶҰ вҹЁ(i, i), trivial, Subset.rflвҹ©, ?_вҹ©
  В· rintro вҹЁk, lвҹ© -
    rcases directed_of (В· вүӨ В·) k l with вҹЁn, hkn, hlnвҹ©
    exact вҹЁn, trivial, UniformOnFun.gen_mono (hmono hkn) (hb.2 <| hln)вҹ©
  В· exact fun k l h вҶҰ UniformOnFun.gen_mono (hmono h) (hb.2 h)

protected theorem isCountablyGenerated_uniformity [IsCountablyGenerated (рқ“Ө ОІ)] {t : в„• вҶ’ Set Оұ}
    (ht : вҲҖ n, t n вҲҲ рқ”–) (hmono : Monotone t) (hex : вҲҖ s вҲҲ рқ”–, вҲғ n, s вҠҶ t n) :
    IsCountablyGenerated (рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ)) :=
  let вҹЁ_V, hVвҹ© := exists_antitone_basis (рқ“Ө ОІ)
  (UniformOnFun.hasAntitoneBasis_uniformity рқ”– ht hmono hex hV).isCountablyGenerated

variable (Оұ ОІ)

/-- For `f : Оұ вҶ’бөӨ[рқ”–] ОІ`, where `рқ”– : Set (Set Оұ)` is nonempty and directed, `рқ“қ f` admits the
family `{g | вҲҖ x вҲҲ S, (f x, g x) вҲҲ V}` for `S вҲҲ рқ”–` and `V вҲҲ рқ“‘` as a filter basis, for any basis
`рқ“‘` of `рқ“Ө ОІ`. -/
protected theorem hasBasis_nhds_of_basis (f : Оұ вҶ’бөӨ[рқ”–] ОІ) (h : рқ”–.Nonempty)
    (h' : DirectedOn (В· вҠҶ В·) рқ”–) {p : О№ вҶ’ Prop} {s : О№ вҶ’ Set (ОІ Г— ОІ)} (hb : HasBasis (рқ“Ө ОІ) p s) :
    (рқ“қ f).HasBasis (fun Si : Set Оұ Г— О№ => Si.1 вҲҲ рқ”– вҲ§ p Si.2) fun Si =>
      { g | (g, f) вҲҲ UniformOnFun.gen рқ”– Si.1 (s Si.2) } :=
  letI : UniformSpace (Оұ вҶ’ ОІ) := UniformOnFun.uniformSpace Оұ ОІ рқ”–
  nhds_basis_uniformity (UniformOnFun.hasBasis_uniformity_of_basis Оұ ОІ рқ”– h h' hb)

/-- For `f : Оұ вҶ’бөӨ[рқ”–] ОІ`, where `рқ”– : Set (Set Оұ)` is nonempty and directed, `рқ“қ f` admits the
family `{g | вҲҖ x вҲҲ S, (f x, g x) вҲҲ V}` for `S вҲҲ рқ”–` and `V вҲҲ рқ“Ө ОІ` as a filter basis. -/
protected theorem hasBasis_nhds (f : Оұ вҶ’бөӨ[рқ”–] ОІ) (h : рқ”–.Nonempty) (h' : DirectedOn (В· вҠҶ В·) рқ”–) :
    (рқ“қ f).HasBasis (fun SV : Set Оұ Г— Set (ОІ Г— ОІ) => SV.1 вҲҲ рқ”– вҲ§ SV.2 вҲҲ рқ“Ө ОІ) fun SV =>
      { g | (g, f) вҲҲ UniformOnFun.gen рқ”– SV.1 SV.2 } :=
  UniformOnFun.hasBasis_nhds_of_basis Оұ ОІ рқ”– f h h' (Filter.basis_sets _)

/-- If `S вҲҲ рқ”–`, then the restriction to `S` is a uniformly continuous map from `Оұ вҶ’бөӨ[рқ”–] ОІ` to
`вҶҘS вҶ’бөӨ ОІ`. -/
protected theorem uniformContinuous_restrict (h : s вҲҲ рқ”–) :
    UniformContinuous (UniformFun.ofFun вҲҳ (s.restrict : (Оұ вҶ’ ОІ) вҶ’ s вҶ’ ОІ) вҲҳ toFun рқ”–) := by
  change _ вүӨ _
  simp only [UniformOnFun.uniformSpace, map_le_iff_le_comap, iInf_uniformity]
