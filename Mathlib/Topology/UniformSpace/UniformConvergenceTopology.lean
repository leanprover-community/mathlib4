section TypeAlias

/-- The type of functions from `Оұ` to `ОІ` equipped with the uniform structure and topology of
uniform convergence. We denote it `Оұ вҶ’бөӨ ОІ`. -/
def UniformFun (Оұ ОІ : Type*) :=
  Оұ вҶ’ ОІ

/-- The type of functions from `Оұ` to `ОІ` equipped with the uniform structure and topology of
uniform convergence on some family `рқ”–` of subsets of `Оұ`. We denote it `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
@[nolint unusedArguments]
def UniformOnFun (Оұ ОІ : Type*) (_ : Set (Set Оұ)) :=
  Оұ вҶ’ ОІ

