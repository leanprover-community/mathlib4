open UniformConvergence

variable {Оұ ОІ : Type*} {рқ”– : Set (Set Оұ)}

instance [Nonempty ОІ] : Nonempty (Оұ вҶ’бөӨ ОІ) := Pi.instNonempty

instance [Nonempty ОІ] : Nonempty (Оұ вҶ’бөӨ[рқ”–] ОІ) := Pi.instNonempty

instance [Subsingleton ОІ] : Subsingleton (Оұ вҶ’бөӨ ОІ) :=
  inferInstanceAs <| Subsingleton <| Оұ вҶ’ ОІ

instance [Subsingleton ОІ] : Subsingleton (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  inferInstanceAs <| Subsingleton <| Оұ вҶ’ ОІ

/-- Reinterpret `f : Оұ вҶ’ ОІ` as an element of `Оұ вҶ’бөӨ ОІ`. -/
def UniformFun.ofFun : (Оұ вҶ’ ОІ) вүғ (Оұ вҶ’бөӨ ОІ) :=
  вҹЁfun x => x, fun x => x, fun _ => rfl, fun _ => rflвҹ©

/-- Reinterpret `f : Оұ вҶ’ ОІ` as an element of `Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
def UniformOnFun.ofFun (рқ”–) : (Оұ вҶ’ ОІ) вүғ (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  вҹЁfun x => x, fun x => x, fun _ => rfl, fun _ => rflвҹ©

/-- Reinterpret `f : Оұ вҶ’бөӨ ОІ` as an element of `Оұ вҶ’ ОІ`. -/
def UniformFun.toFun : (Оұ вҶ’бөӨ ОІ) вүғ (Оұ вҶ’ ОІ) :=
  UniformFun.ofFun.symm

/-- Reinterpret `f : Оұ вҶ’бөӨ[рқ”–] ОІ` as an element of `Оұ вҶ’ ОІ`. -/
def UniformOnFun.toFun (рқ”–) : (Оұ вҶ’бөӨ[рқ”–] ОІ) вүғ (Оұ вҶ’ ОІ) :=
  (UniformOnFun.ofFun рқ”–).symm

@[simp] lemma UniformFun.toFun_ofFun (f : Оұ вҶ’ ОІ) : toFun (ofFun f) = f := rfl
@[simp] lemma UniformFun.ofFun_toFun (f : Оұ вҶ’бөӨ ОІ) : ofFun (toFun f) = f := rfl
@[simp] lemma UniformOnFun.toFun_ofFun (f : Оұ вҶ’ ОІ) : toFun рқ”– (ofFun рқ”– f) = f := rfl
@[simp] lemma UniformOnFun.ofFun_toFun (f : Оұ вҶ’бөӨ[рқ”–] ОІ) : ofFun рқ”– (toFun рқ”– f) = f := rfl

-- Note: we don't declare a `CoeFun` instance because Lean wouldn't insert it when writing
-- `f x` (because of definitional equality with `Оұ вҶ’ ОІ`).
end TypeAlias

