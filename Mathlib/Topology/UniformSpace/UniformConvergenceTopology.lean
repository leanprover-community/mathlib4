variable {Оұ}

/-- A version of `UniformOnFun.hasBasis_uniformity_of_basis`
with weaker conclusion and weaker assumptions.

We make no assumptions about the set `рқ”–`
but conclude only that the uniformity is equal to some indexed infimum. -/
protected theorem uniformity_eq_of_basis {О№ : Sort*} {p : О№ вҶ’ Prop} {V : О№ вҶ’ Set (ОІ Г— ОІ)}
    (h : (рқ“Ө ОІ).HasBasis p V) :
    рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ) = вЁ… s вҲҲ рқ”–, вЁ… (i) (_ : p i), рқ“ҹ (UniformOnFun.gen рқ”– s (V i)) := by
  simp_rw [iInf_uniformity, uniformity_comap,
    (UniformFun.hasBasis_uniformity_of_basis _ _ h).eq_biInf, comap_iInf, comap_principal,
    Function.comp_apply, UniformFun.gen, Subtype.forall, UniformOnFun.gen, preimage_setOf_eq,
    Prod.map_fst, Prod.map_snd, Function.comp_apply, UniformFun.toFun_ofFun, restrict_apply]

protected theorem uniformity_eq : рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ) = вЁ… s вҲҲ рқ”–, вЁ… V вҲҲ рқ“Ө ОІ, рқ“ҹ (UniformOnFun.gen рқ”– s V) :=
  UniformOnFun.uniformity_eq_of_basis _ _ (рқ“Ө ОІ).basis_sets

protected theorem gen_mem_uniformity (hs : s вҲҲ рқ”–) {V : Set (ОІ Г— ОІ)} (hV : V вҲҲ рқ“Ө ОІ) :
    UniformOnFun.gen рқ”– s V вҲҲ рқ“Ө (Оұ вҶ’бөӨ[рқ”–] ОІ) := by
  rw [UniformOnFun.uniformity_eq]
  apply_rules [mem_iInf_of_mem, mem_principal_self]

/-- A version of `UniformOnFun.hasBasis_nhds_of_basis`
with weaker conclusion and weaker assumptions.

We make no assumptions about the set `рқ”–`
but conclude only that the neighbourhoods filter is equal to some indexed infimum. -/
protected theorem nhds_eq_of_basis {О№ : Sort*} {p : О№ вҶ’ Prop} {V : О№ вҶ’ Set (ОІ Г— ОІ)}
    (h : (рқ“Ө ОІ).HasBasis p V) (f : Оұ вҶ’бөӨ[рқ”–] ОІ) :
    рқ“қ f = вЁ… s вҲҲ рқ”–, вЁ… (i) (_ : p i), рқ“ҹ {g | вҲҖ x вҲҲ s, (toFun рқ”– f x, toFun рқ”– g x) вҲҲ V i} := by
  simp_rw [nhds_eq_comap_uniformity, UniformOnFun.uniformity_eq_of_basis _ _ h, comap_iInf,
    comap_principal, UniformOnFun.gen, preimage_setOf_eq]

protected theorem nhds_eq (f : Оұ вҶ’бөӨ[рқ”–] ОІ) :
    рқ“қ f = вЁ… s вҲҲ рқ”–, вЁ… V вҲҲ рқ“Ө ОІ, рқ“ҹ {g | вҲҖ x вҲҲ s, (toFun рқ”– f x, toFun рқ”– g x) вҲҲ V} :=
  UniformOnFun.nhds_eq_of_basis _ _ (рқ“Ө ОІ).basis_sets f

protected theorem gen_mem_nhds (f : Оұ вҶ’бөӨ[рқ”–] ОІ) (hs : s вҲҲ рқ”–) {V : Set (ОІ Г— ОІ)} (hV : V вҲҲ рқ“Ө ОІ) :
    {g | вҲҖ x вҲҲ s, (toFun рқ”– f x, toFun рқ”– g x) вҲҲ V} вҲҲ рқ“қ f := by
  rw [UniformOnFun.nhds_eq]
  apply_rules [mem_iInf_of_mem, mem_principal_self]

theorem uniformContinuous_ofUniformFun :
    UniformContinuous fun f : Оұ вҶ’бөӨ ОІ вҶҰ ofFun рқ”– (UniformFun.toFun f) := by
  simp only [UniformContinuous, UniformOnFun.uniformity_eq, tendsto_iInf, tendsto_principal,
    (UniformFun.hasBasis_uniformity _ _).eventually_iff]
  exact fun _ _ U hU вҶҰ вҹЁU, hU, fun f hf x _ вҶҰ hf xвҹ©

/-- The uniformity on `Оұ вҶ’бөӨ[рқ”–] ОІ` is the same as the uniformity on `Оұ вҶ’бөӨ ОІ`,
provided that `Set.univ вҲҲ рқ”–`.

Here we formulate it as a `UniformEquiv`. -/
def uniformEquivUniformFun (h : univ вҲҲ рқ”–) : (Оұ вҶ’бөӨ[рқ”–] ОІ) вүғбөӨ (Оұ вҶ’бөӨ ОІ) where
  toFun f := UniformFun.ofFun <| toFun _ f
  invFun f := ofFun _ <| UniformFun.toFun f
  left_inv _ := rfl
  right_inv _ := rfl
  uniformContinuous_toFun := by
    simp only [UniformContinuous, (UniformFun.hasBasis_uniformity _ _).tendsto_right_iff]
    intro U hU
    filter_upwards [UniformOnFun.gen_mem_uniformity _ _ h hU] with f hf x using hf x (mem_univ _)
  uniformContinuous_invFun := uniformContinuous_ofUniformFun _ _

/-- Let `uвӮҒ`, `uвӮӮ` be two uniform structures on `Оі` and `рқ”–вӮҒ рқ”–вӮӮ : Set (Set Оұ)`. If `uвӮҒ вүӨ uвӮӮ` and
`рқ”–вӮӮ вҠҶ рқ”–вӮҒ` then `рқ’ұ(Оұ, Оі, рқ”–вӮҒ, uвӮҒ) вүӨ рқ’ұ(Оұ, Оі, рқ”–вӮӮ, uвӮӮ)`. -/
protected theorem mono вҰғuвӮҒ uвӮӮ : UniformSpace ОівҰ„ (hu : uвӮҒ вүӨ uвӮӮ) вҰғрқ”–вӮҒ рқ”–вӮӮ : Set (Set Оұ)вҰ„
    (hрқ”– : рқ”–вӮӮ вҠҶ рқ”–вӮҒ) : рқ’ұ(Оұ, Оі, рқ”–вӮҒ, uвӮҒ) вүӨ рқ’ұ(Оұ, Оі, рқ”–вӮӮ, uвӮӮ) :=
  calc
    рқ’ұ(Оұ, Оі, рқ”–вӮҒ, uвӮҒ) вүӨ рқ’ұ(Оұ, Оі, рқ”–вӮӮ, uвӮҒ) := iInf_le_iInf_of_subset hрқ”–
    _ вүӨ рқ’ұ(Оұ, Оі, рқ”–вӮӮ, uвӮӮ) := iInfвӮӮ_mono fun _i _hi => UniformSpace.comap_mono <| UniformFun.mono hu

/-- If `x : Оұ` is in some `S вҲҲ рқ”–`, then evaluation at `x` is uniformly continuous on
`Оұ вҶ’бөӨ[рқ”–] ОІ`. -/
theorem uniformContinuous_eval_of_mem {x : Оұ} (hxs : x вҲҲ s) (hs : s вҲҲ рқ”–) :
    UniformContinuous ((Function.eval x : (Оұ вҶ’ ОІ) вҶ’ ОІ) вҲҳ toFun рқ”–) :=
  (UniformFun.uniformContinuous_eval ОІ (вҹЁx, hxsвҹ© : s)).comp
    (UniformOnFun.uniformContinuous_restrict Оұ ОІ рқ”– hs)

theorem uniformContinuous_eval_of_mem_sUnion {x : Оұ} (hx : x вҲҲ вӢғвӮҖ рқ”–) :
    UniformContinuous ((Function.eval x : (Оұ вҶ’ ОІ) вҶ’ ОІ) вҲҳ toFun рқ”–) :=
  let вҹЁ_s, hs, hxsвҹ© := hx
  uniformContinuous_eval_of_mem _ _ hxs hs

variable {ОІ} {рқ”–}

theorem uniformContinuous_eval (h : вӢғвӮҖ рқ”– = univ) (x : Оұ) :
    UniformContinuous ((Function.eval x : (Оұ вҶ’ ОІ) вҶ’ ОІ) вҲҳ toFun рқ”–) :=
  uniformContinuous_eval_of_mem_sUnion _ _ <| h.symm в–ё mem_univ _

/-- If `u` is a family of uniform structures on `Оі`, then
`рқ’ұ(Оұ, Оі, рқ”–, (вЁ… i, u i)) = вЁ… i, рқ’ұ(Оұ, Оі, рқ”–, u i)`. -/
protected theorem iInf_eq {u : О№ вҶ’ UniformSpace Оі} :
    рқ’ұ(Оұ, Оі, рқ”–, вЁ… i, u i) = вЁ… i, рқ’ұ(Оұ, Оі, рқ”–, u i) := by
  simp_rw [UniformOnFun.uniformSpace, UniformFun.iInf_eq, UniformSpace.comap_iInf]
  rw [iInf_comm]
  exact iInf_congr fun s => iInf_comm

/-- If `uвӮҒ` and `uвӮӮ` are two uniform structures on `Оі`, then
`рқ’ұ(Оұ, Оі, рқ”–, uвӮҒ вҠ“ uвӮӮ) = рқ’ұ(Оұ, Оі, рқ”–, uвӮҒ) вҠ“ рқ’ұ(Оұ, Оі, рқ”–, uвӮӮ)`. -/
protected theorem inf_eq {uвӮҒ uвӮӮ : UniformSpace Оі} :
    рқ’ұ(Оұ, Оі, рқ”–, uвӮҒ вҠ“ uвӮӮ) = рқ’ұ(Оұ, Оі, рқ”–, uвӮҒ) вҠ“ рқ’ұ(Оұ, Оі, рқ”–, uвӮӮ) := by
  rw [inf_eq_iInf, inf_eq_iInf, UniformOnFun.iInf_eq]
  refine iInf_congr fun i => ?_
  cases i <;> rfl

/-- If `u` is a uniform structure on `ОІ` and `f : Оі вҶ’ ОІ`, then
`рқ’ұ(Оұ, Оі, рқ”–, comap f u) = comap (fun g вҶҰ f вҲҳ g) рқ’ұ(Оұ, Оі, рқ”–, uвӮҒ)`. -/
protected theorem comap_eq {f : Оі вҶ’ ОІ} :
    рқ’ұ(Оұ, Оі, рқ”–, вҖ№UniformSpace ОІвҖә.comap f) = рқ’ұ(Оұ, ОІ, рқ”–, _).comap (f вҲҳ В·) := by
  -- We reduce this to `UniformFun.comap_eq` using the fact that `comap` distributes
  -- on `iInf`.
  simp_rw [UniformOnFun.uniformSpace, UniformSpace.comap_iInf, UniformFun.comap_eq, вҶҗ
    UniformSpace.comap_comap]
  -- By definition, `вҲҖ S вҲҲ рқ”–, (f вҲҳ вҖ”) вҲҳ S.restrict = S.restrict вҲҳ (f вҲҳ вҖ”)`.
  rfl

/-- Post-composition by a uniformly continuous function is uniformly continuous for the
uniform structures of `рқ”–`-convergence.

More precisely, if `f : Оі вҶ’ ОІ` is uniformly continuous, then
`(fun g вҶҰ f вҲҳ g) : (Оұ вҶ’бөӨ[рқ”–] Оі) вҶ’ (Оұ вҶ’бөӨ[рқ”–] ОІ)` is uniformly continuous. -/
protected theorem postcomp_uniformContinuous [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : UniformContinuous f) : UniformContinuous (ofFun рқ”– вҲҳ (f вҲҳ В·) вҲҳ toFun рқ”–) := by
  -- This is a direct consequence of `UniformOnFun.comap_eq`
  rw [uniformContinuous_iff]
  exact (UniformOnFun.mono (uniformContinuous_iff.mp hf) subset_rfl).trans_eq UniformOnFun.comap_eq

/-- Post-composition by a uniform inducing is a uniform inducing for the
uniform structures of `рқ”–`-convergence.

More precisely, if `f : Оі вҶ’ ОІ` is a uniform inducing, then
`(fun g вҶҰ f вҲҳ g) : (Оұ вҶ’бөӨ[рқ”–] Оі) вҶ’ (Оұ вҶ’бөӨ[рқ”–] ОІ)` is a uniform inducing. -/
lemma postcomp_isUniformInducing [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : IsUniformInducing f) : IsUniformInducing (ofFun рқ”– вҲҳ (f вҲҳ В·) вҲҳ toFun рқ”–) := by
  -- This is a direct consequence of `UniformOnFun.comap_eq`
  constructor
  replace hf : (рқ“Ө ОІ).comap (Prod.map f f) = _ := hf.comap_uniformity
  change comap (Prod.map (ofFun рқ”– вҲҳ (f вҲҳ В·) вҲҳ toFun рқ”–) (ofFun рқ”– вҲҳ (f вҲҳ В·) вҲҳ toFun рқ”–)) _ = _
  rw [вҶҗ uniformity_comap] at hf вҠў
  congr
  rw [вҶҗ UniformSpace.ext hf, UniformOnFun.comap_eq]
  rfl

@[deprecated (since := "2024-10-05")]
alias postcomp_uniformInducing := postcomp_isUniformInducing

/-- Post-composition by a uniform embedding is a uniform embedding for the
uniform structures of `рқ”–`-convergence.

More precisely, if `f : Оі вҶ’ ОІ` is a uniform embedding, then
`(fun g вҶҰ f вҲҳ g) : (Оұ вҶ’бөӨ[рқ”–] Оі) вҶ’ (Оұ вҶ’бөӨ[рқ”–] ОІ)` is a uniform embedding. -/
protected theorem postcomp_isUniformEmbedding [UniformSpace Оі] {f : Оі вҶ’ ОІ}
    (hf : IsUniformEmbedding f) : IsUniformEmbedding (ofFun рқ”– вҲҳ (f вҲҳ В·) вҲҳ toFun рқ”–) where
  toIsUniformInducing := UniformOnFun.postcomp_isUniformInducing hf.isUniformInducing
  injective _ _ H := funext fun _ вҶҰ hf.injective (congrFun H _)

@[deprecated (since := "2024-10-01")]
alias postcomp_uniformEmbedding := UniformOnFun.postcomp_isUniformEmbedding

/-- Turn a uniform isomorphism `Оі вүғбөӨ ОІ` into a uniform isomorphism `(Оұ вҶ’бөӨ[рқ”–] Оі) вүғбөӨ (Оұ вҶ’бөӨ[рқ”–] ОІ)`
by post-composing. -/
protected def congrRight [UniformSpace Оі] (e : Оі вүғбөӨ ОІ) : (Оұ вҶ’бөӨ[рқ”–] Оі) вүғбөӨ (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  { Equiv.piCongrRight fun _a => e.toEquiv with
    uniformContinuous_toFun := UniformOnFun.postcomp_uniformContinuous e.uniformContinuous
    uniformContinuous_invFun := UniformOnFun.postcomp_uniformContinuous e.symm.uniformContinuous }

/-- Let `f : Оі вҶ’ Оұ`, `рқ”– : Set (Set Оұ)`, `рқ”— : Set (Set Оі)`, and assume that `вҲҖ T вҲҲ рқ”—, f '' T вҲҲ рқ”–`.
Then, the function `(fun g вҶҰ g вҲҳ f) : (Оұ вҶ’бөӨ[рқ”–] ОІ) вҶ’ (Оі вҶ’бөӨ[рқ”—] ОІ)` is uniformly continuous.

Note that one can easily see that assuming `вҲҖ T вҲҲ рқ”—, вҲғ S вҲҲ рқ”–, f '' T вҠҶ S` would work too, but
we will get this for free when we prove that `рқ’ұ(Оұ, ОІ, рқ”–, uОІ) = рқ’ұ(Оұ, ОІ, рқ”–', uОІ)` where `рқ”–'` is the
***noncovering*** bornology generated by `рқ”–`. -/
protected theorem precomp_uniformContinuous {рқ”— : Set (Set Оі)} {f : Оі вҶ’ Оұ}
    (hf : MapsTo (f '' В·) рқ”— рқ”–) :
    UniformContinuous fun g : Оұ вҶ’бөӨ[рқ”–] ОІ => ofFun рқ”— (toFun рқ”– g вҲҳ f) := by
  -- This follows from the fact that `(В· вҲҳ f) Г— (В· вҲҳ f)` maps `gen (f '' t) V` to `gen t V`.
  simp_rw [UniformContinuous, UniformOnFun.uniformity_eq, tendsto_iInf]
  refine fun t ht V hV вҶҰ tendsto_iInf' (f '' t) <| tendsto_iInf' (hf ht) <|
    tendsto_iInf' V <| tendsto_iInf' hV ?_
  simpa only [tendsto_principal_principal, UniformOnFun.gen] using fun _ вҶҰ forall_mem_image.1

/-- Turn a bijection `e : Оі вүғ Оұ` such that we have both `вҲҖ T вҲҲ рқ”—, e '' T вҲҲ рқ”–` and
`вҲҖ S вҲҲ рқ”–, e вҒ»В№' S вҲҲ рқ”—` into a uniform isomorphism `(Оі вҶ’бөӨ[рқ”—] ОІ) вүғбөӨ (Оұ вҶ’бөӨ[рқ”–] ОІ)` by pre-composing. -/
protected def congrLeft {рқ”— : Set (Set Оі)} (e : Оі вүғ Оұ) (he : рқ”— вҠҶ image e вҒ»В№' рқ”–)
    (he' : рқ”– вҠҶ preimage e вҒ»В№' рқ”—) : (Оі вҶ’бөӨ[рқ”—] ОІ) вүғбөӨ (Оұ вҶ’бөӨ[рқ”–] ОІ) :=
  { Equiv.arrowCongr e (Equiv.refl _) with
    uniformContinuous_toFun := UniformOnFun.precomp_uniformContinuous fun s hs вҶҰ by
      change e.symm '' s вҲҲ рқ”—
      rw [вҶҗ preimage_equiv_eq_image_symm]
      exact he' hs
    uniformContinuous_invFun := UniformOnFun.precomp_uniformContinuous he }

/-- If `рқ”–` covers `Оұ`, then the topology of `рқ”–`-convergence is TвӮӮ. -/
theorem t2Space_of_covering [T2Space ОІ] (h : вӢғвӮҖ рқ”– = univ) : T2Space (Оұ вҶ’бөӨ[рқ”–] ОІ) where
  t2 f g hfg := by
    obtain вҹЁx, hxвҹ© := not_forall.mp (mt funext hfg)
    obtain вҹЁs, hs, hxsвҹ© : вҲғ s вҲҲ рқ”–, x вҲҲ s := mem_sUnion.mp (h.symm в–ё True.intro)
    exact separated_by_continuous (uniformContinuous_eval_of_mem ОІ рқ”– hxs hs).continuous hx

/-- The restriction map from `Оұ вҶ’бөӨ[рқ”–] ОІ` to `вӢғвӮҖ рқ”– вҶ’ ОІ` is uniformly continuous. -/
theorem uniformContinuous_restrict_toFun :
    UniformContinuous ((вӢғвӮҖ рқ”–).restrict вҲҳ toFun рқ”– : (Оұ вҶ’бөӨ[рқ”–] ОІ) вҶ’ вӢғвӮҖ рқ”– вҶ’ ОІ) := by
  rw [uniformContinuous_pi]
  intro вҹЁx, hxвҹ©
  obtain вҹЁs : Set Оұ, hs : s вҲҲ рқ”–, hxs : x вҲҲ sвҹ© := mem_sUnion.mpr hx
  exact uniformContinuous_eval_of_mem ОІ рқ”– hxs hs

/-- If `рқ”–` covers `Оұ`, the natural map `UniformOnFun.toFun` from `Оұ вҶ’бөӨ[рқ”–] ОІ` to `Оұ вҶ’ ОІ` is
uniformly continuous.

In other words, if `рқ”–` covers `Оұ`, then the uniform structure of `рқ”–`-convergence is finer than
that of pointwise convergence. -/
protected theorem uniformContinuous_toFun (h : вӢғвӮҖ рқ”– = univ) :
    UniformContinuous (toFun рқ”– : (Оұ вҶ’бөӨ[рқ”–] ОІ) вҶ’ Оұ вҶ’ ОІ) := by
  rw [uniformContinuous_pi]
  exact uniformContinuous_eval h

/-- If `f : Оұ вҶ’бөӨ[рқ”–] ОІ` is continuous at `x` and `x` admits a neighbourhood `V вҲҲ рқ”–`,
then evaluation of `g : Оұ вҶ’бөӨ[рқ”–] ОІ` at `y : Оұ` is continuous in `(g, y)` at `(f, x)`. -/
protected theorem continuousAt_evalвӮӮ [TopologicalSpace Оұ] {f : Оұ вҶ’бөӨ[рқ”–] ОІ} {x : Оұ}
    (hрқ”– : вҲғ V вҲҲ рқ”–, V вҲҲ рқ“қ x) (hc : ContinuousAt (toFun рқ”– f) x) :
    ContinuousAt (fun fx : (Оұ вҶ’бөӨ[рқ”–] ОІ) Г— Оұ вҶҰ toFun рқ”– fx.1 fx.2) (f, x) := by
  rw [ContinuousAt, nhds_eq_comap_uniformity, tendsto_comap_iff, вҶҗ lift'_comp_uniformity,
    tendsto_lift']
  intro U hU
  rcases hрқ”– with вҹЁV, hV, hVxвҹ©
  filter_upwards [prod_mem_nhds (UniformOnFun.gen_mem_nhds _ _ _ hV hU)
    (inter_mem hVx <| hc <| UniformSpace.ball_mem_nhds _ hU)]
    with вҹЁg, yвҹ© вҹЁhg, hyV, hyвҹ© using вҹЁtoFun рқ”– f y, hy, hg y hyVвҹ©

/-- If each point of `Оұ` admits a neighbourhood `V вҲҲ рқ”–`,
then the evaluation of `f : Оұ вҶ’бөӨ[рқ”–] ОІ` at `x : Оұ` is continuous in `(f, x)`
on the set of `(f, x)` such that `f` is continuous at `x`. -/
protected theorem continuousOn_evalвӮӮ [TopologicalSpace Оұ] (hрқ”– : вҲҖ x, вҲғ V вҲҲ рқ”–, V вҲҲ рқ“қ x) :
    ContinuousOn (fun fx : (Оұ вҶ’бөӨ[рқ”–] ОІ) Г— Оұ вҶҰ toFun рқ”– fx.1 fx.2)
      {fx | ContinuousAt (toFun рқ”– fx.1) fx.2} := fun (_f, x) hc вҶҰ
  (UniformOnFun.continuousAt_evalвӮӮ (hрқ”– x) hc).continuousWithinAt

/-- Convergence in the topology of `рқ”–`-convergence means uniform convergence on `S` (in the sense
of `TendstoUniformlyOn`) for all `S вҲҲ рқ”–`. -/
protected theorem tendsto_iff_tendstoUniformlyOn {F : О№ вҶ’ Оұ вҶ’бөӨ[рқ”–] ОІ} {f : Оұ вҶ’бөӨ[рқ”–] ОІ} :
    Tendsto F p (рқ“қ f) вҶ” вҲҖ s вҲҲ рқ”–, TendstoUniformlyOn (toFun рқ”– вҲҳ F) (toFun рқ”– f) p s := by
  simp only [UniformOnFun.nhds_eq, tendsto_iInf, tendsto_principal, TendstoUniformlyOn,
    Function.comp_apply, mem_setOf]

protected lemma continuous_rng_iff {X : Type*} [TopologicalSpace X] {f : X вҶ’ (Оұ вҶ’бөӨ[рқ”–] ОІ)} :
    Continuous f вҶ” вҲҖ s вҲҲ рқ”–,
      Continuous (UniformFun.ofFun вҲҳ s.restrict вҲҳ UniformOnFun.toFun рқ”– вҲҳ f) := by
  simp only [continuous_iff_continuousAt, ContinuousAt,
    UniformOnFun.tendsto_iff_tendstoUniformlyOn, UniformFun.tendsto_iff_tendstoUniformly,
    tendstoUniformlyOn_iff_tendstoUniformly_comp_coe, @forall_swap X, Function.comp_apply,
    Function.comp_def, restrict_eq, UniformFun.toFun_ofFun]

instance [CompleteSpace ОІ] : CompleteSpace (Оұ вҶ’бөӨ[рқ”–] ОІ) := by
  rcases isEmpty_or_nonempty ОІ
  В· infer_instance
  В· refine вҹЁfun {F} hF вҶҰ ?_вҹ©
    have := hF.1
    have : вҲҖ x вҲҲ вӢғвӮҖ рқ”–, вҲғ y : ОІ, Tendsto (toFun рқ”– В· x) F (рқ“қ y) := fun x hx вҶҰ
      CompleteSpace.complete (hF.map (uniformContinuous_eval_of_mem_sUnion _ _ hx))
    choose! g hg using this
    use ofFun рқ”– g
    simp_rw [UniformOnFun.nhds_eq_of_basis _ _ uniformity_hasBasis_closed, le_iInfвӮӮ_iff,
      le_principal_iff]
    intro s hs U вҹЁhU, hUcвҹ©
    rcases cauchy_iff.mp hF |>.2 _ <| UniformOnFun.gen_mem_uniformity _ _ hs hU
      with вҹЁV, hV, hVUвҹ©
    filter_upwards [hV] with f hf x hx
    refine hUc.mem_of_tendsto ((hg x вҹЁs, hs, hxвҹ©).prod_mk_nhds tendsto_const_nhds) ?_
    filter_upwards [hV] with g' hg' using hVU (mk_mem_prod hg' hf) _ hx

/-- The natural bijection between `Оұ вҶ’ ОІ Г— Оі` and `(Оұ вҶ’ ОІ) Г— (Оұ вҶ’ Оі)`, upgraded to a uniform
isomorphism between `Оұ вҶ’бөӨ[рқ”–] ОІ Г— Оі` and `(Оұ вҶ’бөӨ[рқ”–] ОІ) Г— (Оұ вҶ’бөӨ[рқ”–] Оі)`. -/
protected def uniformEquivProdArrow [UniformSpace Оі] :
    (Оұ вҶ’бөӨ[рқ”–] ОІ Г— Оі) вүғбөӨ (Оұ вҶ’бөӨ[рқ”–] ОІ) Г— (Оұ вҶ’бөӨ[рқ”–] Оі) :=
  -- Denote `ПҶ` this bijection. We want to show that
  -- `comap ПҶ (рқ’ұ(Оұ, ОІ, рқ”–, uОІ) Г— рқ’ұ(Оұ, Оі, рқ”–, uОі)) = рқ’ұ(Оұ, ОІ Г— Оі, рқ”–, uОІ Г— uОі)`.
  -- But `uОІ Г— uОі` is defined as `comap fst uОІ вҠ“ comap snd uОі`, so we just have to apply
  -- `UniformOnFun.inf_eq` and `UniformOnFun.comap_eq`,
  -- which leaves us to check that some square commutes.
  -- We could also deduce this from `UniformFun.uniformEquivProdArrow`,
  -- but it turns out to be more annoying.
  ((UniformOnFun.ofFun рқ”–).symm.trans <| (Equiv.arrowProdEquivProdArrow _ _ _).trans <|
    (UniformOnFun.ofFun рқ”–).prodCongr (UniformOnFun.ofFun рқ”–)).toUniformEquivOfIsUniformInducing <| by
      constructor
      rw [uniformity_prod, comap_inf, comap_comap, comap_comap]
      have H := @UniformOnFun.inf_eq Оұ (ОІ Г— Оі) рқ”–
        (UniformSpace.comap Prod.fst вҖ№_вҖә) (UniformSpace.comap Prod.snd вҖ№_вҖә)
      apply_fun (fun u вҶҰ @uniformity (Оұ вҶ’бөӨ[рқ”–] ОІ Г— Оі) u) at H
      convert H.symm using 1
      rw [UniformOnFun.comap_eq, UniformOnFun.comap_eq]
      erw [inf_uniformity]
      rw [uniformity_comap, uniformity_comap]
      rfl
-- the relevant diagram commutes by definition

variable (рқ”–) (Оҙ : О№ вҶ’ Type*) [вҲҖ i, UniformSpace (Оҙ i)] in
/-- The natural bijection between `Оұ вҶ’ О  i, Оҙ i` and `О  i, Оұ вҶ’ Оҙ i`, upgraded to a uniform
isomorphism between `Оұ вҶ’бөӨ[рқ”–] (О  i, Оҙ i)` and `О  i, Оұ вҶ’бөӨ[рқ”–] Оҙ i`. -/
protected def uniformEquivPiComm : (Оұ вҶ’бөӨ[рқ”–] ((i : О№) вҶ’ Оҙ i)) вүғбөӨ ((i : О№) вҶ’ Оұ вҶ’бөӨ[рқ”–] Оҙ i) :=
  -- Denote `ПҶ` this bijection. We want to show that
  -- `comap ПҶ (О  i, рқ’ұ(Оұ, Оҙ i, рқ”–, uОҙ i)) = рқ’ұ(Оұ, (О  i, Оҙ i), рқ”–, (О  i, uОҙ i))`.
  -- But `О  i, uОҙ i` is defined as `вЁ… i, comap (eval i) (uОҙ i)`, so we just have to apply
  -- `UniformOnFun.iInf_eq` and `UniformOnFun.comap_eq`,
  -- which leaves us to check that some square commutes.
  -- We could also deduce this from `UniformFun.uniformEquivPiComm`, but it turns out
  -- to be more annoying.
  @Equiv.toUniformEquivOfIsUniformInducing (Оұ вҶ’бөӨ[рқ”–] ((i : О№) вҶ’ Оҙ i)) ((i : О№) вҶ’ Оұ вҶ’бөӨ[рқ”–] Оҙ i)
      _ _ (Equiv.piComm _) <| by
    constructor
    change comap (Prod.map Function.swap Function.swap) _ = _
    erw [вҶҗ uniformity_comap]
    congr
    rw [Pi.uniformSpace, UniformSpace.ofCoreEq_toCore, Pi.uniformSpace,
      UniformSpace.ofCoreEq_toCore, UniformSpace.comap_iInf, UniformOnFun.iInf_eq]
    refine iInf_congr fun i => ?_
    rw [вҶҗ UniformSpace.comap_comap, UniformOnFun.comap_eq]
    rfl
-- Like in the previous lemma, the diagram actually commutes by definition

/-- Suppose that the topology on `Оұ` is defined by its restrictions to the sets of `рқ”–`.

Then the set of continuous functions is closed
in the topology of uniform convergence on the sets of `рқ”–`. -/
theorem isClosed_setOf_continuous [TopologicalSpace Оұ] (h : IsRestrictGen рқ”–) :
    IsClosed {f : Оұ вҶ’бөӨ[рқ”–] ОІ | Continuous (toFun рқ”– f)} := by
  refine isClosed_iff_forall_filter.2 fun f u _ hu huf вҶҰ h.continuous_iff.2 fun s hs вҶҰ ?_
  rw [вҶҗ tendsto_id', UniformOnFun.tendsto_iff_tendstoUniformlyOn] at huf
  exact (huf s hs).continuousOn <| hu fun _ вҶҰ Continuous.continuousOn

variable (рқ”–) in
theorem uniformSpace_eq_inf_precomp_of_cover {ОҙвӮҒ ОҙвӮӮ : Type*} (ПҶвӮҒ : ОҙвӮҒ вҶ’ Оұ) (ПҶвӮӮ : ОҙвӮӮ вҶ’ Оұ)
    (рқ”—вӮҒ : Set (Set ОҙвӮҒ)) (рқ”—вӮӮ : Set (Set ОҙвӮӮ))
    (h_imageвӮҒ : MapsTo (ПҶвӮҒ '' В·) рқ”—вӮҒ рқ”–) (h_imageвӮӮ : MapsTo (ПҶвӮӮ '' В·) рқ”—вӮӮ рқ”–)
    (h_preimageвӮҒ : MapsTo (ПҶвӮҒ вҒ»В№' В·) рқ”– рқ”—вӮҒ) (h_preimageвӮӮ : MapsTo (ПҶвӮӮ вҒ»В№' В·) рқ”– рқ”—вӮӮ)
    (h_cover : вҲҖ S вҲҲ рқ”–, S вҠҶ range ПҶвӮҒ вҲӘ range ПҶвӮӮ) :
    рқ’ұ(Оұ, ОІ, рқ”–, _) =
      .comap (ofFun рқ”—вӮҒ вҲҳ (В· вҲҳ ПҶвӮҒ) вҲҳ toFun рқ”–) рқ’ұ(ОҙвӮҒ, ОІ, рқ”—вӮҒ, _) вҠ“
      .comap (ofFun рқ”—вӮӮ вҲҳ (В· вҲҳ ПҶвӮӮ) вҲҳ toFun рқ”–) рқ’ұ(ОҙвӮӮ, ОІ, рқ”—вӮӮ, _) := by
  set ПҲвӮҒ : О  S : Set Оұ, ПҶвӮҒ вҒ»В№' S вҶ’ S := fun S вҶҰ S.restrictPreimage ПҶвӮҒ
  set ПҲвӮӮ : О  S : Set Оұ, ПҶвӮӮ вҒ»В№' S вҶ’ S := fun S вҶҰ S.restrictPreimage ПҶвӮӮ
  have : вҲҖ S вҲҲ рқ”–, рқ’°(S, ОІ, _) = .comap (В· вҲҳ ПҲвӮҒ S) рқ’°(_, ОІ, _) вҠ“ .comap (В· вҲҳ ПҲвӮӮ S) рқ’°(_, ОІ, _) := by
    refine fun S hS вҶҰ UniformFun.uniformSpace_eq_inf_precomp_of_cover ОІ _ _ ?_
    simpa only [вҶҗ univ_subset_iff, ПҲвӮҒ, ПҲвӮӮ, range_restrictPreimage, вҶҗ preimage_union,
      вҶҗ image_subset_iff, image_univ, Subtype.range_val] using h_cover S hS
  refine le_antisymm (le_inf ?_ ?_) (le_iInfвӮӮ fun S hS вҶҰ ?_)
  В· rw [вҶҗ uniformContinuous_iff]
    exact UniformOnFun.precomp_uniformContinuous h_imageвӮҒ
  В· rw [вҶҗ uniformContinuous_iff]
    exact UniformOnFun.precomp_uniformContinuous h_imageвӮӮ
  В· simp_rw [this S hS, UniformSpace.comap_iInf, UniformSpace.comap_inf, вҶҗ UniformSpace.comap_comap]
    exact inf_le_inf
      (iInfвӮӮ_le_of_le _ (h_preimageвӮҒ hS) le_rfl)
      (iInfвӮӮ_le_of_le _ (h_preimageвӮӮ hS) le_rfl)

variable (рқ”–) in
theorem uniformSpace_eq_iInf_precomp_of_cover {Оҙ : О№ вҶ’ Type*} (ПҶ : О  i, Оҙ i вҶ’ Оұ)
    (рқ”— : вҲҖ i, Set (Set (Оҙ i))) (h_image : вҲҖ i, MapsTo (ПҶ i '' В·) (рқ”— i) рқ”–)
    (h_preimage : вҲҖ i, MapsTo (ПҶ i вҒ»В№' В·) рқ”– (рқ”— i))
    (h_cover : вҲҖ S вҲҲ рқ”–, вҲғ I : Set О№, I.Finite вҲ§ S вҠҶ вӢғ i вҲҲ I, range (ПҶ i)) :
    рқ’ұ(Оұ, ОІ, рқ”–, _) = вЁ… i, .comap (ofFun (рқ”— i) вҲҳ (В· вҲҳ ПҶ i) вҲҳ toFun рқ”–) рқ’ұ(Оҙ i, ОІ, рқ”— i, _) := by
  set ПҲ : О  S : Set Оұ, О  i : О№, (ПҶ i) вҒ»В№' S вҶ’ S := fun S i вҶҰ S.restrictPreimage (ПҶ i)
  have : вҲҖ S вҲҲ рқ”–, рқ’°(S, ОІ, _) = вЁ… i, .comap (В· вҲҳ ПҲ S i) рқ’°(_, ОІ, _) := fun S hS вҶҰ by
    rcases h_cover S hS with вҹЁI, I_finite, I_coverвҹ©
    refine UniformFun.uniformSpace_eq_iInf_precomp_of_cover ОІ _ вҹЁI, I_finite, ?_вҹ©
    simpa only [вҶҗ univ_subset_iff, ПҲ, range_restrictPreimage, вҶҗ preimage_iUnionвӮӮ,
      вҶҗ image_subset_iff, image_univ, Subtype.range_val] using I_cover
  -- With a better theory of ideals we may be able to simplify the following by replacing `рқ”— i`
  -- by `(ПҶ i вҒ»В№' В·) '' рқ”–`.
  refine le_antisymm (le_iInf fun i вҶҰ ?_) (le_iInfвӮӮ fun S hS вҶҰ ?_)
  В· rw [вҶҗ uniformContinuous_iff]
    exact UniformOnFun.precomp_uniformContinuous (h_image i)
  В· simp_rw [this S hS, UniformSpace.comap_iInf, вҶҗ UniformSpace.comap_comap]
    exact iInf_mono fun i вҶҰ iInfвӮӮ_le_of_le _ (h_preimage i hS) le_rfl

end UniformOnFun

namespace UniformFun

instance {Оұ ОІ : Type*} [UniformSpace ОІ] [CompleteSpace ОІ] : CompleteSpace (Оұ вҶ’бөӨ ОІ) :=
  (UniformOnFun.uniformEquivUniformFun ОІ {univ} (mem_singleton _)).completeSpace_iff.1 inferInstance

end UniformFun

section UniformComposition

variable {Оұ ОІ Оі О№ : Type*} [UniformSpace ОІ] [UniformSpace Оі] {p : Filter О№}

/-- Composing on the left by a uniformly continuous function preserves uniform convergence -/
theorem UniformContinuousOn.comp_tendstoUniformly (s : Set ОІ) (F : О№ вҶ’ Оұ вҶ’ ОІ) (f : Оұ вҶ’ ОІ)
    (hF : вҲҖ i x, F i x вҲҲ s) (hf : вҲҖ x, f x вҲҲ s)
    {g : ОІ вҶ’ Оі} (hg : UniformContinuousOn g s) (h : TendstoUniformly F f p) :
    TendstoUniformly (fun i x => g (F i x)) (fun x => g (f x)) p := by
  rw [uniformContinuousOn_iff_restrict] at hg
  lift F to О№ вҶ’ Оұ вҶ’ s using hF with F' hF'
  lift f to Оұ вҶ’ s using hf with f' hf'
  rw [tendstoUniformly_iff_tendsto] at h
  have : Tendsto (fun q : О№ Г— Оұ вҶҰ (f' q.2, (F' q.1 q.2))) (p Г—Лў вҠӨ) (рқ“Ө s) :=
    h.of_tendsto_comp isUniformEmbedding_subtype_val.comap_uniformity.le
  apply UniformContinuous.comp_tendstoUniformly hg ?_
  rwa [вҶҗ tendstoUniformly_iff_tendsto] at this

theorem UniformContinuousOn.comp_tendstoUniformly_eventually (s : Set ОІ) (F : О№ вҶ’ Оұ вҶ’ ОІ) (f : Оұ вҶ’ ОІ)
    (hF : вҲҖб¶  i in p, вҲҖ x, F i x вҲҲ s) (hf : вҲҖ x, f x вҲҲ s)
    {g : ОІ вҶ’ Оі} (hg : UniformContinuousOn g s) (h : TendstoUniformly F f p) :
    TendstoUniformly (fun i => fun x => g (F i x)) (fun x => g (f x)) p := by
  classical
  rw [eventually_iff_exists_mem] at hF
  obtain вҹЁs', hs', hsвҹ© := hF
  let F' : О№ вҶ’ Оұ вҶ’ ОІ := fun (i : О№) x => if i вҲҲ s' then F i x else f x
  have hF : F =б¶ [p] F' :=  by
    rw [eventuallyEq_iff_exists_mem]
    refine вҹЁs', hs', fun y hy => by aesopвҹ©
  have h' : TendstoUniformly F' f p := by
    rwa [tendstoUniformly_congr hF] at h
  apply (tendstoUniformly_congr _).mpr
    (UniformContinuousOn.comp_tendstoUniformly s F' f (by aesop) hf hg h')
  rw [eventuallyEq_iff_exists_mem]
  refine вҹЁs', hs', fun i hi => by aesopвҹ©

end UniformComposition
