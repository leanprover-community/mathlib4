/-!
# Zero Outside Presheaf

Given an open subset `U` of `X` and a sheaf `F` on `X`, the zero outside `U` presheaf is the
presheaf that agrees with `F` on `U` and is zero on any open not contained in `U`. It is isomorphic
to the presheaf obtained by pulling back to `U` then doing extension by zero, but can be easier to
work with since it is equal to `F` on `U` and not just isomorphic.

## Main definitions

* `TopCat.Presheaf.zeroOutside`: The presheaf that is equal to `F` on `U` and zero on everything
  else.

* `TopCat.Sheaf.zeroOutsideInt`: This is the sheafification of the constant sheaf of abelian groups
  that is `ℤ` everywhere.

* `TopCat.Sheaf.zeroOutsideInt.sHom`: If `F` is a sheaf of abelian groups and `s` is a section of
  `F(U)`, then `sHom` is a morphism from `zeroOutsideInt U` to `F` that maps `1` to `s`. This can
  be used to define the subsheaf generated by a section as the image of this morphism.

-/

@[expose] public section

universe u v w

noncomputable section

open CategoryTheory Limits TopologicalSpace Opposite ZeroObject ConcreteCategory
open scoped AlgebraicGeometry

variable {X : TopCat.{u}} (U : Opens X)

namespace TopCat

namespace Presheaf

section

variable {C : Type v} [Category.{w} C] [HasZeroObject C] (F : Presheaf C X)

open Classical in
/-- Given a presheaf `F` and an open subset `U`, the presheaf `F.zeroOutside U` is the functor
that sends an open `V` to `F(V)` when `V ≤ U` and `0` otherwise. The restriction maps are the ones
from `F` when both subsets are contained in `U` and are `0` otherwise. We use `eqToHom` when
defining the maps to avoid dependent type theory headaches. -/
@[simps]
def zeroOutside : Presheaf C X where
  obj W := if (unop W) ≤ U then F.obj W else 0
  map {W X} i :=
    if h : (unop W) ≤ U then
      eqToHom (by grind) ≫ F.map i ≫ eqToHom (by rw [if_pos (le_trans (leOfHom i.unop) h)])
    else ((if_neg h).symm.ndrec (isZero_zero C)).to_ _
  map_id W := by
    split_ifs with h
    · simp
    apply IsZero.to_eq
  map_comp {W X Y} iWX iXY := by
    split_ifs with h
    · have := (le_trans (leOfHom iWX.unop) h)
      simp_all
    apply IsZero.to_eq

variable {U}

lemma zeroOutside_isZero {W : Opens X} (h : ¬W ≤ U) : IsZero <| (zeroOutside U F).obj (op W) := by
  simp_all [isZero_zero C]

lemma zeroOutside_le {W : Opens X} (h : W ≤ U) : (zeroOutside U F).obj (op W) = F.obj (op W) := by
  simp_all

variable {V : Opens X} (h : V ≤ U)

open Classical in
/-- Given an inclusion of open sets `V ≤ U`, we get a morphism `F.zeroOutside V ⟶ F.zeroOutside U`
which is the identity on sections of `W` when `W ≤ V` and it `0` otherwise -/
@[simps]
def zeroOutside_openHom : F.zeroOutside V ⟶ F.zeroOutside U where
  app W := if hW : (unop W) ≤ V then
    eqToHom (by rw [F.zeroOutside_le hW, F.zeroOutside_le (le_trans hW h)])
    else (F.zeroOutside_isZero hW).to_ _
  naturality {W X} i := by
    by_cases hWV : (unop W) ≤ V
    · have hXV := (le_trans (leOfHom i.unop) hWV)
      have := le_trans hXV h
      have := le_trans hWV h
      simp_all
    apply (F.zeroOutside_isZero hWV).eq_of_src

variable [HasPullbacks C]

instance zeroOutside_hom_mono : Mono (F.zeroOutside_openHom h) := by
  erw [NatTrans.mono_iff_mono_app]
  intro W
  by_cases hWV : (unop W) ≤ V
  · have := le_trans hWV h
    simp_all [IsIso.mono_of_iso]
  simp_all [IsZero.mono, isZero_zero C]

end

open AddCommGrpCat

/-- The constant presheaf that assigns `ℤ` to every open -/
abbrev constZ : Presheaf AddCommGrpCat.{u} X := (Functor.const _).obj (AddCommGrpCat.of (ULift ℤ))

namespace zeroOutside

/-- `1` as a section of `constZ.zeroOutside U` -/
def generator : (constZ.zeroOutside U).obj (op U) :=
  (eqToHom (by simp) : (AddCommGrpCat.of (ULift ℤ)) ⟶ (constZ.zeroOutside U).obj (op U)) 1

variable {U}

set_option backward.isDefEq.respectTransparency false in
open Classical in
/-- Section hom: Given a section `s` of `F` on `U`, we obtain a presheaf morphism
`constZ.zeroOutside U ⟶ F` that maps `generator U` to `s` -/
@[simps]
def sHom {F : Presheaf AddCommGrpCat.{u} X} (s : F.obj (op U)) :
    constZ.zeroOutside U ⟶ F where
  app {W} :=
    if h : (unop W) ≤ U then
      eqToHom (by simp_all) ≫ (uliftZMultiplesAddEquiv (F.obj W)).symm (F.map (homOfLE h).op s)
      else 0
  naturality {W X} i := by
    by_cases h : (unop W) ≤ U
    · have := le_trans (leOfHom i.unop) h
      simp_all only [zeroOutside_map, ↓reduceDIte, Functor.const_obj_map,
        uliftZMultiplesAddEquiv, homAddEquiv, homEquiv, AddEquiv.mk']
      ext
      simp only [zeroOutside_obj, Functor.const_obj_obj, Category.id_comp, eqToHom_trans,
        AddEquiv.symm_mk, op_unop, homOfLE_leOfHom, AddEquiv.symm_trans_apply, Equiv.symm_symm,
        AddEquiv.coe_mk, Equiv.coe_fn_symm_mk, eqToHom_trans_assoc, AddCommGrpCat.hom_comp,
        AddCommGrpCat.hom_ofHom, AddMonoidHom.coe_comp, Function.comp_apply,
        uliftZMultiplesHom_apply_apply, Category.assoc, map_zsmul, ← comp_apply, ← F.map_comp]
      congr
    have : IsZero ((constZ.zeroOutside U).obj W) := by
      simp_all [isZero_zero]
    apply this.eq_of_src

set_option backward.isDefEq.respectTransparency false in
theorem sHom_app_generator {F : Presheaf AddCommGrpCat.{u} X}
    (s : F.obj (op U)) : (sHom s).app (op U) (generator U) = s := by
  simp [generator, ← comp_apply, uliftZMultiplesAddEquiv, homAddEquiv, AddEquiv.mk',
    homEquiv, uliftZMultiplesHom, AddEquiv.ulift]

set_option backward.isDefEq.respectTransparency false in
theorem openHom_generator {V : Opens X} (h : V ≤ U) :
    (zeroOutside_openHom constZ h).app (op V) (generator V) = (generator U) |_ V := by
  simp [generator, Presheaf.restrictOpen, Presheaf.restrict, ← comp_apply]

end zeroOutside

end Presheaf

namespace Sheaf

/-- The sheafification of `constZ.zeroOutside U` -/
def zeroOutsideInt : Sheaf AddCommGrpCat.{u} X :=
  (presheafToSheaf _ _).obj (Presheaf.constZ.zeroOutside U)

namespace zeroOutsideInt

/-- `1` as a section of `zeroOutsideInt U` -/
def generator : (zeroOutsideInt U).presheaf.obj (op U) :=
  (toSheafify _ (Presheaf.constZ.zeroOutside U)).app (op U) (Presheaf.zeroOutside.generator U)

variable {U}

/-- The sheafification of `zeroOutside_openHom` applied to `constZ.zeroOutside U` -/
@[simps]
def openHom {V : Opens X} (h : V ≤ U) : zeroOutsideInt V ⟶ zeroOutsideInt U where
  hom := sheafifyMap _ (Presheaf.zeroOutside_openHom Presheaf.constZ h)

set_option backward.isDefEq.respectTransparency false in
theorem openHom_generator {V : Opens X} (h : V ≤ U) :
    (openHom h).hom.app (op V) (generator V) = (generator U) |_ V := by
  simp only [openHom, generator, Presheaf.zeroOutside_obj, Functor.const_obj_obj]
  erw [← ConcreteCategory.comp_apply, ← NatTrans.comp_app, ← toSheafify_naturality,
    NatTrans.comp_app, ConcreteCategory.comp_apply, Presheaf.zeroOutside.openHom_generator,
    Presheaf.map_restrict]
  rfl

set_option backward.isDefEq.respectTransparency false in
instance {V : Opens X} (h : V ≤ U) :
    Mono (openHom h) := by
  have := Presheaf.zeroOutside_hom_mono ((Functor.const _).obj (AddCommGrpCat.of (ULift.{u,0} ℤ))) h
  delta openHom
  apply Functor.map_mono (presheafToSheaf _ _)

/-- The induced map on `zeroOutsideInt U` coming from `Presheaf.zeroOutside.sHom` -/
@[simps]
def sHom {F : Sheaf AddCommGrpCat.{u} X} (s : F.presheaf.obj (op U)) :
    zeroOutsideInt U ⟶ F where
  hom := sheafifyLift _ (Presheaf.zeroOutside.sHom s) F.property

theorem sHom_app_generator {F : Sheaf AddCommGrpCat.{u} X}
    (s : F.presheaf.obj (op U)) : (sHom s).hom.app (op U) (generator U) = s := by
  delta generator
  erw [sHom_hom, ← ConcreteCategory.comp_apply, ← NatTrans.comp_app, toSheafify_sheafifyLift]
  exact Presheaf.zeroOutside.sHom_app_generator s

end zeroOutsideInt

open zeroOutsideInt

theorem epi_map_of_injective (I : Sheaf AddCommGrpCat.{u} X) [Injective I] {U V : Opens X}
    (h : V ≤ U) : Epi (I.presheaf.map (homOfLE h).op) := by
  rw [AddCommGrpCat.epi_iff_surjective]
  intro s
  let f := Injective.factorThru (sHom s) (openHom h)
  use f.hom.app (op U) (generator U)
  change f.hom.app (op U) (generator U) |_ V = s
  rw [← Presheaf.map_restrict, ← openHom_generator]
  change (openHom h ≫ f).hom.app (op V) (generator V) = s
  rw [Injective.comp_factorThru, sHom_app_generator]

end Sheaf

end TopCat
