module

public import Mathlib.Topology.Baire.Lemmas
public import Mathlib.Topology.Algebra.ConstMulAction
public import Mathlib.Topology.Bornology.Absorbs

/-!
# Absorbent sets in Baire spaces

At the heart of the open mapping theorem (see `ContinuousLinearMap.isOpenMap`), there is the
statement that a closed subset of a nonempty Baire space has a nonempty interior if the whole space
can be written as the union of images of that set under a countable collection of homeomorphisms.

In the case of the open mapping theorem for Banach spaces, the homeomorphisms are dilates by scalar
multiples, but this setup applies more generally.

## Main Theorems

* `IsClosed.interior_nonempty_of_iUnion`: A closed subset of a Baire space has a nonempty interior
  if the whole space can be written as the union of a countable number of images under
  homeomorphisms
* `IsClosed.interior_nonempty_of_contraction`: A specialization of
  `IsClosed.interior_nonempty_of_iUnion` when the underlying space `E` admits a "contraction" `α`,
   i.e., a homeomorphism `α : E =ₜ E` such that `∀ x : E, ∃ n : ℕ, (α ^ n) x ∈ s`.
* `Absorbent.interior_nonempty`: When the space `E` admits a continuous action by a group `G₀` with
  zero which, as a bornology, has a countably generated `cobounded` filter, then any `Absorbent` set
  has nonempty interior. In the case of the Banach open mapping theorem, `G₀` is a nontrivially
  normed field, so `cobounded G₀` is generated by `{ x | n < ‖x‖ }` where `n : ℕ`.
-/

public section

open Set Filter Bornology
open scoped Pointwise Topology

variable {E : Type*} [TopologicalSpace E] [BaireSpace E] [Nonempty E]
variable {ι : Type*} [Countable ι]
variable {G₀ : Type*} [GroupWithZero G₀] [Bornology G₀] [MulAction G₀ E] [ContinuousConstSMul G₀ E]
variable {s : Set E}

/-- If a closed set `s` in a nonempty Baire space can be spread over the whole space by a countable
family of homeomorphisms `T i : E =ₜ E` then `s` has nonempty interior. -/
theorem IsClosed.interior_nonempty_of_iUnion (hc : IsClosed s) (T : ι → E ≃ₜ E)
    (hcover : ⋃ i, T i '' s = univ) : (interior s).Nonempty := by
  obtain ⟨i, hi⟩ :=
    nonempty_interior_of_iUnion_of_closed (fun i ↦ (T i).isClosedMap _ hc) hcover
  simpa [← (T i).image_interior, image_nonempty] using hi

/-- If a nonempty Baire space `E` admits a "contraction" with respect to a closed set `s`, i.e., a
homeomorphism  `T : E =ₜ E` such that for all `x ∈ E`, there is some iterate `(T ^ n) x ∈ s`,
then `s` has a nonempty interior. Specialization of `IsClosed.interior_nonempty_of_iUnion`
which allows for an arbitrary countable family of homeomorphisms. -/
theorem IsClosed.interior_nonempty_of_iUnion'
    (hc : IsClosed s) (T : E ≃ₜ E) (habs : ∀ x, ∃ n : ℕ, (T ^ n) x ∈ s) :
    (interior s).Nonempty := by
  refine hc.interior_nonempty_of_iUnion (fun n : ℕ ↦ (T ^ n).symm) ?_
  simp_rw [eq_univ_iff_forall, mem_iUnion]
  intro x
  obtain ⟨n, hn⟩ := habs x
  refine ⟨n, (T ^ n) x, by simp [hn]⟩

/-- In a nonempty Baire space, a closed absorbent set has nonempty interior, provided the
`cobounded` filter of the acting group is countably generated and nontrivial. -/
theorem Absorbent.interior_nonempty [(cobounded G₀).IsCountablyGenerated] [NeBot (cobounded G₀)]
    (hs : Absorbent G₀ s) (hc : IsClosed s) : (interior s).Nonempty := by
  obtain ⟨B, hB_ne, hB_basis⟩ := (cobounded G₀).basis_sets.restrict_subset
    (eventually_ne_cobounded (0 : G₀)) |>.exists_antitone_subbasis
  choose a ha using fun n ↦ Filter.nonempty_of_mem (hB_ne n).1
  refine hc.interior_nonempty_of_iUnion (fun n ↦ Homeomorph.smulOfNeZero (a n) (by grind)) ?_
  refine eq_univ_of_forall fun x ↦ mem_iUnion.mpr ?_
  obtain ⟨n, -, hn⟩ := hB_basis.eventually_iff.mp (hs x)
  use n
  simpa using hn (ha n)
