/-! # Nonnegative contractions in a CРІє-algebra form an approximate unit

This file shows that the collection of positive contractions (of norm strictly less than one)
in a possibly non-unital CРІє-algebra form a directed set. The key step uses the continuous functional
calculus applied with the functions `fun x : РёЮРЅЦ0, 1 - (1 + x)РЂ╗┬╣` and `fun x : РёЮРЅЦ0, x * (1 - x)РЂ╗┬╣`,
which are inverses on the interval `{x : РёЮРЅЦ0 | x < 1}`.

In addition, this file defines `IsIncreasingApproximateUnit` to be a filter `l` that is an
approximate unit contained in the closed unit ball of nonnegative elements. Every CРІє-algebra has
a filter generated by the sections `{x | a РЅц x} РѕЕ closedBall 0 1` for `0 РЅц a` and `РђќaРђќ < 1`, and
moreover, this filter is an increasing approximate unit.

## Main declarations

+ `CFC.monotoneOn_one_sub_one_add_inv`: the function `f := fun x : РёЮРЅЦ0, 1 - (1 + x)РЂ╗┬╣` is
  *operator monotone* on `Set.Ici (0 : A)` (i.e., `cfcРѓЎ f` is monotone on `{x : A | 0 РЅц x}`).
+ `Set.InvOn.one_sub_one_add_inv`: the functions `f := fun x : РёЮРЅЦ0, 1 - (1 + x)РЂ╗┬╣` and
  `g := fun x : РёЮРЅЦ0, x * (1 - x)РЂ╗┬╣` are inverses on `{x : РёЮРЅЦ0 | x < 1}`.
+ `CStarAlgebra.directedOn_nonneg_ball`: the set `{x : A | 0 РЅц x} РѕЕ Metric.ball 0 1` is directed.
+ `Filter.IsIncreasingApproximateUnit`: a filter `l` is an *increasing approximate unit* if it is an
  approximate unit contained in the closed unit ball of nonnegative elements.
+ `CStarAlgebra.approximateUnit`: the filter generated by the sections
  `{x | a РЅц x} РѕЕ closedBall 0 1` for `0 РЅц a` with `РђќaРђќ < 1`.
+ `CStarAlgebra.increasingApproximateUnit`: the filter `CStarAlgebra.approximateUnit` is an
  increasing approximate unit.

-/

@[expose] public section

variable {A : Type*} [NonUnitalCStarAlgebra A]

local notation "¤ЃРѓЎ" => quasispectrum
local notation "¤Ѓ" => spectrum

open Unitization NNReal CStarAlgebra

variable [PartialOrder A] [StarOrderedRing A]

lemma CFC.monotoneOn_one_sub_one_add_inv :
    MonotoneOn (cfcРѓЎ (fun x : РёЮРЅЦ0 Рєд 1 - (1 + x)РЂ╗┬╣)) (Set.Ici (0 : A)) := by
  intro a ha b hb hab
  simp only [Set.mem_Ici] at ha hb
  rw [Рєљ inr_le_iff .., nnreal_cfcРѓЎ_eq_cfc_inr a _, nnreal_cfcРѓЎ_eq_cfc_inr b _]
  rw [Рєљ inr_le_iff a b (.of_nonneg ha) (.of_nonneg hb)] at hab
  rw [Рєљ inr_nonneg_iff] at ha hb
  have h_cfc_one_sub (c : AРЂ║┬╣) (hc : 0 РЅц c := by cfc_tac) :
      cfc (fun x : РёЮРЅЦ0 Рєд 1 - (1 + x)РЂ╗┬╣) c = 1 - cfc (┬иРЂ╗┬╣ : РёЮРЅЦ0 Рєњ РёЮРЅЦ0) (1 + c) := by
    rw [cfc_tsub _ _ _ (fun x _ Рєд by simp) (hg := by fun_prop (disch := intro _ _; positivity)),
      cfc_const_one РёЮРЅЦ0 c, cfc_comp' (┬иРЂ╗┬╣) (1 + ┬и) c ?_, cfc_add .., cfc_const_one РёЮРЅЦ0 c,
      cfc_id' РёЮРЅЦ0 c]
    exact continuousOn_id.invРѓђ (Set.forall_mem_image.mpr fun x _ Рєд by dsimp only [id]; positivity)
  rw [h_cfc_one_sub (a : AРЂ║┬╣), h_cfc_one_sub (b : AРЂ║┬╣)]
  gcongr
  rw [Рєљ CFC.rpow_neg_one_eq_cfc_inv, Рєљ CFC.rpow_neg_one_eq_cfc_inv]
  exact rpow_neg_one_le_rpow_neg_one (by gcongr)

lemma CFC.monotoneOn_one_sub_one_add_inv_real :
    MonotoneOn (cfcРѓЎ (fun x : РёЮ => 1 - (1 + x)РЂ╗┬╣)) (Set.Ici (0 : A)) := by
  intro a (ha : 0 РЅц a) b (hb : 0 РЅц b) hab
  calc _ = cfcРѓЎ (fun x : РёЮРЅЦ0 => 1 - (1 + x)РЂ╗┬╣) a := by
          rw [cfcРѓЎ_nnreal_eq_real _ _ ha]
          refine cfcРѓЎ_congr ?_
          intro x hx
          have hx' : 0 РЅц x := by grind
          simp [hx']
    _ РЅц cfcРѓЎ (fun x : РёЮРЅЦ0 => 1 - (1 + x)РЂ╗┬╣) b :=
          CFC.monotoneOn_one_sub_one_add_inv ha hb hab
    _ = cfcРѓЎ (fun x : РёЮ => 1 - (1 + x)РЂ╗┬╣) b := by
          rw [cfcРѓЎ_nnreal_eq_real _ _ hb]
          refine cfcРѓЎ_congr ?_
          intro x hx
          have hx' : 0 РЅц x := by grind
          simp [hx']

lemma Set.InvOn.one_sub_one_add_inv : Set.InvOn (fun x Рєд 1 - (1 + x)РЂ╗┬╣) (fun x Рєд x * (1 - x)РЂ╗┬╣)
    {x : РёЮРЅЦ0 | x < 1} {x : РёЮРЅЦ0 | x < 1} := by
  have : (fun x : РёЮРЅЦ0 Рєд x * (1 + x)РЂ╗┬╣) = fun x Рєд 1 - (1 + x)РЂ╗┬╣ := by
    ext x : 1
    simp [field, mul_tsub]
  rw [Рєљ this]
  constructor <;> intro x (hx : x < 1)
  ┬и have : 0 < 1 - x := tsub_pos_of_lt hx
    simp [field, tsub_add_cancel_of_le hx.le]
  ┬и simp [mul_assoc, Рєљ mul_inv, mul_tsub]
    field_simp
    simp

lemma norm_cfcРѓЎ_one_sub_one_add_inv_lt_one (a : A) :
    РђќcfcРѓЎ (fun x : РёЮРЅЦ0 Рєд 1 - (1 + x)РЂ╗┬╣) aРђќ < 1 :=
  nnnorm_cfcРѓЎ_nnreal_lt fun x _ Рєд tsub_lt_self zero_lt_one (by positivity)

lemma CStarAlgebra.directedOn_nonneg_ball :
    DirectedOn (┬и РЅц ┬и) ({x : A | 0 РЅц x} РѕЕ Metric.ball 0 1) := by
  let f : РёЮРЅЦ0 Рєњ РёЮРЅЦ0 := fun x => 1 - (1 + x)РЂ╗┬╣
  let g : РёЮРЅЦ0 Рєњ РёЮРЅЦ0 := fun x => x * (1 - x)РЂ╗┬╣
  suffices Рѕђ a b : A, 0 РЅц a Рєњ 0 РЅц b Рєњ РђќaРђќ < 1 Рєњ РђќbРђќ < 1 Рєњ
      a РЅц cfcРѓЎ f (cfcРѓЎ g a + cfcРѓЎ g b) by
    rintro a РЪе(haРѓЂ : 0 РЅц a), haРѓѓРЪЕ b РЪе(hbРѓЂ : 0 РЅц b), hbРѓѓРЪЕ
    simp only [Metric.mem_ball, dist_zero_right] at haРѓѓ hbРѓѓ
    refine РЪеcfcРѓЎ f (cfcРѓЎ g a + cfcРѓЎ g b), РЪеby simp, ?_РЪЕ, ?_, ?_РЪЕ
    ┬и simpa only [Metric.mem_ball, dist_zero_right] using norm_cfcРѓЎ_one_sub_one_add_inv_lt_one _
    ┬и exact this a b haРѓЂ hbРѓЂ haРѓѓ hbРѓѓ
    ┬и exact add_comm (cfcРѓЎ g a) (cfcРѓЎ g b) РќИ this b a hbРѓЂ haРѓЂ hbРѓѓ haРѓѓ
  rintro a b haРѓЂ - haРѓѓ -
  calc
    a = cfcРѓЎ (f Рѕў g) a := by
      conv_lhs => rw [Рєљ cfcРѓЎ_id РёЮРЅЦ0 a]
      refine cfcРѓЎ_congr (Set.InvOn.one_sub_one_add_inv.1.eqOn.symm.mono fun x hx Рєд ?_)
      exact lt_of_le_of_lt (le_nnnorm_of_mem_quasispectrum hx) haРѓѓ
    _ = cfcРѓЎ f (cfcРѓЎ g a) := by
      rw [cfcРѓЎ_comp f g a ?_ (by simp [f, tsub_self]) ?_ (by simp [g]) haРѓЂ]
      ┬и fun_prop (disch := intro _ _; positivity)
      ┬и have (x) (hx : x Рѕѕ ¤ЃРѓЎ РёЮРЅЦ0 a) : 1 - x РЅа 0 := by
          refine tsub_pos_of_lt ?_ |>.ne'
          exact lt_of_le_of_lt (le_nnnorm_of_mem_quasispectrum hx) haРѓѓ
        fun_prop (disch := assumption)
    _ РЅц cfcРѓЎ f (cfcРѓЎ g a + cfcРѓЎ g b) := by
      have hab' : cfcРѓЎ g a РЅц cfcРѓЎ g a + cfcРѓЎ g b := le_add_of_nonneg_right cfcРѓЎ_nonneg_of_predicate
      exact CFC.monotoneOn_one_sub_one_add_inv cfcРѓЎ_nonneg_of_predicate
        (cfcРѓЎ_nonneg_of_predicate.trans hab') hab'

section ApproximateUnit

open Metric Filter Topology

/-- An *increasing approximate unit* in a CРІє-algebra is an approximate unit contained in the
closed unit ball of nonnegative elements. -/
structure Filter.IsIncreasingApproximateUnit (l : Filter A) : Prop extends l.IsApproximateUnit where
  eventually_nonneg : РѕђрХа x in l, 0 РЅц x
  eventually_norm : РѕђрХа x in l, РђќxРђќ РЅц 1

namespace Filter.IsIncreasingApproximateUnit

omit [StarOrderedRing A] in
lemma eventually_nnnorm {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    РѕђрХа x in l, РђќxРђќРѓі РЅц 1 :=
  hl.eventually_norm

lemma eventually_isSelfAdjoint {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    РѕђрХа x in l, IsSelfAdjoint x :=
  hl.eventually_nonneg.mp <| .of_forall fun _ Рєд IsSelfAdjoint.of_nonneg

lemma eventually_star_eq {l : Filter A} (hl : l.IsIncreasingApproximateUnit) :
    РѕђрХа x in l, star x = x :=
  hl.eventually_isSelfAdjoint.mp <| .of_forall fun _ Рєд IsSelfAdjoint.star_eq

end Filter.IsIncreasingApproximateUnit

namespace CStarAlgebra

open Submodule in
/-- To show that `l` is a one-sided approximate unit for `A`, it suffices to verify it only for
`m : A` with `0 РЅц m` and `РђќmРђќ < 1`. -/
lemma tendsto_mul_right_of_forall_nonneg_tendsto {l : Filter A}
    (h : Рѕђ m, 0 РЅц m Рєњ РђќmРђќ < 1 Рєњ Tendsto (┬и * m) l (­ЮЊЮ m)) (m : A) :
    Tendsto (┬и * m) l (­ЮЊЮ m) := by
  obtain РЪеn, c, x, rflРЪЕ := mem_span_set'.mp <| by
    change m Рѕѕ span Рёѓ ({x | 0 РЅц x} РѕЕ ball 0 1)
    simp [span_nonneg_inter_unitBall]
  simp_rw [Finset.mul_sum]
  refine tendsto_finset_sum _ fun i _ Рєд ?_
  simp_rw [mul_smul_comm]
  exact tendsto_const_nhds.smul <| h (x i) (x i).2.1 <| by simpa using (x i).2.2

omit [PartialOrder A] in
/-- Multiplication on the left by `m` tends to `­ЮЊЮ m` if and only if multiplication on the right
does, provided the elements are eventually selfadjoint along the filter `l`. -/
lemma tendsto_mul_left_iff_tendsto_mul_right {l : Filter A} (hl : РѕђрХа x in l, IsSelfAdjoint x) :
    (Рѕђ m, Tendsto (m * ┬и) l (­ЮЊЮ m)) Рєћ (Рѕђ m, Tendsto (┬и * m) l (­ЮЊЮ m)) := by
  refine РЪеfun h m Рєд ?_, fun h m Рєд ?_РЪЕ
  all_goals
    apply (star_star m РќИ (continuous_star.tendsto _ |>.comp <| h (star m))).congr'
    filter_upwards [hl] with x hx
    simp [hx.star_eq]

variable (A)

/-- The sections of positive strict contractions form a filter basis. -/
lemma isBasis_nonneg_sections :
    IsBasis (fun x : A Рєд 0 РЅц x РѕД РђќxРђќ < 1) ({x | ┬и РЅц x}) where
  nonempty := РЪе0, by simpРЪЕ
  inter {x y} hx hy := by
    peel directedOn_nonneg_ball x (by simpa) y (by simpa) with z hz
    exact РЪеby simpa using hz.1, fun a ha Рєд РЪеhz.2.1.trans ha, hz.2.2.trans haРЪЕРЪЕ

/-- The canonical approximate unit in a CРІє-algebra generated by the basis of sets
`{x | a РЅц x} РѕЕ closedBall 0 1` for `0 РЅц a`. See also `CStarAlgebra.hasBasis_approximateUnit`. -/
def approximateUnit : Filter A :=
  (isBasis_nonneg_sections A).filter РіЊ ­ЮЊЪ (closedBall 0 1)

/-- The canonical approximate unit in a CРІє-algebra has a basis of sets
`{x | a РЅц x} РѕЕ closedBall 0 1` for `0 РЅц a`. -/
lemma hasBasis_approximateUnit :
    (approximateUnit A).HasBasis (fun x : A Рєд 0 РЅц x РѕД РђќxРђќ < 1) ({x | ┬и РЅц x} РѕЕ closedBall 0 1) :=
  isBasis_nonneg_sections A |>.hasBasis.inf_principal (closedBall 0 1)

/-- This is a common reasoning sequence in CРІє-algebra theory. If `0 РЅц x РЅц y РЅц 1`, then the norm of
`z - y * z` is controlled by the norm of `star z * (1 - x) * z`, which is advantageous because the
latter is nonnegative. This is a key step in establishing the existence of an increasing approximate
unit in general CРІє-algebras. -/
lemma nnnorm_sub_mul_self_le {A : Type*} [CStarAlgebra A] [PartialOrder A] [StarOrderedRing A]
    {x y : A} (z : A) (hxРѓђ : 0 РЅц x) (hy : y Рѕѕ Set.Icc x 1) {c : РёЮРЅЦ0}
    (h : Рђќstar z * (1 - x) * zРђќРѓі РЅц c ^ 2) :
    Рђќz - y * zРђќРѓі РЅц c := by
  nth_rw 1 [Рєљ one_mul z]
  rw [Рєљ sqrt_sq c, le_sqrt_iff_sq_le, Рєљ sub_mul, sq, Рєљ CStarRing.nnnorm_star_mul_self]
  simp only [star_mul, star_sub, star_one]
  have hyРѓђ : y Рѕѕ Set.Icc 0 1 := РЪеhxРѓђ.trans hy.1, hy.2РЪЕ
  have hy' : 1 - y Рѕѕ Set.Icc 0 1 := Set.sub_mem_Icc_zero_iff_right.mpr hyРѓђ
  rw [hyРѓђ.1.star_eq, Рєљ mul_assoc, mul_assoc (star _), Рєљ sq]
  refine nnnorm_le_nnnorm_of_nonneg_of_le (star_left_conjugate_nonneg (pow_nonneg hy'.1 2) _) ?_
    |>.trans h
  refine star_left_conjugate_le_conjugate ?_ _
  trans (1 - y)
  ┬и simpa using pow_antitone hy'.1 hy'.2 one_le_two
  ┬и gcongr
    exact hy.1

/-- A variant of `nnnorm_sub_mul_self_le` which uses `Рђќ┬иРђќ` instead of `Рђќ┬иРђќРѓі`. -/
lemma norm_sub_mul_self_le {A : Type*} [CStarAlgebra A] [PartialOrder A] [StarOrderedRing A]
    {x y : A} (z : A) (hxРѓђ : 0 РЅц x) (hy : y Рѕѕ Set.Icc x 1)
    {c : РёЮ} (hc : 0 РЅц c) (h : Рђќstar z * (1 - x) * zРђќ РЅц c ^ 2) :
    Рђќz - y * zРђќ РЅц c :=
  nnnorm_sub_mul_self_le z hxРѓђ hy h (c := РЪеc, hcРЪЕ)

variable {A} in
/-- A variant of `norm_sub_mul_self_le` for non-unital algebras that passes to the unitization. -/
lemma norm_sub_mul_self_le_of_inr {x y : A} (z : A) (hxРѓђ : 0 РЅц x) (hxy : x РЅц y) (hyРѓЂ : РђќyРђќ РЅц 1)
    {c : РёЮ} (hc : 0 РЅц c) (h : Рђќstar (z : AРЂ║┬╣) * (1 - x) * zРђќ РЅц c ^ 2) :
    Рђќz - y * zРђќ РЅц c := by
  rw [Рєљ norm_inr (­ЮЋю := Рёѓ), inr_sub, inr_mul]
  refine norm_sub_mul_self_le _ ?_ ?_ hc h
  ┬и rwa [inr_nonneg_iff]
  ┬и have hy := hxРѓђ.trans hxy
    rw [Set.mem_Icc, inr_le_iff _ _ hxРѓђ.isSelfAdjoint hy.isSelfAdjoint,
      Рєљ norm_le_one_iff_of_nonneg _, norm_inr]
    exact РЪеhxy, hyРѓЂРЪЕ

variable {A} in
/-- This shows `CStarAlgebra.approximateUnit` is a one-sided approximate unit, but this is marked
`private` because it is only used to prove `CStarAlgebra.increasingApproximateUnit`. -/
private lemma tendsto_mul_right_approximateUnit (m : A) :
    Tendsto (┬и * m) (approximateUnit A) (­ЮЊЮ m) := by
  refine tendsto_mul_right_of_forall_nonneg_tendsto (fun m hmРѓЂ hmРѓѓ Рєд ?_) m
  rw [(hasBasis_approximateUnit A).tendsto_iff nhds_basis_closedBall]
  intro ╬х h╬х
  lift ╬х to РёЮРЅЦ0 using h╬х.le
  rw [coe_pos] at h╬х
  refine РЪеcfcРѓЎ (fun y : РёЮРЅЦ0 Рєд 1 - (1 + y)РЂ╗┬╣) (╬хРЂ╗┬╣ ^ 2 Рђб m),
    РЪеcfcРѓЎ_nonneg_of_predicate, norm_cfcРѓЎ_one_sub_one_add_inv_lt_one (╬хРЂ╗┬╣ ^ 2 Рђб m)РЪЕ, ?_РЪЕ
  rintro x РЪе(hxРѓЂ : _ РЅц x), hxРѓѓРЪЕ
  simp only [mem_closedBall, dist_eq_norm', zero_sub, norm_neg] at hxРѓѓ Ріб
  rw [Рєљ coe_nnnorm, coe_le_coe]
  have hxРѓђ : 0 РЅц x := cfcРѓЎ_nonneg_of_predicate.trans hxРѓЂ
  rw [Рєљ inr_le_iff _ _ (.of_nonneg cfcРѓЎ_nonneg_of_predicate) (.of_nonneg hxРѓђ),
    nnreal_cfcРѓЎ_eq_cfc_inr _ _ (by simp [tsub_self]), inr_smul] at hxРѓЂ
  rw [Рєљ norm_inr (­ЮЋю := Рёѓ)] at hmРѓѓ hxРѓѓ
  rw [Рєљ inr_nonneg_iff] at hxРѓђ hmРѓЂ
  rw [Рєљ nnnorm_inr (­ЮЋю := Рёѓ), inr_sub, inr_mul]
  generalize (x : AРЂ║┬╣) = x, (m : AРЂ║┬╣) = m at *
  set g : РёЮРЅЦ0 Рєњ РёЮРЅЦ0 := fun y Рєд 1 - (1 + y)РЂ╗┬╣
  have hg : Continuous g := by
    rw [Рєљ continuousOn_univ]
    fun_prop (disch := intro _ _; positivity)
  have hg' : ContinuousOn (fun y Рєд (1 + ╬хРЂ╗┬╣ ^ 2 Рђб y)РЂ╗┬╣) (spectrum РёЮРЅЦ0 m) :=
    ContinuousOn.invРѓђ (by fun_prop) fun _ _ Рєд by positivity
  have hx : x Рѕѕ Set.Icc 0 1 := mem_Icc_iff_norm_le_one.mpr РЪеhxРѓђ, hxРѓѓРЪЕ
  have hx' : x Рѕѕ Set.Icc _ 1 := РЪеhxРѓЂ, hx.2РЪЕ
  refine nnnorm_sub_mul_self_le m cfc_nonneg_of_predicate hx' ?_
  suffices star m * (1 - cfc g (╬хРЂ╗┬╣ ^ 2 Рђб m)) * m =
      cfc (fun y : РёЮРЅЦ0 Рєд y * (1 + ╬хРЂ╗┬╣ ^ 2 Рђб y)РЂ╗┬╣ * y) m by
    rw [this]
    refine nnnorm_cfc_nnreal_le fun y hy Рєд ?_
    calc
      y * (1 + ╬хРЂ╗┬╣ ^ 2 Рђб y)РЂ╗┬╣ * y = y * ╬х ^ 2 * (y / (╬х ^ 2 + y)) := by simp [field]
      _ РЅц ╬х ^ 2 * 1 := by
        gcongr
        ┬и refine mul_le_of_le_one_left (zero_le _) ?_
          have hm' := hmРѓѓ.le
          rw [norm_le_one_iff_of_nonneg m hmРѓЂ, Рєљ cfc_id' РёЮРЅЦ0 m, Рєљ cfc_one (R := РёЮРЅЦ0) m,
            cfc_nnreal_le_iff _ _ _ (QuasispectrumRestricts.nnreal_of_nonneg hmРѓЂ)] at hm'
          exact hm' y hy
        ┬и exact div_le_one (by positivity) |>.mpr le_add_self
      _ = ╬х ^ 2 := mul_one _
  rw [fun_cfc_mul _ _ m (continuousOn_id' _ |>.fun_mul hg') (continuousOn_id' _),
    fun_cfc_mul _ _ m (continuousOn_id' _) hg', cfc_id' .., hmРѓЂ.star_eq]
  congr
  rw [Рєљ cfc_one (R := РёЮРЅЦ0) m, Рєљ cfc_comp_smul _ _ _ hg.continuousOn hmРѓЂ,
    Рєљ cfc_tsub _ _ m (by simp [g]) hmРѓЂ (by fun_prop) (Continuous.continuousOn <| by fun_prop)]
  refine cfc_congr (fun y _ Рєд ?_)
  simp [g, tsub_tsub_cancel_of_le]

/-- The filter `CStarAlgebra.approximateUnit` generated by the sections
`{x | a РЅц x} РѕЕ closedBall 0 1` for `0 РЅц a` forms an increasing approximate unit. -/
lemma increasingApproximateUnit :
    IsIncreasingApproximateUnit (approximateUnit A) where
  tendsto_mul_left := by
    rw [tendsto_mul_left_iff_tendsto_mul_right]
    ┬и exact tendsto_mul_right_approximateUnit
    ┬и rw [(hasBasis_approximateUnit A).eventually_iff]
      peel (hasBasis_approximateUnit A).ex_mem with x hx
      exact РЪеhx, fun y hy Рєд (hx.1.trans hy.1).isSelfAdjointРЪЕ
  tendsto_mul_right := tendsto_mul_right_approximateUnit
  eventually_nonneg := .filter_mono inf_le_left <|
    (isBasis_nonneg_sections A).hasBasis.eventually_iff.mpr РЪе0, by simpРЪЕ
  eventually_norm := .filter_mono inf_le_right <| by simp
  neBot := hasBasis_approximateUnit A |>.neBot_iff.mpr
    fun hx Рєд РЪе_, РЪеle_rfl, by simpa using hx.2.leРЪЕРЪЕ

end CStarAlgebra

end ApproximateUnit
