section NonUnitalStarAlgHom

open scoped ContinuousMapZero NonUnitalContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A ‚Üí Prop} {q : B ‚Üí Prop}
  [CommSemiring R] [Nontrivial R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R]
  [ContinuousStar R] [CommRing S] [Algebra R S]
  [NonUnitalRing A] [StarRing A] [TopologicalSpace A] [Module R A]
  [IsScalarTower R A A] [SMulCommClass R A A]
  [NonUnitalRing B] [StarRing B] [TopologicalSpace B] [Module R B]
  [IsScalarTower R B B] [SMulCommClass R B B]
  [Module S A] [Module S B] [IsScalarTower R S A] [IsScalarTower R S B]
  [NonUnitalContinuousFunctionalCalculus R A p] [NonUnitalContinuousFunctionalCalculus R B q]
  [ContinuousMapZero.UniqueHom R B] [FunLike F A B] [NonUnitalAlgHomClass F S A B]
  [StarHomClass F A B]

set_option backward.isDefEq.respectTransparency false in
include S in
/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus. -/
lemma NonUnitalStarAlgHomClass.map_cfc‚āô (ŌÜ : F) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hf‚āÄ : f 0 = 0 := by cfc_zero_tac) (hŌÜ : Continuous ŌÜ := by fun_prop) (ha : p a := by cfc_tac)
    (hŌÜa : q (ŌÜ a) := by cfc_tac) : ŌÜ (cfc‚āô f a) = cfc‚āô f (ŌÜ a) := by
  let Ōą : A ‚Üí‚čÜ‚āô‚āź[R] B := (ŌÜ : A ‚Üí‚čÜ‚āô‚āź[S] B).restrictScalars R
  have : Continuous Ōą := hŌÜ
  have h_spec := NonUnitalAlgHom.quasispectrum_apply_subset' (R := R) S ŌÜ a
  have hŌąa : q (Ōą a) := hŌÜa
  let őĻ : C(quasispectrum R (Ōą a), quasispectrum R a)‚āÄ :=
    ‚ü®‚ü®Set.inclusion h_spec, continuous_id.subtype_map h_spec‚ü©, rfl‚ü©
  suffices Ōą.comp (cfc‚āôHom ha) =
      (cfc‚āôHom hŌąa).comp (ContinuousMapZero.nonUnitalStarAlgHom_precomp R őĻ) by
    have hf' : ContinuousOn f (quasispectrum R (Ōą a)) := hf.mono h_spec
    rw [cfc‚āô_apply .., cfc‚āô_apply ..]
    exact DFunLike.congr_fun this _
  refine ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfc‚āôHom hŌąa (.id (quasispectrum R (Ōą a)))
    ¬∑ simp [cfc‚āôHom_id]
    ¬∑ congr
  all_goals
    dsimp [ContinuousMapZero.nonUnitalStarAlgHom_precomp]
    fun_prop

/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus.  This version is specialized to `A ‚Üí‚čÜ‚āô‚āź[S] B` to allow for dot notation. -/
lemma NonUnitalStarAlgHom.map_cfc‚āô (ŌÜ : A ‚Üí‚čÜ‚āô‚āź[S] B) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hf‚āÄ : f 0 = 0 := by cfc_zero_tac) (hŌÜ : Continuous ŌÜ := by fun_prop) (ha : p a := by cfc_tac)
    (hŌÜa : q (ŌÜ a) := by cfc_tac) : ŌÜ (cfc‚āô f a) = cfc‚āô f (ŌÜ a) :=
  NonUnitalStarAlgHomClass.map_cfc‚āô ŌÜ f a

end NonUnitalStarAlgHom

section StarAlgHom

open scoped ContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A ‚Üí Prop} {q : B ‚Üí Prop}
  [CommSemiring R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R] [ContinuousStar R]
  [Ring A] [StarRing A] [TopologicalSpace A] [Algebra R A]
  [Ring B] [StarRing B] [TopologicalSpace B] [Algebra R B]
  [CommSemiring S] [Algebra R S] [Algebra S A] [Algebra S B] [IsScalarTower R S A]
  [IsScalarTower R S B] [ContinuousFunctionalCalculus R A p] [ContinuousFunctionalCalculus R B q]
  [ContinuousMap.UniqueHom R B] [FunLike F A B] [AlgHomClass F S A B]
  [StarHomClass F A B]

include S in
/-- Star algebra homomorphisms commute with the continuous functional calculus. -/
lemma StarAlgHomClass.map_cfc (ŌÜ : F) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac)
    (hŌÜ : Continuous ŌÜ := by fun_prop) (ha : p a := by cfc_tac) (hŌÜa : q (ŌÜ a) := by cfc_tac) :
    ŌÜ (cfc f a) = cfc f (ŌÜ a) := by
  let Ōą : A ‚Üí‚čÜ‚āź[R] B := (ŌÜ : A ‚Üí‚čÜ‚āź[S] B).restrictScalars R
  have : Continuous Ōą := hŌÜ
  have h_spec := AlgHom.spectrum_apply_subset Ōą a
  have hŌąa : q (Ōą a) := hŌÜa
  let őĻ : C(spectrum R (Ōą a), spectrum R a) :=
    ‚ü®Set.inclusion h_spec, continuous_id.subtype_map h_spec‚ü©
  suffices Ōą.comp (cfcHom ha) = (cfcHom hŌąa).comp (ContinuousMap.compStarAlgHom' R R őĻ) by
    have hf' : ContinuousOn f (spectrum R (Ōą a)) := hf.mono h_spec
    rw [cfc_apply .., cfc_apply ..]
    congrm($(this) ‚ü®_, hf.restrict‚ü©)
  refine ContinuousMap.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfcHom hŌąa (.restrict (spectrum R (Ōą a)) (.id R))
    ¬∑ simp [cfcHom_id]
    ¬∑ congr
  all_goals
    dsimp [ContinuousMap.compStarAlgHom']
    fun_prop

/-- Star algebra homomorphisms commute with the continuous functional calculus.
This version is specialized to `A ‚Üí‚čÜ‚āź[S] B` to allow for dot notation. -/
lemma StarAlgHom.map_cfc (ŌÜ : A ‚Üí‚čÜ‚āź[S] B) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac) (hŌÜ : Continuous ŌÜ := by fun_prop)
    (ha : p a := by cfc_tac) (hŌÜa : q (ŌÜ a) := by cfc_tac) :
    ŌÜ (cfc f a) = cfc f (ŌÜ a) :=
  StarAlgHomClass.map_cfc ŌÜ f a

end StarAlgHom
