/-!
# Uniqueness of the continuous functional calculus

Let `s : Set ūĚēú` be compact where `ūĚēú` is either `‚ĄĚ` or `‚Ąā`. By the Stone-Weierstrass theorem, the
(star) subalgebra generated by polynomial functions on `s` is dense in `C(s, ūĚēú)`. Moreover, this
star subalgebra is generated by `X : ūĚēú[X]` (i.e., `ContinuousMap.restrict s (.id ūĚēú)`) alone.
Consequently, any continuous star `ūĚēú`-algebra homomorphism with domain `C(s, ūĚēú)`, is uniquely
determined by its value on `X : ūĚēú[X]`.

The same is true for `ūĚēú := ‚ĄĚ‚Č•0`, so long as the algebra `A` is an `‚ĄĚ`-algebra, which we establish
by upgrading a map `C((s : Set ‚ĄĚ‚Č•0), ‚ĄĚ‚Č•0) ‚Üí‚čÜ‚āź[‚ĄĚ‚Č•0] A` to `C(((‚ÜĎ) '' s : Set ‚ĄĚ), ‚ĄĚ) ‚Üí‚čÜ‚āź[‚ĄĚ] A` in
the natural way, and then applying the uniqueness for `‚ĄĚ`-algebra homomorphisms.

This is the reason the `ContinuousMap.UniqueHom` class exists in the first place, as
opposed to simply appealing directly to Stone-Weierstrass to prove `StarAlgHom.ext_continuousMap`.
-/

@[expose] public section

open Topology

section UniqueUnital

section RCLike

variable {ūĚēú A : Type*} [RCLike ūĚēú]

instance (priority := 100) RCLike.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ūĚēú A] :
    ContinuousMap.UniqueHom ūĚēú A where
  eq_of_continuous_of_map_id s _ ŌÜ Ōą hŌÜ hŌą h :=
    ContinuousMap.starAlgHom_ext_map_X hŌÜ hŌą <| by
      convert h using 1
      all_goals exact congr_arg _ (by ext; simp)

instance Real.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ‚ĄĚ A] :
    ContinuousMap.UniqueHom ‚ĄĚ A :=
  inferInstance

instance Complex.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ‚Ąā A] :
    ContinuousMap.UniqueHom ‚Ąā A :=
  inferInstance

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X]

namespace ContinuousMap

/-- This map sends `f : C(X, ‚ĄĚ)` to `Real.toNNReal ‚ąė f`, bundled as a continuous map `C(X, ‚ĄĚ‚Č•0)`. -/
noncomputable def toNNReal (f : C(X, ‚ĄĚ)) : C(X, ‚ĄĚ‚Č•0) := .realToNNReal |>.comp f

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := continuous_postcomp _

@[simp]
lemma toNNReal_apply (f : C(X, ‚ĄĚ)) (x : X) : f.toNNReal x = (f x).toNNReal := rfl

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, ‚ĄĚ)) :
    (f + g).toNNReal + (-f).toNNReal + (-g).toNNReal =
      (-(f + g)).toNNReal + f.toNNReal + g.toNNReal := by
  ext x
  simp [max_neg_zero, -neg_add_rev]
  abel

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, ‚ĄĚ)) :
    (f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal =
      (-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal := by
  ext x
  simp [max_neg_zero, add_mul, mul_add]
  abel

@[simp]
lemma toNNReal_algebraMap (r : ‚ĄĚ‚Č•0) :
    (algebraMap ‚ĄĚ C(X, ‚ĄĚ) r).toNNReal = algebraMap ‚ĄĚ‚Č•0 C(X, ‚ĄĚ‚Č•0) r := by
  ext; simp

@[simp]
lemma toNNReal_neg_algebraMap (r : ‚ĄĚ‚Č•0) : (- algebraMap ‚ĄĚ C(X, ‚ĄĚ) r).toNNReal = 0 := by
  ext; simp

@[simp]
lemma toNNReal_one : (1 : C(X, ‚ĄĚ)).toNNReal = 1 := toNNReal_algebraMap 1

@[simp]
lemma toNNReal_neg_one : (-1 : C(X, ‚ĄĚ)).toNNReal = 0 := toNNReal_neg_algebraMap 1

end ContinuousMap

variable {A : Type*} [Ring A] [StarRing A] [Algebra ‚ĄĚ A]

namespace StarAlgHom

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a star `‚ĄĚ‚Č•0`-algebra homomorphism `ŌÜ` from `C(X, ‚ĄĚ‚Č•0)` into an `‚ĄĚ`-algebra `A`, this is
the unique extension of `ŌÜ` from `C(X, ‚ĄĚ)` to `A` as a star `‚ĄĚ`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapOfNNReal (ŌÜ : C(X, ‚ĄĚ‚Č•0) ‚Üí‚čÜ‚āź[‚ĄĚ‚Č•0] A) :
    C(X, ‚ĄĚ) ‚Üí‚čÜ‚āź[‚ĄĚ] A where
  toFun f := ŌÜ f.toNNReal - ŌÜ (-f).toNNReal
  map_one' := by simp
  map_zero' := by simp
  map_mul' f g := by
    have := congr(ŌÜ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this ‚äĘ
    rw [‚Üź sub_eq_zero] at this ‚äĘ
    convert this using 1
    abel
  map_add' f g := by
    have := congr(ŌÜ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this ‚äĘ
    rw [‚Üź sub_eq_zero] at this ‚äĘ
    convert this using 1
    abel
  commutes' r := by
    obtain (hr | hr) := le_total 0 r
    ¬∑ lift r to ‚ĄĚ‚Č•0 using hr
      simpa only [ContinuousMap.toNNReal_algebraMap, ContinuousMap.toNNReal_neg_algebraMap,
        map_zero, sub_zero] using AlgHomClass.commutes ŌÜ r
    ¬∑ rw [‚Üź neg_neg r, ‚Üź map_neg, neg_neg (-r)]
      rw [‚Üź neg_nonneg] at hr
      lift -r to ‚ĄĚ‚Č•0 using hr with r
      simpa only [map_neg, ContinuousMap.toNNReal_neg_algebraMap, map_zero,
        ContinuousMap.toNNReal_algebraMap, zero_sub, neg_inj] using AlgHomClass.commutes ŌÜ r
  map_star' f := by simp only [star_trivial, star_sub, ‚Üź map_star]

@[fun_prop]
lemma continuous_realContinuousMapOfNNReal (ŌÜ : C(X, ‚ĄĚ‚Č•0) ‚Üí‚čÜ‚āź[‚ĄĚ‚Č•0] A)
    (hŌÜ : Continuous ŌÜ) : Continuous ŌÜ.realContinuousMapOfNNReal := by
  dsimp [realContinuousMapOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapOfNNReal_apply_comp_toReal (ŌÜ : C(X, ‚ĄĚ‚Č•0) ‚Üí‚čÜ‚āź[‚ĄĚ‚Č•0] A)
    (f : C(X, ‚ĄĚ‚Č•0)) :
    ŌÜ.realContinuousMapOfNNReal ((ContinuousMap.mk toReal continuous_coe).comp f) = ŌÜ f := by
  simp only [realContinuousMapOfNNReal_apply]
  convert_to ŌÜ f - ŌÜ 0 = ŌÜ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapOfNNReal_injective :
    Function.Injective (realContinuousMapOfNNReal (X := X) (A := A)) := by
  intro ŌÜ Ōą h
  ext f
  simpa using congr($(h) ((ContinuousMap.mk toReal continuous_coe).comp f))

end StarAlgHom

variable [TopologicalSpace A] [IsSemitopologicalRing A]

instance NNReal.instContinuousMap.UniqueHom [T2Space A] :
    ContinuousMap.UniqueHom ‚ĄĚ‚Č•0 A where
  eq_of_continuous_of_map_id s hs ŌÜ Ōą hŌÜ hŌą h := by
    let s' : Set ‚ĄĚ := (‚ÜĎ) '' s
    let e : s ‚ČÉ‚āú s' := NNReal.isEmbedding_coe.homeomorphImage s
    have (őĺ : C(s, ‚ĄĚ‚Č•0) ‚Üí‚čÜ‚āź[‚ĄĚ‚Č•0] A) (hőĺ : Continuous őĺ) :
        (let őĺ' := őĺ.realContinuousMapOfNNReal.comp <| ContinuousMap.compStarAlgHom' ‚ĄĚ ‚ĄĚ e
        Continuous őĺ' ‚ąß őĺ' (.restrict s' <| .id ‚ĄĚ) = őĺ (.restrict s <| .id ‚ĄĚ‚Č•0)) := by
      intro őĺ'
      refine ‚ü®őĺ.continuous_realContinuousMapOfNNReal hőĺ |>.comp <|
        ContinuousMap.continuous_precomp _, ?_‚ü©
      exact őĺ.realContinuousMapOfNNReal_apply_comp_toReal (.restrict s <| .id ‚ĄĚ‚Č•0)
    obtain ‚ü®hŌÜ', hŌÜ_id‚ü© := this ŌÜ hŌÜ
    obtain ‚ü®hŌą', hŌą_id‚ü© := this Ōą hŌą
    have hs' : CompactSpace s' := e.compactSpace
    have h' := ContinuousMap.UniqueHom.eq_of_continuous_of_map_id s' _ _ hŌÜ' hŌą'
      (hŌÜ_id ‚Ėł hŌą_id ‚Ėł h)
    have h'' := congr($(h').comp <| ContinuousMap.compStarAlgHom' ‚ĄĚ ‚ĄĚ (e.symm : C(s', s)))
    have : (ContinuousMap.compStarAlgHom' ‚ĄĚ ‚ĄĚ (e : C(s, s'))).comp
        (ContinuousMap.compStarAlgHom' ‚ĄĚ ‚ĄĚ (e.symm : C(s', s))) = StarAlgHom.id _ _ := by
      ext1; simp
    simp only [StarAlgHom.comp_assoc, this, StarAlgHom.comp_id] at h''
    exact StarAlgHom.realContinuousMapOfNNReal_injective h''

end NNReal

end UniqueUnital

section UniqueNonUnital

section RCLike

variable {ūĚēú A : Type*} [RCLike ūĚēú]

open NonUnitalStarAlgebra in
instance RCLike.uniqueNonUnitalContinuousFunctionalCalculus
    [TopologicalSpace A] [T2Space A] [NonUnitalRing A] [StarRing A] [Module ūĚēú A]
    [IsScalarTower ūĚēú A A] [SMulCommClass ūĚēú A A] :
    ContinuousMapZero.UniqueHom ūĚēú A where
  eq_of_continuous_of_map_id s hs h0 ŌÜ Ōą hŌÜ hŌą h := by
    rw [DFunLike.ext'_iff, ‚Üź Set.eqOn_univ, ‚Üź (ContinuousMapZero.adjoin_id_dense _).closure_eq]
    refine Set.EqOn.closure (fun f hf ‚Ü¶ ?_) hŌÜ hŌą
    rw [‚Üź NonUnitalStarAlgHom.mem_equalizer]
    apply adjoin_le ?_ hf
    rw [Set.singleton_subset_iff]
    exact h

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X] [Zero X]

namespace ContinuousMapZero

/-- This map sends `f : C(X, ‚ĄĚ)` to `Real.toNNReal ‚ąė f`, bundled as a continuous map `C(X, ‚ĄĚ‚Č•0)`. -/
noncomputable def toNNReal (f : C(X, ‚ĄĚ)‚āÄ) : C(X, ‚ĄĚ‚Č•0)‚āÄ := ‚ü®.realToNNReal |>.comp f, by simp‚ü©

@[simp]
lemma toNNReal_apply (f : C(X, ‚ĄĚ)‚āÄ) (x : X) : f.toNNReal x = Real.toNNReal (f x) := rfl

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := by
  rw [continuous_induced_rng]
  convert_to Continuous (ContinuousMap.toNNReal ‚ąė ((‚ÜĎ) : C(X, ‚ĄĚ)‚āÄ ‚Üí C(X, ‚ĄĚ))) using 1
  exact ContinuousMap.continuous_postcomp _ |>.comp continuous_induced_dom

lemma toContinuousMapHom_toNNReal (f : C(X, ‚ĄĚ)‚āÄ) :
    (toContinuousMapHom (X := X) (R := ‚ĄĚ) f).toNNReal =
      toContinuousMapHom (X := X) (R := ‚ĄĚ‚Č•0) f.toNNReal :=
  rfl

@[simp]
lemma toNNReal_smul (r : ‚ĄĚ‚Č•0) (f : C(X, ‚ĄĚ)‚āÄ) : (r ‚ÄĘ f).toNNReal = r ‚ÄĘ f.toNNReal := by
  ext x
  by_cases! h : 0 ‚Č§ f x
  ¬∑ simpa [max_eq_left h, NNReal.smul_def] using mul_nonneg r.coe_nonneg h
  ¬∑ simpa [max_eq_right h.le, NNReal.smul_def]
      using mul_nonpos_of_nonneg_of_nonpos r.coe_nonneg h.le

@[simp]
lemma toNNReal_neg_smul (r : ‚ĄĚ‚Č•0) (f : C(X, ‚ĄĚ)‚āÄ) : (-(r ‚ÄĘ f)).toNNReal = r ‚ÄĘ (-f).toNNReal := by
  rw [NNReal.smul_def, ‚Üź smul_neg, ‚Üź NNReal.smul_def, toNNReal_smul]

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, ‚ĄĚ)‚āÄ) :
    ((f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal) =
    ((-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal) := by
  apply toContinuousMap_injective
  simpa only [‚Üź toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, ‚ĄĚ)).toNNReal_mul_add_neg_mul_add_mul_neg_eq g

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, ‚ĄĚ)‚āÄ) :
    ((f + g).toNNReal + (-f).toNNReal + (-g).toNNReal) =
      ((-(f + g)).toNNReal + f.toNNReal + g.toNNReal) := by
  apply toContinuousMap_injective
  simpa only [‚Üź toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, ‚ĄĚ)).toNNReal_add_add_neg_add_neg_eq g

end ContinuousMapZero

variable {A : Type*} [NonUnitalRing A] [StarRing A] [Module ‚ĄĚ A]

namespace NonUnitalStarAlgHom

open ContinuousMapZero

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a non-unital star `‚ĄĚ‚Č•0`-algebra homomorphism `ŌÜ` from `C(X, ‚ĄĚ‚Č•0)‚āÄ` into a non-unital
`‚ĄĚ`-algebra `A`, this is the unique extension of `ŌÜ` from `C(X, ‚ĄĚ)‚āÄ` to `A` as a non-unital
star `‚ĄĚ`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapZeroOfNNReal (ŌÜ : C(X, ‚ĄĚ‚Č•0)‚āÄ ‚Üí‚čÜ‚āô‚āź[‚ĄĚ‚Č•0] A) :
    C(X, ‚ĄĚ)‚āÄ ‚Üí‚čÜ‚āô‚āź[‚ĄĚ] A where
  toFun f := ŌÜ f.toNNReal - ŌÜ (-f).toNNReal
  map_zero' := by simp
  map_mul' f g := by
    have := congr(ŌÜ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this ‚äĘ
    rw [‚Üź sub_eq_zero] at this ‚äĘ
    rw [‚Üź this]
    abel
  map_add' f g := by
    have := congr(ŌÜ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this ‚äĘ
    rw [‚Üź sub_eq_zero] at this ‚äĘ
    rw [‚Üź this]
    abel
  map_smul' r f := by
    simp only [MonoidHom.id_apply]
    by_cases! hr : 0 ‚Č§ r
    ¬∑ lift r to ‚ĄĚ‚Č•0 using hr
      simp only [‚Üź smul_def, toNNReal_smul, map_smul, toNNReal_neg_smul, smul_sub]
    ¬∑ rw [‚Üź neg_pos] at hr
      rw [‚Üź neg_smul]
      nth_rw 1 [‚Üź neg_neg r]
      nth_rw 3 [‚Üź neg_neg r]
      lift -r to ‚ĄĚ‚Č•0 using hr.le with r
      simp only [neg_smul, ‚Üź smul_def, toNNReal_neg_smul, map_smul, toNNReal_smul, smul_sub,
        sub_neg_eq_add]
      rw [sub_eq_add_neg, add_comm]
  map_star' f := by simp only [star_trivial, star_sub, ‚Üź map_star]

set_option backward.isDefEq.respectTransparency false in
@[fun_prop]
lemma continuous_realContinuousMapZeroOfNNReal (ŌÜ : C(X, ‚ĄĚ‚Č•0)‚āÄ ‚Üí‚čÜ‚āô‚āź[‚ĄĚ‚Č•0] A)
    (hŌÜ : Continuous ŌÜ) : Continuous ŌÜ.realContinuousMapZeroOfNNReal := by
  dsimp [realContinuousMapZeroOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapZeroOfNNReal_apply_comp_toReal (ŌÜ : C(X, ‚ĄĚ‚Č•0)‚āÄ ‚Üí‚čÜ‚āô‚āź[‚ĄĚ‚Č•0] A)
    (f : C(X, ‚ĄĚ‚Č•0)‚āÄ) :
    ŌÜ.realContinuousMapZeroOfNNReal ((ContinuousMapZero.mk ‚ü®toReal, continuous_coe‚ü© rfl).comp f) =
      ŌÜ f := by
  simp only [realContinuousMapZeroOfNNReal_apply]
  convert_to ŌÜ f - ŌÜ 0 = ŌÜ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapZeroOfNNReal_injective :
    Function.Injective (realContinuousMapZeroOfNNReal (X := X) (A := A)) := by
  intro ŌÜ Ōą h
  ext f
  simpa using congr($(h) ((ContinuousMapZero.mk ‚ü®toReal, continuous_coe‚ü© rfl).comp f))

end NonUnitalStarAlgHom

open ContinuousMapZero

instance NNReal.instContinuousMapZero.UniqueHom
    [TopologicalSpace A] [IsSemitopologicalRing A] [IsScalarTower ‚ĄĚ A A] [SMulCommClass ‚ĄĚ A A]
    [T2Space A] :
    ContinuousMapZero.UniqueHom ‚ĄĚ‚Č•0 A where
  eq_of_continuous_of_map_id s hs h0 ŌÜ Ōą hŌÜ hŌą h := by
    let s' : Set ‚ĄĚ := (‚ÜĎ) '' s
    let e : s ‚ČÉ‚āú s' := NNReal.isEmbedding_coe.homeomorphImage s
    have : Fact (0 ‚ąą s') := ‚ü®0, Fact.out, coe_zero‚ü©
    have e0 : e 0 = 0 := rfl
    have e0' : e.symm 0 = 0 := e.symm_apply_eq.mpr e0
    have (őĺ : C(s, ‚ĄĚ‚Č•0)‚āÄ ‚Üí‚čÜ‚āô‚āź[‚ĄĚ‚Č•0] A) (hőĺ : Continuous őĺ) :
        (let őĺ' := őĺ.realContinuousMapZeroOfNNReal.comp <|
          ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚ĄĚ ‚ü®e, e0‚ü©;
          Continuous őĺ' ‚ąß őĺ' (.id s') = őĺ (.id s)) := by
      intro őĺ'
      refine ‚ü®őĺ.continuous_realContinuousMapZeroOfNNReal hőĺ |>.comp <| ?_, ?_‚ü©
      ¬∑ rw [continuous_induced_rng]
        exact ContinuousMap.continuous_precomp _ |>.comp continuous_induced_dom
      ¬∑ exact őĺ.realContinuousMapZeroOfNNReal_apply_comp_toReal (.id _)
    obtain ‚ü®hŌÜ', hŌÜ_id‚ü© := this ŌÜ hŌÜ
    obtain ‚ü®hŌą', hŌą_id‚ü© := this Ōą hŌą
    have hs' : CompactSpace s' := e.compactSpace
    have : ContinuousMapZero.UniqueHom ‚ĄĚ A := inferInstance
    have h' := ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id
      s' _ _ hŌÜ' hŌą' (hŌÜ_id ‚Ėł hŌą_id ‚Ėł h)
    have h'' := congr($(h').comp <|
      ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚ĄĚ ‚ü®(e.symm : C(s', s)), e0'‚ü©)
    have : (ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚ĄĚ ‚ü®(e : C(s, s')), e0‚ü©).comp
        (ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚ĄĚ ‚ü®(e.symm : C(s', s)), e0'‚ü©) =
        NonUnitalStarAlgHom.id _ _ := by
      ext; simp
    simp only [NonUnitalStarAlgHom.comp_assoc, this, NonUnitalStarAlgHom.comp_id] at h''
    exact NonUnitalStarAlgHom.realContinuousMapZeroOfNNReal_injective h''

end NNReal

