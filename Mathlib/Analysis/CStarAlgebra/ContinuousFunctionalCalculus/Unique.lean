/-!
# Uniqueness of the continuous functional calculus

Let `s : Set рЭХЬ` be compact where `рЭХЬ` is either `вДЭ` or `вДВ`. By the Stone-Weierstrass theorem, the
(star) subalgebra generated by polynomial functions on `s` is dense in `C(s, рЭХЬ)`. Moreover, this
star subalgebra is generated by `X : рЭХЬ[X]` (i.e., `ContinuousMap.restrict s (.id рЭХЬ)`) alone.
Consequently, any continuous star `рЭХЬ`-algebra homomorphism with domain `C(s, рЭХЬ)`, is uniquely
determined by its value on `X : рЭХЬ[X]`.

The same is true for `рЭХЬ := вДЭвЙ•0`, so long as the algebra `A` is an `вДЭ`-algebra, which we establish
by upgrading a map `C((s : Set вДЭвЙ•0), вДЭвЙ•0) вЖТвЛЖвВР[вДЭвЙ•0] A` to `C(((вЖС) '' s : Set вДЭ), вДЭ) вЖТвЛЖвВР[вДЭ] A` in
the natural way, and then applying the uniqueness for `вДЭ`-algebra homomorphisms.

This is the reason the `ContinuousMap.UniqueHom` class exists in the first place, as
opposed to simply appealing directly to Stone-Weierstrass to prove `StarAlgHom.ext_continuousMap`.
-/

@[expose] public section

open Topology

section UniqueUnital

section RCLike

variable {рЭХЬ A : Type*} [RCLike рЭХЬ]

instance (priority := 100) RCLike.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra рЭХЬ A] :
    ContinuousMap.UniqueHom рЭХЬ A where
  eq_of_continuous_of_map_id s _ ѕЖ ѕИ hѕЖ hѕИ h :=
    ContinuousMap.starAlgHom_ext_map_X hѕЖ hѕИ <| by
      convert h using 1
      all_goals exact congr_arg _ (by ext; simp)

instance Real.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra вДЭ A] :
    ContinuousMap.UniqueHom вДЭ A :=
  inferInstance

instance Complex.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra вДВ A] :
    ContinuousMap.UniqueHom вДВ A :=
  inferInstance

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X]

namespace ContinuousMap

/-- This map sends `f : C(X, вДЭ)` to `Real.toNNReal вИШ f`, bundled as a continuous map `C(X, вДЭвЙ•0)`. -/
noncomputable def toNNReal (f : C(X, вДЭ)) : C(X, вДЭвЙ•0) := .realToNNReal |>.comp f

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := continuous_postcomp _

@[simp]
lemma toNNReal_apply (f : C(X, вДЭ)) (x : X) : f.toNNReal x = (f x).toNNReal := rfl

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, вДЭ)) :
    (f + g).toNNReal + (-f).toNNReal + (-g).toNNReal =
      (-(f + g)).toNNReal + f.toNNReal + g.toNNReal := by
  ext x
  simp [max_neg_zero, -neg_add_rev]
  abel

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, вДЭ)) :
    (f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal =
      (-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal := by
  ext x
  simp [max_neg_zero, add_mul, mul_add]
  abel

@[simp]
lemma toNNReal_algebraMap (r : вДЭвЙ•0) :
    (algebraMap вДЭ C(X, вДЭ) r).toNNReal = algebraMap вДЭвЙ•0 C(X, вДЭвЙ•0) r := by
  ext; simp

@[simp]
lemma toNNReal_neg_algebraMap (r : вДЭвЙ•0) : (- algebraMap вДЭ C(X, вДЭ) r).toNNReal = 0 := by
  ext; simp

@[simp]
lemma toNNReal_one : (1 : C(X, вДЭ)).toNNReal = 1 := toNNReal_algebraMap 1

@[simp]
lemma toNNReal_neg_one : (-1 : C(X, вДЭ)).toNNReal = 0 := toNNReal_neg_algebraMap 1

end ContinuousMap

variable {A : Type*} [Ring A] [StarRing A] [Algebra вДЭ A]

namespace StarAlgHom

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a star `вДЭвЙ•0`-algebra homomorphism `ѕЖ` from `C(X, вДЭвЙ•0)` into an `вДЭ`-algebra `A`, this is
the unique extension of `ѕЖ` from `C(X, вДЭ)` to `A` as a star `вДЭ`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapOfNNReal (ѕЖ : C(X, вДЭвЙ•0) вЖТвЛЖвВР[вДЭвЙ•0] A) :
    C(X, вДЭ) вЖТвЛЖвВР[вДЭ] A where
  toFun f := ѕЖ f.toNNReal - ѕЖ (-f).toNNReal
  map_one' := by simp
  map_zero' := by simp
  map_mul' f g := by
    have := congr(ѕЖ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this вКҐ
    rw [вЖР sub_eq_zero] at this вКҐ
    convert this using 1
    abel
  map_add' f g := by
    have := congr(ѕЖ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this вКҐ
    rw [вЖР sub_eq_zero] at this вКҐ
    convert this using 1
    abel
  commutes' r := by
    obtain (hr | hr) := le_total 0 r
    ¬Ј lift r to вДЭвЙ•0 using hr
      simpa only [ContinuousMap.toNNReal_algebraMap, ContinuousMap.toNNReal_neg_algebraMap,
        map_zero, sub_zero] using AlgHomClass.commutes ѕЖ r
    ¬Ј rw [вЖР neg_neg r, вЖР map_neg, neg_neg (-r)]
      rw [вЖР neg_nonneg] at hr
      lift -r to вДЭвЙ•0 using hr with r
      simpa only [map_neg, ContinuousMap.toNNReal_neg_algebraMap, map_zero,
        ContinuousMap.toNNReal_algebraMap, zero_sub, neg_inj] using AlgHomClass.commutes ѕЖ r
  map_star' f := by simp only [star_trivial, star_sub, вЖР map_star]

@[fun_prop]
lemma continuous_realContinuousMapOfNNReal (ѕЖ : C(X, вДЭвЙ•0) вЖТвЛЖвВР[вДЭвЙ•0] A)
    (hѕЖ : Continuous ѕЖ) : Continuous ѕЖ.realContinuousMapOfNNReal := by
  dsimp [realContinuousMapOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapOfNNReal_apply_comp_toReal (ѕЖ : C(X, вДЭвЙ•0) вЖТвЛЖвВР[вДЭвЙ•0] A)
    (f : C(X, вДЭвЙ•0)) :
    ѕЖ.realContinuousMapOfNNReal ((ContinuousMap.mk toReal continuous_coe).comp f) = ѕЖ f := by
  simp only [realContinuousMapOfNNReal_apply]
  convert_to ѕЖ f - ѕЖ 0 = ѕЖ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapOfNNReal_injective :
    Function.Injective (realContinuousMapOfNNReal (X := X) (A := A)) := by
  intro ѕЖ ѕИ h
  ext f
  simpa using congr($(h) ((ContinuousMap.mk toReal continuous_coe).comp f))

end StarAlgHom

variable [TopologicalSpace A] [IsSemitopologicalRing A]

instance NNReal.instContinuousMap.UniqueHom [T2Space A] :
    ContinuousMap.UniqueHom вДЭвЙ•0 A where
  eq_of_continuous_of_map_id s hs ѕЖ ѕИ hѕЖ hѕИ h := by
    let s' : Set вДЭ := (вЖС) '' s
    let e : s вЙГвВЬ s' := NNReal.isEmbedding_coe.homeomorphImage s
    have (ќЊ : C(s, вДЭвЙ•0) вЖТвЛЖвВР[вДЭвЙ•0] A) (hќЊ : Continuous ќЊ) :
        (let ќЊ' := ќЊ.realContinuousMapOfNNReal.comp <| ContinuousMap.compStarAlgHom' вДЭ вДЭ e
        Continuous ќЊ' вИІ ќЊ' (.restrict s' <| .id вДЭ) = ќЊ (.restrict s <| .id вДЭвЙ•0)) := by
      intro ќЊ'
      refine вЯ®ќЊ.continuous_realContinuousMapOfNNReal hќЊ |>.comp <|
        ContinuousMap.continuous_precomp _, ?_вЯ©
      exact ќЊ.realContinuousMapOfNNReal_apply_comp_toReal (.restrict s <| .id вДЭвЙ•0)
    obtain вЯ®hѕЖ', hѕЖ_idвЯ© := this ѕЖ hѕЖ
    obtain вЯ®hѕИ', hѕИ_idвЯ© := this ѕИ hѕИ
    have hs' : CompactSpace s' := e.compactSpace
    have h' := ContinuousMap.UniqueHom.eq_of_continuous_of_map_id s' _ _ hѕЖ' hѕИ'
      (hѕЖ_id вЦЄ hѕИ_id вЦЄ h)
    have h'' := congr($(h').comp <| ContinuousMap.compStarAlgHom' вДЭ вДЭ (e.symm : C(s', s)))
    have : (ContinuousMap.compStarAlgHom' вДЭ вДЭ (e : C(s, s'))).comp
        (ContinuousMap.compStarAlgHom' вДЭ вДЭ (e.symm : C(s', s))) = StarAlgHom.id _ _ := by
      ext1; simp
    simp only [StarAlgHom.comp_assoc, this, StarAlgHom.comp_id] at h''
    exact StarAlgHom.realContinuousMapOfNNReal_injective h''

end NNReal

end UniqueUnital

section UniqueNonUnital

section RCLike

variable {рЭХЬ A : Type*} [RCLike рЭХЬ]

open NonUnitalStarAlgebra in
instance RCLike.uniqueNonUnitalContinuousFunctionalCalculus
    [TopologicalSpace A] [T2Space A] [NonUnitalRing A] [StarRing A] [Module рЭХЬ A]
    [IsScalarTower рЭХЬ A A] [SMulCommClass рЭХЬ A A] :
    ContinuousMapZero.UniqueHom рЭХЬ A where
  eq_of_continuous_of_map_id s hs h0 ѕЖ ѕИ hѕЖ hѕИ h := by
    rw [DFunLike.ext'_iff, вЖР Set.eqOn_univ, вЖР (ContinuousMapZero.adjoin_id_dense _).closure_eq]
    refine Set.EqOn.closure (fun f hf вЖ¶ ?_) hѕЖ hѕИ
    rw [вЖР NonUnitalStarAlgHom.mem_equalizer]
    apply adjoin_le ?_ hf
    rw [Set.singleton_subset_iff]
    exact h

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X] [Zero X]

namespace ContinuousMapZero

/-- This map sends `f : C(X, вДЭ)` to `Real.toNNReal вИШ f`, bundled as a continuous map `C(X, вДЭвЙ•0)`. -/
noncomputable def toNNReal (f : C(X, вДЭ)вВА) : C(X, вДЭвЙ•0)вВА := вЯ®.realToNNReal |>.comp f, by simpвЯ©

@[simp]
lemma toNNReal_apply (f : C(X, вДЭ)вВА) (x : X) : f.toNNReal x = Real.toNNReal (f x) := rfl

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := by
  rw [continuous_induced_rng]
  convert_to Continuous (ContinuousMap.toNNReal вИШ ((вЖС) : C(X, вДЭ)вВА вЖТ C(X, вДЭ))) using 1
  exact ContinuousMap.continuous_postcomp _ |>.comp continuous_induced_dom

lemma toContinuousMapHom_toNNReal (f : C(X, вДЭ)вВА) :
    (toContinuousMapHom (X := X) (R := вДЭ) f).toNNReal =
      toContinuousMapHom (X := X) (R := вДЭвЙ•0) f.toNNReal :=
  rfl

@[simp]
lemma toNNReal_smul (r : вДЭвЙ•0) (f : C(X, вДЭ)вВА) : (r вАҐ f).toNNReal = r вАҐ f.toNNReal := by
  ext x
  by_cases! h : 0 вЙ§ f x
  ¬Ј simpa [max_eq_left h, NNReal.smul_def] using mul_nonneg r.coe_nonneg h
  ¬Ј simpa [max_eq_right h.le, NNReal.smul_def]
      using mul_nonpos_of_nonneg_of_nonpos r.coe_nonneg h.le

@[simp]
lemma toNNReal_neg_smul (r : вДЭвЙ•0) (f : C(X, вДЭ)вВА) : (-(r вАҐ f)).toNNReal = r вАҐ (-f).toNNReal := by
  simpa [smul_neg] using (toNNReal_smul (X := X) r (-f))

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, вДЭ)вВА) :
    ((f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal) =
    ((-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal) := by
  apply toContinuousMap_injective
  simpa only [вЖР toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, вДЭ)).toNNReal_mul_add_neg_mul_add_mul_neg_eq g

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, вДЭ)вВА) :
    ((f + g).toNNReal + (-f).toNNReal + (-g).toNNReal) =
      ((-(f + g)).toNNReal + f.toNNReal + g.toNNReal) := by
  apply toContinuousMap_injective
  simpa only [вЖР toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, вДЭ)).toNNReal_add_add_neg_add_neg_eq g

end ContinuousMapZero

variable {A : Type*} [NonUnitalRing A] [StarRing A] [Module вДЭ A]

namespace NonUnitalStarAlgHom

open ContinuousMapZero

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a non-unital star `вДЭвЙ•0`-algebra homomorphism `ѕЖ` from `C(X, вДЭвЙ•0)вВА` into a non-unital
`вДЭ`-algebra `A`, this is the unique extension of `ѕЖ` from `C(X, вДЭ)вВА` to `A` as a non-unital
star `вДЭ`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapZeroOfNNReal (ѕЖ : C(X, вДЭвЙ•0)вВА вЖТвЛЖвВЩвВР[вДЭвЙ•0] A) :
    C(X, вДЭ)вВА вЖТвЛЖвВЩвВР[вДЭ] A where
  toFun f := ѕЖ f.toNNReal - ѕЖ (-f).toNNReal
  map_zero' := by simp
  map_mul' f g := by
    have := congr(ѕЖ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this вКҐ
    rw [вЖР sub_eq_zero] at this вКҐ
    rw [вЖР this]
    abel
  map_add' f g := by
    have := congr(ѕЖ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this вКҐ
    rw [вЖР sub_eq_zero] at this вКҐ
    rw [вЖР this]
    abel
  map_smul' r f := by
    simp only [MonoidHom.id_apply]
    by_cases! hr : 0 вЙ§ r
    ¬Ј lift r to вДЭвЙ•0 using hr
      simp only [вЖР smul_def, toNNReal_smul, map_smul, toNNReal_neg_smul, smul_sub]
    ¬Ј rw [вЖР neg_pos] at hr
      rw [вЖР neg_smul]
      nth_rw 1 [вЖР neg_neg r]
      nth_rw 3 [вЖР neg_neg r]
      lift -r to вДЭвЙ•0 using hr.le with r
      simp only [neg_smul, вЖР smul_def, toNNReal_neg_smul, map_smul, toNNReal_smul, smul_sub,
        sub_neg_eq_add]
      rw [sub_eq_add_neg, add_comm]
  map_star' f := by simp only [star_trivial, star_sub, вЖР map_star]

set_option backward.isDefEq.respectTransparency false in
@[fun_prop]
lemma continuous_realContinuousMapZeroOfNNReal (ѕЖ : C(X, вДЭвЙ•0)вВА вЖТвЛЖвВЩвВР[вДЭвЙ•0] A)
    (hѕЖ : Continuous ѕЖ) : Continuous ѕЖ.realContinuousMapZeroOfNNReal := by
  dsimp [realContinuousMapZeroOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapZeroOfNNReal_apply_comp_toReal (ѕЖ : C(X, вДЭвЙ•0)вВА вЖТвЛЖвВЩвВР[вДЭвЙ•0] A)
    (f : C(X, вДЭвЙ•0)вВА) :
    ѕЖ.realContinuousMapZeroOfNNReal ((ContinuousMapZero.mk вЯ®toReal, continuous_coeвЯ© rfl).comp f) =
      ѕЖ f := by
  simp only [realContinuousMapZeroOfNNReal_apply]
  convert_to ѕЖ f - ѕЖ 0 = ѕЖ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapZeroOfNNReal_injective :
    Function.Injective (realContinuousMapZeroOfNNReal (X := X) (A := A)) := by
  intro ѕЖ ѕИ h
  ext f
  simpa using congr($(h) ((ContinuousMapZero.mk вЯ®toReal, continuous_coeвЯ© rfl).comp f))

end NonUnitalStarAlgHom

open ContinuousMapZero

instance NNReal.instContinuousMapZero.UniqueHom
    [TopologicalSpace A] [IsSemitopologicalRing A] [IsScalarTower вДЭ A A] [SMulCommClass вДЭ A A]
    [T2Space A] :
    ContinuousMapZero.UniqueHom вДЭвЙ•0 A where
  eq_of_continuous_of_map_id s hs h0 ѕЖ ѕИ hѕЖ hѕИ h := by
    let s' : Set вДЭ := (вЖС) '' s
    let e : s вЙГвВЬ s' := NNReal.isEmbedding_coe.homeomorphImage s
    have hs' : Fact (0 вИИ s') := вЯ®0, Fact.out, coe_zeroвЯ©
    have e0 : e вЯ®0, Fact.outвЯ© = вЯ®0, hs'.outвЯ© := by
      rfl
    have e0' : e.symm 0 = 0 := by
      simpa only [Homeomorph.symm_apply_apply] using congr(e.symm $(e0)).symm
    have (ќЊ : C(s, вДЭвЙ•0)вВА вЖТвЛЖвВЩвВР[вДЭвЙ•0] A) (hќЊ : Continuous ќЊ) :
        (let ќЊ' := ќЊ.realContinuousMapZeroOfNNReal.comp <|
          ContinuousMapZero.nonUnitalStarAlgHom_precomp вДЭ вЯ®e, e0вЯ©;
          Continuous ќЊ' вИІ ќЊ' (.id s') = ќЊ (.id s)) := by
      intro ќЊ'
      refine вЯ®ќЊ.continuous_realContinuousMapZeroOfNNReal hќЊ |>.comp <| ?_, ?_вЯ©
      ¬Ј rw [continuous_induced_rng]
        exact ContinuousMap.continuous_precomp _ |>.comp continuous_induced_dom
      ¬Ј exact ќЊ.realContinuousMapZeroOfNNReal_apply_comp_toReal (.id _)
    obtain вЯ®hѕЖ', hѕЖ_idвЯ© := this ѕЖ hѕЖ
    obtain вЯ®hѕИ', hѕИ_idвЯ© := this ѕИ hѕИ
    have hs' : CompactSpace s' := e.compactSpace
    have : ContinuousMapZero.UniqueHom вДЭ A := inferInstance
    have h' := ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id
      s' _ _ hѕЖ' hѕИ' (hѕЖ_id вЦЄ hѕИ_id вЦЄ h)
    have h'' := congr($(h').comp <|
      ContinuousMapZero.nonUnitalStarAlgHom_precomp вДЭ вЯ®(e.symm : C(s', s)), e0'вЯ©)
    have : (ContinuousMapZero.nonUnitalStarAlgHom_precomp вДЭ вЯ®(e : C(s, s')), e0вЯ©).comp
        (ContinuousMapZero.nonUnitalStarAlgHom_precomp вДЭ вЯ®(e.symm : C(s', s)), e0'вЯ©) =
        NonUnitalStarAlgHom.id _ _ := by
      ext; simp
    simp only [NonUnitalStarAlgHom.comp_assoc, this, NonUnitalStarAlgHom.comp_id] at h''
    exact NonUnitalStarAlgHom.realContinuousMapZeroOfNNReal_injective h''

end NNReal

end UniqueNonUnital

section NonUnitalStarAlgHom

open scoped ContinuousMapZero NonUnitalContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A вЖТ Prop} {q : B вЖТ Prop}
  [CommSemiring R] [Nontrivial R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R]
  [ContinuousStar R] [CommRing S] [Algebra R S]
  [NonUnitalRing A] [StarRing A] [TopologicalSpace A] [Module R A]
  [IsScalarTower R A A] [SMulCommClass R A A]
  [NonUnitalRing B] [StarRing B] [TopologicalSpace B] [Module R B]
  [IsScalarTower R B B] [SMulCommClass R B B]
  [Module S A] [Module S B] [IsScalarTower R S A] [IsScalarTower R S B]
  [NonUnitalContinuousFunctionalCalculus R A p] [NonUnitalContinuousFunctionalCalculus R B q]
  [ContinuousMapZero.UniqueHom R B] [FunLike F A B] [NonUnitalAlgHomClass F S A B]
  [StarHomClass F A B]

set_option backward.isDefEq.respectTransparency false in
include S in
/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus. -/
lemma NonUnitalStarAlgHomClass.map_cfcвВЩ (ѕЖ : F) (f : R вЖТ R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hfвВА : f 0 = 0 := by cfc_zero_tac) (hѕЖ : Continuous ѕЖ := by fun_prop) (ha : p a := by cfc_tac)
    (hѕЖa : q (ѕЖ a) := by cfc_tac) : ѕЖ (cfcвВЩ f a) = cfcвВЩ f (ѕЖ a) := by
  let ѕИ : A вЖТвЛЖвВЩвВР[R] B := (ѕЖ : A вЖТвЛЖвВЩвВР[S] B).restrictScalars R
  have : Continuous ѕИ := hѕЖ
  have h_spec := NonUnitalAlgHom.quasispectrum_apply_subset' (R := R) S ѕЖ a
  have hѕИa : q (ѕИ a) := hѕЖa
  let ќє : C(quasispectrum R (ѕИ a), quasispectrum R a)вВА :=
    вЯ®вЯ®Set.inclusion h_spec, continuous_id.subtype_map h_specвЯ©, rflвЯ©
  suffices ѕИ.comp (cfcвВЩHom ha) =
      (cfcвВЩHom hѕИa).comp (ContinuousMapZero.nonUnitalStarAlgHom_precomp R ќє) by
    have hf' : ContinuousOn f (quasispectrum R (ѕИ a)) := hf.mono h_spec
    rw [cfcвВЩ_apply .., cfcвВЩ_apply ..]
    exact DFunLike.congr_fun this _
  refine ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfcвВЩHom hѕИa (.id (quasispectrum R (ѕИ a)))
    ¬Ј simp [cfcвВЩHom_id]
    ¬Ј congr
  all_goals
    dsimp [ContinuousMapZero.nonUnitalStarAlgHom_precomp]
    fun_prop

/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus.  This version is specialized to `A вЖТвЛЖвВЩвВР[S] B` to allow for dot notation. -/
lemma NonUnitalStarAlgHom.map_cfcвВЩ (ѕЖ : A вЖТвЛЖвВЩвВР[S] B) (f : R вЖТ R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hfвВА : f 0 = 0 := by cfc_zero_tac) (hѕЖ : Continuous ѕЖ := by fun_prop) (ha : p a := by cfc_tac)
    (hѕЖa : q (ѕЖ a) := by cfc_tac) : ѕЖ (cfcвВЩ f a) = cfcвВЩ f (ѕЖ a) :=
  NonUnitalStarAlgHomClass.map_cfcвВЩ ѕЖ f a

end NonUnitalStarAlgHom

section StarAlgHom

open scoped ContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A вЖТ Prop} {q : B вЖТ Prop}
  [CommSemiring R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R] [ContinuousStar R]
  [Ring A] [StarRing A] [TopologicalSpace A] [Algebra R A]
  [Ring B] [StarRing B] [TopologicalSpace B] [Algebra R B]
  [CommSemiring S] [Algebra R S] [Algebra S A] [Algebra S B] [IsScalarTower R S A]
  [IsScalarTower R S B] [ContinuousFunctionalCalculus R A p] [ContinuousFunctionalCalculus R B q]
  [ContinuousMap.UniqueHom R B] [FunLike F A B] [AlgHomClass F S A B]
  [StarHomClass F A B]

include S in
/-- Star algebra homomorphisms commute with the continuous functional calculus. -/
lemma StarAlgHomClass.map_cfc (ѕЖ : F) (f : R вЖТ R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac)
    (hѕЖ : Continuous ѕЖ := by fun_prop) (ha : p a := by cfc_tac) (hѕЖa : q (ѕЖ a) := by cfc_tac) :
    ѕЖ (cfc f a) = cfc f (ѕЖ a) := by
  let ѕИ : A вЖТвЛЖвВР[R] B := (ѕЖ : A вЖТвЛЖвВР[S] B).restrictScalars R
  have : Continuous ѕИ := hѕЖ
  have h_spec := AlgHom.spectrum_apply_subset ѕИ a
  have hѕИa : q (ѕИ a) := hѕЖa
  let ќє : C(spectrum R (ѕИ a), spectrum R a) :=
    вЯ®Set.inclusion h_spec, continuous_id.subtype_map h_specвЯ©
  suffices ѕИ.comp (cfcHom ha) = (cfcHom hѕИa).comp (ContinuousMap.compStarAlgHom' R R ќє) by
    have hf' : ContinuousOn f (spectrum R (ѕИ a)) := hf.mono h_spec
    rw [cfc_apply .., cfc_apply ..]
    congrm($(this) вЯ®_, hf.restrictвЯ©)
  refine ContinuousMap.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfcHom hѕИa (.restrict (spectrum R (ѕИ a)) (.id R))
    ¬Ј simp [cfcHom_id]
    ¬Ј congr
  all_goals
    dsimp [ContinuousMap.compStarAlgHom']
    fun_prop

/-- Star algebra homomorphisms commute with the continuous functional calculus.
This version is specialized to `A вЖТвЛЖвВР[S] B` to allow for dot notation. -/
lemma StarAlgHom.map_cfc (ѕЖ : A вЖТвЛЖвВР[S] B) (f : R вЖТ R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac) (hѕЖ : Continuous ѕЖ := by fun_prop)
    (ha : p a := by cfc_tac) (hѕЖa : q (ѕЖ a) := by cfc_tac) :
    ѕЖ (cfc f a) = cfc f (ѕЖ a) :=
  StarAlgHomClass.map_cfc ѕЖ f a

end StarAlgHom
