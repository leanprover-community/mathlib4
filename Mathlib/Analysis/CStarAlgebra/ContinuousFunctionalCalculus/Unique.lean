/-!
# Uniqueness of the continuous functional calculus

Let `s : Set ùïú` be compact where `ùïú` is either `‚Ñù` or `‚ÑÇ`. By the Stone-Weierstrass theorem, the
(star) subalgebra generated by polynomial functions on `s` is dense in `C(s, ùïú)`. Moreover, this
star subalgebra is generated by `X : ùïú[X]` (i.e., `ContinuousMap.restrict s (.id ùïú)`) alone.
Consequently, any continuous star `ùïú`-algebra homomorphism with domain `C(s, ùïú)`, is uniquely
determined by its value on `X : ùïú[X]`.

The same is true for `ùïú := ‚Ñù‚â•0`, so long as the algebra `A` is an `‚Ñù`-algebra, which we establish
by upgrading a map `C((s : Set ‚Ñù‚â•0), ‚Ñù‚â•0) ‚Üí‚ãÜ‚Çê[‚Ñù‚â•0] A` to `C(((‚Üë) '' s : Set ‚Ñù), ‚Ñù) ‚Üí‚ãÜ‚Çê[‚Ñù] A` in
the natural way, and then applying the uniqueness for `‚Ñù`-algebra homomorphisms.

This is the reason the `ContinuousMap.UniqueHom` class exists in the first place, as
opposed to simply appealing directly to Stone-Weierstrass to prove `StarAlgHom.ext_continuousMap`.
-/

@[expose] public section

open Topology

section UniqueUnital

section RCLike

variable {ùïú A : Type*} [RCLike ùïú]

instance (priority := 100) RCLike.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ùïú A] :
    ContinuousMap.UniqueHom ùïú A where
  eq_of_continuous_of_map_id s _ œÜ œà hœÜ hœà h :=
    ContinuousMap.starAlgHom_ext_map_X hœÜ hœà <| by
      convert h using 1
      all_goals exact congr_arg _ (by ext; simp)

instance Real.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ‚Ñù A] :
    ContinuousMap.UniqueHom ‚Ñù A :=
  inferInstance

instance Complex.instContinuousMapUniqueHom [TopologicalSpace A]
    [T2Space A] [Ring A] [StarRing A] [Algebra ‚ÑÇ A] :
    ContinuousMap.UniqueHom ‚ÑÇ A :=
  inferInstance

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X]

namespace ContinuousMap

/-- This map sends `f : C(X, ‚Ñù)` to `Real.toNNReal ‚àò f`, bundled as a continuous map `C(X, ‚Ñù‚â•0)`. -/
noncomputable def toNNReal (f : C(X, ‚Ñù)) : C(X, ‚Ñù‚â•0) := .realToNNReal |>.comp f

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := continuous_postcomp _

@[simp]
lemma toNNReal_apply (f : C(X, ‚Ñù)) (x : X) : f.toNNReal x = (f x).toNNReal := rfl

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, ‚Ñù)) :
    (f + g).toNNReal + (-f).toNNReal + (-g).toNNReal =
      (-(f + g)).toNNReal + f.toNNReal + g.toNNReal := by
  ext x
  simp [max_neg_zero, -neg_add_rev]
  abel

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, ‚Ñù)) :
    (f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal =
      (-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal := by
  ext x
  simp [max_neg_zero, add_mul, mul_add]
  abel

@[simp]
lemma toNNReal_algebraMap (r : ‚Ñù‚â•0) :
    (algebraMap ‚Ñù C(X, ‚Ñù) r).toNNReal = algebraMap ‚Ñù‚â•0 C(X, ‚Ñù‚â•0) r := by
  ext; simp

@[simp]
lemma toNNReal_neg_algebraMap (r : ‚Ñù‚â•0) : (- algebraMap ‚Ñù C(X, ‚Ñù) r).toNNReal = 0 := by
  ext; simp

@[simp]
lemma toNNReal_one : (1 : C(X, ‚Ñù)).toNNReal = 1 := toNNReal_algebraMap 1

@[simp]
lemma toNNReal_neg_one : (-1 : C(X, ‚Ñù)).toNNReal = 0 := toNNReal_neg_algebraMap 1

end ContinuousMap

variable {A : Type*} [Ring A] [StarRing A] [Algebra ‚Ñù A]

namespace StarAlgHom

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a star `‚Ñù‚â•0`-algebra homomorphism `œÜ` from `C(X, ‚Ñù‚â•0)` into an `‚Ñù`-algebra `A`, this is
the unique extension of `œÜ` from `C(X, ‚Ñù)` to `A` as a star `‚Ñù`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapOfNNReal (œÜ : C(X, ‚Ñù‚â•0) ‚Üí‚ãÜ‚Çê[‚Ñù‚â•0] A) :
    C(X, ‚Ñù) ‚Üí‚ãÜ‚Çê[‚Ñù] A where
  toFun f := œÜ f.toNNReal - œÜ (-f).toNNReal
  map_one' := by simp
  map_zero' := by simp
  map_mul' f g := by
    have := congr(œÜ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this ‚ä¢
    rw [‚Üê sub_eq_zero] at this ‚ä¢
    convert this using 1
    abel
  map_add' f g := by
    have := congr(œÜ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this ‚ä¢
    rw [‚Üê sub_eq_zero] at this ‚ä¢
    convert this using 1
    abel
  commutes' r := by
    obtain (hr | hr) := le_total 0 r
    ¬∑ lift r to ‚Ñù‚â•0 using hr
      simpa only [ContinuousMap.toNNReal_algebraMap, ContinuousMap.toNNReal_neg_algebraMap,
        map_zero, sub_zero] using AlgHomClass.commutes œÜ r
    ¬∑ rw [‚Üê neg_neg r, ‚Üê map_neg, neg_neg (-r)]
      rw [‚Üê neg_nonneg] at hr
      lift -r to ‚Ñù‚â•0 using hr with r
      simpa only [map_neg, ContinuousMap.toNNReal_neg_algebraMap, map_zero,
        ContinuousMap.toNNReal_algebraMap, zero_sub, neg_inj] using AlgHomClass.commutes œÜ r
  map_star' f := by simp only [star_trivial, star_sub, ‚Üê map_star]

@[fun_prop]
lemma continuous_realContinuousMapOfNNReal (œÜ : C(X, ‚Ñù‚â•0) ‚Üí‚ãÜ‚Çê[‚Ñù‚â•0] A)
    (hœÜ : Continuous œÜ) : Continuous œÜ.realContinuousMapOfNNReal := by
  dsimp [realContinuousMapOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapOfNNReal_apply_comp_toReal (œÜ : C(X, ‚Ñù‚â•0) ‚Üí‚ãÜ‚Çê[‚Ñù‚â•0] A)
    (f : C(X, ‚Ñù‚â•0)) :
    œÜ.realContinuousMapOfNNReal ((ContinuousMap.mk toReal continuous_coe).comp f) = œÜ f := by
  simp only [realContinuousMapOfNNReal_apply]
  convert_to œÜ f - œÜ 0 = œÜ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapOfNNReal_injective :
    Function.Injective (realContinuousMapOfNNReal (X := X) (A := A)) := by
  intro œÜ œà h
  ext f
  simpa using congr($(h) ((ContinuousMap.mk toReal continuous_coe).comp f))

end StarAlgHom

variable [TopologicalSpace A] [IsSemitopologicalRing A]

instance NNReal.instContinuousMap.UniqueHom [T2Space A] :
    ContinuousMap.UniqueHom ‚Ñù‚â•0 A where
  eq_of_continuous_of_map_id s hs œÜ œà hœÜ hœà h := by
    let s' : Set ‚Ñù := (‚Üë) '' s
    let e : s ‚âÉ‚Çú s' := NNReal.isEmbedding_coe.homeomorphImage s
    have (Œæ : C(s, ‚Ñù‚â•0) ‚Üí‚ãÜ‚Çê[‚Ñù‚â•0] A) (hŒæ : Continuous Œæ) :
        (let Œæ' := Œæ.realContinuousMapOfNNReal.comp <| ContinuousMap.compStarAlgHom' ‚Ñù ‚Ñù e
        Continuous Œæ' ‚àß Œæ' (.restrict s' <| .id ‚Ñù) = Œæ (.restrict s <| .id ‚Ñù‚â•0)) := by
      intro Œæ'
      refine ‚ü®Œæ.continuous_realContinuousMapOfNNReal hŒæ |>.comp <|
        ContinuousMap.continuous_precomp _, ?_‚ü©
      exact Œæ.realContinuousMapOfNNReal_apply_comp_toReal (.restrict s <| .id ‚Ñù‚â•0)
    obtain ‚ü®hœÜ', hœÜ_id‚ü© := this œÜ hœÜ
    obtain ‚ü®hœà', hœà_id‚ü© := this œà hœà
    have hs' : CompactSpace s' := e.compactSpace
    have h' := ContinuousMap.UniqueHom.eq_of_continuous_of_map_id s' _ _ hœÜ' hœà'
      (hœÜ_id ‚ñ∏ hœà_id ‚ñ∏ h)
    have h'' := congr($(h').comp <| ContinuousMap.compStarAlgHom' ‚Ñù ‚Ñù (e.symm : C(s', s)))
    have : (ContinuousMap.compStarAlgHom' ‚Ñù ‚Ñù (e : C(s, s'))).comp
        (ContinuousMap.compStarAlgHom' ‚Ñù ‚Ñù (e.symm : C(s', s))) = StarAlgHom.id _ _ := by
      ext1; simp
    simp only [StarAlgHom.comp_assoc, this, StarAlgHom.comp_id] at h''
    exact StarAlgHom.realContinuousMapOfNNReal_injective h''

end NNReal

end UniqueUnital

section UniqueNonUnital

section RCLike

variable {ùïú A : Type*} [RCLike ùïú]

open NonUnitalStarAlgebra in
instance RCLike.uniqueNonUnitalContinuousFunctionalCalculus
    [TopologicalSpace A] [T2Space A] [NonUnitalRing A] [StarRing A] [Module ùïú A]
    [IsScalarTower ùïú A A] [SMulCommClass ùïú A A] :
    ContinuousMapZero.UniqueHom ùïú A where
  eq_of_continuous_of_map_id s hs h0 œÜ œà hœÜ hœà h := by
    rw [DFunLike.ext'_iff, ‚Üê Set.eqOn_univ, ‚Üê (ContinuousMapZero.adjoin_id_dense _).closure_eq]
    refine Set.EqOn.closure (fun f hf ‚Ü¶ ?_) hœÜ hœà
    rw [‚Üê NonUnitalStarAlgHom.mem_equalizer]
    apply adjoin_le ?_ hf
    rw [Set.singleton_subset_iff]
    exact h

end RCLike

section NNReal
open NNReal

variable {X : Type*} [TopologicalSpace X] [Zero X]

namespace ContinuousMapZero

/-- This map sends `f : C(X, ‚Ñù)` to `Real.toNNReal ‚àò f`, bundled as a continuous map `C(X, ‚Ñù‚â•0)`. -/
noncomputable def toNNReal (f : C(X, ‚Ñù)‚ÇÄ) : C(X, ‚Ñù‚â•0)‚ÇÄ := ‚ü®.realToNNReal |>.comp f, by simp‚ü©

@[simp]
lemma toNNReal_apply (f : C(X, ‚Ñù)‚ÇÄ) (x : X) : f.toNNReal x = Real.toNNReal (f x) := rfl

@[fun_prop]
lemma continuous_toNNReal : Continuous (toNNReal (X := X)) := by
  rw [continuous_induced_rng]
  convert_to Continuous (ContinuousMap.toNNReal ‚àò ((‚Üë) : C(X, ‚Ñù)‚ÇÄ ‚Üí C(X, ‚Ñù))) using 1
  exact ContinuousMap.continuous_postcomp _ |>.comp continuous_induced_dom

lemma toContinuousMapHom_toNNReal (f : C(X, ‚Ñù)‚ÇÄ) :
    (toContinuousMapHom (X := X) (R := ‚Ñù) f).toNNReal =
      toContinuousMapHom (X := X) (R := ‚Ñù‚â•0) f.toNNReal :=
  rfl

@[simp]
lemma toNNReal_smul (r : ‚Ñù‚â•0) (f : C(X, ‚Ñù)‚ÇÄ) : (r ‚Ä¢ f).toNNReal = r ‚Ä¢ f.toNNReal := by
  ext x
  by_cases! h : 0 ‚â§ f x
  ¬∑ simpa [max_eq_left h, NNReal.smul_def] using mul_nonneg r.coe_nonneg h
  ¬∑ simpa [max_eq_right h.le, NNReal.smul_def]
      using mul_nonpos_of_nonneg_of_nonpos r.coe_nonneg h.le

@[simp]
lemma toNNReal_neg_smul (r : ‚Ñù‚â•0) (f : C(X, ‚Ñù)‚ÇÄ) : (-(r ‚Ä¢ f)).toNNReal = r ‚Ä¢ (-f).toNNReal := by
  simpa [smul_neg] using (toNNReal_smul (X := X) r (-f))

lemma toNNReal_mul_add_neg_mul_add_mul_neg_eq (f g : C(X, ‚Ñù)‚ÇÄ) :
    ((f * g).toNNReal + (-f).toNNReal * g.toNNReal + f.toNNReal * (-g).toNNReal) =
    ((-(f * g)).toNNReal + f.toNNReal * g.toNNReal + (-f).toNNReal * (-g).toNNReal) := by
  apply toContinuousMap_injective
  simpa only [‚Üê toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, ‚Ñù)).toNNReal_mul_add_neg_mul_add_mul_neg_eq g

lemma toNNReal_add_add_neg_add_neg_eq (f g : C(X, ‚Ñù)‚ÇÄ) :
    ((f + g).toNNReal + (-f).toNNReal + (-g).toNNReal) =
      ((-(f + g)).toNNReal + f.toNNReal + g.toNNReal) := by
  apply toContinuousMap_injective
  simpa only [‚Üê toContinuousMapHom_apply, map_add, map_mul, map_neg, toContinuousMapHom_toNNReal]
    using (f : C(X, ‚Ñù)).toNNReal_add_add_neg_add_neg_eq g

end ContinuousMapZero

variable {A : Type*} [NonUnitalRing A] [StarRing A] [Module ‚Ñù A]

namespace NonUnitalStarAlgHom

open ContinuousMapZero

section IsTopologicalRing

variable [TopologicalSpace A] [IsSemitopologicalRing A]

/-- Given a non-unital star `‚Ñù‚â•0`-algebra homomorphism `œÜ` from `C(X, ‚Ñù‚â•0)‚ÇÄ` into a non-unital
`‚Ñù`-algebra `A`, this is the unique extension of `œÜ` from `C(X, ‚Ñù)‚ÇÄ` to `A` as a non-unital
star `‚Ñù`-algebra homomorphism. -/
@[simps]
noncomputable def realContinuousMapZeroOfNNReal (œÜ : C(X, ‚Ñù‚â•0)‚ÇÄ ‚Üí‚ãÜ‚Çô‚Çê[‚Ñù‚â•0] A) :
    C(X, ‚Ñù)‚ÇÄ ‚Üí‚ãÜ‚Çô‚Çê[‚Ñù] A where
  toFun f := œÜ f.toNNReal - œÜ (-f).toNNReal
  map_zero' := by simp
  map_mul' f g := by
    have := congr(œÜ $(f.toNNReal_mul_add_neg_mul_add_mul_neg_eq g))
    simp only [map_add, map_mul, sub_mul, mul_sub] at this ‚ä¢
    rw [‚Üê sub_eq_zero] at this ‚ä¢
    rw [‚Üê this]
    abel
  map_add' f g := by
    have := congr(œÜ $(f.toNNReal_add_add_neg_add_neg_eq g))
    simp only [map_add] at this ‚ä¢
    rw [‚Üê sub_eq_zero] at this ‚ä¢
    rw [‚Üê this]
    abel
  map_smul' r f := by
    simp only [MonoidHom.id_apply]
    by_cases! hr : 0 ‚â§ r
    ¬∑ lift r to ‚Ñù‚â•0 using hr
      simp only [‚Üê smul_def, toNNReal_smul, map_smul, toNNReal_neg_smul, smul_sub]
    ¬∑ rw [‚Üê neg_pos] at hr
      rw [‚Üê neg_smul]
      nth_rw 1 [‚Üê neg_neg r]
      nth_rw 3 [‚Üê neg_neg r]
      lift -r to ‚Ñù‚â•0 using hr.le with r
      simp only [neg_smul, ‚Üê smul_def, toNNReal_neg_smul, map_smul, toNNReal_smul, smul_sub,
        sub_neg_eq_add]
      rw [sub_eq_add_neg, add_comm]
  map_star' f := by simp only [star_trivial, star_sub, ‚Üê map_star]

set_option backward.isDefEq.respectTransparency false in
@[fun_prop]
lemma continuous_realContinuousMapZeroOfNNReal (œÜ : C(X, ‚Ñù‚â•0)‚ÇÄ ‚Üí‚ãÜ‚Çô‚Çê[‚Ñù‚â•0] A)
    (hœÜ : Continuous œÜ) : Continuous œÜ.realContinuousMapZeroOfNNReal := by
  dsimp [realContinuousMapZeroOfNNReal]
  fun_prop

end IsTopologicalRing

@[simp high]
lemma realContinuousMapZeroOfNNReal_apply_comp_toReal (œÜ : C(X, ‚Ñù‚â•0)‚ÇÄ ‚Üí‚ãÜ‚Çô‚Çê[‚Ñù‚â•0] A)
    (f : C(X, ‚Ñù‚â•0)‚ÇÄ) :
    œÜ.realContinuousMapZeroOfNNReal ((ContinuousMapZero.mk ‚ü®toReal, continuous_coe‚ü© rfl).comp f) =
      œÜ f := by
  simp only [realContinuousMapZeroOfNNReal_apply]
  convert_to œÜ f - œÜ 0 = œÜ f using 2
  on_goal -1 => rw [map_zero, sub_zero]
  all_goals
    congr
    ext x
    simp

lemma realContinuousMapZeroOfNNReal_injective :
    Function.Injective (realContinuousMapZeroOfNNReal (X := X) (A := A)) := by
  intro œÜ œà h
  ext f
  simpa using congr($(h) ((ContinuousMapZero.mk ‚ü®toReal, continuous_coe‚ü© rfl).comp f))

end NonUnitalStarAlgHom

open ContinuousMapZero

instance NNReal.instContinuousMapZero.UniqueHom
    [TopologicalSpace A] [IsSemitopologicalRing A] [IsScalarTower ‚Ñù A A] [SMulCommClass ‚Ñù A A]
    [T2Space A] :
    ContinuousMapZero.UniqueHom ‚Ñù‚â•0 A where
  eq_of_continuous_of_map_id s hs h0 œÜ œà hœÜ hœà h := by
    let s' : Set ‚Ñù := (‚Üë) '' s
    let e : s ‚âÉ‚Çú s' := NNReal.isEmbedding_coe.homeomorphImage s
    have : Fact (0 ‚àà s') := ‚ü®0, Fact.out, coe_zero‚ü©
    have e0 : e 0 = 0 := rfl
    have e0' : e.symm 0 = 0 := e.symm_apply_eq.mpr e0
    have (Œæ : C(s, ‚Ñù‚â•0)‚ÇÄ ‚Üí‚ãÜ‚Çô‚Çê[‚Ñù‚â•0] A) (hŒæ : Continuous Œæ) :
        (let Œæ' := Œæ.realContinuousMapZeroOfNNReal.comp <|
          ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚Ñù ‚ü®e, e0‚ü©;
          Continuous Œæ' ‚àß Œæ' (.id s') = Œæ (.id s)) := by
      intro Œæ'
      refine ‚ü®Œæ.continuous_realContinuousMapZeroOfNNReal hŒæ |>.comp <| ?_, ?_‚ü©
      ¬∑ rw [continuous_induced_rng]
        exact ContinuousMap.continuous_precomp _ |>.comp continuous_induced_dom
      ¬∑ exact Œæ.realContinuousMapZeroOfNNReal_apply_comp_toReal (.id _)
    obtain ‚ü®hœÜ', hœÜ_id‚ü© := this œÜ hœÜ
    obtain ‚ü®hœà', hœà_id‚ü© := this œà hœà
    have hs' : CompactSpace s' := e.compactSpace
    have : ContinuousMapZero.UniqueHom ‚Ñù A := inferInstance
    have h' := ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id
      s' _ _ hœÜ' hœà' (hœÜ_id ‚ñ∏ hœà_id ‚ñ∏ h)
    have h'' := congr($(h').comp <|
      ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚Ñù ‚ü®(e.symm : C(s', s)), e0'‚ü©)
    have : (ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚Ñù ‚ü®(e : C(s, s')), e0‚ü©).comp
        (ContinuousMapZero.nonUnitalStarAlgHom_precomp ‚Ñù ‚ü®(e.symm : C(s', s)), e0'‚ü©) =
        NonUnitalStarAlgHom.id _ _ := by
      ext; simp
    simp only [NonUnitalStarAlgHom.comp_assoc, this, NonUnitalStarAlgHom.comp_id] at h''
    exact NonUnitalStarAlgHom.realContinuousMapZeroOfNNReal_injective h''

end NNReal

end UniqueNonUnital

section NonUnitalStarAlgHom

open scoped ContinuousMapZero NonUnitalContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A ‚Üí Prop} {q : B ‚Üí Prop}
  [CommSemiring R] [Nontrivial R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R]
  [ContinuousStar R] [CommRing S] [Algebra R S]
  [NonUnitalRing A] [StarRing A] [TopologicalSpace A] [Module R A]
  [IsScalarTower R A A] [SMulCommClass R A A]
  [NonUnitalRing B] [StarRing B] [TopologicalSpace B] [Module R B]
  [IsScalarTower R B B] [SMulCommClass R B B]
  [Module S A] [Module S B] [IsScalarTower R S A] [IsScalarTower R S B]
  [NonUnitalContinuousFunctionalCalculus R A p] [NonUnitalContinuousFunctionalCalculus R B q]
  [ContinuousMapZero.UniqueHom R B] [FunLike F A B] [NonUnitalAlgHomClass F S A B]
  [StarHomClass F A B]

set_option backward.isDefEq.respectTransparency false in
include S in
/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus. -/
lemma NonUnitalStarAlgHomClass.map_cfc‚Çô (œÜ : F) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hf‚ÇÄ : f 0 = 0 := by cfc_zero_tac) (hœÜ : Continuous œÜ := by fun_prop) (ha : p a := by cfc_tac)
    (hœÜa : q (œÜ a) := by cfc_tac) : œÜ (cfc‚Çô f a) = cfc‚Çô f (œÜ a) := by
  let œà : A ‚Üí‚ãÜ‚Çô‚Çê[R] B := (œÜ : A ‚Üí‚ãÜ‚Çô‚Çê[S] B).restrictScalars R
  have : Continuous œà := hœÜ
  have h_spec := NonUnitalAlgHom.quasispectrum_apply_subset' (R := R) S œÜ a
  have hœàa : q (œà a) := hœÜa
  let Œπ : C(quasispectrum R (œà a), quasispectrum R a)‚ÇÄ :=
    ‚ü®‚ü®Set.inclusion h_spec, continuous_id.subtype_map h_spec‚ü©, rfl‚ü©
  suffices œà.comp (cfc‚ÇôHom ha) =
      (cfc‚ÇôHom hœàa).comp (ContinuousMapZero.nonUnitalStarAlgHom_precomp R Œπ) by
    have hf' : ContinuousOn f (quasispectrum R (œà a)) := hf.mono h_spec
    rw [cfc‚Çô_apply .., cfc‚Çô_apply ..]
    exact DFunLike.congr_fun this _
  refine ContinuousMapZero.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfc‚ÇôHom hœàa (.id (quasispectrum R (œà a)))
    ¬∑ simp [cfc‚ÇôHom_id]
    ¬∑ congr
  all_goals
    dsimp [ContinuousMapZero.nonUnitalStarAlgHom_precomp]
    fun_prop

/-- Non-unital star algebra homomorphisms commute with the non-unital continuous functional
calculus.  This version is specialized to `A ‚Üí‚ãÜ‚Çô‚Çê[S] B` to allow for dot notation. -/
lemma NonUnitalStarAlgHom.map_cfc‚Çô (œÜ : A ‚Üí‚ãÜ‚Çô‚Çê[S] B) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (quasispectrum R a) := by cfc_cont_tac)
    (hf‚ÇÄ : f 0 = 0 := by cfc_zero_tac) (hœÜ : Continuous œÜ := by fun_prop) (ha : p a := by cfc_tac)
    (hœÜa : q (œÜ a) := by cfc_tac) : œÜ (cfc‚Çô f a) = cfc‚Çô f (œÜ a) :=
  NonUnitalStarAlgHomClass.map_cfc‚Çô œÜ f a

end NonUnitalStarAlgHom

section StarAlgHom

open scoped ContinuousFunctionalCalculus

variable {F R S A B : Type*} {p : A ‚Üí Prop} {q : B ‚Üí Prop}
  [CommSemiring R] [StarRing R] [MetricSpace R] [IsTopologicalSemiring R] [ContinuousStar R]
  [Ring A] [StarRing A] [TopologicalSpace A] [Algebra R A]
  [Ring B] [StarRing B] [TopologicalSpace B] [Algebra R B]
  [CommSemiring S] [Algebra R S] [Algebra S A] [Algebra S B] [IsScalarTower R S A]
  [IsScalarTower R S B] [ContinuousFunctionalCalculus R A p] [ContinuousFunctionalCalculus R B q]
  [ContinuousMap.UniqueHom R B] [FunLike F A B] [AlgHomClass F S A B]
  [StarHomClass F A B]

include S in
/-- Star algebra homomorphisms commute with the continuous functional calculus. -/
lemma StarAlgHomClass.map_cfc (œÜ : F) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac)
    (hœÜ : Continuous œÜ := by fun_prop) (ha : p a := by cfc_tac) (hœÜa : q (œÜ a) := by cfc_tac) :
    œÜ (cfc f a) = cfc f (œÜ a) := by
  let œà : A ‚Üí‚ãÜ‚Çê[R] B := (œÜ : A ‚Üí‚ãÜ‚Çê[S] B).restrictScalars R
  have : Continuous œà := hœÜ
  have h_spec := AlgHom.spectrum_apply_subset œà a
  have hœàa : q (œà a) := hœÜa
  let Œπ : C(spectrum R (œà a), spectrum R a) :=
    ‚ü®Set.inclusion h_spec, continuous_id.subtype_map h_spec‚ü©
  suffices œà.comp (cfcHom ha) = (cfcHom hœàa).comp (ContinuousMap.compStarAlgHom' R R Œπ) by
    have hf' : ContinuousOn f (spectrum R (œà a)) := hf.mono h_spec
    rw [cfc_apply .., cfc_apply ..]
    congrm($(this) ‚ü®_, hf.restrict‚ü©)
  refine ContinuousMap.UniqueHom.eq_of_continuous_of_map_id _ _ _ ?_ ?_ ?apply_id
  case apply_id =>
    trans cfcHom hœàa (.restrict (spectrum R (œà a)) (.id R))
    ¬∑ simp [cfcHom_id]
    ¬∑ congr
  all_goals
    dsimp [ContinuousMap.compStarAlgHom']
    fun_prop

/-- Star algebra homomorphisms commute with the continuous functional calculus.
This version is specialized to `A ‚Üí‚ãÜ‚Çê[S] B` to allow for dot notation. -/
lemma StarAlgHom.map_cfc (œÜ : A ‚Üí‚ãÜ‚Çê[S] B) (f : R ‚Üí R) (a : A)
    (hf : ContinuousOn f (spectrum R a) := by cfc_cont_tac) (hœÜ : Continuous œÜ := by fun_prop)
    (ha : p a := by cfc_tac) (hœÜa : q (œÜ a) := by cfc_tac) :
    œÜ (cfc f a) = cfc f (œÜ a) :=
  StarAlgHomClass.map_cfc œÜ f a

end StarAlgHom
