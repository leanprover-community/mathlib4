module

public import Mathlib.Analysis.Fourier.AddCircle
public import Mathlib.MeasureTheory.Integral.Pi

/-!
# Multivariate Fourier series

In this file we define the Fourier series of an L¬≤ function on the `d`-dimensional unit circle, and
show that it converges to the function in the L¬≤ norm. We also prove uniform convergence of the
Fourier series if `f` is continuous and the sequence of its Fourier coefficients is summable.
-/

@[expose] public section

noncomputable section

open scoped ComplexConjugate ENNReal

open Set Algebra Submodule MeasureTheory

-- some instances for unit circle

/-- In this file we normalise the measure on `‚ĄĚ / ‚Ą§` to have total volume 1. -/
local instance : MeasureSpace UnitAddCircle := ‚ü®AddCircle.haarAddCircle‚ü©

/-- The measure on `‚ĄĚ / ‚Ą§` is a Haar measure. -/
local instance : Measure.IsAddHaarMeasure (volume : Measure UnitAddCircle) :=
  inferInstanceAs (Measure.IsAddHaarMeasure AddCircle.haarAddCircle)

/-- The measure on `‚ĄĚ / ‚Ą§` is a probability measure. -/
local instance : IsProbabilityMeasure (volume : Measure UnitAddCircle) :=
  inferInstanceAs (IsProbabilityMeasure AddCircle.haarAddCircle)

/-- The product of finitely many copies of the unit circle, indexed by `d`. -/
abbrev UnitAddTorus (d : Type*) := d ‚Üí UnitAddCircle

namespace UnitAddTorus

variable {d : Type*} [Fintype d]

section Monomials

variable (n : d ‚Üí ‚Ą§)

/-- Exponential monomials in `d` variables. -/
def mFourier : C(UnitAddTorus d, ‚Ąā) where
  toFun x := ‚ąŹ i : d, fourier (n i) (x i)
  continuous_toFun := by fun_prop

variable {n} {x : UnitAddTorus d}

lemma mFourier_neg : mFourier (-n) x = conj (mFourier n x) := by
  simp only [mFourier, Pi.neg_apply, fourier_neg, ContinuousMap.coe_mk, map_prod]

lemma mFourier_add {m : d ‚Üí ‚Ą§} : mFourier (m + n) x = mFourier m x * mFourier n x := by
  simp only [mFourier, Pi.add_apply, fourier_add, ContinuousMap.coe_mk, ‚Üź Finset.prod_mul_distrib]

lemma mFourier_zero : mFourier (0 : d ‚Üí ‚Ą§) = 1 := by
  ext x
  simp only [mFourier, Pi.zero_apply, fourier_zero, Finset.prod_const_one, ContinuousMap.coe_mk,
    ContinuousMap.one_apply]

lemma mFourier_norm : ‚ÄĖmFourier n‚ÄĖ = 1 := by
  apply le_antisymm
  ¬∑ refine (ContinuousMap.norm_le _ zero_le_one).mpr fun i ‚Ü¶ ?_
    simp only [mFourier, fourier_apply, ContinuousMap.coe_mk, norm_prod, Circle.norm_coe,
      Finset.prod_const_one, le_rfl]
  ¬∑ refine (le_of_eq ?_).trans ((mFourier n).norm_coe_le_norm fun _ ‚Ü¶ 0)
    simp only [mFourier, ContinuousMap.coe_mk, fourier_eval_zero, Finset.prod_const_one,
      CStarRing.norm_one]

lemma mFourier_single [DecidableEq d] (z : d ‚Üí AddCircle (1 : ‚ĄĚ)) (i : d) :
    mFourier (Pi.single i 1) z = fourier 1 (z i) := by
  simp_rw [mFourier, ContinuousMap.coe_mk]
  have := Finset.prod_mul_prod_compl {i} (fun j ‚Ü¶ fourier ((Pi.single i (1 : ‚Ą§) : d ‚Üí ‚Ą§) j) (z j))
  rw [Finset.prod_singleton, Finset.prod_congr rfl (fun j hj ‚Ü¶ ?_)] at this
  ¬∑ rw [‚Üź this, Finset.prod_const_one, mul_one, Pi.single_eq_same]
  ¬∑ rw [Finset.mem_compl, Finset.mem_singleton] at hj
    simp only [Pi.single_eq_of_ne hj, fourier_zero]

end Monomials

section Algebra

/-- The star subalgebra of `C(UnitAddTorus d, ‚Ąā)` generated by `mFourier n` for `n ‚ąą ‚Ą§ŠĶą`. -/
def mFourierSubalgebra (d : Type*) [Fintype d] : StarSubalgebra ‚Ąā C(UnitAddTorus d, ‚Ąā) where
  toSubalgebra := Algebra.adjoin ‚Ąā (range mFourier)
  star_mem' := by
    change Algebra.adjoin ‚Ąā (range mFourier) ‚Č§ star (Algebra.adjoin ‚Ąā (range mFourier))
    refine adjoin_le ?_
    rintro _ ‚ü®n, rfl‚ü©
    refine subset_adjoin ‚ü®-n, ?_‚ü©
    ext1 x
    simp only [mFourier_neg, starRingEnd_apply, ContinuousMap.star_apply]

/-- The star subalgebra of `C(UnitAddTorus d, ‚Ąā)` generated by `mFourier n` for `n ‚ąą ‚Ą§ŠĶą` is in fact
the linear span of these functions. -/
theorem mFourierSubalgebra_coe :
    (mFourierSubalgebra d).toSubalgebra.toSubmodule = span ‚Ąā (range mFourier) := by
  apply adjoin_eq_span_of_subset
  refine .trans (fun x ‚Ü¶ Submonoid.closure_induction (fun _ ‚Ü¶ id) ‚ü®0, ?_‚ü© ?_) subset_span
  ¬∑ ext z
    simp only [mFourier, Pi.zero_apply, fourier_zero, Finset.prod_const, one_pow,
      ContinuousMap.coe_mk, ContinuousMap.one_apply]
  ¬∑ rintro _ _ _ _ ‚ü®m, rfl‚ü© ‚ü®n, rfl‚ü©
    refine ‚ü®m + n, ?_‚ü©
    ext z
    simp only [mFourier, Pi.add_apply, fourier_apply, fourier_add', Finset.prod_mul_distrib,
      ContinuousMap.coe_mk, ContinuousMap.mul_apply]

/-- The subalgebra of `C(UnitAddTorus d, ‚Ąā)` generated by `mFourier n` for `n ‚ąą ‚Ą§ŠĶą` separates
points. -/
theorem mFourierSubalgebra_separatesPoints : (mFourierSubalgebra d).SeparatesPoints := by
  classical
  intro x y hxy
  rw [Ne, funext_iff, not_forall] at hxy
  obtain ‚ü®i, hi‚ü© := hxy
  refine ‚ü®_, ‚ü®mFourier (Pi.single i 1), subset_adjoin ‚ü®Pi.single i 1, rfl‚ü©, rfl‚ü©, ?_‚ü©
  dsimp only
  rw [mFourier_single, mFourier_single, fourier_one, fourier_one, Ne, Subtype.coe_inj]
  contrapose hi
  exact AddCircle.injective_toCircle one_ne_zero hi

/-- The subalgebra of `C(UnitAddTorus d, ‚Ąā)` generated by `mFourier n` for `n : d ‚Üí ‚Ą§` is dense. -/
theorem mFourierSubalgebra_closure_eq_top : (mFourierSubalgebra d).topologicalClosure = ‚ä§ :=
  ContinuousMap.starSubalgebra_topologicalClosure_eq_top_of_separatesPoints _
    mFourierSubalgebra_separatesPoints

/-- The linear span of the monomials `mFourier n` is dense in `C(UnitAddTorus d, ‚Ąā)`. -/
theorem span_mFourier_closure_eq_top :
    (span ‚Ąā (range <| mFourier (d := d))).topologicalClosure = ‚ä§ := by
  rw [‚Üź mFourierSubalgebra_coe]
  exact congr_arg (Subalgebra.toSubmodule <| StarSubalgebra.toSubalgebra ¬∑)
    mFourierSubalgebra_closure_eq_top

end Algebra

section Integral

variable (a : d ‚Üí ‚ĄĚ) {őĻ : Type*} (b : őĻ ‚Üí ‚ĄĚ)

/-- The measurable equivalence between `UnitAddTorus` and a product of `Ioc` intervals. -/
def measurableEquivPiIoc : UnitAddTorus őĻ ‚ČÉŠĶź {x : őĻ ‚Üí ‚ĄĚ // ‚ąÄ i, x i ‚ąą Ioc (b i) (b i + 1)} :=
  (MeasurableEquiv.piCongrRight fun i => AddCircle.measurableEquivIoc 1 (b i)).trans <|
  MeasurableEquiv.subtypePiEquivPi.symm

theorem coe_measurableEquivPiIoc :
    ‚áĎ(measurableEquivPiIoc b) = fun x =>
      ‚ü®fun i => (AddCircle.equivIoc 1 (b i) (x i)).1,
      fun i => (AddCircle.equivIoc 1 (b i) (x i)).2‚ü© := rfl

@[simp]
theorem coe_measurableEquivPiIoc_apply (x : UnitAddTorus őĻ) :
    (measurableEquivPiIoc b) x = ‚ü®fun i => (AddCircle.equivIoc 1 (b i) (x i)).1,
      fun i => (AddCircle.equivIoc 1 (b i) (x i)).2‚ü© := rfl

theorem coe_symm_measurableEquivPiIoc :
    ‚áĎ(measurableEquivPiIoc b).symm = fun x i => x.1 i := rfl

@[simp]
theorem coe_symm_measurableEquivPiIoc_apply (y : {x : őĻ ‚Üí ‚ĄĚ // ‚ąÄ i, x i ‚ąą Ioc (b i) (b i + 1)}) :
    (measurableEquivPiIoc b).symm y = fun i => (y.1 i : UnitAddCircle) := rfl

/-- The equivalence `measurableEquivPiIoc` is measure preserving. -/
lemma measurePreserving_equivPiIoc :
    MeasurePreserving (measurableEquivPiIoc a) volume (Measure.comap Subtype.val volume) := by
  refine (‚ü®(measurableEquivPiIoc a).symm.measurable, symm ?_‚ü© :
    MeasurePreserving (measurableEquivPiIoc a).symm _ _).symm
  have := Measure.map_map (őľ := volume.comap Subtype.val) (measurable_pi_lambda
    (fun (x : d ‚Üí ‚ĄĚ) => (fun i => x i : UnitAddTorus d))
    (fun i => AddCircle.measurable_mk'.comp (measurable_pi_apply i)))
    measurable_subtype_coe (őĪ := {x : d ‚Üí ‚ĄĚ // ‚ąÄ i, x i ‚ąą Ioc (a i) (a i + 1)})
  simp only [Function.comp_def] at this
  simp_rw [coe_symm_measurableEquivPiIoc, ‚Üź this]
  convert! (measurePreserving_pi _ _ (fun i => AddCircle.measurePreserving_mk 1 (a i))).map_eq.symm
  ¬∑ simp [volume, AddCircle.haarAddCircle]
  ¬∑ convert! (map_comap_subtype_coe (MeasurableSet.univ_pi'
      (fun i => measurableSet_Ioc (a := a i))) volume)
    convert! (Measure.restrict_pi_pi (fun i => volume) (fun i => Ioc (a i) (a i + 1))).symm
    grind

theorem lintegral_preimage (f : UnitAddTorus d ‚Üí ‚ĄĚ‚Č•0‚ąě) (a : d ‚Üí ‚ĄĚ) :
    ‚ąę‚ĀĽ x : UnitAddTorus d, f x =
    ‚ąę‚ĀĽ (x : d ‚Üí ‚ĄĚ) in {x : d ‚Üí ‚ĄĚ | ‚ąÄ i, x i ‚ąą Ioc (a i) (a i + 1)}, f (fun i => x i) := by
  convert! lintegral_map_equiv (őľ := volume.comap Subtype.val) f (measurableEquivPiIoc a).symm
  ¬∑ exact (measurePreserving_equivPiIoc a).symm.map_eq.symm
  ¬∑ rw [‚Üź lintegral_subtype_comap (MeasurableSet.univ_pi' (fun i => measurableSet_Ioc))]
    rfl

theorem integral_preimage {E : Type*} [NormedAddCommGroup E] [NormedSpace ‚ĄĚ E]
    (f : UnitAddTorus d ‚Üí E) (a : d ‚Üí ‚ĄĚ) :
    ‚ąę x : UnitAddTorus d, f x =
    ‚ąę (x : d ‚Üí ‚ĄĚ) in {x : d ‚Üí ‚ĄĚ | ‚ąÄ i, x i ‚ąą Ioc (a i) (a i + 1)}, f (fun i => x i) := by
  convert! integral_map_equiv (őľ := volume.comap Subtype.val) (measurableEquivPiIoc a).symm f
  ¬∑ exact (measurePreserving_equivPiIoc a).symm.map_eq.symm
  ¬∑ rw [‚Üź integral_subtype_comap (MeasurableSet.univ_pi' (fun i => measurableSet_Ioc))]
    rfl

end Integral

section Lp

/-- The family of monomials `mFourier n`, parametrized by `n : ‚Ą§ŠĶą` and considered as
elements of the `Lp` space of functions `UnitAddTorus d ‚Üí ‚Ąā`. -/
abbrev mFourierLp (p : ‚ĄĚ‚Č•0‚ąě) [Fact (1 ‚Č§ p)] (n : d ‚Üí ‚Ą§) :
    Lp ‚Ąā p (volume : Measure (UnitAddTorus d)) :=
  ContinuousMap.toLp (E := ‚Ąā) p volume ‚Ąā (mFourier n)

theorem coeFn_mFourierLp (p : ‚ĄĚ‚Č•0‚ąě) [Fact (1 ‚Č§ p)] (n : d ‚Üí ‚Ą§) :
    mFourierLp p n =ŠĶź[volume] mFourier n :=
  ContinuousMap.coeFn_toLp volume (mFourier n)

/-- For each `1 ‚Č§ p < ‚ąě`, the linear span of the monomials `mFourier n` is dense in the `LŠĶĖ` space
of functions on `UnitAddTorus d`. -/
theorem span_mFourierLp_closure_eq_top {p : ‚ĄĚ‚Č•0‚ąě} [Fact (1 ‚Č§ p)] (hp : p ‚Č† ‚ąě) :
    (span ‚Ąā (range (@mFourierLp d _ p _))).topologicalClosure = ‚ä§ := by
  simpa only [map_span, ContinuousLinearMap.coe_coe, ‚Üź range_comp, Function.comp_def] using
    (ContinuousMap.toLp_denseRange ‚Ąā volume ‚Ąā hp).topologicalClosure_map_submodule
      span_mFourier_closure_eq_top

/-- The monomials `mFourierLp 2 n` are an orthonormal set in `L¬≤`. -/
theorem orthonormal_mFourier : Orthonormal ‚Ąā (mFourierLp (d := d) 2) := by
  rw [orthonormal_iff_ite]
  intro m n
  simp only [ContinuousMap.inner_toLp, ‚Üź mFourier_neg, ‚Üź mFourier_add]
  split_ifs with h
  ¬∑ simpa only [h, add_neg_cancel, mFourier_zero, probReal_univ, one_smul] using
      integral_const (őĪ := UnitAddTorus d) (őľ := volume) (1 : ‚Ąā)
  rw [mFourier, ContinuousMap.coe_mk, MeasureTheory.integral_fintype_prod_volume_eq_prod]
  obtain ‚ü®i, hi‚ü© := Function.ne_iff.mp h
  apply Finset.prod_eq_zero (Finset.mem_univ i)
  simpa only [eq_false_intro hi, if_false, ContinuousMap.inner_toLp, ‚Üź fourier_neg,
    ‚Üź fourier_add] using (orthonormal_iff_ite.mp <| orthonormal_fourier) (m i) (n i)

end Lp

section fourierCoeff

variable {E : Type*} [NormedAddCommGroup E] [NormedSpace ‚Ąā E]

/-- The `n`-th Fourier coefficient of a function `UnitAddTorus d ‚Üí E`, for `E` a complete normed
`‚Ąā`-vector space, defined as the integral over `UnitAddTorus d` of `mFourier (-n) t ‚ÄĘ f t`. -/
def mFourierCoeff (f : UnitAddTorus d ‚Üí E) (n : d ‚Üí ‚Ą§) : E := ‚ąę t, mFourier (-n) t ‚ÄĘ f t

/-- The Fourier coefficients of a function on `UnitAddTorus d` can be computed as integrals
over `‚ąŹ i, (aŠĶĘ, aŠĶĘ + 1]`, for any `a : d ‚Üí ‚ĄĚ`. -/
theorem mFourierCoeff_eq_integral (f : UnitAddTorus d ‚Üí E) (n : d ‚Üí ‚Ą§) (a : d ‚Üí ‚ĄĚ) :
    mFourierCoeff f n =
    ‚ąę (x : d ‚Üí ‚ĄĚ) in {x : d ‚Üí ‚ĄĚ | ‚ąÄ i, x i ‚ąą Ioc (a i) (a i + 1)},
    mFourier (-n) (fun i => x i) ‚ÄĘ f (fun i => x i) :=
  integral_preimage (fun x => (mFourier (-n)) x ‚ÄĘ f x) a

end fourierCoeff

section FourierL2

local notation "L¬≤(" őĪ ")" => Lp ‚Ąā 2 (volume : Measure őĪ)

/-- We define `mFourierBasis` to be a `‚Ą§ŠĶą`-indexed Hilbert basis for the `L¬≤` space of functions
on `UnitAddTorus d`, which by definition is an isometric isomorphism from `L¬≤(UnitAddTorus d)`
to `‚Ąď¬≤(‚Ą§ŠĶą, ‚Ąā)`. -/
def mFourierBasis : HilbertBasis (d ‚Üí ‚Ą§) ‚Ąā L¬≤(UnitAddTorus d) :=
  HilbertBasis.mk orthonormal_mFourier (span_mFourierLp_closure_eq_top (by simp)).ge

/-- The elements of the Hilbert basis `mFourierBasis` are the functions `mFourierLp 2`, i.e. the
monomials `mFourier n` on `UnitAddTorus d` considered as elements of `L¬≤`. -/
@[simp]
theorem coe_mFourierBasis : ‚áĎ(mFourierBasis (d := d)) = mFourierLp 2 := HilbertBasis.coe_mk _ _

/-- Under the isometric isomorphism `mFourierBasis` from `L¬≤(UnitAddTorus d)` to `‚Ąď¬≤(‚Ą§ŠĶą, ‚Ąā)`,
the `i`-th coefficient is `mFourierCoeff f i`. -/
theorem mFourierBasis_repr (f : L¬≤(UnitAddTorus d)) (i : d ‚Üí ‚Ą§) :
    mFourierBasis.repr f i = mFourierCoeff f i := by
  trans ‚ąę t, conj (mFourierLp 2 i t) * f t
  ¬∑ rw [mFourierBasis.repr_apply_apply f i, MeasureTheory.L2.inner_def, coe_mFourierBasis]
    simp only [RCLike.inner_apply, mul_comm]
  ¬∑ apply integral_congr_ae
    filter_upwards [coeFn_mFourierLp 2 i] with _ ht
    rw [ht, ‚Üź mFourier_neg, smul_eq_mul]

/-- The Fourier series of an `L2` function `f` sums to `f` in the `L¬≤` norm. -/
theorem hasSum_mFourier_series_L2 (f : L¬≤(UnitAddTorus d)) :
    HasSum (fun i ‚Ü¶ mFourierCoeff f i ‚ÄĘ mFourierLp 2 i) f := by
  simpa [‚Üź coe_mFourierBasis, mFourierBasis_repr] using mFourierBasis.hasSum_repr f

/-- **Parseval's identity** for inner products: for `L¬≤` functions `f, g` on `UnitAddTorus d`, the
inner product of the Fourier coefficients of `f` and `g` is the inner product of `f` and `g`. -/
theorem hasSum_prod_mFourierCoeff (f g : L¬≤(UnitAddTorus d)) :
    HasSum (fun i ‚Ü¶ conj (mFourierCoeff f i) * (mFourierCoeff g i)) (‚ąę t, conj (f t) * g t) := by
  simp_rw [mul_comm (conj _)]
  refine HasSum.congr_fun (mFourierBasis.hasSum_inner_mul_inner f g) (fun n ‚Ü¶ ?_)
  simp only [‚Üź mFourierBasis_repr, HilbertBasis.repr_apply_apply, inner_conj_symm,
    mul_comm (inner ‚Ąā f _)]

/-- **Parseval's identity** for norms: for an `L¬≤` function `f` on `UnitAddTorus d`, the sum of the
squared norms of the Fourier coefficients equals the `L¬≤` norm of `f`. -/
theorem hasSum_sq_mFourierCoeff (f : L¬≤(UnitAddTorus d)) :
    HasSum (fun i ‚Ü¶ ‚ÄĖmFourierCoeff f i‚ÄĖ ^ 2) (‚ąę t, ‚ÄĖf t‚ÄĖ ^ 2) := by
  simpa only [‚Üź RCLike.inner_apply', inner_self_eq_norm_sq, ‚Üź integral_re
    (L2.integrable_inner f f)] using RCLike.hasSum_re ‚Ąā (hasSum_prod_mFourierCoeff f f)

end FourierL2

section Convergence

variable (f : C(UnitAddTorus d, ‚Ąā))

theorem mFourierCoeff_toLp (n : d ‚Üí ‚Ą§) :
    mFourierCoeff (f.toLp 2 volume ‚Ąā) n = mFourierCoeff f n :=
  integral_congr_ae (ae_eq_rfl.mul <| f.coeFn_toAEEqFun _)

variable {f}

/-- If the sequence of Fourier coefficients of `f` is summable, then the Fourier series converges
uniformly to `f`. -/
theorem hasSum_mFourier_series_of_summable (h : Summable (mFourierCoeff f)) :
    HasSum (fun i ‚Ü¶ mFourierCoeff f i ‚ÄĘ mFourier i) f := by
  have sum_L2 := hasSum_mFourier_series_L2 (ContinuousMap.toLp 2 volume ‚Ąā f)
  simp only [mFourierCoeff_toLp] at sum_L2
  refine ContinuousMap.hasSum_of_hasSum_Lp (.of_norm ?_) sum_L2
  simpa only [norm_smul, mFourier_norm, mul_one] using h.norm

/-- If the sequence of Fourier coefficients of `f` is summable, then the Fourier series of `f`
converges everywhere pointwise to `f`. -/
theorem hasSum_mFourier_series_apply_of_summable (h : Summable (mFourierCoeff f))
    (x : UnitAddTorus d) : HasSum (fun i ‚Ü¶ mFourierCoeff f i ‚ÄĘ mFourier i x) (f x) := by
  simpa only [map_smul] using (ContinuousMap.evalCLM ‚Ąā x).hasSum
    (hasSum_mFourier_series_of_summable h)

end Convergence

end UnitAddTorus
