section CommMonoid

variable {R : Type*} [CommMonoid R] {S : Type*} [SetLike S R] [SubmonoidClass S R] (T : S)
  {R' : Type*} [CommMonoidWithZero R']

/-- Two multiplicative characters on a monoid whose unit group is generated by `g`
are equal if and only if they agree on `g`. -/
lemma eq_iff {g : RЛЈ} (hg : в€Ђ x, x в€€ Subgroup.zpowers g) (П‡в‚Ѓ П‡в‚‚ : MulChar R R') :
    П‡в‚Ѓ = П‡в‚‚ в†” П‡в‚Ѓ g.val = П‡в‚‚ g.val := by
  rw [в†ђ Equiv.apply_eq_iff_eq equivToUnitHom, MonoidHom.eq_iff_eq_on_generator hg,
    в†ђ coe_equivToUnitHom, в†ђ coe_equivToUnitHom, Units.ext_iff]

theorem restrict_ofUnitHom (f : RЛЈ в†’* R'ЛЈ) (S : Submonoid R) :
    restrict S (ofUnitHom f) =
      ofUnitHom ((f.restrict S.units).comp S.unitsEquivUnitsType.symm) := by
  ext x
  simp only [ofUnitHom_eq, restrict_apply, Units.isUnit, reduceIte, equivToUnitHom_symm_coe,
    MonoidHom.coe_comp, MonoidHom.coe_coe, Function.comp_apply, MonoidHom.restrict_apply]
  rw [в†ђ Submonoid.val_unitsEquivUnitsType_symm_apply_coe S x, equivToUnitHom_symm_coe]

variable (R')

/--
The restriction of a `MulChar` to a submonoid as an homomorphism.
-/
@[simps]
noncomputable def restrictHom :
    MulChar R R' в†’* MulChar T R' where
  toFun П‡ := П‡.restrict T
  map_one' := by
    ext x
    rw [restrict_apply, if_pos x.isUnit, MulChar.one_apply x.isUnit.coe, one_apply_coe]
  map_mul' _ _ := by ext; simp

end CommMonoid

section Ring

variable {R R' : Type*} [CommRing R] [CommRing R']

/-- Define the conjugation (`star`) of a multiplicative character by conjugating pointwise. -/
@[simps!]
def starComp [StarRing R'] (П‡ : MulChar R R') : MulChar R R' :=
  П‡.ringHomComp (starRingEnd R')

instance instStarMul [StarRing R'] : StarMul (MulChar R R') where
  star := starComp
  star_involutive П‡ := by
    ext1
    simp only [starComp_apply, RingHomCompTriple.comp_apply, RingHom.id_apply]
  star_mul П‡ П‡' := by
    ext1
    simp only [starComp_apply, starRingEnd, coeToFun_mul, Pi.mul_apply, map_mul, RingHom.coe_coe,
      starRingAut_apply, mul_comm]

@[simp]
lemma star_apply [StarRing R'] (П‡ : MulChar R R') (a : R) : (star П‡) a = star (П‡ a) :=
  rfl

/-- The values of a multiplicative character on `R` are `n`th roots of unity, where `n = #RЛЈ`. -/
lemma apply_mem_rootsOfUnity [Fintype RЛЈ] (a : RЛЈ) {П‡ : MulChar R R'} :
    equivToUnitHom П‡ a в€€ rootsOfUnity (Fintype.card RЛЈ) R' := by
  rw [mem_rootsOfUnity, в†ђ map_pow, в†ђ (equivToUnitHom П‡).map_one, pow_card_eq_one]

variable [Finite RЛЈ]

open Complex in
/-- The conjugate of a multiplicative character with values in `в„‚` is its inverse. -/
lemma star_eq_inv (П‡ : MulChar R в„‚) : star П‡ = П‡вЃ»В№ := by
  cases nonempty_fintype RЛЈ
  ext1 a
  simp only [inv_apply_eq_inv']
  exact (inv_eq_conj <| norm_eq_one_of_mem_rootsOfUnity <| П‡.apply_mem_rootsOfUnity a).symm

lemma star_apply' (П‡ : MulChar R в„‚) (a : R) : star (П‡ a) = П‡вЃ»В№ a := by
  simp only [RCLike.star_def, в†ђ star_eq_inv, star_apply]

end Ring

section IsCyclic

/-!
### Multiplicative characters on finite monoids with cyclic unit group
-/

variable {M : Type*} [CommMonoid M] [Fintype M] [DecidableEq M]
variable {R : Type*} [CommMonoidWithZero R]

/-- Given a finite monoid `M` with unit group `MЛЈ` cyclic of order `n` and an `n`th root of
unity `О¶` in `R`, there is a multiplicative character `M в†’ R` that sends a given generator
of `MЛЈ` to `О¶`. -/
noncomputable def ofRootOfUnity {О¶ : RЛЈ} (hО¶ : О¶ в€€ rootsOfUnity (Fintype.card MЛЈ) R)
    {g : MЛЈ} (hg : в€Ђ x, x в€€ Subgroup.zpowers g) :
    MulChar M R := by
  have : orderOf О¶ в€Ј Fintype.card MЛЈ :=
    orderOf_dvd_iff_pow_eq_one.mpr <| (mem_rootsOfUnity _ О¶).mp hО¶
  refine ofUnitHom <| monoidHomOfForallMemZpowers hg <| this.trans <| dvd_of_eq ?_
  rw [orderOf_eq_card_of_forall_mem_zpowers hg, Nat.card_eq_fintype_card]

lemma ofRootOfUnity_spec {О¶ : RЛЈ} (hО¶ : О¶ в€€ rootsOfUnity (Fintype.card MЛЈ) R)
    {g : MЛЈ} (hg : в€Ђ x, x в€€ Subgroup.zpowers g) :
    ofRootOfUnity hО¶ hg g = О¶ := by
  simp only [ofRootOfUnity, ofUnitHom_eq, equivToUnitHom_symm_coe,
    monoidHomOfForallMemZpowers_apply_gen]

variable (M R) in
/-- The group of multiplicative characters on a finite monoid `M` with cyclic unit group `MЛЈ`
of order `n` is isomorphic to the group of `n`th roots of unity in the target `R`. -/
noncomputable def equiv_rootsOfUnity [inst_cyc : IsCyclic MЛЈ] :
    MulChar M R в‰ѓ* rootsOfUnity (Fintype.card MЛЈ) R where
  toFun П‡ :=
    вџЁП‡.toUnitHom <| Classical.choose inst_cyc.exists_generator, by
      simp only [toUnitHom_eq, mem_rootsOfUnity, в†ђ map_pow, pow_card_eq_one, map_one]вџ©
  invFun О¶ := ofRootOfUnity О¶.prop <| Classical.choose_spec inst_cyc.exists_generator
  left_inv П‡ := by
    simp only [toUnitHom_eq, eq_iff <| Classical.choose_spec inst_cyc.exists_generator,
      ofRootOfUnity_spec, coe_equivToUnitHom]
  right_inv О¶ := by
    ext
    simp only [toUnitHom_eq, coe_equivToUnitHom, ofRootOfUnity_spec]
  map_mul' x y := by
    simp only [toUnitHom_eq, equivToUnitHom_mul_apply, MulMemClass.mk_mul_mk]

end IsCyclic

section FiniteField

/-!
### Multiplicative characters on finite fields
-/

section Fintype

variable (F : Type*) [Field F] [Fintype F]
variable {R : Type*} [CommRing R]

/-- There is a character of order `n` on `F` if `#F в‰Ў 1 mod n` and the target contains
a primitive `n`th root of unity. -/
lemma exists_mulChar_orderOf {n : в„•} (h : n в€Ј Fintype.card F - 1) {О¶ : R}
    (hО¶ : IsPrimitiveRoot О¶ n) :
    в€ѓ П‡ : MulChar F R, orderOf П‡ = n := by
  classical
  have hnв‚Ђ : 0 < n := by
    refine Nat.pos_of_ne_zero fun hn в†¦ ?_
    simp only [hn, zero_dvd_iff, Nat.sub_eq_zero_iff_le] at h
    exact (Fintype.one_lt_card.trans_le h).false
  let e := MulChar.equiv_rootsOfUnity F R
  let О¶' : RЛЈ := (hО¶.isUnit hnв‚Ђ.ne').unit
  have h' : О¶' ^ (Fintype.card FЛЈ : в„•) = 1 :=
    Units.ext_iff.mpr <| (hО¶.pow_eq_one_iff_dvd _).mpr <| Fintype.card_units (О± := F) в–ё h
  use e.symm вџЁО¶', (mem_rootsOfUnity (Fintype.card FЛЈ) О¶').mpr h'вџ©
  rw [e.symm.orderOf_eq, orderOf_eq_iff hnв‚Ђ]
  refine вџЁ?_, fun m hm hmв‚Ђ h в†¦ ?_вџ©
  В· ext
    push_cast
    exact hО¶.pow_eq_one
  В· rw [Subtype.ext_iff, Units.ext_iff] at h
    push_cast at h
    exact ((Nat.le_of_dvd hmв‚Ђ <| hО¶.dvd_of_pow_eq_one _ h).trans_lt hm).false

/-- If there is a multiplicative character of order `n` on `F`, then `#F в‰Ў 1 mod n`. -/
lemma orderOf_dvd_card_sub_one (П‡ : MulChar F R) : orderOf П‡ в€Ј Fintype.card F - 1 := by
  classical
  rw [в†ђ Fintype.card_units]
  exact orderOf_dvd_of_pow_eq_one П‡.pow_card_eq_one

/-- There is always a character on `F` of order `#F-1` with values in a ring that has
a primitive `(#F-1)`th root of unity. -/
lemma exists_mulChar_orderOf_eq_card_units [DecidableEq F]
    {О¶ : R} (hО¶ : IsPrimitiveRoot О¶ (Fintype.card FЛЈ)) :
    в€ѓ П‡ : MulChar F R, orderOf П‡ = Fintype.card FЛЈ :=
  exists_mulChar_orderOf F (by rw [Fintype.card_units]) hО¶

end Fintype

variable {F : Type*} [Field F] [Finite F]
variable {R : Type*} [CommRing R]

/- The non-zero values of a multiplicative character of order `n` are `n`th roots of unity. -/
lemma apply_mem_rootsOfUnity_orderOf (П‡ : MulChar F R) {a : F} (ha : a в‰  0) :
    в€ѓ О¶ в€€ rootsOfUnity (orderOf П‡) R, О¶ = П‡ a := by
  have hu : IsUnit (П‡ a) := ha.isUnit.map П‡
  refine вџЁhu.unit, ?_, hu.unit_specвџ©
  rw [mem_rootsOfUnity, Units.ext_iff, Units.val_pow_eq_pow_val, Units.val_one,
    IsUnit.unit_spec, в†ђ П‡.pow_apply' П‡.orderOf_pos.ne', pow_orderOf_eq_one,
    show a = (isUnit_iff_ne_zero.mpr ha).unit by simp only [IsUnit.unit_spec],
    MulChar.one_apply_coe]

/-- The non-zero values of a multiplicative character `П‡` such that `П‡^n = 1`
are `n`th roots of unity. -/
lemma apply_mem_rootsOfUnity_of_pow_eq_one {П‡ : MulChar F R} {n : в„•} (hП‡ : П‡ ^ n = 1)
    {a : F} (ha : a в‰  0) :
    в€ѓ О¶ в€€ rootsOfUnity n R, О¶ = П‡ a := by
  obtain вџЁОј, hОјв‚Ѓ, hОјв‚‚вџ© := П‡.apply_mem_rootsOfUnity_orderOf ha
  exact вџЁОј, rootsOfUnity_le_of_dvd (orderOf_dvd_of_pow_eq_one hП‡) hОјв‚Ѓ, hОјв‚‚вџ©

-- Results involving primitive roots of unity require `R` to be an integral domain.
variable [IsDomain R]

/-- If `П‡` is a multiplicative character with `П‡^n = 1` and `Ој` is a primitive `n`th root
of unity, then, for `a в‰  0`, there is some `k` such that `П‡ a = Ој^k`. -/
lemma exists_apply_eq_pow {П‡ : MulChar F R} {n : в„•} [NeZero n] (hП‡ : П‡ ^ n = 1) {Ој : R}
    (hОј : IsPrimitiveRoot Ој n) {a : F} (ha : a в‰  0) :
    в€ѓ k < n, П‡ a = Ој ^ k := by
  obtain вџЁО¶, hО¶в‚Ѓ, hО¶в‚‚вџ© := apply_mem_rootsOfUnity_of_pow_eq_one hП‡ ha
  have hО¶' : О¶.val ^ n = 1 := (mem_rootsOfUnity' n в†‘О¶).mp hО¶в‚Ѓ
  obtain вџЁk, hkв‚Ѓ, hkв‚‚вџ© := hОј.eq_pow_of_pow_eq_one hО¶'
  exact вџЁk, hkв‚Ѓ, (hО¶в‚‚ в–ё hkв‚‚).symmвџ©

/-- The values of a multiplicative character `П‡` such that `П‡^n = 1` are contained in `в„¤[Ој]` when
`Ој` is a primitive `n`th root of unity. -/
lemma apply_mem_algebraAdjoin_of_pow_eq_one {П‡ : MulChar F R} {n : в„•} [NeZero n] (hП‡ : П‡ ^ n = 1)
    {Ој : R} (hОј : IsPrimitiveRoot Ој n) (a : F) :
    П‡ a в€€ Algebra.adjoin в„¤ {Ој} := by
  rcases eq_or_ne a 0 with rfl | h
  В· exact П‡.map_zero в–ё Subalgebra.zero_mem _
  В· obtain вџЁО¶, hО¶в‚Ѓ, hО¶в‚‚вџ© := apply_mem_rootsOfUnity_of_pow_eq_one hП‡ h
    rw [mem_rootsOfUnity, Units.ext_iff, Units.val_pow_eq_pow_val] at hО¶в‚Ѓ
    obtain вџЁk, _, hkвџ© := IsPrimitiveRoot.eq_pow_of_pow_eq_one hОј hО¶в‚Ѓ
    exact hО¶в‚‚ в–ё hk в–ё Subalgebra.pow_mem _ (Algebra.self_mem_adjoin_singleton в„¤ Ој) k

/-- The values of a multiplicative character of order `n` are contained in `в„¤[Ој]` when
`Ој` is a primitive `n`th root of unity. -/
lemma apply_mem_algebraAdjoin {П‡ : MulChar F R} {Ој : R} (hОј : IsPrimitiveRoot Ој (orderOf П‡))
    (a : F) :
    П‡ a в€€ Algebra.adjoin в„¤ {Ој} :=
  have : NeZero (orderOf П‡) := вџЁП‡.orderOf_pos.ne'вџ©
  apply_mem_algebraAdjoin_of_pow_eq_one (pow_orderOf_eq_one П‡) hОј a

end FiniteField

