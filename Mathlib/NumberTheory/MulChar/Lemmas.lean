section CommMonoid

variable {R : Type*} [CommMonoid R] {S : Type*} [SetLike S R] [SubmonoidClass S R] (T : S)
  {R' : Type*} [CommMonoidWithZero R']

/-- Two multiplicative characters on a monoid whose unit group is generated by `g`
are equal if and only if they agree on `g`. -/
lemma eq_iff {g : RЛЈ} (hg : вҲҖ x, x вҲҲ Subgroup.zpowers g) (ПҮвӮҒ ПҮвӮӮ : MulChar R R') :
    ПҮвӮҒ = ПҮвӮӮ вҶ” ПҮвӮҒ g.val = ПҮвӮӮ g.val := by
  rw [вҶҗ Equiv.apply_eq_iff_eq equivToUnitHom, MonoidHom.eq_iff_eq_on_generator hg,
    вҶҗ coe_equivToUnitHom, вҶҗ coe_equivToUnitHom, Units.ext_iff]

theorem restrict_ofUnitHom (f : RЛЈ вҶ’* R'ЛЈ) (S : Submonoid R) :
    restrict S (ofUnitHom f) =
      ofUnitHom ((f.restrict S.units).comp S.unitsEquivUnitsType.symm) := by
  ext x
  simp only [ofUnitHom_eq, restrict_apply, Units.isUnit, reduceIte, equivToUnitHom_symm_coe,
    MonoidHom.coe_comp, MonoidHom.coe_coe, Function.comp_apply, MonoidHom.restrict_apply]
  rw [вҶҗ Submonoid.val_unitsEquivUnitsType_symm_apply_coe S x, equivToUnitHom_symm_coe]

variable (R')

/--
The restriction of a `MulChar` to a submonoid as an homomorphism.
-/
@[simps]
noncomputable def restrictHom :
    MulChar R R' вҶ’* MulChar T R' where
  toFun ПҮ := ПҮ.restrict T
  map_one' := by
    ext x
    rw [restrict_apply, if_pos x.isUnit, MulChar.one_apply x.isUnit.coe, one_apply_coe]
  map_mul' _ _ := by ext; simp

end CommMonoid

section Ring

variable {R R' : Type*} [CommRing R] [CommRing R']

/-- Define the conjugation (`star`) of a multiplicative character by conjugating pointwise. -/
@[simps!]
def starComp [StarRing R'] (ПҮ : MulChar R R') : MulChar R R' :=
  ПҮ.ringHomComp (starRingEnd R')

instance instStarMul [StarRing R'] : StarMul (MulChar R R') where
  star := starComp
  star_involutive ПҮ := by
    ext1
    simp only [starComp_apply, RingHomCompTriple.comp_apply, RingHom.id_apply]
  star_mul ПҮ ПҮ' := by
    ext1
    simp only [starComp_apply, starRingEnd, coeToFun_mul, Pi.mul_apply, map_mul, RingHom.coe_coe,
      starRingAut_apply, mul_comm]

@[simp]
lemma star_apply [StarRing R'] (ПҮ : MulChar R R') (a : R) : (star ПҮ) a = star (ПҮ a) :=
  rfl

/-- The values of a multiplicative character on `R` are `n`th roots of unity, where `n = #RЛЈ`. -/
lemma apply_mem_rootsOfUnity [Fintype RЛЈ] (a : RЛЈ) {ПҮ : MulChar R R'} :
    equivToUnitHom ПҮ a вҲҲ rootsOfUnity (Fintype.card RЛЈ) R' := by
  rw [mem_rootsOfUnity, вҶҗ map_pow, вҶҗ (equivToUnitHom ПҮ).map_one, pow_card_eq_one]

variable [Finite RЛЈ]

open Complex in
/-- The conjugate of a multiplicative character with values in `в„Ӯ` is its inverse. -/
lemma star_eq_inv (ПҮ : MulChar R в„Ӯ) : star ПҮ = ПҮвҒ»В№ := by
  cases nonempty_fintype RЛЈ
  ext1 a
  simp only [inv_apply_eq_inv']
  exact (inv_eq_conj <| norm_eq_one_of_mem_rootsOfUnity <| ПҮ.apply_mem_rootsOfUnity a).symm

lemma star_apply' (ПҮ : MulChar R в„Ӯ) (a : R) : star (ПҮ a) = ПҮвҒ»В№ a := by
  simp only [RCLike.star_def, вҶҗ star_eq_inv, star_apply]

end Ring

section IsCyclic

/-!
### Multiplicative characters on finite monoids with cyclic unit group
-/

variable {M : Type*} [CommMonoid M] [Fintype M] [DecidableEq M]
variable {R : Type*} [CommMonoidWithZero R]

/-- Given a finite monoid `M` with unit group `MЛЈ` cyclic of order `n` and an `n`th root of
unity `О¶` in `R`, there is a multiplicative character `M вҶ’ R` that sends a given generator
of `MЛЈ` to `О¶`. -/
noncomputable def ofRootOfUnity {О¶ : RЛЈ} (hО¶ : О¶ вҲҲ rootsOfUnity (Fintype.card MЛЈ) R)
    {g : MЛЈ} (hg : вҲҖ x, x вҲҲ Subgroup.zpowers g) :
    MulChar M R := by
  have : orderOf О¶ вҲЈ Fintype.card MЛЈ :=
    orderOf_dvd_iff_pow_eq_one.mpr <| (mem_rootsOfUnity _ О¶).mp hО¶
  refine ofUnitHom <| monoidHomOfForallMemZpowers hg <| this.trans <| dvd_of_eq ?_
  rw [orderOf_eq_card_of_forall_mem_zpowers hg, Nat.card_eq_fintype_card]

lemma ofRootOfUnity_spec {О¶ : RЛЈ} (hО¶ : О¶ вҲҲ rootsOfUnity (Fintype.card MЛЈ) R)
    {g : MЛЈ} (hg : вҲҖ x, x вҲҲ Subgroup.zpowers g) :
    ofRootOfUnity hО¶ hg g = О¶ := by
  simp only [ofRootOfUnity, ofUnitHom_eq, equivToUnitHom_symm_coe,
    monoidHomOfForallMemZpowers_apply_gen]

variable (M R) in
/-- The group of multiplicative characters on a finite monoid `M` with cyclic unit group `MЛЈ`
of order `n` is isomorphic to the group of `n`th roots of unity in the target `R`. -/
noncomputable def equiv_rootsOfUnity [inst_cyc : IsCyclic MЛЈ] :
    MulChar M R вүғ* rootsOfUnity (Fintype.card MЛЈ) R where
  toFun ПҮ :=
    вҹЁПҮ.toUnitHom <| Classical.choose inst_cyc.exists_generator, by
      simp only [toUnitHom_eq, mem_rootsOfUnity, вҶҗ map_pow, pow_card_eq_one, map_one]вҹ©
  invFun О¶ := ofRootOfUnity О¶.prop <| Classical.choose_spec inst_cyc.exists_generator
  left_inv ПҮ := by
    simp only [toUnitHom_eq, eq_iff <| Classical.choose_spec inst_cyc.exists_generator,
      ofRootOfUnity_spec, coe_equivToUnitHom]
  right_inv О¶ := by
    ext
    simp only [toUnitHom_eq, coe_equivToUnitHom, ofRootOfUnity_spec]
  map_mul' x y := by
    simp only [toUnitHom_eq, equivToUnitHom_mul_apply, MulMemClass.mk_mul_mk]

end IsCyclic

section FiniteField

/-!
### Multiplicative characters on finite fields
-/

section Fintype

variable (F : Type*) [Field F] [Fintype F]
variable {R : Type*} [CommRing R]

/-- There is a character of order `n` on `F` if `#F вүЎ 1 mod n` and the target contains
a primitive `n`th root of unity. -/
lemma exists_mulChar_orderOf {n : в„•} (h : n вҲЈ Fintype.card F - 1) {О¶ : R}
    (hО¶ : IsPrimitiveRoot О¶ n) :
    вҲғ ПҮ : MulChar F R, orderOf ПҮ = n := by
  classical
  have hnвӮҖ : 0 < n := by
    refine Nat.pos_of_ne_zero fun hn вҶҰ ?_
    simp only [hn, zero_dvd_iff, Nat.sub_eq_zero_iff_le] at h
    exact (Fintype.one_lt_card.trans_le h).false
  let e := MulChar.equiv_rootsOfUnity F R
  let О¶' : RЛЈ := (hО¶.isUnit hnвӮҖ.ne').unit
  have h' : О¶' ^ (Fintype.card FЛЈ : в„•) = 1 :=
    Units.ext_iff.mpr <| (hО¶.pow_eq_one_iff_dvd _).mpr <| Fintype.card_units (Оұ := F) в–ё h
  use e.symm вҹЁО¶', (mem_rootsOfUnity (Fintype.card FЛЈ) О¶').mpr h'вҹ©
  rw [e.symm.orderOf_eq, orderOf_eq_iff hnвӮҖ]
  refine вҹЁ?_, fun m hm hmвӮҖ h вҶҰ ?_вҹ©
  В· ext
    push_cast
    exact hО¶.pow_eq_one
  В· rw [Subtype.ext_iff, Units.ext_iff] at h
    push_cast at h
    exact ((Nat.le_of_dvd hmвӮҖ <| hО¶.dvd_of_pow_eq_one _ h).trans_lt hm).false

/-- If there is a multiplicative character of order `n` on `F`, then `#F вүЎ 1 mod n`. -/
lemma orderOf_dvd_card_sub_one (ПҮ : MulChar F R) : orderOf ПҮ вҲЈ Fintype.card F - 1 := by
  classical
  rw [вҶҗ Fintype.card_units]
  exact orderOf_dvd_of_pow_eq_one ПҮ.pow_card_eq_one

/-- There is always a character on `F` of order `#F-1` with values in a ring that has
a primitive `(#F-1)`th root of unity. -/
lemma exists_mulChar_orderOf_eq_card_units [DecidableEq F]
    {О¶ : R} (hО¶ : IsPrimitiveRoot О¶ (Fintype.card FЛЈ)) :
    вҲғ ПҮ : MulChar F R, orderOf ПҮ = Fintype.card FЛЈ :=
  exists_mulChar_orderOf F (by rw [Fintype.card_units]) hО¶

end Fintype

variable {F : Type*} [Field F] [Finite F]
variable {R : Type*} [CommRing R]

/- The non-zero values of a multiplicative character of order `n` are `n`th roots of unity. -/
lemma apply_mem_rootsOfUnity_orderOf (ПҮ : MulChar F R) {a : F} (ha : a вү  0) :
    вҲғ О¶ вҲҲ rootsOfUnity (orderOf ПҮ) R, О¶ = ПҮ a := by
  have hu : IsUnit (ПҮ a) := ha.isUnit.map ПҮ
  refine вҹЁhu.unit, ?_, hu.unit_specвҹ©
  rw [mem_rootsOfUnity, Units.ext_iff, Units.val_pow_eq_pow_val, Units.val_one,
    IsUnit.unit_spec, вҶҗ ПҮ.pow_apply' ПҮ.orderOf_pos.ne', pow_orderOf_eq_one,
    show a = (isUnit_iff_ne_zero.mpr ha).unit by simp only [IsUnit.unit_spec],
    MulChar.one_apply_coe]

/-- The non-zero values of a multiplicative character `ПҮ` such that `ПҮ^n = 1`
are `n`th roots of unity. -/
lemma apply_mem_rootsOfUnity_of_pow_eq_one {ПҮ : MulChar F R} {n : в„•} (hПҮ : ПҮ ^ n = 1)
    {a : F} (ha : a вү  0) :
    вҲғ О¶ вҲҲ rootsOfUnity n R, О¶ = ПҮ a := by
  obtain вҹЁОј, hОјвӮҒ, hОјвӮӮвҹ© := ПҮ.apply_mem_rootsOfUnity_orderOf ha
  exact вҹЁОј, rootsOfUnity_le_of_dvd (orderOf_dvd_of_pow_eq_one hПҮ) hОјвӮҒ, hОјвӮӮвҹ©

-- Results involving primitive roots of unity require `R` to be an integral domain.
variable [IsDomain R]

/-- If `ПҮ` is a multiplicative character with `ПҮ^n = 1` and `Ој` is a primitive `n`th root
of unity, then, for `a вү  0`, there is some `k` such that `ПҮ a = Ој^k`. -/
lemma exists_apply_eq_pow {ПҮ : MulChar F R} {n : в„•} [NeZero n] (hПҮ : ПҮ ^ n = 1) {Ој : R}
    (hОј : IsPrimitiveRoot Ој n) {a : F} (ha : a вү  0) :
    вҲғ k < n, ПҮ a = Ој ^ k := by
  obtain вҹЁО¶, hО¶вӮҒ, hО¶вӮӮвҹ© := apply_mem_rootsOfUnity_of_pow_eq_one hПҮ ha
  have hО¶' : О¶.val ^ n = 1 := (mem_rootsOfUnity' n вҶ‘О¶).mp hО¶вӮҒ
  obtain вҹЁk, hkвӮҒ, hkвӮӮвҹ© := hОј.eq_pow_of_pow_eq_one hО¶'
  exact вҹЁk, hkвӮҒ, (hО¶вӮӮ в–ё hkвӮӮ).symmвҹ©

/-- The values of a multiplicative character `ПҮ` such that `ПҮ^n = 1` are contained in `в„Ө[Ој]` when
`Ој` is a primitive `n`th root of unity. -/
lemma apply_mem_algebraAdjoin_of_pow_eq_one {ПҮ : MulChar F R} {n : в„•} [NeZero n] (hПҮ : ПҮ ^ n = 1)
    {Ој : R} (hОј : IsPrimitiveRoot Ој n) (a : F) :
    ПҮ a вҲҲ Algebra.adjoin в„Ө {Ој} := by
  rcases eq_or_ne a 0 with rfl | h
  В· exact ПҮ.map_zero в–ё Subalgebra.zero_mem _
  В· obtain вҹЁО¶, hО¶вӮҒ, hО¶вӮӮвҹ© := apply_mem_rootsOfUnity_of_pow_eq_one hПҮ h
    rw [mem_rootsOfUnity, Units.ext_iff, Units.val_pow_eq_pow_val] at hО¶вӮҒ
    obtain вҹЁk, _, hkвҹ© := IsPrimitiveRoot.eq_pow_of_pow_eq_one hОј hО¶вӮҒ
    exact hО¶вӮӮ в–ё hk в–ё Subalgebra.pow_mem _ (Algebra.self_mem_adjoin_singleton в„Ө Ој) k

/-- The values of a multiplicative character of order `n` are contained in `в„Ө[Ој]` when
`Ој` is a primitive `n`th root of unity. -/
lemma apply_mem_algebraAdjoin {ПҮ : MulChar F R} {Ој : R} (hОј : IsPrimitiveRoot Ој (orderOf ПҮ))
    (a : F) :
    ПҮ a вҲҲ Algebra.adjoin в„Ө {Ој} :=
  have : NeZero (orderOf ПҮ) := вҹЁПҮ.orderOf_pos.ne'вҹ©
  apply_mem_algebraAdjoin_of_pow_eq_one (pow_orderOf_eq_one ПҮ) hОј a

end FiniteField

