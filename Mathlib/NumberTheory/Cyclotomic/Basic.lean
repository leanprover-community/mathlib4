/-- If `S` is finite and `IsCyclotomicExtension S A B`, then `B` is a finite `A`-algebra. -/
protected theorem finite [IsDomain B] [hÔéü : Finite S] [hÔéé : IsCyclotomicExtension S A B] :
    Module.Finite A B := by
