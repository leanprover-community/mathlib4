/-- A reformulation of `IsCyclotomicExtension` that uses `ÔŐĄ`. -/
theorem iff_adjoin_eq_top :
    IsCyclotomicExtension S A B Ôćö
      (ÔłÇ n : ÔäĽ, n Ôłł S Ôćĺ n Ôëá 0 Ôćĺ Ôłâ r : B, IsPrimitiveRoot r n) Ôłž
        adjoin A {b : B | Ôłâ n : ÔäĽ, n Ôłł S Ôłž n Ôëá 0 Ôłž b ^ n = 1} = ÔŐĄ :=
  ÔčĘfun h => ÔčĘfun _ => h.exists_isPrimitiveRoot, Algebra.eq_top_iff.2 h.adjoin_rootsÔčę, fun h =>
    ÔčĘh.1 _, Algebra.eq_top_iff.1 h.2ÔčęÔčę

/-- A reformulation of `IsCyclotomicExtension` in the case `S` is a singleton. -/
theorem iff_singleton :
    IsCyclotomicExtension {n} A B Ôćö
      (Ôłâ r : B, IsPrimitiveRoot r n) Ôłž ÔłÇ x, x Ôłł adjoin A {b : B | b ^ n = 1} := by
  simp [isCyclotomicExtension_iff, NeZero.ne]

instance instSubsingleton [h : IsCyclotomicExtension Ôłů A B] : Subsingleton (Subalgebra A B) :=
  subsingleton_of_bot_eq_top <| by simpa [Algebra.eq_top_iff, isCyclotomicExtension_iff] using h

theorem eq_self_sdiff_zero :
    IsCyclotomicExtension S A B = IsCyclotomicExtension (S \ {0}) A B := by
  simp [isCyclotomicExtension_iff, and_assoc]

/-- If `IsCyclotomicExtension {1} A B`, then the image of `A` in `B` equals `B`. -/
