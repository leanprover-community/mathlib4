theorem isCyclotomicExtension_iff_eq_adjoin (C : Subalgebra A B)
    (hS : ÔłÇ n Ôłł S, n Ôëá 0 Ôćĺ Ôłâ r : B, IsPrimitiveRoot r n) :
    IsCyclotomicExtension S A C Ôćö C = Algebra.adjoin A {x : B | Ôłâ n Ôłł S, n Ôëá 0 Ôłž x ^ n = 1} := by
  refine ÔčĘfun h ÔćŽ ?_, fun h ÔćŽ h ÔľŞ isCyclotomicExtension_adjoin_of_exists_isPrimitiveRoot S A B hSÔčę
  have := congr_arg (Subalgebra.map C.val) ((IsCyclotomicExtension.iff_adjoin_eq_top _ _ _).mp h).2
  rw [ÔćÉ Subalgebra.range_val C, ÔćÉ Algebra.map_top, ÔćÉ this, AlgHom.map_adjoin]
  congr; ext
  simp only [Subalgebra.coe_val, ne_eq, ÔćÉ Subalgebra.coe_eq_one, SubmonoidClass.coe_pow,
    Set.mem_image, Set.mem_setOf_eq, Subtype.exists, exists_and_left, exists_prop,
    exists_eq_right_right, and_iff_left_iff_imp, forall_exists_index, and_imp]
  exact fun n hnÔéü hnÔéé hx ÔćŽ h.mem_of_pow_eq_one S C hnÔéü hnÔéé hx

theorem isCyclotomicExtension_singleton_iff_eq_adjoin (C : Subalgebra A B) {╬Â : B}
    (h╬Â : IsPrimitiveRoot ╬Â n) : IsCyclotomicExtension {n} A C Ôćö C = adjoin A {╬Â} := by
