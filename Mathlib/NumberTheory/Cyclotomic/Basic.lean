instance isCyclotomicExtension [IsFractionRing A K] [NeZero ((n : ÔäĽ) : A)] :
    IsCyclotomicExtension {n} A (CyclotomicRing n A K) where
  exists_isPrimitiveRoot {a} han _ := by
    rw [mem_singleton_iff] at han
    subst a
    have := NeZero.of_faithfulSMul A K n
    have := NeZero.of_faithfulSMul A (CyclotomicField n K) n
    obtain ÔčĘ╬╝, h╬╝Ôčę := (CyclotomicField.isCyclotomicExtension n K).exists_isPrimitiveRoot
      (mem_singleton n) (NeZero.ne n)
    refine ÔčĘÔčĘ╬╝, subset_adjoin ?_Ôčę, ?_Ôčę
    ┬Ě apply (isRoot_of_unity_iff (NeZero.pos n) (CyclotomicField n K)).mpr
      refine ÔčĘn, Nat.mem_divisors_self _ (NeZero.ne n), ?_Ôčę
      rwa [ÔćÉ isRoot_cyclotomic_iff] at h╬╝
    ┬Ě rwa [ÔćÉ IsPrimitiveRoot.coe_submonoidClass_iff, Subtype.coe_mk]
  adjoin_roots x := by
    obtain ÔčĘx, hxÔčę := x
    refine
      adjoin_induction (fun y hy => ?_) (fun a => ?_) (fun y z _ _ hy hz => ?_)
        (fun y z  _ _ hy hz => ?_) hx
    ┬Ě refine subset_adjoin ?_
      simp only [mem_singleton_iff, exists_eq_left, mem_setOf_eq]
      exact ÔčĘNeZero.ne n, by rwa [ÔćÉ Subalgebra.coe_eq_one, Subalgebra.coe_pow, Subtype.coe_mk]Ôčę
    ┬Ě exact Subalgebra.algebraMap_mem _ a
    ┬Ě exact Subalgebra.add_mem _ hy hz
    ┬Ě exact Subalgebra.mul_mem _ hy hz

instance [IsFractionRing A K] [IsDomain A] [NeZero (n : A)] :
    IsFractionRing (CyclotomicRing n A K) (CyclotomicField n K) where
  map_units := fun ÔčĘx, hxÔčę => by
    rw [isUnit_iff_ne_zero]
    apply map_ne_zero_of_mem_nonZeroDivisors
    ┬Ě apply adjoin_algebra_injective
    ┬Ě exact hx
  surj x := by
    have : NeZero (n : K) := NeZero.nat_of_injective (IsFractionRing.injective A K)
    refine
      Algebra.adjoin_induction
        (hx := ((IsCyclotomicExtension.iff_singleton n K (CyclotomicField n K)).1
            (CyclotomicField.isCyclotomicExtension n K)).2 x)
        (fun y hy => ?_) (fun k => ?_) ?_ ?_
    ┬Ě exact ÔčĘÔčĘÔčĘy, subset_adjoin hyÔčę, 1Ôčę, by simp; rflÔčę
    ┬Ě have : IsLocalization (nonZeroDivisors A) K := inferInstance
      replace := this.surj
      obtain ÔčĘÔčĘz, wÔčę, hwÔčę := this k
      refine ÔčĘÔčĘalgebraMap A (CyclotomicRing n A K) z, algebraMap A (CyclotomicRing n A K) w,
        map_mem_nonZeroDivisors _ (algebraBase_injective n A K) w.2Ôčę, ?_Ôčę
      letI : IsScalarTower A K (CyclotomicField n K) :=
        IsScalarTower.of_algebraMap_eq (congr_fun rfl)
      rw [ÔćÉ IsScalarTower.algebraMap_apply, ÔćÉ IsScalarTower.algebraMap_apply,
        @IsScalarTower.algebraMap_apply A K _ _ _ _ _ (_root_.CyclotomicField.algebra n K) _ _ w,
        ÔćÉ map_mul, hw, ÔćÉ IsScalarTower.algebraMap_apply]
    ┬Ě rintro y z - - ÔčĘa, haÔčę ÔčĘb, hbÔčę
      refine ÔčĘÔčĘa.1 * b.2 + b.1 * a.2, a.2 * b.2, mul_mem_nonZeroDivisors.2 ÔčĘa.2.2, b.2.2ÔčęÔčę, ?_Ôčę
      rw [map_mul, add_mul, ÔćÉ mul_assoc, ha,
        mul_comm ((algebraMap (CyclotomicRing n A K) _) ÔćĹa.2), ÔćÉ mul_assoc, hb]
      simp only [map_add, map_mul]
    ┬Ě rintro y z - - ÔčĘa, haÔčę ÔčĘb, hbÔčę
      refine ÔčĘÔčĘa.1 * b.1, a.2 * b.2, mul_mem_nonZeroDivisors.2 ÔčĘa.2.2, b.2.2ÔčęÔčę, ?_Ôčę
      rw [map_mul, mul_comm ((algebraMap (CyclotomicRing n A K) _) ÔćĹa.2), mul_assoc, ÔćÉ
        mul_assoc z, hb, ÔćÉ mul_comm ((algebraMap (CyclotomicRing n A K) _) ÔćĹa.2), ÔćÉ mul_assoc, ha]
      simp only [map_mul]
  exists_of_eq {x y} h := ÔčĘ1, by rw [adjoin_algebra_injective n A K h]Ôčę

theorem eq_adjoin_primitive_root {╬╝ : CyclotomicField n K} (h : IsPrimitiveRoot ╬╝ n) :
