  ┬Ě simpa only [Set.mem_singleton_iff, ne_eq, forall_eq, NeZero.ne n, not_false_eq_true,
      forall_const] using ÔčĘ╬Â, h╬ÂÔčę

theorem IsCyclotomicExtension.eq (CÔéü CÔéé : Subalgebra A B) [hÔéü : IsCyclotomicExtension S A CÔéü]
