  replace h╬ÂÔéé := h╬ÂÔéé.map_of_injective (FaithfulSMul.algebraMap_injective CÔéé B)
  have h╬Â := h╬ÂÔéü.pow_mul_pow_lcm h╬ÂÔéé (NeZero.ne nÔéü) (NeZero.ne nÔéé)
