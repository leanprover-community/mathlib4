/-- Transitivity of cyclotomic extensions. -/
theorem trans (C : Type w) [CommRing C] [Algebra A C] [Algebra B C] [IsScalarTower A B C]
    [hS : IsCyclotomicExtension S A B] [hT : IsCyclotomicExtension T B C]
    (h : Function.Injective (algebraMap B C)) : IsCyclotomicExtension (S Ôł¬ T) A C := by
  refine ÔčĘfun hn => ?_, fun x => ?_Ôčę
  ┬Ě intro hn'
    rcases hn with hn | hn
    ┬Ě obtain ÔčĘb, hbÔčę := ((isCyclotomicExtension_iff _ _ _).1 hS).1 hn hn'
      refine ÔčĘalgebraMap B C b, ?_Ôčę
      exact hb.map_of_injective h
    ┬Ě exact ((isCyclotomicExtension_iff _ _ _).1 hT).1 hn hn'
  ┬Ě refine adjoin_induction (hx := ((isCyclotomicExtension_iff T B _).1 hT).2 x)
      (fun c ÔčĘn, hnÔčę => subset_adjoin ÔčĘn, Or.inr hn.1, hn.2Ôčę) (fun b => ?_)
      (fun x y _ _ hx hy => Subalgebra.add_mem _ hx hy)
      fun x y _ _ hx hy => Subalgebra.mul_mem _ hx hy
    let f := IsScalarTower.toAlgHom A B C
    have hb : f b Ôłł (adjoin A {b : B | Ôłâ a : ÔäĽ, a Ôłł S Ôłž a Ôëá 0 Ôłž b ^ a = 1}).map f :=
      ÔčĘb, ((isCyclotomicExtension_iff _ _ _).1 hS).2 b, rflÔčę
    rw [IsScalarTower.toAlgHom_apply, ÔćÉ adjoin_image] at hb
    refine adjoin_mono (fun y hy => ?_) hb
    obtain ÔčĘbÔéü, ÔčĘÔčĘn, hnÔčę, hÔéüÔčęÔčę := hy
    exact ÔčĘn, ÔčĘmem_union_left T hn.1, hn.2.1, by rw [ÔćÉ hÔéü, ÔćÉ map_pow, hn.2.2, map_one]ÔčęÔčę

@[nontriviality]
theorem subsingleton_iff [Subsingleton B] :
    IsCyclotomicExtension S A B Ôćö S ÔŐć {0, 1} := by
  have : Subsingleton (Subalgebra A B) := inferInstance
  refine ÔčĘfun ÔčĘhprim, _Ôčę ÔćŽ ?_, fun hS ÔćŽ ?_Ôčę
  ┬Ě refine subset_pair_iff.mpr fun s hs ÔćŽ or_iff_not_imp_left.mpr fun hs' ÔćŽ ?_
    obtain ÔčĘ╬Â, h╬ÂÔčę := hprim hs hs'
    exact mod_cast h╬Â.unique (IsPrimitiveRoot.of_subsingleton ╬Â)
  ┬Ě refine ÔčĘfun {s} hs hs' ÔćŽ ?_, fun x ÔćŽ by convert (mem_top (R := A) : x Ôłł ÔŐĄ)Ôčę
    ┬Ě have : s = 1 := (subset_pair_iff.mp hS s hs).resolve_left hs'
      exact ÔčĘ0, this ÔľŞ IsPrimitiveRoot.of_subsingleton 0Ôčę

/-- If `B` is a cyclotomic extension of `A` given by roots of unity of order in `S Ôł¬ T`, then `B`
is a cyclotomic extension of `adjoin A { b : B | Ôłâ a : ÔäĽ, a Ôłł S Ôłž a Ôëá 0 Ôłž b ^ a = 1 }` given by
roots of unity of order in `T`. -/
theorem union_right [h : IsCyclotomicExtension (S Ôł¬ T) A B] :
    IsCyclotomicExtension T (adjoin A {b : B | Ôłâ a : ÔäĽ, a Ôłł S Ôłž a Ôëá 0 Ôłž b ^ a = 1}) B := by
  have : {b : B | Ôłâ n : ÔäĽ, n Ôłł S Ôł¬ T Ôłž n Ôëá 0 Ôłž b ^ n = 1} =
      {b : B | Ôłâ n : ÔäĽ, n Ôłł S Ôłž n Ôëá 0 Ôłž b ^ n = 1} Ôł¬
        {b : B | Ôłâ n : ÔäĽ, n Ôłł T Ôłž n Ôëá 0 Ôłž b ^ n = 1} := by
    refine le_antisymm ?_ ?_
    ┬Ě rintro x ÔčĘn, hnÔéü | hnÔéé, hnpowÔčę
      ┬Ě left; exact ÔčĘn, hnÔéü, hnpowÔčę
      ┬Ě right; exact ÔčĘn, hnÔéé, hnpowÔčę
    ┬Ě rintro x (ÔčĘn, hnÔčę | ÔčĘn, hnÔčę)
      ┬Ě exact ÔčĘn, Or.inl hn.1, hn.2Ôčę
      ┬Ě exact ÔčĘn, Or.inr hn.1, hn.2Ôčę
  refine ÔčĘfun hn => ((isCyclotomicExtension_iff _ A _).1 h).1 (mem_union_right S hn), fun b => ?_Ôčę
  replace h := ((isCyclotomicExtension_iff _ _ _).1 h).2 b
  rwa [this, adjoin_union_eq_adjoin_adjoin, Subalgebra.mem_restrictScalars] at h

/-- If `B` is a cyclotomic extension of `A` given by roots of unity of order in `T` and `S ÔŐć T`,
then `adjoin A { b : B | Ôłâ a : ÔäĽ, a Ôłł S Ôłž a Ôëá 0 Ôłž b ^ a = 1 }` is a cyclotomic extension of `B`
given by roots of unity of order in `S`. -/
theorem union_left [h : IsCyclotomicExtension T A B] (hS : S ÔŐć T) :
    IsCyclotomicExtension S A (adjoin A {b : B | Ôłâ a : ÔäĽ, a Ôłł S Ôłž a Ôëá 0 Ôłž b ^ a = 1}) := by
  refine ÔčĘfun {n} hn hn' => ?_, fun b => ?_Ôčę
  ┬Ě obtain ÔčĘb, hbÔčę := ((isCyclotomicExtension_iff _ _ _).1 h).1 (hS hn) hn'
    refine ÔčĘÔčĘb, subset_adjoin ÔčĘn, hn, hn', hb.pow_eq_oneÔčęÔčę, ?_Ôčę
    rwa [ÔćÉ IsPrimitiveRoot.coe_submonoidClass_iff, Subtype.coe_mk]
  ┬Ě convert mem_top (R := A) (x := b)
    rw [ÔćÉ adjoin_adjoin_coe_preimage, preimage_setOf_eq]
    norm_cast

variable {n S}

/-- If there exists a nonzero `s Ôłł S` such that `n Ôłú s`, then `IsCyclotomicExtension S A B`
implies `IsCyclotomicExtension (S Ôł¬ {n}) A B`. -/
theorem of_union_of_dvd (h : Ôłâ s Ôłł S, s Ôëá 0 Ôłž n Ôłú s) [H : IsCyclotomicExtension S A B] :
    IsCyclotomicExtension (S Ôł¬ {n}) A B := by
  refine (iff_adjoin_eq_top _ A _).2 ÔčĘfun s hs hs' ÔćŽ ?_, ?_Ôčę
  ┬Ě rw [mem_union, mem_singleton_iff] at hs
    obtain hs | rfl := hs
    ┬Ě exact H.exists_isPrimitiveRoot hs hs'
    ┬Ě obtain ÔčĘm, hm, hm', ÔčĘx, rflÔčęÔčę := h
      obtain ÔčĘ╬Â, h╬ÂÔčę := H.exists_isPrimitiveRoot hm hm'
      refine ÔčĘ╬Â ^ x, ?_Ôčę
      have h_xnz : x Ôëá 0 := Nat.ne_zero_of_mul_ne_zero_right hm'
      have := h╬Â.pow_of_dvd h_xnz (dvd_mul_left x s)
      rwa [mul_div_cancel_rightÔéÇ _ h_xnz] at this
  ┬Ě refine _root_.eq_top_iff.2 ?_
    rw [ÔćÉ ((iff_adjoin_eq_top S A B).1 H).2]
    refine adjoin_mono fun x hx ÔćŽ ?_
    simp only [union_singleton, mem_insert_iff, mem_setOf_eq] at hx ÔŐó
    obtain ÔčĘm, hm, hm'Ôčę := hx
    exact ÔčĘm, ÔčĘOr.inr hm, hm'ÔčęÔčę

/-- If there exists a nonzero `s Ôłł S` such that `n Ôłú s`, then `IsCyclotomicExtension S A B`
  if and only if `IsCyclotomicExtension (S Ôł¬ {n}) A B`. -/
theorem iff_union_of_dvd (h : Ôłâ s Ôłł S, s Ôëá 0 Ôłž n Ôłú s) :
    IsCyclotomicExtension S A B Ôćö IsCyclotomicExtension (S Ôł¬ {n}) A B := by
  refine
    ÔčĘfun H ÔćŽ of_union_of_dvd A B h, fun H => (iff_adjoin_eq_top _ A _).2
      ÔčĘfun s hs ÔćŽ ?_, ?_ÔčęÔčę
  ┬Ě exact H.exists_isPrimitiveRoot (subset_union_left hs)
  ┬Ě rw [_root_.eq_top_iff, ÔćÉ ((iff_adjoin_eq_top _ A B).1 H).2]
    refine adjoin_mono fun x hx => ?_
    simp only [union_singleton, mem_insert_iff, mem_setOf_eq] at hx ÔŐó
    obtain ÔčĘm, rfl | hm, hxpowÔčę := hx
    ┬Ě obtain ÔčĘy, ÔčĘhy, hy', ÔčĘz, rflÔčęÔčęÔčę := h
      exact ÔčĘ_, ÔčĘhy, hy', by simp only [pow_mul, hxpow, one_pow]ÔčęÔčę
    ┬Ě exact ÔčĘm, ÔčĘhm, hxpowÔčęÔčę

variable (n S)

/-- `IsCyclotomicExtension S A B` is equivalent to `IsCyclotomicExtension (S Ôł¬ {1}) A B`. -/
theorem iff_union_singleton_one :
    IsCyclotomicExtension S A B Ôćö IsCyclotomicExtension (S Ôł¬ {1}) A B := by
  by_cases hS : Ôłâ s Ôłł S, s Ôëá 0
  ┬Ě exact iff_union_of_dvd _ _ (by simpa)
  ┬Ě rw [eq_self_sdiff_zero S, eq_self_sdiff_zero (S Ôł¬ {1}), union_diff_distrib,
      show S \ {0} = Ôłů by aesop, empty_union, show {1} \ {0} = {1} by simp]
    refine ÔčĘfun H ÔćŽ ?_, fun H ÔćŽ ?_Ôčę
    ┬Ě refine (iff_adjoin_eq_top _ A _).2 ÔčĘfun s hs _ ÔćŽ ÔčĘ1, by simp [mem_singleton_iff.1 hs]Ôčę, ?_Ôčę
      simpa [adjoin_singleton_one] using subsingleton_iff_bot_eq_top.mpr inferInstance
    ┬Ě refine (iff_adjoin_eq_top _ A _).2 ÔčĘfun s hs ÔćŽ (notMem_empty s hs).elim, ?_Ôčę
      simp [singleton_one]

