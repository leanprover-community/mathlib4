/-- Given `(f : B ÔëâÔéÉ[A] C)`, if `IsCyclotomicExtension S A B` then
`IsCyclotomicExtension S A C`. -/
protected
theorem equiv {C : Type*} [CommRing C] [Algebra A C] [h : IsCyclotomicExtension S A B]
    (f : B ÔëâÔéÉ[A] C) : IsCyclotomicExtension S A C := by
  letI : Algebra B C := f.toAlgHom.toRingHom.toAlgebra
  haveI : IsCyclotomicExtension {1} B C := singleton_one_of_algebraMap_bijective f.surjective
  haveI : IsScalarTower A B C := IsScalarTower.of_algHom f.toAlgHom
  exact (iff_union_singleton_one _ _ _).2 (trans S {1} A B C f.injective)

theorem neZero_of_mem [IsCyclotomicExtension S A B] [IsDomain B] (hn : n Ôłł S) : NeZero (n : B) :=
  (exists_isPrimitiveRoot A B hn NeZero.out).choose_spec.neZero'

theorem neZero_of_mem' [IsCyclotomicExtension S A B] [IsDomain B] (hn : n Ôłł S) : NeZero (n : A) :=
  (neZero_of_mem n S A B hn).nat_of_neZero (algebraMap A B)

protected
theorem neZero [IsCyclotomicExtension {n} A B] [IsDomain B] : NeZero (n : B) :=
  neZero_of_mem n {n} A B (mem_singleton n)

protected
theorem neZero' [IsCyclotomicExtension {n} A B] [IsDomain B] : NeZero (n : A) :=
  neZero_of_mem' n {n} A B (mem_singleton n)

/-- A cyclotomic extension is integral. -/
theorem integral [IsCyclotomicExtension S A B] : Algebra.IsIntegral A B := by
  rw [ÔćÉ (Subalgebra.equivOfEq _ _ ((IsCyclotomicExtension.iff_adjoin_eq_top S A B).1 ÔÇ╣_ÔÇ║).2
    |>.trans Subalgebra.topEquiv).isIntegral_iff]
  exact Algebra.IsIntegral.adjoin fun x ÔčĘn, hn, h1, h2Ôčę ÔćŽ
    ÔčĘX ^ n - 1, monic_X_pow_sub_C 1 h1, by simp [h2]Ôčę

theorem _root_.Algebra.isCyclotomicExtension_adjoin_of_exists_isPrimitiveRoot
    (h : ÔłÇ n Ôłł S, n Ôëá 0 Ôćĺ Ôłâ r : B, IsPrimitiveRoot r n) :
    IsCyclotomicExtension S A (adjoin A {b : B | Ôłâ n Ôłł S, n Ôëá 0 Ôłž b ^ n = 1}) where
  exists_isPrimitiveRoot {n} hn1 hn2 := by
    obtain ÔčĘr, hr1, hr2Ôčę := h n hn1 hn2
    exact ÔčĘÔčĘr, subset_adjoin ÔčĘn, hn1, hn2, hr1ÔčęÔčę, Subtype.val_injective hr1,
      fun l hl ÔćŽ hr2 l congr($hl.1)Ôčę
  adjoin_roots := by
    rintro ÔčĘx, hxÔčę
    induction hx using adjoin_induction with
    | mem x hx =>
      obtain ÔčĘn, hn1, hn2, hxÔčę := hx
      exact subset_adjoin ÔčĘn, hn1, hn2, Subtype.val_injective hxÔčę
    | algebraMap x => exact Subalgebra.algebraMap_mem _ x
    | add x y hx hy ihx ihy => exact Subalgebra.add_mem _ ihx ihy
    | mul x y hx hy ihx ihy => exact Subalgebra.mul_mem _ ihx ihy

/-- Two elements in the Galois group of a cyclotomic extension are equal if
their actions on primitive roots are equal. -/
theorem algEquiv_eq_of_apply_eq [IsCyclotomicExtension S A B] [IsDomain B] {f g : B ÔëâÔéÉ[A] B}
    (H : ÔłÇ n Ôłł S, n Ôëá 0 Ôćĺ Ôłâ r : B, IsPrimitiveRoot r n Ôłž f r = g r) : f = g := by
  ext x
  have hx := ÔÇ╣IsCyclotomicExtension S A BÔÇ║.adjoin_roots x
  induction hx using Algebra.adjoin_induction with
  | mem y hy =>
    obtain ÔčĘn, hn, h1, h2Ôčę := hy
    obtain ÔčĘr, hr1, hr2Ôčę := H n hn h1
    have := NeZero.mk h1
    obtain ÔčĘm, -, rflÔčę := hr1.eq_pow_of_pow_eq_one h2
    simp [hr2]
  | algebraMap y => simp
  | add x y hx hy ihx ihy => simp [ihx, ihy]
  | mul x y hx hy ihx ihy => simp [ihx, ihy]

/-- Cyclotomic extensions are abelian. -/
theorem isMulCommutative [IsCyclotomicExtension S A B] [IsDomain B] :
    IsMulCommutative (B ÔëâÔéÉ[A] B) := by
  refine ÔčĘÔčĘfun f g ÔćŽ algEquiv_eq_of_apply_eq S A B fun n hn h1 ÔćŽ ?_ÔčęÔčę
  obtain ÔčĘr, hrÔčę := ÔÇ╣IsCyclotomicExtension S A BÔÇ║.exists_isPrimitiveRoot hn h1
  use r, hr
