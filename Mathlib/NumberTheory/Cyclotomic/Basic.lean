    have : Module.Finite (adjoin A {b : B | Ôłâ n : ÔäĽ, n Ôłł S Ôłž n Ôëá 0 Ôłž b ^ n = 1}) B := by
      rw [ÔćÉ union_singleton] at hÔéé
