    [h : IsCyclotomicExtension S A C] {m : ÔäĽ} {╬Â : B} (hÔéü : m Ôłł S) (hÔéé : m Ôëá 0)
    (h╬Â : ╬Â ^ m = 1) : ╬Â Ôłł C := by
