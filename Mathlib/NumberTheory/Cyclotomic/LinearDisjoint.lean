module

public import Mathlib.FieldTheory.LinearDisjoint
public import Mathlib.NumberTheory.NumberField.Cyclotomic.Basic
public import Mathlib.NumberTheory.Cyclotomic.PrimitiveRoots

/-!
# Linear disjointness of cyclotomic subfields

This file contains linear-disjointness results for cyclotomic subfields of coprime orders.
-/

@[expose] public section

noncomputable section

open Algebra IntermediateField Nat
open scoped IntermediateField

set_option backward.isDefEq.respectTransparency false in
/-- In a cyclotomic extension of order `n₁ * n₂`, the subfields generated by the `n₁`-part
and the `n₂`-part are linearly disjoint over `ℚ`, when `n₁` and `n₂` are coprime. -/
theorem IsPrimitiveRoot.linearDisjoint_adjoin_pow_of_coprime
    {K : Type*} [Field K] [CharZero K] [Algebra.IsIntegral ℚ K]
    {n₁ n₂ : ℕ} [NeZero n₁] [NeZero n₂]
    [IsCyclotomicExtension {n₁ * n₂} ℚ K]
    {ζ : K} (hζ : IsPrimitiveRoot ζ (n₁ * n₂)) (hcop : n₁.Coprime n₂) :
    (ℚ⟮ζ ^ n₂⟯ : IntermediateField ℚ K).LinearDisjoint
      (ℚ⟮ζ ^ n₁⟯ : IntermediateField ℚ K) := by
  let F₁ : IntermediateField ℚ K := ℚ⟮ζ ^ n₂⟯
  let F₂ : IntermediateField ℚ K := ℚ⟮ζ ^ n₁⟯
  change F₁.LinearDisjoint F₂
  have hnpos : 0 < n₁ * n₂ := mul_pos n₁.pos_of_neZero n₂.pos_of_neZero
  have hζ₁ : IsPrimitiveRoot (ζ ^ n₂) n₁ := by
    simpa [mul_comm] using hζ.pow hnpos (a := n₂) (b := n₁) (by simp [mul_comm])
  have hζ₂ : IsPrimitiveRoot (ζ ^ n₁) n₂ := by
    simpa using hζ.pow hnpos (a := n₁) (b := n₂) rfl
  haveI : IsCyclotomicExtension {n₁} ℚ F₁ :=
    hζ₁.intermediateField_adjoin_isCyclotomicExtension (K := ℚ) (L := K)
  haveI : IsCyclotomicExtension {n₂} ℚ F₂ :=
    hζ₂.intermediateField_adjoin_isCyclotomicExtension (K := ℚ) (L := K)
  haveI : Module.Finite ℚ F₁ := IsCyclotomicExtension.finite_of_singleton n₁ ℚ F₁
  haveI : Module.Finite ℚ F₂ := IsCyclotomicExtension.finite_of_singleton n₂ ℚ F₂
  have h_top : F₁ ⊔ F₂ = ⊤ := by
    have : IsCyclotomicExtension {n₁ * n₂} ℚ (⊤ : IntermediateField ℚ K) :=
      (inferInstance : IsCyclotomicExtension {n₁ * n₂} ℚ K).equiv _ _ _ topEquiv.symm
    have : IsCyclotomicExtension {n₁ * n₂} ℚ ↥(F₁ ⊔ F₂) := by
      simpa [Nat.Coprime.lcm_eq_mul hcop] using
        IntermediateField.isCyclotomicExtension_lcm_sup ℚ K n₁ n₂ F₁ F₂
    exact IntermediateField.isCyclotomicExtension_eq {n₁ * n₂} ℚ K (F₁ ⊔ F₂) ⊤
  apply IntermediateField.LinearDisjoint.of_finrank_sup (A := F₁) (B := F₂)
  haveI : NeZero (n₁ * n₂) := ⟨Nat.ne_of_gt hnpos⟩
  rw [h_top, IntermediateField.finrank_top',
    IsCyclotomicExtension.Rat.finrank (k := n₁ * n₂) (K := K),
    IsCyclotomicExtension.Rat.finrank (k := n₁) (K := F₁),
    IsCyclotomicExtension.Rat.finrank (k := n₂) (K := F₂),
    Nat.totient_mul hcop]

end
