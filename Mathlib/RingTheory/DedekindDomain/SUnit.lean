/-- A module is finitely generated if the kernel and range of some linear map out of it are both
finitely generated (it is an extension of its range by its kernel). General; a candidate for
`Mathlib/RingTheory/Finiteness/`. -/
theorem Module.Finite.of_fg_ker_of_fg_range {R G H : Type*} [Ring R] [AddCommGroup G]
    [AddCommGroup H] [Module R G] [Module R H] (f : G вҶ’вӮ—[R] H)
    [Module.Finite R (LinearMap.ker f)] [Module.Finite R (LinearMap.range f)] :
    Module.Finite R G := by
  have : Module.Finite R (G в§ё LinearMap.ker f) :=
    Module.Finite.equiv (LinearMap.quotKerEquivRange f).symm
  exact Module.Finite.of_submodule_quotient (LinearMap.ker f)

/-- A commutative group is finitely generated if the kernel and range of some hom out of it are both
finitely generated. Proved by transporting `Module.Finite.of_fg_ker_of_fg_range` along
`Additive`/`в„Ө`-modules. -/
theorem CommGroup.fg_of_fg_ker_of_fg_range {G H : Type*} [CommGroup G] [CommGroup H]
    (f : G вҶ’* H) (hk : Group.FG (f.ker : Subgroup G)) (hr : Group.FG (f.range : Subgroup H)) :
    Group.FG G := by
  rw [GroupFG.iff_add_fg, вҶҗ Module.Finite.iff_addGroup_fg]
  haveI : Module.Finite в„Ө (LinearMap.ker (MonoidHom.toAdditive f).toIntLinearMap) := by
    rw [AddMonoidHom.coe_toIntLinearMap_ker, Module.Finite.iff_fg, Submodule.fg_iff_addSubgroup_fg,
      AddSubgroup.toIntSubmodule_toAddSubgroup]
    exact (Subgroup.fg_iff_add_fg f.ker).mp ((Group.fg_iff_subgroup_fg f.ker).mp hk)
  haveI : Module.Finite в„Ө (LinearMap.range (MonoidHom.toAdditive f).toIntLinearMap) := by
    rw [AddMonoidHom.coe_toIntLinearMap_range, Module.Finite.iff_fg,
      Submodule.fg_iff_addSubgroup_fg, AddSubgroup.toIntSubmodule_toAddSubgroup]
    exact (Subgroup.fg_iff_add_fg f.range).mp ((Group.fg_iff_subgroup_fg f.range).mp hr)
  exact Module.Finite.of_fg_ker_of_fg_range (MonoidHom.toAdditive f).toIntLinearMap

/-- A subgroup of a finitely generated commutative group is finitely generated (`в„Ө` is
Noetherian). -/
theorem Subgroup.fg_of_fg_commGroup {M : Type*} [CommGroup M] [Group.FG M] (P : Subgroup M) :
    Group.FG P := by
  haveI : Module.Finite в„Ө (Additive M) :=
    Module.Finite.iff_addGroup_fg.mpr (GroupFG.iff_add_fg.mp вҖ№Group.FG MвҖә)
  haveI : IsNoetherian в„Ө (Additive M) := inferInstance
  have h : (AddSubgroup.toIntSubmodule (Subgroup.toAddSubgroup P)).FG := IsNoetherian.noetherian _
  rw [Submodule.fg_iff_addSubgroup_fg, AddSubgroup.toIntSubmodule_toAddSubgroup] at h
  exact (Group.fg_iff_subgroup_fg P).mpr ((Subgroup.fg_iff_add_fg P).mpr h)

namespace Set

variable {R : Type*} [CommRing R] [IsDedekindDomain R]
  (S : Set (HeightOneSpectrum R)) (K : Type*) [Field K] [Algebra R K] [IsFractionRing R K]

/-- The `S`-valuation map on `S`-units: `u вҶҰ (v(u))_{v вҲҲ S}`, valued in `вҶҘS вҶ’ Multiplicative в„Ө`. -/
noncomputable def unitValuation : S.unit K вҶ’* (вҶҘS вҶ’ Multiplicative в„Ө) where
  toFun u v := (v : HeightOneSpectrum R).valuationOfNeZero ((u : KЛЈ))
  map_one' := by ext v; simp only [Subgroup.coe_one, map_one, Pi.one_apply]
  map_mul' u u' := by ext v; simp only [Subgroup.coe_mul, map_mul, Pi.mul_apply]

@[simp] theorem unitValuation_apply (u : S.unit K) (v : вҶҘS) :
    unitValuation S K u v = (v : HeightOneSpectrum R).valuationOfNeZero ((u : KЛЈ)) := rfl

/-- The `вҲ…`-units (units with trivial valuation at *every* prime, i.e. the units `рқ’Ә_K^Г—` of the base
ring) sit inside the `S`-units. -/
theorem unit_empty_le : (вҲ… : Set (HeightOneSpectrum R)).unit K вүӨ S.unit K :=
  fun _ hu v _ => hu v (Set.notMem_empty v)

/-- A unit has trivial `v`-adic `valuationOfNeZero` iff its `v`-adic valuation is `1`. -/
theorem valuationOfNeZero_eq_one_iff (v : HeightOneSpectrum R) (x : KЛЈ) :
    v.valuationOfNeZero x = 1 вҶ” v.valuation K (x : K) = 1 := by
  rw [вҶҗ WithZero.coe_inj, valuationOfNeZero_eq, WithZero.coe_one]

/-- **The kernel of the `S`-valuation map is the `вҲ…`-units.** Equivalently, an `S`-unit lies in the
kernel iff it has trivial valuation at every prime вҖ” i.e. it is a unit of `рқ’Ә_K`. This is the exact
`1 вҶ’ рқ’Ә_K^Г— вҶ’ рқ’Ә_{K,S}^Г— вҶ’ вҠ•_{vвҲҲS} в„Ө` left-exactness. -/
theorem unitValuation_ker :
    (unitValuation S K).ker = ((вҲ… : Set (HeightOneSpectrum R)).unit K).subgroupOf (S.unit K) := by
  ext u
  rw [MonoidHom.mem_ker, Subgroup.mem_subgroupOf, funext_iff]
  constructor
  В· intro h v _
    by_cases hvS : v вҲҲ S
    В· have := h вҹЁv, hvSвҹ©
      rwa [unitValuation_apply, Pi.one_apply, valuationOfNeZero_eq_one_iff] at this
    В· exact u.property v hvS
  В· intro h v
    rw [unitValuation_apply, Pi.one_apply, valuationOfNeZero_eq_one_iff]
    exact h v (Set.notMem_empty v)

/-- **Finite generation of `S`-units.** If `S` is finite and the `вҲ…`-units `рқ’Ә_K^Г—` are finitely
generated (e.g. `K` is a number field, by Dirichlet's unit theorem), then the `S`-units `рқ’Ә_{K,S}^Г—`
are finitely generated. The kernel of `unitValuation` is `рқ’Ә_K^Г—` (`unitValuation_ker`) and its range
is a subgroup of the finitely generated free group `вҶҘS вҶ’ в„Ө`, so `рқ’Ә_{K,S}^Г—` is an extension of
finitely generated by finitely generated. -/
theorem unit_fg [Finite S] (hu : Group.FG ((вҲ… : Set (HeightOneSpectrum R)).unit K)) :
    Group.FG (S.unit K) := by
  haveI : Group.FG ((вҲ… : Set (HeightOneSpectrum R)).unit K) := hu
  haveI : Group.FG (вҶҘS вҶ’ Multiplicative в„Ө) := by
    rw [GroupFG.iff_add_fg, вҶҗ Module.Finite.iff_addGroup_fg]
    exact inferInstanceAs (Module.Finite в„Ө (вҶҘS вҶ’ в„Ө))
  refine CommGroup.fg_of_fg_ker_of_fg_range (unitValuation S K) ?_ ?_
  В· rw [unitValuation_ker]
    exact Group.fg_of_surjective
      (f := (Subgroup.subgroupOfEquivOfLe (unit_empty_le S K)).symm.toMonoidHom)
      (Subgroup.subgroupOfEquivOfLe (unit_empty_le S K)).symm.surjective
  В· exact Subgroup.fg_of_fg_commGroup _

open Module

omit [IsDedekindDomain R] in
/-- The codomain `вҶҘS вҶ’ Multiplicative в„Ө` of `unitValuation` is `в„Ө`-free of rank `|S|`. -/
theorem finrank_codomain [Finite S] :
    finrank в„Ө (Additive (вҶҘS вҶ’ Multiplicative в„Ө)) = Nat.card S := by
  have : Fintype вҶҘS := Fintype.ofFinite _
  rw [Nat.card_eq_fintype_card]
  exact Module.finrank_pi в„Ө

/-- The kernel of the additive `unitValuation` has the same `в„Ө`-rank as the `вҲ…`-units `рқ’Ә_K^Г—`. -/
theorem finrank_ker [Finite S] :
    finrank в„Ө (LinearMap.ker (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap)
      = finrank в„Ө (Additive ((вҲ… : Set (HeightOneSpectrum R)).unit K)) := by
  rw [AddMonoidHom.coe_toIntLinearMap_ker, MonoidHom.coe_toAdditive_ker, unitValuation_ker]
  exact LinearEquiv.finrank_eq
    (AddEquiv.toIntLinearEquiv
      (MulEquiv.toAdditive (Subgroup.subgroupOfEquivOfLe (unit_empty_le S K))))

/-- **Rank-nullity for `S`-units.** The `в„Ө`-rank of `рқ’Ә_{K,S}^Г—` is the rank of `рқ’Ә_K^Г—` plus the rank
of the image of `unitValuation`. -/
theorem finrank_eq_add_finrank_range [Finite S]
    (hu : Group.FG ((вҲ… : Set (HeightOneSpectrum R)).unit K)) :
    finrank в„Ө (Additive (S.unit K)) = finrank в„Ө (Additive ((вҲ… : Set (HeightOneSpectrum R)).unit K))
      + finrank в„Ө (LinearMap.range (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap) := by
  haveI : Group.FG (S.unit K) := unit_fg S K hu
  haveI : Module.Finite в„Ө (Additive (S.unit K)) :=
    Module.Finite.iff_addGroup_fg.mpr (GroupFG.iff_add_fg.mp вҖ№_вҖә)
  have hrn := Submodule.finrank_quotient_add_finrank
    (LinearMap.ker (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap)
  rw [LinearEquiv.finrank_eq
    (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap.quotKerEquivRange, finrank_ker]
    at hrn
  omega

/-- **Upper bound on the `S`-unit rank.** `rank рқ’Ә_{K,S}^Г— вүӨ rank рқ’Ә_K^Г— + |S|`. -/
theorem finrank_le [Finite S] (hu : Group.FG ((вҲ… : Set (HeightOneSpectrum R)).unit K)) :
    finrank в„Ө (Additive (S.unit K))
      вүӨ finrank в„Ө (Additive ((вҲ… : Set (HeightOneSpectrum R)).unit K)) + Nat.card S := by
  rw [finrank_eq_add_finrank_range S K hu]
  gcongr
  rw [вҶҗ finrank_codomain (S := S)]
  exact Submodule.finrank_le _

/-- The image of `unitValuation` has full `в„Ө`-rank `|S|`: its cokernel injects into the finite class
group, so it has finite index in `вҶҘS вҶ’ в„Ө`. -/
theorem finrank_range [Finite S] [Finite (ClassGroup R)] :
    finrank в„Ө (LinearMap.range (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap)
      = Nat.card S := by
  classical
  refine le_antisymm (by rw [вҶҗ finrank_codomain (S := S)]; exact Submodule.finrank_le _) ?_
  haveI : Fintype вҶҘS := Fintype.ofFinite _
  set g := (MonoidHom.toAdditive (unitValuation S K)).toIntLinearMap with hg
  -- For each `v вҲҲ S`, an `S`-unit whose `S`-valuation is supported exactly at `v`.
  have key : вҲҖ v : вҶҘS, вҲғ u : S.unit K,
      (вҲҖ w : вҶҘS, w вү  v вҶ’ unitValuation S K u w = 1) вҲ§ unitValuation S K u v вү  1 := by
    intro v
    set I := (v : HeightOneSpectrum R).asIdeal with hIdef
    have hbot : I вү  вҠҘ := (v : HeightOneSpectrum R).ne_bot
    have hI0 : I вҲҲ (Ideal R)вҒ° :=
      mem_nonZeroDivisors_iff_ne_zero.mpr (by rwa [Ne, Ideal.zero_eq_bot])
    set k := orderOf (ClassGroup.mk0 вҹЁI, hI0вҹ©) with hk
    have hkpos : 0 < k := orderOf_pos _
    have hIk0 : I ^ k вҲҲ (Ideal R)вҒ° := pow_mem hI0 k
    have hprin : (I ^ k).IsPrincipal := by
      rw [вҶҗ ClassGroup.mk0_eq_one_iff hIk0,
        show (вҹЁI ^ k, hIk0вҹ© : (Ideal R)вҒ°) = вҹЁI, hI0вҹ© ^ k from Subtype.ext (by simp), map_pow]
      exact pow_orderOf_eq_one _
    set x := hprin.generator with hx
    have hspan : Ideal.span {x} = I ^ k := hprin.span_singleton_generator
    have hIne : I вү  0 := by rwa [Ne, вҶҗ Ideal.zero_eq_bot] at hbot
    have hxne : x вү  0 := by
      intro hx0
      apply pow_ne_zero k hIne
      rw [Ideal.zero_eq_bot, вҶҗ hspan, hx0, Ideal.span_singleton_zero]
    have hxKne : algebraMap R K x вү  0 :=
      (map_ne_zero_iff _ (IsFractionRing.injective R K)).mpr hxne
    set u : KЛЈ := Units.mk0 (algebraMap R K x) hxKne with hu
    have hval : вҲҖ w : HeightOneSpectrum R, w.valuationOfNeZero u = 1 вҶ” В¬ w.asIdeal вҲЈ I ^ k := by
      intro w
      rw [valuationOfNeZero_eq_one_iff, Units.val_mk0, valuation_of_algebraMap,
        intValuation_eq_one_iff, вҶҗ hspan, Ideal.dvd_span_singleton]
    have not_dvd : вҲҖ w : HeightOneSpectrum R, w вү  (v : HeightOneSpectrum R) вҶ’
        В¬ w.asIdeal вҲЈ I ^ k := by
      intro w hwv hdvd
      have hwprime : Prime w.asIdeal := Ideal.prime_of_isPrime w.ne_bot w.isPrime
      have hle : I вүӨ w.asIdeal := Ideal.le_of_dvd (hwprime.dvd_of_dvd_pow hdvd)
      have hmax : I.IsMaximal := (v : HeightOneSpectrum R).isPrime.isMaximal hbot
      exact hwv (HeightOneSpectrum.ext (hmax.eq_of_le w.isPrime.ne_top hle).symm)
    have huS : u вҲҲ S.unit K := by
      intro w hwS
      have hne : w вү  (v : HeightOneSpectrum R) := fun h => hwS (h в–ё v.2)
      rw [вҶҗ valuationOfNeZero_eq_one_iff]
      exact (hval w).mpr (not_dvd w hne)
    refine вҹЁвҹЁu, huSвҹ©, fun w hwv => ?_, ?_вҹ©
    В· exact (hval w).mpr (not_dvd w fun h => hwv (Subtype.ext h))
    В· intro hcontra
      have hc : (v : HeightOneSpectrum R).valuationOfNeZero u = 1 := hcontra
      rw [hval] at hc
      exact hc (dvd_pow_self _ hkpos.ne')
  -- Assemble `|S|` linearly independent vectors in the range.
  choose u hu using key
  set b : вҶҘS вҶ’ Additive (вҶҘS вҶ’ Multiplicative в„Ө) := fun v => g (Additive.ofMul (u v)) with hb
  have hbrange : вҲҖ v, b v вҲҲ LinearMap.range g := fun v => вҹЁAdditive.ofMul (u v), rflвҹ©
  have hindep : LinearIndependent в„Ө b := by
    rw [Fintype.linearIndependent_iff]
    intro c hc i
    set proj : Additive (вҶҘS вҶ’ Multiplicative в„Ө) вҶ’+ в„Ө :=
      AddMonoidHom.mk' (fun y => Multiplicative.toAdd (Additive.toMul y i))
        (fun _ _ => rfl) with hproj
    have happ : proj (вҲ‘ j, c j вҖў b j)
        = вҲ‘ j, c j * Multiplicative.toAdd (Additive.toMul (b j) i) := by
      rw [map_sum]; exact Finset.sum_congr rfl fun j _ => by rw [map_zsmul, smul_eq_mul]; rfl
    rw [hc, map_zero] at happ
    have hMzero : вҲҖ j, j вү  i вҶ’ c j * Multiplicative.toAdd (Additive.toMul (b j) i) = 0 := by
      intro j hji
      have huj : unitValuation S K (u j) i = 1 := (hu j).1 i fun h => hji h.symm
      rw [show Additive.toMul (b j) i = unitValuation S K (u j) i from rfl, huj]
      simp
    have hsingle : вҲ‘ j, c j * Multiplicative.toAdd (Additive.toMul (b j) i)
        = c i * Multiplicative.toAdd (Additive.toMul (b i) i) :=
      Finset.sum_eq_single i (fun j _ hji => hMzero j hji) fun h => absurd (Finset.mem_univ i) h
    rw [hsingle] at happ
    have hMi : Multiplicative.toAdd (Additive.toMul (b i) i) вү  0 := by
      rw [show Additive.toMul (b i) i = unitValuation S K (u i) i from rfl]
      exact fun h => (hu i).2 (toAdd_eq_zero.mp h)
    obtain h | h := mul_eq_zero.mp happ.symm
    В· exact h
    В· exact absurd h hMi
  have hindep' : LinearIndependent в„Ө fun v : вҶҘS => (вҹЁb v, hbrange vвҹ© : LinearMap.range g) :=
    LinearIndependent.of_comp (LinearMap.range g).subtype hindep
  rw [Nat.card_eq_fintype_card]
  exact hindep'.fintype_card_le_finrank

/-- **Dirichlet's `S`-unit theorem (rank form).** If `S` is finite, the class group of `R` is
finite, and the `вҲ…`-units `рқ’Ә_K^Г—` are finitely generated, then the `в„Ө`-rank of the `S`-units is the
rank of `рқ’Ә_K^Г—` plus `|S|`: `rank рқ’Ә_{K,S}^Г— = rank рқ’Ә_K^Г— + |S|`. -/
theorem finrank_eq [Finite S] [Finite (ClassGroup R)]
    (hu : Group.FG ((вҲ… : Set (HeightOneSpectrum R)).unit K)) :
    finrank в„Ө (Additive (S.unit K))
      = finrank в„Ө (Additive ((вҲ… : Set (HeightOneSpectrum R)).unit K)) + Nat.card S := by
  rw [finrank_eq_add_finrank_range S K hu, finrank_range]

/-- The `вҲ…`-units are exactly the units of the base ring: `Set.unit вҲ… K вүғ* RЛЈ`. The `вҲ…`-integers are
the base ring `R` (`IsDedekindDomain.integer_empty`), and `S`-units are the units of the
`S`-integers (`Set.unitEquivUnitsInteger`). -/
noncomputable def unitEmptyEquivUnits : (вҲ… : Set (HeightOneSpectrum R)).unit K вүғ* RЛЈ :=
  (unitEquivUnitsInteger (вҲ… : Set (HeightOneSpectrum R)) K).trans
    (Units.mapEquiv
      ((Subalgebra.equivOfEq _ _ (IsDedekindDomain.integer_empty R K)).trans
        (Algebra.botEquivOfInjective (IsFractionRing.injective R K))).toRingEquiv.toMulEquiv)

/-- **Dirichlet's `S`-unit theorem for number fields.** For a number field `K` and a finite set `S`
of finite primes of `рқ’Ә_K`, the `в„Ө`-rank of the `S`-units is `(rвӮҒ + rвӮӮ - 1) + |S|`, where
`NumberField.Units.rank K = rвӮҒ + rвӮӮ - 1` is the rank of `рқ’Ә_K^Г—` (Dirichlet's unit theorem). -/
theorem unit_finrank_numberField (F : Type*) [Field F] [NumberField F]
    (T : Set (HeightOneSpectrum (NumberField.RingOfIntegers F))) [Finite T] :
    finrank в„Ө (Additive (T.unit F)) = NumberField.Units.rank F + Nat.card T := by
  haveI : Group.FG (NumberField.RingOfIntegers F)ЛЈ := Group.fg_iff_monoid_fg.mpr inferInstance
  haveI : Group.FG ((вҲ… : Set (HeightOneSpectrum (NumberField.RingOfIntegers F))).unit F) :=
    Group.fg_of_surjective (f := (unitEmptyEquivUnits F).symm.toMonoidHom)
      (unitEmptyEquivUnits F).symm.surjective
  rw [finrank_eq T F this]
  congr 1
  rw [LinearEquiv.finrank_eq
    (AddEquiv.toIntLinearEquiv (MulEquiv.toAdditive (unitEmptyEquivUnits F)))]
  exact NumberField.Units.finrank_eq F

end Set
