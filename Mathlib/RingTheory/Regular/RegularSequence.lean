lemma map_first_exact_on_four_term_right_exact_of_isSMulRegular_last
    {rs : List R} {f‚āĀ : M ‚Üí‚āó[R] M‚āā} {f‚āā : M‚āā ‚Üí‚āó[R] M‚āÉ} {f‚āÉ : M‚āÉ ‚Üí‚āó[R] M‚āĄ}
    (h‚āĀ‚āā : Exact f‚āĀ f‚āā) (h‚āā‚āÉ : Exact f‚āā f‚āÉ) (h‚āÉ : Surjective f‚āÉ)
    (h‚āĄ : IsWeaklyRegular M‚āĄ rs) :
    Exact (mapQ _ _ _ (smul_top_le_comap_smul_top (Ideal.ofList rs) f‚āĀ))
          (mapQ _ _ _ (smul_top_le_comap_smul_top (Ideal.ofList rs) f‚āā)) := by
  induction h‚āĄ generalizing M M‚āā M‚āÉ with
  | nil =>
    apply (Exact.iff_of_ladder_linearEquiv ?_ ?_).mp h‚āĀ‚āā
    any_goals exact quotEquivOfEqBot _ <|
      Eq.trans (congrArg (¬∑ ‚ÄĘ ‚ä§) Ideal.ofList_nil) (bot_smul ‚ä§)
    all_goals exact quot_hom_ext _ _ _ fun _ => rfl
  | cons r rs h‚āĄ _ ih =>
    specialize ih
      (map_first_exact_on_four_term_exact_of_isSMulRegular_last h‚āĀ‚āā h‚āā‚āÉ h‚āĄ)
      (map_exact r h‚āā‚āÉ h‚āÉ) (map_surjective r h‚āÉ)
    have H‚āĀ := quotOfListConsSMulTopEquivQuotSMulTopInner_naturality r rs f‚āĀ
    have H‚āā := quotOfListConsSMulTopEquivQuotSMulTopInner_naturality r rs f‚āā
    exact (Exact.iff_of_ladder_linearEquiv H‚āĀ.symm H‚āā.symm).mp ih

