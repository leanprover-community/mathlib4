/-!
# Regular sequences and weakly regular sequences

The notion of a regular sequence is fundamental in commutative algebra.
Properties of regular sequences encode information about singularities of a
ring and regularity of a sequence can be tested homologically.
However the notion of a regular sequence is only really sensible for Noetherian local rings.

TODO: Koszul regular sequences, `H_1`-regular sequences, quasi-regular sequences, depth.

## Tags

module, regular element, regular sequence, commutative algebra
-/

@[expose] public section

universe u v

open scoped Pointwise

variable {R S M M‚āā M‚āÉ M‚āĄ : Type*}

namespace Ideal

variable [Semiring R] [Semiring S]

/-- The ideal generated by a list of elements. -/
abbrev ofList (rs : List R) := span { r | r ‚ąą rs }

@[simp] lemma ofList_nil : (ofList [] : Ideal R) = ‚ä• :=
  have : { r | r ‚ąą [] } = ‚ąÖ := Set.eq_empty_of_forall_notMem (fun _ => List.not_mem_nil)
  Eq.trans (congrArg span this) span_empty

@[simp] lemma ofList_append (rs‚āĀ rs‚āā : List R) :
    ofList (rs‚āĀ ++ rs‚āā) = ofList rs‚āĀ ‚äĒ ofList rs‚āā :=
  have : { r | r ‚ąą rs‚āĀ ++ rs‚āā } = _ := Set.ext (fun _ => List.mem_append)
  Eq.trans (congrArg span this) (span_union _ _)

lemma ofList_singleton (r : R) : ofList [r] = span {r} :=
  congrArg span (Set.ext fun _ => List.mem_singleton)

@[simp] lemma ofList_cons (r : R) (rs : List R) :
    ofList (r::rs) = span {r} ‚äĒ ofList rs :=
  Eq.trans (ofList_append [r] rs) (congrArg (¬∑ ‚äĒ _) (ofList_singleton r))

@[simp] lemma map_ofList (f : R ‚Üí+* S) (rs : List R) :
    map f (ofList rs) = ofList (rs.map f) :=
  Eq.trans (map_span f { r | r ‚ąą rs }) <| congrArg span <|
    Set.ext (fun _ => List.mem_map.symm)

lemma ofList_cons_smul {R} [CommSemiring R] (r : R) (rs : List R) {M}
    [AddCommMonoid M] [Module R M] (N : Submodule R M) :
    ofList (r :: rs) ‚ÄĘ N = r ‚ÄĘ N ‚äĒ ofList rs ‚ÄĘ N := by
  rw [ofList_cons, Submodule.sup_smul, Submodule.ideal_span_singleton_smul]

end Ideal

namespace Submodule

variable (M) [CommRing R] [AddCommGroup M] [AddCommGroup M‚āā]
    [Module R M] [Module R M‚āā] (r : R) (rs : List R)

/-- The equivalence between M ‚ßł (r‚āÄ, r‚āĀ, ‚Ä¶, r‚āô)M and (M ‚ßł r‚āÄM) ‚ßł (r‚āĀ, ‚Ä¶, r‚āô) (M ‚ßł r‚āÄM). -/
def quotOfListConsSMulTopEquivQuotSMulTopInner :
    (M ‚ßł (Ideal.ofList (r :: rs) ‚ÄĘ ‚ä§ : Submodule R M)) ‚ČÉ‚āó[R]
      QuotSMulTop r M ‚ßł (Ideal.ofList rs ‚ÄĘ ‚ä§ : Submodule R (QuotSMulTop r M)) :=
  quotEquivOfEq _ _ (Ideal.ofList_cons_smul r rs ‚ä§) ‚Č™‚Čę‚āó
    (quotientQuotientEquivQuotientSup (r ‚ÄĘ ‚ä§) (Ideal.ofList rs ‚ÄĘ ‚ä§)).symm ‚Č™‚Čę‚āó
      quotEquivOfEq _ _ (by rw [map_smul'', map_top, range_mkQ])

/-- The equivalence between M ‚ßł (r‚āÄ, r‚āĀ, ‚Ä¶, r‚āô)M and (M ‚ßł (r‚āĀ, ‚Ä¶, r‚āô)) ‚ßł r‚āÄ (M ‚ßł (r‚āĀ, ‚Ä¶, r‚āô)). -/
def quotOfListConsSMulTopEquivQuotSMulTopOuter :
    (M ‚ßł (Ideal.ofList (r :: rs) ‚ÄĘ ‚ä§ : Submodule R M)) ‚ČÉ‚āó[R]
      QuotSMulTop r (M ‚ßł (Ideal.ofList rs ‚ÄĘ ‚ä§ : Submodule R M)) :=
  quotEquivOfEq _ _ (Eq.trans (Ideal.ofList_cons_smul r rs ‚ä§) (sup_comm _ _)) ‚Č™‚Čę‚āó
    (quotientQuotientEquivQuotientSup (Ideal.ofList rs ‚ÄĘ ‚ä§) (r ‚ÄĘ ‚ä§)).symm ‚Č™‚Čę‚āó
      quotEquivOfEq _ _ (by rw [map_pointwise_smul, map_top, range_mkQ])

variable {M}

lemma quotOfListConsSMulTopEquivQuotSMulTopInner_naturality (f : M ‚Üí‚āó[R] M‚āā) :
    (quotOfListConsSMulTopEquivQuotSMulTopInner M‚āā r rs).toLinearMap ‚ąė‚āó
        mapQ _ _ _ (smul_top_le_comap_smul_top (Ideal.ofList (r :: rs)) f) =
      mapQ _ _ _ (smul_top_le_comap_smul_top _ (QuotSMulTop.map r f)) ‚ąė‚āó
        (quotOfListConsSMulTopEquivQuotSMulTopInner M r rs).toLinearMap :=
  quot_hom_ext _ _ _ fun _ => rfl

lemma top_eq_ofList_cons_smul_iff :
    (‚ä§ : Submodule R M) = Ideal.ofList (r :: rs) ‚ÄĘ ‚ä§ ‚ÜĒ
      (‚ä§ : Submodule R (QuotSMulTop r M)) = Ideal.ofList rs ‚ÄĘ ‚ä§ := by
  conv => congr <;> rw [eq_comm, ‚Üź Quotient.subsingleton_iff]
  exact (quotOfListConsSMulTopEquivQuotSMulTopInner M r rs).toEquiv.subsingleton_congr

end Submodule

namespace RingTheory.Sequence

open scoped TensorProduct List
open Function Submodule QuotSMulTop

variable (S M)

section Definitions

/-
In theory, regularity of `rs : List őĪ` on `M` makes sense as soon as
`[Monoid őĪ]`, `[AddCommGroup M]`, and `[DistribMulAction őĪ M]`.
Instead of `Ideal.ofList (rs.take i) ‚ÄĘ (‚ä§ : Submodule R M)` we use
`‚®Ü (j : Fin i), rs[j] ‚ÄĘ (‚ä§ : AddSubgroup M)`.
However it's not clear that this is a useful generalization.
If we add the assumption `[SMulCommClass őĪ őĪ M]` this is essentially the same
as focusing on the commutative ring case, by passing to the monoid ring
`‚Ą§[abelianization of őĪ]`.
-/
variable [CommRing R] [AddCommGroup M] [Module R M]

open Ideal

/-- A sequence `[r‚āĀ, ‚Ä¶, r‚āô]` is weakly regular on `M` iff `rŠĶĘ` is regular on
`M‚ßł(r‚āĀ, ‚Ä¶, rŠĶĘ‚āč‚āĀ)M` for all `1 ‚Č§ i ‚Č§ n`. -/
@[mk_iff]
structure IsWeaklyRegular (rs : List R) : Prop where
  regular_mod_prev : ‚ąÄ i (h : i < rs.length),
    IsSMulRegular (M ‚ßł (ofList (rs.take i) ‚ÄĘ ‚ä§ : Submodule R M)) rs[i]

lemma isWeaklyRegular_iff_Fin (rs : List R) :
    IsWeaklyRegular M rs ‚ÜĒ ‚ąÄ (i : Fin rs.length),
      IsSMulRegular (M ‚ßł (ofList (rs.take i) ‚ÄĘ ‚ä§ : Submodule R M)) rs[i] :=
  Iff.trans (isWeaklyRegular_iff M rs) (Iff.symm Fin.forall_iff)

/-- A weakly regular sequence `rs` on `M` is regular if also `M/rsM ‚Č† 0`. -/
@[mk_iff]
structure IsRegular (rs : List R) : Prop extends IsWeaklyRegular M rs where
  top_ne_smul : (‚ä§ : Submodule R M) ‚Č† Ideal.ofList rs ‚ÄĘ ‚ä§

end Definitions

section Congr

variable {S M} [CommRing R] [CommRing S] [AddCommGroup M] [AddCommGroup M‚āā]
    [Module R M] [Module S M‚āā]
    {ŌÉ : R ‚Üí+* S} {ŌÉ' : S ‚Üí+* R} [RingHomInvPair ŌÉ ŌÉ'] [RingHomInvPair ŌÉ' ŌÉ]

open DistribMulAction AddSubgroup in
private lemma _root_.AddHom.map_smul_top_toAddSubgroup_of_surjective
    {f : M ‚Üí+ M‚āā} {as : List R} {bs : List S} (hf : Function.Surjective f)
    (h : List.Forall‚āā (fun r s => ‚ąÄ x, f (r ‚ÄĘ x) = s ‚ÄĘ f x) as bs) :
    (Ideal.ofList as ‚ÄĘ ‚ä§ : Submodule R M).toAddSubgroup.map f =
      (Ideal.ofList bs ‚ÄĘ ‚ä§ : Submodule S M‚āā).toAddSubgroup := by
  induction h with
  | nil =>
    convert AddSubgroup.map_bot f using 1 <;>
      rw [Ideal.ofList_nil, bot_smul, bot_toAddSubgroup]
  | @cons r s _ _ h _ ih =>
    conv => congr <;> rw [Ideal.ofList_cons, sup_smul, sup_toAddSubgroup,
      ideal_span_singleton_smul, pointwise_smul_toAddSubgroup,
      top_toAddSubgroup, AddSubgroup.pointwise_smul_def]
    apply DFunLike.ext (f.comp (toAddMonoidEnd R M r))
      ((toAddMonoidEnd S M‚āā s).comp f) at h
    rw [AddSubgroup.map_sup, ih, map_map, h, ‚Üź map_map,
      map_top_of_surjective f hf]

lemma _root_.AddEquiv.isWeaklyRegular_congr {e : M ‚ČÉ+ M‚āā} {as bs}
    (h : List.Forall‚āā (fun (r : R) (s : S) => ‚ąÄ x, e (r ‚ÄĘ x) = s ‚ÄĘ e x) as bs) :
    IsWeaklyRegular M as ‚ÜĒ IsWeaklyRegular M‚āā bs := by
  conv => congr <;> rw [isWeaklyRegular_iff_Fin]
  let e' i : (M ‚ßł (Ideal.ofList (as.take i) ‚ÄĘ ‚ä§ : Submodule R M)) ‚ČÉ+
      M‚āā ‚ßł (Ideal.ofList (bs.take i) ‚ÄĘ ‚ä§ : Submodule S M‚āā) :=
    QuotientAddGroup.congr _ _ e <|
      AddHom.map_smul_top_toAddSubgroup_of_surjective e.surjective <|
        List.forall‚āā_take i h
  refine (finCongr h.length_eq).forall_congr @fun _ => (e' _).isSMulRegular_congr ?_
  exact (mkQ_surjective _).forall.mpr fun _ => congrArg (mkQ _) (h.get _ _ _)

lemma _root_.LinearEquiv.isWeaklyRegular_congr' (e : M ‚ČÉ‚āõ‚āó[ŌÉ] M‚āā) (rs : List R) :
    IsWeaklyRegular M rs ‚ÜĒ IsWeaklyRegular M‚āā (rs.map ŌÉ) :=
  e.toAddEquiv.isWeaklyRegular_congr <| List.forall‚āā_map_right_iff.mpr <|
    List.forall‚āā_same.mpr fun r _ x => e.map_smul' r x

lemma _root_.LinearEquiv.isWeaklyRegular_congr [Module R M‚āā] (e : M ‚ČÉ‚āó[R] M‚āā) (rs : List R) :
    IsWeaklyRegular M rs ‚ÜĒ IsWeaklyRegular M‚āā rs :=
  Iff.trans (e.isWeaklyRegular_congr' rs) <| iff_of_eq <| congrArg _ rs.map_id

lemma _root_.AddEquiv.isRegular_congr {e : M ‚ČÉ+ M‚āā} {as bs}
    (h : List.Forall‚āā (fun (r : R) (s : S) => ‚ąÄ x, e (r ‚ÄĘ x) = s ‚ÄĘ e x) as bs) :
    IsRegular M as ‚ÜĒ IsRegular M‚āā bs := by
  conv => congr <;> rw [isRegular_iff, ne_comm, ‚Üź Quotient.nontrivial_iff]
  let e' := QuotientAddGroup.congr _ _ e <|
    AddHom.map_smul_top_toAddSubgroup_of_surjective e.surjective h
  exact and_congr (e.isWeaklyRegular_congr h) e'.nontrivial_congr

lemma _root_.LinearEquiv.isRegular_congr' (e : M ‚ČÉ‚āõ‚āó[ŌÉ] M‚āā) (rs : List R) :
    IsRegular M rs ‚ÜĒ IsRegular M‚āā (rs.map ŌÉ) :=
  e.toAddEquiv.isRegular_congr <| List.forall‚āā_map_right_iff.mpr <|
    List.forall‚āā_same.mpr fun r _ x => e.map_smul' r x

lemma _root_.LinearEquiv.isRegular_congr [Module R M‚āā] (e : M ‚ČÉ‚āó[R] M‚āā) (rs : List R) :
    IsRegular M rs ‚ÜĒ IsRegular M‚āā rs :=
  Iff.trans (e.isRegular_congr' rs) <| iff_of_eq <| congrArg _ rs.map_id

end Congr

lemma isWeaklyRegular_map_algebraMap_iff [CommRing R] [CommRing S]
    [Algebra R S] [AddCommGroup M] [Module R M] [Module S M]
    [IsScalarTower R S M] (rs : List R) :
    IsWeaklyRegular M (rs.map (algebraMap R S)) ‚ÜĒ IsWeaklyRegular M rs :=
  (AddEquiv.refl M).isWeaklyRegular_congr <| List.forall‚āā_map_left_iff.mpr <|
    List.forall‚āā_same.mpr fun r _ => algebraMap_smul S r

variable [CommRing R] [AddCommGroup M] [AddCommGroup M‚āā] [AddCommGroup M‚āÉ]
    [AddCommGroup M‚āĄ] [Module R M] [Module R M‚āā] [Module R M‚āÉ] [Module R M‚āĄ]

@[simp]
lemma isWeaklyRegular_cons_iff (r : R) (rs : List R) :
    IsWeaklyRegular M (r :: rs) ‚ÜĒ
      IsSMulRegular M r ‚ąß IsWeaklyRegular (QuotSMulTop r M) rs :=
  have := Eq.trans (congrArg (¬∑ ‚ÄĘ ‚ä§) Ideal.ofList_nil) (bot_smul ‚ä§)
  let e i := quotOfListConsSMulTopEquivQuotSMulTopInner M r (rs.take i)
  Iff.trans (isWeaklyRegular_iff_Fin _ _) <| Iff.trans Fin.forall_iff_succ <|
    and_congr ((quotEquivOfEqBot _ this).isSMulRegular_congr r) <|
      Iff.trans (forall_congr' fun i => (e i).isSMulRegular_congr (rs.get i))
        (isWeaklyRegular_iff_Fin _ _).symm

lemma isWeaklyRegular_cons_iff' (r : R) (rs : List R) :
    IsWeaklyRegular M (r :: rs) ‚ÜĒ
      IsSMulRegular M r ‚ąß
        IsWeaklyRegular (QuotSMulTop r M)
          (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) :=
  Iff.trans (isWeaklyRegular_cons_iff M r rs) <| and_congr_right' <|
    Iff.symm <| isWeaklyRegular_map_algebraMap_iff (R ‚ßł Ideal.span {r}) _ rs

@[simp]
lemma isRegular_cons_iff (r : R) (rs : List R) :
    IsRegular M (r :: rs) ‚ÜĒ
      IsSMulRegular M r ‚ąß IsRegular (QuotSMulTop r M) rs := by
  rw [isRegular_iff, isRegular_iff, isWeaklyRegular_cons_iff M r rs,
    ne_eq, top_eq_ofList_cons_smul_iff, and_assoc]

lemma isRegular_cons_iff' (r : R) (rs : List R) :
    IsRegular M (r :: rs) ‚ÜĒ
      IsSMulRegular M r ‚ąß IsRegular (QuotSMulTop r M)
          (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) := by
  conv => congr <;> rw [isRegular_iff, ne_eq]
  rw [isWeaklyRegular_cons_iff', ‚Üź restrictScalars_inj R (R ‚ßł _),
    ‚Üź Ideal.map_ofList, ‚Üź Ideal.Quotient.algebraMap_eq, Ideal.smul_restrictScalars,
    restrictScalars_top, top_eq_ofList_cons_smul_iff, and_assoc]

variable {M}

namespace IsWeaklyRegular

variable (R M) in
@[simp] lemma nil : IsWeaklyRegular M ([] : List R) :=
  .mk (False.elim <| Nat.not_lt_zero ¬∑ ¬∑)

lemma cons {r : R} {rs : List R} (h1 : IsSMulRegular M r)
    (h2 : IsWeaklyRegular (QuotSMulTop r M) rs) : IsWeaklyRegular M (r :: rs) :=
  (isWeaklyRegular_cons_iff M r rs).mpr ‚ü®h1, h2‚ü©

lemma cons' {r : R} {rs : List R} (h1 : IsSMulRegular M r)
    (h2 : IsWeaklyRegular (QuotSMulTop r M)
            (rs.map (Ideal.Quotient.mk (Ideal.span {r})))) :
    IsWeaklyRegular M (r :: rs) :=
  (isWeaklyRegular_cons_iff' M r rs).mpr ‚ü®h1, h2‚ü©

/-- Weakly regular sequences can be inductively characterized by:
* The empty sequence is weakly regular on any module.
* If `r` is regular on `M` and `rs` is a weakly regular sequence on `M‚ßłrM` then
  the sequence obtained from `rs` by prepending `r` is weakly regular on `M`.

This is the induction principle produced by the inductive definition above.
The motive will usually be valued in `Prop`, but `Sort*` works too. -/
@[induction_eliminator]
def recIterModByRegular
    {motive : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí
      IsWeaklyRegular M rs ‚Üí Sort*}
    (nil : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí motive M [] (nil R M))
    (cons : {M : Type v} ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (r : R) ‚Üí
      (rs : List R) ‚Üí (h1 : IsSMulRegular M r) ‚Üí
      (h2 : IsWeaklyRegular (QuotSMulTop r M) rs) ‚Üí
      (ih : motive (QuotSMulTop r M) rs h2) ‚Üí motive M (r :: rs) (cons h1 h2)) :
    {M : Type v} ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí {rs : List R} ‚Üí
    (h : IsWeaklyRegular M rs) ‚Üí motive M rs h
  | M, _, _, [], _ => nil M
  | M, _, _, r :: rs, h =>
    let ‚ü®h1, h2‚ü© := (isWeaklyRegular_cons_iff M r rs).mp h
    cons r rs h1 h2 (recIterModByRegular nil cons h2)

/-- A simplified version of `IsWeaklyRegular.recIterModByRegular` where the
motive is not allowed to depend on the proof of `IsWeaklyRegular`. -/
def ndrecIterModByRegular
    {motive : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí Sort*}
    (nil : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí motive M [])
    (cons : {M : Type v} ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (r : R) ‚Üí
      (rs : List R) ‚Üí IsSMulRegular M r ‚Üí IsWeaklyRegular (QuotSMulTop r M) rs ‚Üí
      motive (QuotSMulTop r M) rs ‚Üí motive M (r :: rs))
    {M} [AddCommGroup M] [Module R M] {rs} :
    IsWeaklyRegular M rs ‚Üí motive M rs :=
  recIterModByRegular (motive := fun M _ _ rs _ => motive M rs) nil cons

/-- An alternate induction principle from `IsWeaklyRegular.recIterModByRegular`
where we mod out by successive elements in both the module and the base ring.
This is useful for propagating certain properties of the initial `M`, e.g.
faithfulness or freeness, throughout the induction. -/
def recIterModByRegularWithRing
    {motive : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí (rs : List R) ‚Üí IsWeaklyRegular M rs ‚Üí Sort*}
    (nil : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí motive R M [] (nil R M))
    (cons : {R : Type u} ‚Üí [CommRing R] ‚Üí {M : Type v} ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí (r : R) ‚Üí (rs : List R) ‚Üí (h1 : IsSMulRegular M r) ‚Üí
      (h2 : IsWeaklyRegular (QuotSMulTop r M)
              (rs.map (Ideal.Quotient.mk (Ideal.span {r})))) ‚Üí
      (ih : motive (R ‚ßł Ideal.span {r}) (QuotSMulTop r M)
              (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) h2) ‚Üí
            motive R M (r :: rs) (cons' h1 h2)) :
    {R : Type u} ‚Üí [CommRing R] ‚Üí {M : Type v} ‚Üí [AddCommGroup M] ‚Üí
    [Module R M] ‚Üí {rs : List R} ‚Üí (h : IsWeaklyRegular M rs) ‚Üí motive R M rs h
  | R, _, M, _, _, [], _ => nil R M
  | _, _, M, _, _, r :: rs, h =>
    let ‚ü®h1, h2‚ü© := (isWeaklyRegular_cons_iff' M r rs).mp h
    cons r rs h1 h2 (recIterModByRegularWithRing nil cons h2)
  termination_by _ _ _ _ _ rs => List.length rs

/-- A simplified version of `IsWeaklyRegular.recIterModByRegularWithRing` where
the motive is not allowed to depend on the proof of `IsWeaklyRegular`. -/
def ndrecWithRing
    {motive : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí
      [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí Sort*}
    (nil : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí
      [AddCommGroup M] ‚Üí [Module R M] ‚Üí motive R M [])
    (cons : {R : Type u} ‚Üí [CommRing R] ‚Üí {M : Type v} ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí (r : R) ‚Üí (rs : List R) ‚Üí IsSMulRegular M r ‚Üí
      IsWeaklyRegular (QuotSMulTop r M)
        (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) ‚Üí
      motive (R ‚ßł Ideal.span {r}) (QuotSMulTop r M)
        (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) ‚Üí motive R M (r :: rs))
    {R} [CommRing R] {M} [AddCommGroup M] [Module R M] {rs} :
    IsWeaklyRegular M rs ‚Üí motive R M rs :=
  recIterModByRegularWithRing (motive := fun R _ M _ _ rs _ => motive R M rs)
    nil cons

end IsWeaklyRegular

section

variable (M)

lemma isWeaklyRegular_singleton_iff (r : R) :
    IsWeaklyRegular M [r] ‚ÜĒ IsSMulRegular M r :=
  Iff.trans (isWeaklyRegular_cons_iff M r []) (and_iff_left (.nil R _))

lemma isWeaklyRegular_append_iff (rs‚āĀ rs‚āā : List R) :
    IsWeaklyRegular M (rs‚āĀ ++ rs‚āā) ‚ÜĒ
      IsWeaklyRegular M rs‚āĀ ‚ąß
        IsWeaklyRegular (M ‚ßł (Ideal.ofList rs‚āĀ ‚ÄĘ ‚ä§ : Submodule R M)) rs‚āā := by
  induction rs‚āĀ generalizing M with
  | nil =>
    refine Iff.symm <| Iff.trans (and_iff_right (.nil R M)) ?_
    refine (quotEquivOfEqBot _ ?_).isWeaklyRegular_congr rs‚āā
    rw [Ideal.ofList_nil, bot_smul]
  | cons r rs‚āĀ ih =>
    let e := quotOfListConsSMulTopEquivQuotSMulTopInner M r rs‚āĀ
    rw [List.cons_append, isWeaklyRegular_cons_iff, isWeaklyRegular_cons_iff,
      ih, ‚Üź and_assoc, ‚Üź e.isWeaklyRegular_congr rs‚āā]

lemma isWeaklyRegular_append_iff' (rs‚āĀ rs‚āā : List R) :
    IsWeaklyRegular M (rs‚āĀ ++ rs‚āā) ‚ÜĒ
      IsWeaklyRegular M rs‚āĀ ‚ąß
        IsWeaklyRegular (M ‚ßł (Ideal.ofList rs‚āĀ ‚ÄĘ ‚ä§ : Submodule R M))
          (rs‚āā.map (Ideal.Quotient.mk (Ideal.ofList rs‚āĀ))) :=
  Iff.trans (isWeaklyRegular_append_iff M rs‚āĀ rs‚āā) <| and_congr_right' <|
    Iff.symm <| isWeaklyRegular_map_algebraMap_iff (R ‚ßł Ideal.ofList rs‚āĀ) _ rs‚āā

end

namespace IsRegular

variable (R M) in
lemma nil [Nontrivial M] : IsRegular M ([] : List R) where
  toIsWeaklyRegular := IsWeaklyRegular.nil R M
  top_ne_smul h := by
    rw [Ideal.ofList_nil, bot_smul, eq_comm, subsingleton_iff_bot_eq_top] at h
    exact not_subsingleton M ((Submodule.subsingleton_iff _).mp h)

lemma cons {r : R} {rs : List R} (h1 : IsSMulRegular M r)
    (h2 : IsRegular (QuotSMulTop r M) rs) : IsRegular M (r :: rs) :=
  (isRegular_cons_iff M r rs).mpr ‚ü®h1, h2‚ü©

lemma cons' {r : R} {rs : List R} (h1 : IsSMulRegular M r)
    (h2 : IsRegular (QuotSMulTop r M) (rs.map (Ideal.Quotient.mk (Ideal.span {r})))) :
    IsRegular M (r :: rs) :=
  (isRegular_cons_iff' M r rs).mpr ‚ü®h1, h2‚ü©

/-- Regular sequences can be inductively characterized by:
* The empty sequence is regular on any nonzero module.
* If `r` is regular on `M` and `rs` is a regular sequence on `M‚ßłrM` then the
  sequence obtained from `rs` by prepending `r` is regular on `M`.

This is the induction principle produced by the inductive definition above.
The motive will usually be valued in `Prop`, but `Sort*` works too. -/
@[induction_eliminator]
def recIterModByRegular
    {motive : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí
      IsRegular M rs ‚Üí Sort*}
    (nil : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí [Nontrivial M] ‚Üí
      motive M [] (nil R M))
    (cons : {M : Type v} ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (r : R) ‚Üí
      (rs : List R) ‚Üí (h1 : IsSMulRegular M r) ‚Üí (h2 : IsRegular (QuotSMulTop r M) rs) ‚Üí
      (ih : motive (QuotSMulTop r M) rs h2) ‚Üí motive M (r :: rs) (cons h1 h2))
    {M} [AddCommGroup M] [Module R M] {rs} (h : IsRegular M rs) : motive M rs h :=
  h.toIsWeaklyRegular.recIterModByRegular
    (motive := fun N _ _ rs' h' => ‚ąÄ h'', motive N rs' ‚ü®h', h''‚ü©)
    (fun N _ _ h' =>
      haveI := (nontrivial_iff R).mp (nontrivial_of_ne _ _ h'); nil N)
    (fun r rs' h1 h2 h3 h4 =>
      have ‚ü®h5, h6‚ü© := (isRegular_cons_iff _ _ _).mp ‚ü®h2.cons h1, h4‚ü©
      cons r rs' h5 h6 (h3 h6.top_ne_smul))
    h.top_ne_smul

/-- A simplified version of `IsRegular.recIterModByRegular` where the motive is
not allowed to depend on the proof of `IsRegular`. -/
def ndrecIterModByRegular
    {motive : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí Sort*}
    (nil : (M : Type v) ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí [Nontrivial M] ‚Üí motive M [])
    (cons : {M : Type v} ‚Üí [AddCommGroup M] ‚Üí [Module R M] ‚Üí (r : R) ‚Üí
      (rs : List R) ‚Üí IsSMulRegular M r ‚Üí IsRegular (QuotSMulTop r M) rs ‚Üí
      motive (QuotSMulTop r M) rs ‚Üí motive M (r :: rs))
    {M} [AddCommGroup M] [Module R M] {rs} : IsRegular M rs ‚Üí motive M rs :=
  recIterModByRegular (motive := fun M _ _ rs _ => motive M rs) nil cons

/-- An alternate induction principle from `IsRegular.recIterModByRegular` where
we mod out by successive elements in both the module and the base ring. This is
useful for propagating certain properties of the initial `M`, e.g. faithfulness
or freeness, throughout the induction. -/
def recIterModByRegularWithRing
    {motive : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí (rs : List R) ‚Üí IsRegular M rs ‚Üí Sort*}
    (nil : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí [Nontrivial M] ‚Üí motive R M [] (nil R M))
    (cons : {R : Type u} ‚Üí [CommRing R] ‚Üí {M : Type v} ‚Üí [AddCommGroup M] ‚Üí
      [Module R M] ‚Üí (r : R) ‚Üí (rs : List R) ‚Üí (h1 : IsSMulRegular M r) ‚Üí
      (h2 : IsRegular (QuotSMulTop r M)
              (rs.map (Ideal.Quotient.mk (Ideal.span {r})))) ‚Üí
      (ih : motive (R ‚ßł Ideal.span {r}) (QuotSMulTop r M)
              (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) h2) ‚Üí
            motive R M (r :: rs) (cons' h1 h2))
    {R} [CommRing R] {M} [AddCommGroup M] [Module R M] {rs}
    (h : IsRegular M rs) : motive R M rs h :=
  h.toIsWeaklyRegular.recIterModByRegularWithRing
    (motive := fun R _ N _ _ rs' h' => ‚ąÄ h'', motive R N rs' ‚ü®h', h''‚ü©)
    (fun R _ N _ _ h' =>
      haveI := (nontrivial_iff R).mp (nontrivial_of_ne _ _ h'); nil R N)
    (fun r rs' h1 h2 h3 h4 =>
      have ‚ü®h5, h6‚ü© := (isRegular_cons_iff' _ _ _).mp ‚ü®h2.cons' h1, h4‚ü©
      cons r rs' h5 h6 <| h3 h6.top_ne_smul)
    h.top_ne_smul

/-- A simplified version of `IsRegular.recIterModByRegularWithRing` where the
motive is not allowed to depend on the proof of `IsRegular`. -/
def ndrecIterModByRegularWithRing
    {motive : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí
      [AddCommGroup M] ‚Üí [Module R M] ‚Üí (rs : List R) ‚Üí Sort*}
    (nil : (R : Type u) ‚Üí [CommRing R] ‚Üí (M : Type v) ‚Üí
      [AddCommGroup M] ‚Üí [Module R M] ‚Üí [Nontrivial M] ‚Üí motive R M [])
    (cons : {R : Type u} ‚Üí [CommRing R] ‚Üí {M : Type v} ‚Üí
      [AddCommGroup M] ‚Üí [Module R M] ‚Üí (r : R) ‚Üí (rs : List R) ‚Üí
      IsSMulRegular M r ‚Üí
      IsRegular (QuotSMulTop r M)
        (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) ‚Üí
      motive (R ‚ßł Ideal.span {r}) (QuotSMulTop r M)
        (rs.map (Ideal.Quotient.mk (Ideal.span {r}))) ‚Üí
      motive R M (r :: rs))
    {R} [CommRing R] {M} [AddCommGroup M] [Module R M] {rs} :
    IsRegular M rs ‚Üí motive R M rs :=
  recIterModByRegularWithRing (motive := fun R _ M _ _ rs _ => motive R M rs)
    nil cons

lemma quot_ofList_smul_nontrivial {rs : List R} (h : IsRegular M rs)
    (N : Submodule R M) : Nontrivial (M ‚ßł Ideal.ofList rs ‚ÄĘ N) :=
  Submodule.Quotient.nontrivial_iff.mpr <|
    ne_top_of_le_ne_top h.top_ne_smul.symm (smul_mono_right _ le_top)

lemma nontrivial {rs : List R} (h : IsRegular M rs) : Nontrivial M :=
  haveI := quot_ofList_smul_nontrivial h ‚ä§
  (mkQ_surjective (Ideal.ofList rs ‚ÄĘ ‚ä§ : Submodule R M)).nontrivial

end IsRegular

lemma isRegular_iff_isWeaklyRegular_of_subset_jacobson_annihilator
    [Nontrivial M] [Module.Finite R M] {rs : List R}
    (h : ‚ąÄ r ‚ąą rs, r ‚ąą Ideal.jacobson (Module.annihilator R M)) :
    IsRegular M rs ‚ÜĒ IsWeaklyRegular M rs :=
  Iff.trans (isRegular_iff M rs) <| and_iff_left <|
    top_ne_ideal_smul_of_le_jacobson_annihilator <| Ideal.span_le.mpr h

lemma _root_.IsLocalRing.isRegular_iff_isWeaklyRegular_of_subset_maximalIdeal
    [IsLocalRing R] [Nontrivial M] [Module.Finite R M] {rs : List R}
    (h : ‚ąÄ r ‚ąą rs, r ‚ąą IsLocalRing.maximalIdeal R) :
    IsRegular M rs ‚ÜĒ IsWeaklyRegular M rs :=
  have H h' := bot_ne_top.symm <| annihilator_eq_top_iff.mp <|
    Eq.trans annihilator_top h'
  isRegular_iff_isWeaklyRegular_of_subset_jacobson_annihilator fun r hr =>
    IsLocalRing.jacobson_eq_maximalIdeal (Module.annihilator R M) H ‚Ėł h r hr

open IsWeaklyRegular IsArtinian in
lemma eq_nil_of_isRegular_on_artinian [IsArtinian R M] :
    {rs : List R} ‚Üí IsRegular M rs ‚Üí rs = []
  | [], _ => rfl
  | r :: rs, h => by
    rw [isRegular_iff, ne_comm, ‚Üź lt_top_iff_ne_top, Ideal.ofList_cons,
      sup_smul, ideal_span_singleton_smul, isWeaklyRegular_cons_iff] at h
    refine absurd ?_ (ne_of_lt (lt_of_le_of_lt le_sup_left h.right))
    exact Eq.trans (Submodule.map_top _) <| LinearMap.range_eq_top.mpr <|
      surjective_of_injective_endomorphism (LinearMap.lsmul R M r) h.left.left

lemma IsWeaklyRegular.isWeaklyRegular_lTensor [Module.Flat R M‚āā]
    {rs : List R} (h : IsWeaklyRegular M rs) :
    IsWeaklyRegular (M‚āā ‚äó[R] M) rs := by
  induction h with
  | nil N => exact nil R (M‚āā ‚äó[R] N)
  | @cons N _ _ r rs' h1 _ ih =>
    let e := tensorQuotSMulTopEquivQuotSMulTop r M‚āā N
    exact ((e.isWeaklyRegular_congr rs').mp ih).cons (h1.lTensor M‚āā)

lemma IsWeaklyRegular.isWeaklyRegular_rTensor [Module.Flat R M‚āā]
    {rs : List R} (h : IsWeaklyRegular M rs) :
    IsWeaklyRegular (M ‚äó[R] M‚āā) rs := by
  induction h with
  | nil N => exact nil R (N ‚äó[R] M‚āā)
  | @cons N _ _ r rs' h1 _ ih =>
    let e := quotSMulTopTensorEquivQuotSMulTop r M‚āā N
    exact ((e.isWeaklyRegular_congr rs').mp ih).cons (h1.rTensor M‚āā)
