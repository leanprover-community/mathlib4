/-!
# Presentations on subrings

In this file we establish the API for realising a presentation over a
subring of `R`. We define a property `HasCoeffs R‚āÄ` for a presentation `P` to mean
the (sub)ring `R‚āÄ` contains the coefficients of the relations of `P`.
subring `R‚āÄ` of `R` that contains the coefficients of the relations
In this case there exists a model of `S` over `R‚āÄ`, i.e., there exists an `R‚āÄ`-algebra `S‚āÄ`
such that `S` is isomorphic to `R ‚äó[R‚āÄ] S‚āÄ`.

If the presentation is finite, `R‚āÄ` may be chosen as a Noetherian ring. In this case,
this API can be used to remove Noetherian hypothesis in certain cases.

-/

@[expose] public section

open TensorProduct

variable {R S őĻ ŌÉ : Type*} [CommRing R] [CommRing S] [Algebra R S]

variable {P : Algebra.Presentation R S őĻ ŌÉ}

namespace Algebra.Presentation

variable (P) in
/-- The coefficients of a presentation are the coefficients of the relations. -/
def coeffs : Set R := ‚čÉ (i : ŌÉ), (P.relation i).coeffs

lemma coeffs_relation_subset_coeffs (x : ŌÉ) :
    ((P.relation x).coeffs : Set R) ‚äÜ P.coeffs :=
  Set.subset_iUnion_of_subset x (by simp)

lemma finite_coeffs [Finite ŌÉ] : P.coeffs.Finite :=
  Set.finite_iUnion fun _ ‚Ü¶ Finset.finite_toSet _

variable (P) in
/-- The core of a presentation is the subalgebra generated by the coefficients of the relations. -/
def core : Subalgebra ‚Ą§ R := Algebra.adjoin _ P.coeffs

variable (P) in
lemma coeffs_subset_core : P.coeffs ‚äÜ P.core := Algebra.subset_adjoin

lemma coeffs_relation_subset_core (x : ŌÉ) :
    ((P.relation x).coeffs : Set R) ‚äÜ P.core :=
  subset_trans (P.coeffs_relation_subset_coeffs x) P.coeffs_subset_core

variable (P) in
/-- The core coerced to a type for performance reasons. -/
def Core : Type _ := P.core

instance : CommRing P.Core := fast_instance% (inferInstanceAs <| CommRing P.core)
instance : Algebra P.Core R := fast_instance% (inferInstanceAs <| Algebra P.core R)
instance : FaithfulSMul P.Core R := inferInstanceAs <| FaithfulSMul P.core R
instance : Algebra P.Core S := fast_instance% (inferInstanceAs <| Algebra P.core S)
instance : IsScalarTower P.Core R S := inferInstanceAs <| IsScalarTower P.core R S

instance [Finite ŌÉ] : FiniteType ‚Ą§ P.Core := .adjoin_of_finite P.finite_coeffs

variable (P) in
/--
A ring `R‚āÄ` has the coefficients of the presentation `P` if the coefficients of the relations of `P`
lie in the image of `R‚āÄ` in `R`.
The smallest subring of `R` satisfying this is given by `Algebra.Presentation.Core P`.
-/
class HasCoeffs (R‚āÄ : Type*) [CommRing R‚āÄ] [Algebra R‚āÄ R] [Algebra R‚āÄ S]
    [IsScalarTower R‚āÄ R S] where
  coeffs_subset_range : P.coeffs ‚äÜ Set.range (algebraMap R‚āÄ R)

set_option backward.isDefEq.respectTransparency false in
instance : P.HasCoeffs P.Core where
  coeffs_subset_range := by
    refine subset_trans P.coeffs_subset_core ?_
    simp [Core, Subalgebra.algebraMap_eq]

variable (R‚āÄ : Type*) [CommRing R‚āÄ] [Algebra R‚āÄ R] [Algebra R‚āÄ S] [IsScalarTower R‚āÄ R S]
  [P.HasCoeffs R‚āÄ]

lemma coeffs_subset_range : (P.coeffs : Set R) ‚äÜ Set.range (algebraMap R‚āÄ R) :=
  HasCoeffs.coeffs_subset_range

lemma HasCoeffs.of_isScalarTower {R‚āĀ : Type*} [CommRing R‚āĀ] [Algebra R‚āÄ R‚āĀ] [Algebra R‚āĀ R]
    [IsScalarTower R‚āÄ R‚āĀ R] [Algebra R‚āĀ S] [IsScalarTower R‚āĀ R S] :
    P.HasCoeffs R‚āĀ := by
  refine ‚ü®subset_trans (P.coeffs_subset_range R‚āÄ) ?_‚ü©
  simp [IsScalarTower.algebraMap_eq R‚āÄ R‚āĀ R, RingHom.coe_comp, Set.range_comp]

instance (s : Set R) : P.HasCoeffs (Algebra.adjoin R‚āÄ s) := HasCoeffs.of_isScalarTower R‚āÄ

lemma HasCoeffs.coeffs_relation_mem_range (x : ŌÉ) :
    ‚ÜĎ(P.relation x).coeffs ‚äÜ Set.range (algebraMap R‚āÄ R) :=
  subset_trans (P.coeffs_relation_subset_coeffs x) HasCoeffs.coeffs_subset_range

lemma HasCoeffs.relation_mem_range_map (x : ŌÉ) :
    P.relation x ‚ąą Set.range (MvPolynomial.map (algebraMap R‚āÄ R)) := by
  rw [MvPolynomial.mem_range_map_iff_coeffs_subset]
  exact HasCoeffs.coeffs_relation_mem_range R‚āÄ x

/-- The `r`-th relation of `P` as a polynomial in `R‚āÄ`. This is the (arbitrary) choice of a
pre-image under the map `R‚āÄ[X] ‚Üí R[X]`. -/
noncomputable def relationOfHasCoeffs (r : ŌÉ) : MvPolynomial őĻ R‚āÄ :=
  (HasCoeffs.relation_mem_range_map (P := P) R‚āÄ r).choose

lemma map_relationOfHasCoeffs (r : ŌÉ) :
    MvPolynomial.map (algebraMap R‚āÄ R) (P.relationOfHasCoeffs R‚āÄ r) = P.relation r :=
  (HasCoeffs.relation_mem_range_map R‚āÄ r).choose_spec

@[simp]
lemma aeval_val_relationOfHasCoeffs (r : ŌÉ) :
    MvPolynomial.aeval P.val (P.relationOfHasCoeffs R‚āÄ r) = 0 := by
  rw [‚Üź MvPolynomial.aeval_map_algebraMap R, map_relationOfHasCoeffs, aeval_val_relation]

@[simp]
lemma algebraTensorAlgEquiv_symm_relation (r : ŌÉ) :
    (MvPolynomial.algebraTensorAlgEquiv R‚āÄ R).symm (P.relation r) =
      1 ‚äó‚āú P.relationOfHasCoeffs R‚āÄ r := by
  rw [‚Üź map_relationOfHasCoeffs R‚āÄ, MvPolynomial.algebraTensorAlgEquiv_symm_map]

/-- The model of `S` over a `R‚āÄ` that contains the coefficients of `P` is `R‚āÄ[X]` quotiented by the
same relations. -/
abbrev ModelOfHasCoeffs : Type _ :=
  MvPolynomial őĻ R‚āÄ ‚ßł (Ideal.span <| Set.range (P.relationOfHasCoeffs R‚āÄ))

instance [Finite őĻ] [Finite ŌÉ] : Algebra.FinitePresentation R‚āÄ (P.ModelOfHasCoeffs R‚āÄ) := by
  classical
  cases nonempty_fintype ŌÉ
  exact .quotient ‚ü®Finset.image (P.relationOfHasCoeffs R‚āÄ) .univ, by simp‚ü©

variable (P) in
/-- (Implementation detail): The underlying `AlgHom` of `tensorModelOfHasCoeffsEquiv`. -/
noncomputable def tensorModelOfHasCoeffsHom : R ‚äó[R‚āÄ] P.ModelOfHasCoeffs R‚āÄ ‚Üí‚āź[R] S :=
  Algebra.TensorProduct.lift (Algebra.ofId R S)
    (Ideal.Quotient.lift‚āź _ (MvPolynomial.aeval P.val) <| by
      simp_rw [‚Üź RingHom.mem_ker, ‚Üź SetLike.le_def, Ideal.span_le]
      rintro a ‚ü®i, rfl‚ü©
      simp)
    fun _ _ ‚Ü¶ Commute.all _ _

@[simp]
lemma tensorModelOfHasCoeffsHom_tmul (x : R) (y : MvPolynomial őĻ R‚āÄ) :
    P.tensorModelOfHasCoeffsHom R‚āÄ (x ‚äó‚āú y) = algebraMap R S x * MvPolynomial.aeval P.val y :=
  rfl

variable (P) in
/-- (Implementation detail): The inverse of `tensorModelOfHasCoeffsHom`. -/
noncomputable def tensorModelOfHasCoeffsInv : S ‚Üí‚āź[R] R ‚äó[R‚āÄ] P.ModelOfHasCoeffs R‚āÄ :=
  (Ideal.Quotient.lift‚āź _
    ((Algebra.TensorProduct.map (.id R R) (Ideal.Quotient.mk‚āź _ _)).comp
      (MvPolynomial.algebraTensorAlgEquiv R‚āÄ R).symm.toAlgHom) <| by
    simp_rw [‚Üź RingHom.mem_ker, ‚Üź SetLike.le_def]
    rw [‚Üź P.span_range_relation_eq_ker, Ideal.span_le]
    rintro a ‚ü®i, rfl‚ü©
    simp only [SetLike.mem_coe, RingHom.mem_ker, AlgHom.coe_comp,
      AlgEquiv.coe_algHom, Function.comp_apply, algebraTensorAlgEquiv_symm_relation]
    simp only [TensorProduct.map_tmul, AlgHom.coe_id, id_eq, Ideal.Quotient.mk‚āź_eq_mk,
      Ideal.Quotient.mk_span_range, tmul_zero]).comp
    (P.quotientEquiv.restrictScalars R).symm.toAlgHom

@[simp]
lemma tensorModelOfHasCoeffsInv_aeval_val (x : MvPolynomial őĻ R‚āÄ) :
    P.tensorModelOfHasCoeffsInv R‚āÄ (MvPolynomial.aeval P.val x) =
      1 ‚äó‚āú[R‚āÄ] (Ideal.Quotient.mk _ x) := by
  rw [‚Üź MvPolynomial.aeval_map_algebraMap R, ‚Üź Generators.algebraMap_apply, ‚Üź quotientEquiv_mk]
  simp [tensorModelOfHasCoeffsInv, -quotientEquiv_symm, -quotientEquiv_mk]

lemma tensorModelOfHasCoeffsHom_comp :
    (P.tensorModelOfHasCoeffsHom R‚āÄ).comp (P.tensorModelOfHasCoeffsInv R‚āÄ) = AlgHom.id R S := by
  have h : Function.Surjective
      ((P.quotientEquiv.restrictScalars R).toAlgHom.comp (Ideal.Quotient.mk‚āź _ _)) :=
    (P.quotientEquiv.restrictScalars R).surjective.comp Ideal.Quotient.mk_surjective
  simp only [‚Üź AlgHom.cancel_right h, tensorModelOfHasCoeffsInv, AlgHom.id_comp]
  rw [AlgHom.comp_assoc, AlgHom.comp_assoc, ‚Üź AlgHom.comp_assoc _ _ (Ideal.Quotient.mk‚āź R P.ker),
    AlgEquiv.symm_comp, AlgHom.id_comp]
  ext x
  simp

lemma tensorModelOfHasCoeffsInv_comp :
    (P.tensorModelOfHasCoeffsInv R‚āÄ).comp (P.tensorModelOfHasCoeffsHom R‚āÄ) = AlgHom.id R _ := by
  ext x
  obtain ‚ü®x, rfl‚ü© := Ideal.Quotient.mk_surjective x
  simp

/-- The natural isomorphism `R ‚äó[R‚āÄ] S‚āÄ ‚ČÉ‚āź[R] S`. -/
noncomputable def tensorModelOfHasCoeffsEquiv : R ‚äó[R‚āÄ] P.ModelOfHasCoeffs R‚āÄ ‚ČÉ‚āź[R] S :=
  AlgEquiv.ofAlgHom (P.tensorModelOfHasCoeffsHom R‚āÄ) (P.tensorModelOfHasCoeffsInv R‚āÄ)
    (P.tensorModelOfHasCoeffsHom_comp R‚āÄ) (P.tensorModelOfHasCoeffsInv_comp R‚āÄ)

@[simp]
lemma tensorModelOfHasCoeffsEquiv_tmul (x : R) (y : MvPolynomial őĻ R‚āÄ) :
    P.tensorModelOfHasCoeffsEquiv R‚āÄ (x ‚äó‚āú y) = algebraMap R S x * MvPolynomial.aeval P.val y :=
  rfl

@[simp]
lemma tensorModelOfHasCoeffsEquiv_symm_tmul (x : MvPolynomial őĻ R‚āÄ) :
    (P.tensorModelOfHasCoeffsEquiv R‚āÄ).symm (MvPolynomial.aeval P.val x) =
      1 ‚äó‚āú[R‚āÄ] (Ideal.Quotient.mk _ x) :=
  tensorModelOfHasCoeffsInv_aeval_val _ x

end Algebra.Presentation
namespace Algebra.PreSubmersivePresentation

variable (P : Algebra.PreSubmersivePresentation R S őĻ ŌÉ)
variable (R‚āÄ : Type*) [CommRing R‚āÄ] [Algebra R‚āÄ R] [Algebra R‚āÄ S] [IsScalarTower R‚āÄ R S]
  [P.HasCoeffs R‚āÄ]

/-- The presubmersive presentation on `P.ModelOfHasCoeffs R‚āÄ` provided `P.HasCoeffs R‚āÄ`. -/
@[simps!]
noncomputable def ofHasCoeffs :
    Algebra.PreSubmersivePresentation R‚āÄ (P.ModelOfHasCoeffs R‚āÄ) őĻ ŌÉ where
  __ := Algebra.Presentation.naive
  map := P.map
  map_inj := P.map_inj

end Algebra.PreSubmersivePresentation

namespace Algebra.SubmersivePresentation

variable [Finite ŌÉ] (P : Algebra.SubmersivePresentation R S őĻ ŌÉ)

set_option backward.isDefEq.respectTransparency false in
lemma exists_sum_eq_ŌÉ_jacobian_mul_ŌÉ_jacobian_inv_sub_one
    [DecidableEq ŌÉ] [Fintype ŌÉ] :
    ‚ąÉ v : ŌÉ ‚Üí MvPolynomial őĻ R, ‚ąĎ i, v i * P.relation i =
        P.jacobiMatrix.det * P.ŌÉ ‚ÜĎ(P.jacobian_isUnit.unit‚ĀĽ¬Ļ) - 1 := by
  have H : P.jacobiMatrix.det * P.ŌÉ ‚ÜĎ(P.jacobian_isUnit.unit‚ĀĽ¬Ļ) - 1 ‚ąą P.ker := by
    simp [PreSubmersivePresentation.jacobian_eq_jacobiMatrix_det]
  rwa [‚Üź P.span_range_relation_eq_ker, Ideal.mem_span_range_iff_exists_fun] at H

/-- An arbitrarily chosen relation exhibiting the fact that `P.jacobian` is invertible. -/
noncomputable
def jacobianRelations (s : ŌÉ) : MvPolynomial őĻ R :=
  letI := Fintype.ofFinite ŌÉ
  letI := Classical.decEq ŌÉ
  P.exists_sum_eq_ŌÉ_jacobian_mul_ŌÉ_jacobian_inv_sub_one.choose s

lemma jacobianRelations_spec [DecidableEq ŌÉ] [Fintype ŌÉ] :
    ‚ąĎ i, P.jacobianRelations i * P.relation i =
      P.jacobiMatrix.det * P.ŌÉ ‚ÜĎ(P.jacobian_isUnit.unit‚ĀĽ¬Ļ) - 1 := by
  delta jacobianRelations
  convert P.exists_sum_eq_ŌÉ_jacobian_mul_ŌÉ_jacobian_inv_sub_one.choose_spec

/-- The set of coefficients that is enough to descend a submersive presentation `P`. -/
def coeffs : Set R :=
  P.toPresentation.coeffs ‚ą™ (P.ŌÉ (P.jacobian_isUnit.unit‚ĀĽ¬Ļ :)).coeffs ‚ą™
    ‚čÉ i, (P.jacobianRelations i).coeffs

lemma finite_coeffs : P.coeffs.Finite :=
  .union (P.toPresentation.finite_coeffs.union (by simp))
    (.iUnion Set.finite_univ (by simp) (by simp))

lemma coeffs_toPresentation_subset_coeffs : P.toPresentation.coeffs ‚äÜ P.coeffs :=
  Set.subset_union_left.trans Set.subset_union_left

/-- A type class witnessing the fact that `R‚āÄ` contains enough coefficients to descend
`P` to a submersive presentation. -/
class HasCoeffs (R‚āÄ : Type*) [CommRing R‚āÄ] [Algebra R‚āÄ R] [Algebra R‚āÄ S]
    [IsScalarTower R‚āÄ R S] where
  coeffs_subset_range : P.coeffs ‚äÜ ‚ÜĎ(algebraMap R‚āÄ R).range

variable (R‚āÄ : Type*) [CommRing R‚āÄ] [Algebra R‚āÄ R] [Algebra R‚āÄ S] [IsScalarTower R‚āÄ R S]
  [P.HasCoeffs R‚āÄ]

instance (priority := low) : P.toPresentation.HasCoeffs R‚āÄ where
  coeffs_subset_range := P.coeffs_toPresentation_subset_coeffs.trans HasCoeffs.coeffs_subset_range

/-- The jacobian of a presentation in the smaller coefficient ring, provided `P.HasCoeffs R‚āÄ`. -/
noncomputable
def jacobianOfHasCoeffs : MvPolynomial őĻ R‚āÄ :=
  letI := Classical.decEq ŌÉ
  letI := Fintype.ofFinite ŌÉ
  (P.toPreSubmersivePresentation.ofHasCoeffs R‚āÄ).jacobiMatrix.det

@[simp]
lemma map_jacobianOfHasCoeffs [Fintype ŌÉ] [DecidableEq ŌÉ] :
    (P.jacobianOfHasCoeffs R‚āÄ).map (algebraMap R‚āÄ R) = P.jacobiMatrix.det := by
  rw [jacobianOfHasCoeffs, @RingHom.map_det]
  congr! 1
  ext1 i j
  simp [Presentation.map_relationOfHasCoeffs, ‚Üź MvPolynomial.pderiv_map,
    PreSubmersivePresentation.jacobiMatrix_apply]

@[simp]
lemma aeval_jacobianOfHasCoeffs :
    MvPolynomial.aeval P.val (P.jacobianOfHasCoeffs R‚āÄ) = P.jacobian := by
  classical
  let : Fintype ŌÉ := Fintype.ofFinite _
  rw [‚Üź MvPolynomial.aeval_map_algebraMap R, map_jacobianOfHasCoeffs,
    P.jacobian_eq_jacobiMatrix_det, Generators.algebraMap_apply]

/-- The inverse jacobian of a presentation in the smaller coefficient ring,
provided `P.HasCoeffs R‚āÄ`. -/
noncomputable
def invJacobianOfHasCoeffs : MvPolynomial őĻ R‚āÄ :=
  (MvPolynomial.mem_range_map_iff_coeffs_subset.mpr
    ((Set.subset_union_right.trans Set.subset_union_left).trans
      (HasCoeffs.coeffs_subset_range (P := P)))).choose

@[simp]
lemma map_invJacobianOfHasCoeffs :
    (P.invJacobianOfHasCoeffs R‚āÄ).map (algebraMap R‚āÄ R) = P.ŌÉ ‚ÜĎ(P.jacobian_isUnit.unit‚ĀĽ¬Ļ) :=
  (MvPolynomial.mem_range_map_iff_coeffs_subset.mpr
    ((Set.subset_union_right.trans Set.subset_union_left).trans
      (HasCoeffs.coeffs_subset_range (P := P)))).choose_spec

@[simp]
lemma aeval_invJacobianOfHasCoeffs :
    MvPolynomial.aeval P.val (P.invJacobianOfHasCoeffs R‚āÄ) = ‚ÜĎ(P.jacobian_isUnit.unit‚ĀĽ¬Ļ) := by
  simpa [-map_invJacobianOfHasCoeffs, MvPolynomial.aeval_map_algebraMap] using
    congr(MvPolynomial.aeval P.val $(P.map_invJacobianOfHasCoeffs R‚āÄ))

/-- An arbitrarily chosen relation exhibiting the fact that `P.jacobian` is invertible,
provided `P.HasCoeffs R‚āÄ`. -/
noncomputable
def jacobianRelationsOfHasCoeffs (i : ŌÉ) : MvPolynomial őĻ R‚āÄ :=
  (MvPolynomial.mem_range_map_iff_coeffs_subset.mpr
    ((Set.subset_iUnion _ i).trans (Set.subset_union_right.trans
      (HasCoeffs.coeffs_subset_range (P := P))))).choose

@[simp]
lemma map_jacobianRelationsOfHasCoeffs (i : ŌÉ) :
    (P.jacobianRelationsOfHasCoeffs R‚āÄ i).map (algebraMap R‚āÄ R) = P.jacobianRelations i :=
  (MvPolynomial.mem_range_map_iff_coeffs_subset.mpr
    ((Set.subset_iUnion _ i).trans (Set.subset_union_right.trans
      (HasCoeffs.coeffs_subset_range (P := P))))).choose_spec

lemma sum_jacobianRelationsOfHasCoeffs_mul_relationOfHasCoeffs [FaithfulSMul R‚āÄ R] [Fintype ŌÉ] :
    ‚ąĎ i, P.jacobianRelationsOfHasCoeffs R‚āÄ i * P.relationOfHasCoeffs R‚āÄ i =
      P.jacobianOfHasCoeffs R‚āÄ * P.invJacobianOfHasCoeffs R‚āÄ - 1 := by
  classical
  apply MvPolynomial.map_injective _ (FaithfulSMul.algebraMap_injective R‚āÄ R)
  simp [P.map_relationOfHasCoeffs, jacobianRelations_spec]

set_option backward.isDefEq.respectTransparency false in
/-- The submersive presentation on `P.ModelOfHasCoeffs R‚āÄ` provided `P.HasCoeffs R‚āÄ`. -/
noncomputable
def ofHasCoeffs [FaithfulSMul R‚āÄ R] :
    Algebra.SubmersivePresentation R‚āÄ (P.ModelOfHasCoeffs R‚āÄ) őĻ ŌÉ where
  __ := P.toPreSubmersivePresentation.ofHasCoeffs R‚āÄ
  jacobian_isUnit := by
    classical
    let : Fintype ŌÉ := Fintype.ofFinite _
    have := congr((Ideal.Quotient.mk _ : _ ‚Üí+* P.ModelOfHasCoeffs R‚āÄ)
      $(P.sum_jacobianRelationsOfHasCoeffs_mul_relationOfHasCoeffs R‚āÄ))
    simp only [map_sum, map_mul, Ideal.Quotient.mk_span_range, mul_zero, Finset.sum_const_zero,
      map_sub, map_one, @eq_comm (P.ModelOfHasCoeffs R‚āÄ) 0, sub_eq_zero] at this
    convert IsUnit.of_mul_eq_one _ this
    rw [PreSubmersivePresentation.jacobian_eq_jacobiMatrix_det]
    simp [jacobianOfHasCoeffs]

end Algebra.SubmersivePresentation
