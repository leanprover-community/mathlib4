section Equiv'

variable [CommRing R] [CommRing S] [Algebra R S]
variable (g : R[X]) (pb : PowerBasis R S)

/-- If `S` is an extension of `R` with power basis `pb` and `g` is a monic polynomial over `R`
such that `pb.gen` has a minimal polynomial `g`, then `S` is isomorphic to `AdjoinRoot g`.

Compare `PowerBasis.equivOfRoot`, which would require
`h‚ÇÇ : aeval pb.gen (minpoly R (root g)) = 0`; that minimal polynomial is not
guaranteed to be identical to `g`. -/
@[simps -fullyApplied]
def equiv' (h‚ÇÅ : aeval (root g) (minpoly R pb.gen) = 0) (h‚ÇÇ : aeval pb.gen g = 0) :
    AdjoinRoot g ‚âÉ‚Çê[R] S where
  __ := AdjoinRoot.liftAlgHom g _ pb.gen h‚ÇÇ
  toFun := AdjoinRoot.liftAlgHom g _ pb.gen h‚ÇÇ
  invFun := pb.lift (root g) h‚ÇÅ
  left_inv x := AdjoinRoot.induction_on _ x fun x => by
    change pb.lift _ _ (aeval _ _) = _; rw [pb.lift_aeval, aeval_eq]
  right_inv x := by
    nontriviality S
    obtain ‚ü®f, _hf, rfl‚ü© := pb.exists_eq_aeval x
    rw [pb.lift_aeval, aeval_eq, liftAlgHom_mk, Polynomial.aeval_def, Algebra.toRingHom_ofId]

-- This lemma should have the simp tag but this causes a lint issue.
theorem equiv'_toAlgHom (h‚ÇÅ : aeval (root g) (minpoly R pb.gen) = 0) (h‚ÇÇ : aeval pb.gen g = 0) :
    (equiv' g pb h‚ÇÅ h‚ÇÇ).toAlgHom = AdjoinRoot.liftAlgHom g _ pb.gen h‚ÇÇ :=
  rfl

-- This lemma should have the simp tag but this causes a lint issue.
theorem equiv'_symm_toAlgHom (h‚ÇÅ : aeval (root g) (minpoly R pb.gen) = 0)
    (h‚ÇÇ : aeval pb.gen g = 0) : (equiv' g pb h‚ÇÅ h‚ÇÇ).symm.toAlgHom = pb.lift (root g) h‚ÇÅ :=
  rfl

end Equiv'

