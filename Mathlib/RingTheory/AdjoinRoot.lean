/-!
# Adjoining roots of polynomials

This file defines the commutative ring `AdjoinRoot f`, the ring R[X]/(f) obtained from a
commutative ring `R` and a polynomial `f : R[X]`. If furthermore `R` is a field and `f` is
irreducible, the field structure on `AdjoinRoot f` is constructed.

We suggest stating results on `IsAdjoinRoot` instead of `AdjoinRoot` to achieve higher
generality, since `IsAdjoinRoot` works for all different constructions of `R[Œ±]`
including `AdjoinRoot f = R[X]/(f)` itself.

## Main definitions and results

The main definitions are in the `AdjoinRoot` namespace.

*  `mk f : R[X] ‚Üí+* AdjoinRoot f`, the natural ring homomorphism.

*  `of f : R ‚Üí+* AdjoinRoot f`, the natural ring homomorphism.

* `root f : AdjoinRoot f`, the image of X in R[X]/(f).

* `lift (i : R ‚Üí+* S) (x : S) (h : f.eval‚ÇÇ i x = 0) : (AdjoinRoot f) ‚Üí+* S`, the ring
  homomorphism from R[X]/(f) to S extending `i : R ‚Üí+* S` and sending `X` to `x`.

* `lift_hom (x : S) (hfx : aeval x f = 0) : AdjoinRoot f ‚Üí‚Çê[R] S`, the algebra
  homomorphism from R[X]/(f) to S extending `algebraMap R S` and sending `X` to `x`

* `equiv : (AdjoinRoot f ‚Üí‚Çê[F] E) ‚âÉ {x // x ‚àà f.aroots E}` a
  bijection between algebra homomorphisms from `AdjoinRoot` and roots of `f` in `S`

-/

@[expose] public section

noncomputable section

open Algebra (FinitePresentation FiniteType)
open Ideal Module Polynomial

variable {R S T U K : Type*}

/-- Adjoin a root of a polynomial `f` to a commutative ring `R`. We define the new ring
as the quotient of `R[X]` by the principal ideal generated by `f`. -/
def AdjoinRoot [CommRing R] (f : R[X]) : Type _ :=
  Polynomial R ‚ß∏ (span {f} : Ideal R[X])

namespace AdjoinRoot

section CommRing

variable [CommRing R] (f g : R[X])

deriving instance CommRing, Inhabited for AdjoinRoot

instance : DecidableEq (AdjoinRoot f) :=
  Classical.decEq _

protected theorem nontrivial [IsDomain R] (h : degree f ‚âÝ 0) : Nontrivial (AdjoinRoot f) := by
  simp only [AdjoinRoot, Quotient.nontrivial_iff, Ne, span_singleton_eq_top,
    Polynomial.isUnit_iff, not_exists, not_and]
  rintro x hx rfl
  exact h (degree_C hx.ne_zero)

/-- Ring homomorphism from `R[x]` to `AdjoinRoot f` sending `X` to the `root`. -/
def mk : R[X] ‚Üí+* AdjoinRoot f :=
  Ideal.Quotient.mk _

@[elab_as_elim]
theorem induction_on {C : AdjoinRoot f ‚Üí Prop} (x : AdjoinRoot f) (ih : ‚àÄ p : R[X], C (mk f p)) :
    C x :=
  Quotient.inductionOn' x ih

/-- Embedding of the original ring `R` into `AdjoinRoot f`. -/
def of : R ‚Üí+* AdjoinRoot f :=
  (mk f).comp C

instance instSMulAdjoinRoot [DistribSMul S R] [IsScalarTower S R R] : SMul S (AdjoinRoot f) :=
  inferInstanceAs <| SMul S (_ ‚ß∏ _)

instance [DistribSMul S R] [IsScalarTower S R R] : DistribSMul S (AdjoinRoot f) :=
  inferInstanceAs <| DistribSMul S (_ ‚ß∏ _)

@[simp]
theorem smul_mk [DistribSMul S R] [IsScalarTower S R R] (a : S) (x : R[X]) :
    a ‚Ä¢ mk f x = mk f (a ‚Ä¢ x) :=
  rfl

theorem smul_of [DistribSMul S R] [IsScalarTower S R R] (a : S) (x : R) :
    a ‚Ä¢ of f x = of f (a ‚Ä¢ x) := by rw [of, RingHom.comp_apply, RingHom.comp_apply, smul_mk, smul_C]

instance (R‚ÇÅ R‚ÇÇ : Type*) [SMul R‚ÇÅ R‚ÇÇ] [DistribSMul R‚ÇÅ R] [DistribSMul R‚ÇÇ R] [IsScalarTower R‚ÇÅ R R]
    [IsScalarTower R‚ÇÇ R R] [IsScalarTower R‚ÇÅ R‚ÇÇ R] (f : R[X]) :
    IsScalarTower R‚ÇÅ R‚ÇÇ (AdjoinRoot f) :=
  inferInstanceAs <| IsScalarTower R‚ÇÅ R‚ÇÇ (_ ‚ß∏ _)

instance (R‚ÇÅ R‚ÇÇ : Type*) [DistribSMul R‚ÇÅ R] [DistribSMul R‚ÇÇ R] [IsScalarTower R‚ÇÅ R R]
    [IsScalarTower R‚ÇÇ R R] [SMulCommClass R‚ÇÅ R‚ÇÇ R] (f : R[X]) :
    SMulCommClass R‚ÇÅ R‚ÇÇ (AdjoinRoot f) :=
  inferInstanceAs <| SMulCommClass R‚ÇÅ R‚ÇÇ (_ ‚ß∏ _)

instance isScalarTower_right [DistribSMul S R] [IsScalarTower S R R] :
    IsScalarTower S (AdjoinRoot f) (AdjoinRoot f) :=
  inferInstanceAs <| IsScalarTower S (_ ‚ß∏ _) (_ ‚ß∏ _)

instance [Monoid S] [DistribMulAction S R] [IsScalarTower S R R] (f : R[X]) :
    DistribMulAction S (AdjoinRoot f) :=
  inferInstanceAs <| DistribMulAction S (_ ‚ß∏ _)

/-- `R[x]/(f)` is `R`-algebra -/
@[stacks 09FX "second part"]
instance [CommSemiring S] [Algebra S R] : Algebra S (AdjoinRoot f) :=
  inferInstanceAs <| Algebra S (_ ‚ß∏ _)

/- TODO : generalise base ring -/
/-- `R`-algebra homomorphism from `R[x]` to `AdjoinRoot f` sending `X` to the `root`. -/
def mk‚Çê : R[X] ‚Üí‚Çê[R] AdjoinRoot f :=
  Ideal.Quotient.mk‚Çê R _

@[simp, norm_cast] theorem mk‚Çê_toRingHom : ‚Üë(mk‚Çê f) = mk f := rfl

@[simp] theorem coe_mk‚Çê : ‚áë(mk‚Çê f) = mk f := rfl

@[simp]
theorem algebraMap_eq : algebraMap R (AdjoinRoot f) = of f :=
  rfl

variable (S) in
theorem algebraMap_eq' [CommSemiring S] [Algebra S R] :
    algebraMap S (AdjoinRoot f) = (of f).comp (algebraMap S R) :=
  rfl

instance finiteType [CommSemiring S] [Algebra S R] [FiniteType S R] :
    FiniteType S (AdjoinRoot f) :=
  inferInstanceAs <| FiniteType S (_ ‚ß∏ (_ : Ideal R[X]))

instance finitePresentation [CommRing S] [Algebra S R] [FinitePresentation S R] :
    FinitePresentation S (AdjoinRoot f) :=
  .quotient (Submodule.fg_span_singleton f)

/-- The adjoined root. -/
def root : AdjoinRoot f :=
  mk f X

section Algebra
variable [CommSemiring S] [Semiring T] [Algebra S R] [Algebra S T] (p : R[X])

variable (S) in
/-- Embedding of the original ring `R` into `AdjoinRoot p`. -/
abbrev ofAlgHom : R ‚Üí‚Çê[S] AdjoinRoot p := Algebra.algHom S R <| AdjoinRoot p

@[simp] lemma toRingHom_ofAlgHom : ofAlgHom S p = of p := rfl

@[simp] lemma coe_ofAlgHom : ‚áë(ofAlgHom S p) = of p := rfl

variable {p}

@[ext high] -- This should have higher precedence than `RingHom.ext`.
lemma ringHom_ext {f g : AdjoinRoot p ‚Üí+* T} (hAlg : f.comp (of p) = g.comp (of p))
    (hRoot : f (root p) = g (root p)) : f = g := by
  apply Ideal.Quotient.ringHom_ext
  ext x
  ¬∑ simpa using congr($(hAlg) x)
  ¬∑ simpa

@[ext high] -- This should have higher precedence than `AlgHom.ext`.
lemma algHom_ext' {f g : AdjoinRoot p ‚Üí‚Çê[S] T}
    (hAlg : f.comp (ofAlgHom S p) = g.comp (ofAlgHom S p))
    (hRoot : f (root p) = g (root p)) : f = g := by
  apply AlgHom.coe_ringHom_injective; exact ringHom_ext congr(($hAlg).toRingHom) hRoot

end Algebra

variable {f g}

instance hasCoeT : CoeTC R (AdjoinRoot f) :=
  ‚ü®of f‚ü©

/-- Two `R`-`AlgHom` from `AdjoinRoot f` to the same `R`-algebra are the same iff
they agree on `root f`. -/
@[ext high] -- This should have higher precedence than `algHom_ext'`.
theorem algHom_ext [Semiring S] [Algebra R S] {g‚ÇÅ g‚ÇÇ : AdjoinRoot f ‚Üí‚Çê[R] S}
    (h : g‚ÇÅ (root f) = g‚ÇÇ (root f)) : g‚ÇÅ = g‚ÇÇ :=
  Ideal.Quotient.algHom_ext R <| Polynomial.algHom_ext h

@[simp]
theorem mk_eq_mk {g h : R[X]} : mk f g = mk f h ‚Üî f ‚à£ g - h :=
  Ideal.Quotient.eq.trans Ideal.mem_span_singleton

@[simp]
theorem mk_eq_zero {g : R[X]} : mk f g = 0 ‚Üî f ‚à£ g :=
  mk_eq_mk.trans <| by rw [sub_zero]

@[simp]
theorem mk_self : mk f f = 0 :=
  Quotient.sound' <| QuotientAddGroup.leftRel_apply.mpr (mem_span_singleton.2 <| by simp)

@[simp]
theorem mk_C (x : R) : mk f (C x) = x :=
  rfl

@[simp]
theorem mk_X : mk f X = root f :=
  rfl

theorem mk_ne_zero_of_degree_lt (hf : Monic f) {g : R[X]} (h0 : g ‚âÝ 0) (hd : degree g < degree f) :
    mk f g ‚âÝ 0 :=
  mk_eq_zero.not.2 <| hf.not_dvd_of_degree_lt h0 hd

theorem mk_ne_zero_of_natDegree_lt (hf : Monic f) {g : R[X]} (h0 : g ‚âÝ 0)
    (hd : natDegree g < natDegree f) : mk f g ‚âÝ 0 :=
  mk_eq_zero.not.2 <| hf.not_dvd_of_natDegree_lt h0 hd

theorem aeval_eq_of_algebra [CommRing S] [Algebra R S] (f : S[X]) (p : R[X]) :
    aeval (root f) p = mk f (map (algebraMap R S) p) := by
  induction p using Polynomial.induction_on with
  | C a =>
    simp only [Polynomial.aeval_C, Polynomial.map_C, mk_C]
    rw [IsScalarTower.algebraMap_apply R S]
    simp
  | add p q _ _ => simp_all
  | monomial n a _ => simp_all [pow_add, ‚Üê mul_assoc]

@[simp]
theorem aeval_eq (p : R[X]) : aeval (root f) p = mk f p := by
  rw [aeval_eq_of_algebra, Algebra.algebraMap_self, Polynomial.map_id]

theorem adjoinRoot_eq_top : Algebra.adjoin R ({root f} : Set (AdjoinRoot f)) = ‚ä§ := by
  refine Algebra.eq_top_iff.2 fun x => ?_
  induction x using AdjoinRoot.induction_on with
    | ih p => exact (Algebra.adjoin_singleton_eq_range_aeval R (root f)).symm ‚ñ∏ ‚ü®p, aeval_eq p‚ü©

@[simp]
theorem eval‚ÇÇ_root (f : R[X]) : f.eval‚ÇÇ (of f) (root f) = 0 := by
  rw [‚Üê algebraMap_eq, ‚Üê aeval_def, aeval_eq, mk_self]

theorem isRoot_root (f : R[X]) : IsRoot (f.map (of f)) (root f) := by
  rw [IsRoot, eval_map, eval‚ÇÇ_root]

theorem isAlgebraic_root (hf : f ‚âÝ 0) : IsAlgebraic R (root f) :=
  ‚ü®f, hf, eval‚ÇÇ_root f‚ü©

theorem of.injective_of_degree_ne_zero [IsDomain R] (hf : f.degree ‚âÝ 0) :
    Function.Injective (AdjoinRoot.of f) := by
  rw [injective_iff_map_eq_zero]
  intro p hp
  rw [AdjoinRoot.of, RingHom.comp_apply, AdjoinRoot.mk_eq_zero] at hp
  by_cases h : f = 0
  ¬∑ exact C_eq_zero.mp (eq_zero_of_zero_dvd (by rwa [h] at hp))
  ¬∑ contrapose! hf with h_contra
    rw [‚Üê degree_C h_contra]
    apply le_antisymm (degree_le_of_dvd hp (by rwa [Ne, C_eq_zero])) _
    rwa [degree_C h_contra, zero_le_degree_iff]

variable [CommRing S]

/-- Lift a ring homomorphism `i : R ‚Üí+* S` to `AdjoinRoot f ‚Üí+* S`. -/
def lift (i : R ‚Üí+* S) (x : S) (h : f.eval‚ÇÇ i x = 0) : AdjoinRoot f ‚Üí+* S := by
  apply Ideal.Quotient.lift _ (eval‚ÇÇRingHom i x)
  intro g H
  rcases mem_span_singleton.1 H with ‚ü®y, hy‚ü©
  rw [hy, map_mul, coe_eval‚ÇÇRingHom, h, zero_mul]

variable {i : R ‚Üí+* S} {a : S} (h : f.eval‚ÇÇ i a = 0)

@[simp]
theorem lift_mk (g : R[X]) : lift i a h (mk f g) = g.eval‚ÇÇ i a :=
  Ideal.Quotient.lift_mk _ _ _

@[simp]
theorem lift_root : lift i a h (root f) = a := by rw [root, lift_mk, eval‚ÇÇ_X]

@[simp]
theorem lift_of {x : R} : lift i a h x = i x := by rw [‚Üê mk_C x, lift_mk, eval‚ÇÇ_C]

@[simp]
theorem lift_comp_of : (lift i a h).comp (of f) = i :=
  RingHom.ext fun _ => @lift_of _ _ _ _ _ _ _ h _

section
variable [CommRing T] [Algebra S R] [Algebra S T] (p : R[X])

/-- Produce an algebra homomorphism `AdjoinRoot f ‚Üí‚Çê[R] S` sending `root f` to
a root of `f` in `S`. -/
def liftAlgHom (i : R ‚Üí‚Çê[S] T) (x : T) (h : p.eval‚ÇÇ i x = 0) : AdjoinRoot p ‚Üí‚Çê[S] T where
  __ := lift i.toRingHom _ h
  commutes' r := by simp [lift_of h, AdjoinRoot.algebraMap_eq']

@[simp] lemma toRingHom_liftAlgHom (i : R ‚Üí‚Çê[S] T) (x : T) (h) :
    (liftAlgHom p i x h : AdjoinRoot p ‚Üí+* T) = lift i.toRingHom _ h := rfl

lemma coe_liftAlgHom (i : R ‚Üí‚Çê[S] T) (x : T) (h) : ‚áë(liftAlgHom p i x h) = lift i.toRingHom _ h :=
  rfl

@[simp]
lemma liftAlgHom_of (i : R ‚Üí‚Çê[S] T) (x : T) (h) (r : R) : liftAlgHom p i x h (of p r) = i r := by
  simp [liftAlgHom]

@[simp]
lemma liftAlgHom_mk (i : R ‚Üí‚Çê[S] T) (x : T) (h) (f : R[X]) :
    liftAlgHom p i x h (mk p f) = eval‚ÇÇ i x f := rfl

@[simp]
lemma liftAlgHom_root (i : R ‚Üí‚Çê[S] T) (x : T) (h) : liftAlgHom p i x h (root p) = x := by
  simp [liftAlgHom]

end

