section AdjoinInv

@[simp]
theorem root_isInv (r : R) : of _ r * root (C r * X - 1) = 1 := by
  convert sub_eq_zero.1 ((eval‚ÇÇ_sub _).symm.trans <| eval‚ÇÇ_root <| C r * X - 1) <;>
    simp only [eval‚ÇÇ_mul, eval‚ÇÇ_C, eval‚ÇÇ_X, eval‚ÇÇ_one]

theorem algHom_subsingleton {S : Type*} [CommRing S] [Algebra R S] {r : R} :
    Subsingleton (AdjoinRoot (C r * X - 1) ‚Üí‚Çê[R] S) :=
  ‚ü®fun f g =>
    algHom_ext
      (@inv_unique _ _ (algebraMap R S r) _ _
        (by rw [‚Üê f.commutes, ‚Üê map_mul, algebraMap_eq, root_isInv, map_one])
        (by rw [‚Üê g.commutes, ‚Üê map_mul, algebraMap_eq, root_isInv, map_one]))‚ü©

end AdjoinInv

section Prime

theorem isDomain_of_prime (hf : Prime f) : IsDomain (AdjoinRoot f) :=
  (Ideal.Quotient.isDomain_iff_prime (span {f} : Ideal R[X])).mpr <|
    (Ideal.span_singleton_prime hf.ne_zero).mpr hf

theorem noZeroSMulDivisors_of_prime_of_degree_ne_zero [IsDomain R] (hf : Prime f)
    (hf' : f.degree ‚âÝ 0) : IsTorsionFree R (AdjoinRoot f) :=
  haveI := isDomain_of_prime hf
  isTorsionFree_iff_algebraMap_injective.mpr (of.injective_of_degree_ne_zero hf')

end Prime

variable [CommRing T]

/-- The canonical homomorphism from `AdjoinRoot p` to `AdjoinRoot q` induced by `f : R ‚Üí+* S`,
where the polynomial `q : S[X]` divides `f(p) : R[X]`. -/
def map (f : R ‚Üí+* S) (p : R[X]) (q : S[X]) (h : q ‚à£ p.map f) : AdjoinRoot p ‚Üí+* AdjoinRoot q :=
  lift ((of _).comp f) (root q) <| by simpa [‚Üê Polynomial.eval‚ÇÇ_map, ‚Üê algebraMap_eq, ‚Üê aeval_def]

@[simp] lemma map_of (f : R ‚Üí+* S) (p : R[X]) (q : S[X]) (h) (r : R) :
    map f p q h (of p r) = f r := by simp [map]

@[simp] lemma map_root (f : R ‚Üí+* S) (p : R[X]) (q : S[X]) (h) : map f p q h (root p) = root q := by
  simp [map]

lemma map_comp_map (f : R ‚Üí+* S) (g : S ‚Üí+* T) (p : R[X]) (q : S[X]) (r : T[X]) (hf hg) :
    (map g q r hg).comp (map f p q hf) =
      map (g.comp f) p r
        (hg.trans <| by simpa [Polynomial.map_map] using Polynomial.map_dvd g hf) := by ext <;> simp

/-- `AdjoinRoot.map` as a `RingEquiv`. -/
def mapRingEquiv (f : R ‚âÉ+* S) (p : R[X]) (q : S[X]) (h : Associated (p.map f) q) :
    AdjoinRoot p ‚âÉ+* AdjoinRoot q :=
  .ofRingHom
    (map f p q h.symm.dvd)
    (map f.symm q p <| by
      simpa [Polynomial.map_map] using map_dvd f.symm.toRingHom h.dvd)
    (by ext <;> simp) (by ext <;> simp)

@[simp] lemma coe_mapRingEquiv (f : R ‚âÉ+* S) (p : R[X]) (q : S[X]) (h) :
    ‚áë(mapRingEquiv f p q h) = map f p q h.symm.dvd := rfl

@[simp] lemma symm_mapRingEquiv (f : R ‚âÉ+* S) (p : R[X]) (q : S[X]) (h) :
    (mapRingEquiv f p q h).symm = mapRingEquiv f.symm q p (by
      simpa [Polynomial.map_map] using associated_map_map f.symm.toRingHom h.symm) := rfl

variable [CommRing U] [Algebra R S] [Algebra R T] [Algebra R U]

/-- `AdjoinRoot.map` as an `AlgHom`. -/
def mapAlgHom (f : S ‚Üí‚Çê[R] T) (p : S[X]) (q : T[X]) (h : q ‚à£ p.map f) :
    AdjoinRoot p ‚Üí‚Çê[R] AdjoinRoot q where
  __ := map f p q h
  commutes' r := by simp [map, AdjoinRoot.algebraMap_eq']

@[simp] lemma coe_mapAlgHom (f : S ‚Üí‚Çê[R] T) (p : S[X]) (q : T[X]) (h) :
    ‚áë(mapAlgHom f p q h) = map f p q h := rfl

lemma mapAlgHom_comp_mapAlghom (f : S ‚Üí‚Çê[R] T) (g : T ‚Üí‚Çê[R] U) (p : S[X]) (q : T[X]) (r : U[X])
    (hf hg) :
    (mapAlgHom g q r hg).comp (mapAlgHom f p q hf) =
      mapAlgHom (g.comp f) p r
        (hg.trans <| by simpa [Polynomial.map_map] using Polynomial.map_dvd g.toRingHom hf) := by
  aesop

/-- `AdjoinRoot.map` as an `AlgEquiv`. -/
def mapAlgEquiv (f : S ‚âÉ‚Çê[R] T) (p : S[X]) (q : T[X]) (h : Associated (p.map f) q) :
    AdjoinRoot p ‚âÉ‚Çê[R] AdjoinRoot q :=
  .ofAlgHom
    (mapAlgHom f p q h.symm.dvd)
    (mapAlgHom f.symm q p <| by
      -- FIXME: Coercion hell. See https://github.com/leanprover-community/mathlib4/issues/31365.
      have : (RingHomClass.toRingHom f.toRingEquiv.symm).comp (RingHomClass.toRingHom f) =
        .id S := by ext; exact f.symm_apply_apply _
      simpa [Polynomial.map_map, this] using map_dvd f.symm.toRingHom h.dvd)
    (by ext <;> simp) (by ext <;> simp)

@[simp] lemma coe_mapAlgEquiv (f : S ‚âÉ‚Çê[R] T) (p : S[X]) (q : T[X]) (h) :
    ‚áë(mapAlgEquiv f p q h) = map f p q h.symm.dvd := rfl

@[simp] lemma symm_mapAlgEquiv (f : S ‚âÉ‚Çê[R] T) (p : S[X]) (q : T[X]) (h) :
    (mapAlgEquiv f p q h).symm = mapAlgEquiv f.symm q p (by
      -- FIXME: Coercion hell. See https://github.com/leanprover-community/mathlib4/issues/31365.
      have : (RingHomClass.toRingHom f.toRingEquiv.symm).comp (RingHomClass.toRingHom f) =
        .id S := by ext; exact f.symm_apply_apply _
      simpa [Polynomial.map_map, this] using associated_map_map f.symm.toRingHom h.symm) := rfl

variable (R) in
/-- The canonical algebraic homomorphism from `AdjoinRoot f` to `AdjoinRoot g`, where
the polynomial `g : S[X]` divides `f`. -/
noncomputable def algHomOfDvd (f g : S[X]) (hgf : g ‚à£ f) : AdjoinRoot f ‚Üí‚Çê[R] AdjoinRoot g :=
  mapAlgHom (.id R S) _ _ <| by simpa

lemma coe_algHomOfDvd (f g : S[X]) (hgf) :
    ‚áë(algHomOfDvd R f g hgf) =
      liftAlgHom f (Algebra.ofId ..) (root g) ((aeval_eq _).trans <| by simp [mk_eq_zero, hgf]) :=
  rfl

/-- `algHomOfDvd` sends `AdjoinRoot.root f` to `AdjoinRoot.root q`. -/
@[simp] lemma algHomOfDvd_root (f g : S[X]) (hgf) : algHomOfDvd R f g hgf (root f) = root g := by
  simp [algHomOfDvd]

variable (R) in
/-- The canonical algebraic equivalence between `AdjoinRoot p` and `AdjoinRoot g`,
where the two polynomials `f g : S[X]` are associated. -/
noncomputable def algEquivOfAssociated (f g : S[X]) (hfg : Associated f g) :
    AdjoinRoot f ‚âÉ‚Çê[R] AdjoinRoot g := mapAlgEquiv .refl f g <| by simpa

lemma coe_algEquivOfAssociated (f g : S[X]) (hfg) :
    ‚áë(algEquivOfAssociated R f g hfg) = algHomOfDvd R f g hfg.symm.dvd := rfl

@[simp] lemma algEquivOfAssociated_symm (f g : S[X]) (hfg) :
    (algEquivOfAssociated R f g hfg).symm = algEquivOfAssociated R g f hfg.symm := rfl

lemma algEquivOfAssociated_toAlgHom (f g : S[X]) (hfg) :
    (algEquivOfAssociated R f g hfg).toAlgHom = algHomOfDvd R f g hfg.symm.dvd := rfl

/-- `algEquivOfAssociated` sends `AdjoinRoot.root f` to `AdjoinRoot.root g`. -/
@[simp] lemma algEquivOfAssociated_root (f g : S[X]) (hfg) :
    algEquivOfAssociated R f g hfg (root f) = root g := by
  rw [coe_algEquivOfAssociated, algHomOfDvd_root]

variable (R) in
/-- The canonical algebraic equivalence between `AdjoinRoot f` and `AdjoinRoot g`, where
the two polynomials `f g : S[X]` are equal. -/
noncomputable def algEquivOfEq (f g : S[X]) (hfg : f = g) : AdjoinRoot f ‚âÉ‚Çê[R] AdjoinRoot g :=
  algEquivOfAssociated R f g (by rw [hfg])

lemma coe_algEquivOfEq (f g : S[X]) (hfg) :
    ‚áë(algEquivOfEq R f g hfg) = algHomOfDvd R f g hfg.symm.dvd := rfl

@[simp] lemma algEquivOfEq_symm (f g : S[X]) (hfg) :
    (algEquivOfEq R f g hfg).symm = algEquivOfEq R g f hfg.symm := rfl

lemma algEquivOfEq_toAlgHom (f g : S[X]) (hfg) :
    (algEquivOfEq R f g hfg).toAlgHom = algHomOfDvd R f g hfg.symm.dvd := rfl

/-- `algEquivOfEq` sends `AdjoinRoot.root f` to `AdjoinRoot.root g`. -/
lemma algEquivOfEq_root (f g : S[X]) (hfg) : algEquivOfEq R f g hfg (root f) = root g := by
  rw [coe_algEquivOfEq, algHomOfDvd_root]

