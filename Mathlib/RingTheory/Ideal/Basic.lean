@[simp]
theorem mul_unit_mem_iff_mem {x y : ╬▒} (hy : IsUnit y) : x * y Ôłł I Ôćö x Ôłł I :=
  mul_comm y x ÔľŞ unit_mul_mem_iff_mem I hy

theorem mem_span_singleton {x y : ╬▒} : x Ôłł span ({y} : Set ╬▒) Ôćö y Ôłú x :=
  mem_span_singleton'.trans <| exists_congr fun _ => by rw [eq_comm, mul_comm]

theorem span_singleton_le_span_singleton {x y : ╬▒} :
    span ({x} : Set ╬▒) ÔëĄ span ({y} : Set ╬▒) Ôćö y Ôłú x :=
  span_le.trans <| singleton_subset_iff.trans mem_span_singleton

theorem span_singleton_eq_span_singleton {╬▒ : Type u} [CommRing ╬▒] [IsDomain ╬▒] {x y : ╬▒} :
    span ({x} : Set ╬▒) = span ({y} : Set ╬▒) Ôćö Associated x y := by
  rw [ÔćÉ dvd_dvd_iff_associated, le_antisymm_iff, and_comm]
  apply and_congr <;> rw [span_singleton_le_span_singleton]

theorem span_singleton_mul_right_unit {a : ╬▒} (h2 : IsUnit a) (x : ╬▒) :
    span ({x * a} : Set ╬▒) = span {x} := by rw [mul_comm, span_singleton_mul_left_unit h2]

@[simp]
theorem span_singleton_eq_top {x} : span ({x} : Set ╬▒) = ÔŐĄ Ôćö IsUnit x := by
  rw [isUnit_iff_dvd_one, ÔćÉ span_singleton_le_span_singleton, span_singleton_one, eq_top_iff]

theorem span_singleton_prime {p : ╬▒} (hp : p Ôëá 0) : IsPrime (span ({p} : Set ╬▒)) Ôćö Prime p := by
  simp [isPrime_iff, Prime, span_singleton_eq_top, hp, mem_span_singleton]

theorem IsMaximal.isPrime {I : Ideal ╬▒} (H : I.IsMaximal) : I.IsPrime :=
  ÔčĘH.1.1, @fun x y hxy =>
    or_iff_not_imp_left.2 fun hx => by
      let J : Ideal ╬▒ := Submodule.span ╬▒ (insert x ÔćĹI)
      have IJ : I ÔëĄ J := Set.Subset.trans (subset_insert _ _) subset_span
      have xJ : x Ôłł J := Ideal.subset_span (Set.mem_insert x I)
      cases' isMaximal_iff.1 H with _ oJ
      specialize oJ J x IJ hx xJ
      rcases Submodule.mem_span_insert.mp oJ with ÔčĘa, b, h, oeÔčę
      obtain F : y * 1 = y * (a ÔÇó x + b) := congr_arg (fun g : ╬▒ => y * g) oe
      rw [ÔćÉ mul_one y, F, mul_add, mul_comm, smul_eq_mul, mul_assoc]
      refine Submodule.add_mem I (I.mul_mem_left a hxy) (Submodule.smul_mem I y ?_)
      rwa [Submodule.span_eq] at hÔčę

-- see Note [lower instance priority]
instance (priority := 100) IsMaximal.isPrime' (I : Ideal ╬▒) : ÔłÇ [_H : I.IsMaximal], I.IsPrime :=
  @IsMaximal.isPrime _ _ _

theorem span_singleton_lt_span_singleton [IsDomain ╬▒] {x y : ╬▒} :
    span ({x} : Set ╬▒) < span ({y} : Set ╬▒) Ôćö DvdNotUnit y x := by
  rw [lt_iff_le_not_le, span_singleton_le_span_singleton, span_singleton_le_span_singleton,
    dvd_and_not_dvd_iff]

theorem factors_decreasing [IsDomain ╬▒] (bÔéü bÔéé : ╬▒) (hÔéü : bÔéü Ôëá 0) (hÔéé : ┬ČIsUnit bÔéé) :
    span ({bÔéü * bÔéé} : Set ╬▒) < span {bÔéü} :=
  lt_of_le_not_le
    (Ideal.span_le.2 <| singleton_subset_iff.2 <| Ideal.mem_span_singleton.2 ÔčĘbÔéé, rflÔčę) fun h =>
    hÔéé <| isUnit_of_dvd_one <|
        (mul_dvd_mul_iff_left hÔéü).1 <| by rwa [mul_one, ÔćÉ Ideal.span_singleton_le_span_singleton]

variable (b)

theorem mul_mem_right (h : a Ôłł I) : a * b Ôłł I :=
  mul_comm b a ÔľŞ I.mul_mem_left b h

variable {b}

lemma mem_of_dvd (hab : a Ôłú b) (ha : a Ôłł I) : b Ôłł I := by
  obtain ÔčĘc, rflÔčę := hab; exact I.mul_mem_right _ ha

theorem pow_mem_of_mem (ha : a Ôłł I) (n : ÔäĽ) (hn : 0 < n) : a ^ n Ôłł I :=
  Nat.casesOn n (Not.elim (by decide))
    (fun m _hm => (pow_succ a m).symm ÔľŞ I.mul_mem_left (a ^ m) ha) hn

theorem pow_mem_of_pow_mem {m n : ÔäĽ} (ha : a ^ m Ôłł I) (h : m ÔëĄ n) : a ^ n Ôłł I := by
  rw [ÔćÉ Nat.add_sub_of_le h, pow_add]
  exact I.mul_mem_right _ ha

theorem add_pow_mem_of_pow_mem_of_le {m n k : ÔäĽ}
    (ha : a ^ m Ôłł I) (hb : b ^ n Ôłł I) (hk : m + n ÔëĄ k + 1) :
    (a + b) ^ k Ôłł I := by
  rw [add_pow]
  apply I.sum_mem
  intro c _
  apply mul_mem_right
  by_cases h : m ÔëĄ c
  ┬Ě exact I.mul_mem_right _ (I.pow_mem_of_pow_mem ha h)
  ┬Ě refine I.mul_mem_left _ (I.pow_mem_of_pow_mem hb ?_)
    simp only [not_le, Nat.lt_iff_add_one_le] at h
    have hck : c ÔëĄ k := by
      rw [ÔćÉ add_le_add_iff_right 1]
      exact le_trans h (le_trans (Nat.le_add_right _ _) hk)
    rw [Nat.le_sub_iff_add_le hck, ÔćÉ add_le_add_iff_right 1]
    exact le_trans (by rwa [add_comm _ n, add_assoc, add_le_add_iff_left]) hk

theorem add_pow_add_pred_mem_of_pow_mem  {m n : ÔäĽ}
    (ha : a ^ m Ôłł I) (hb : b ^ n Ôłł I) :
    (a + b) ^ (m + n - 1) Ôłł I :=
  I.add_pow_mem_of_pow_mem_of_le ha hb <| by rw [ÔćÉ Nat.sub_le_iff_le_add]

theorem IsPrime.mul_mem_iff_mem_or_mem {I : Ideal ╬▒} (hI : I.IsPrime) :
    ÔłÇ {x y : ╬▒}, x * y Ôłł I Ôćö x Ôłł I ÔłĘ y Ôłł I := @fun x y =>
  ÔčĘhI.mem_or_mem, by
    rintro (h | h)
    exacts [I.mul_mem_right y h, I.mul_mem_left x h]Ôčę

theorem IsPrime.pow_mem_iff_mem {I : Ideal ╬▒} (hI : I.IsPrime) {r : ╬▒} (n : ÔäĽ) (hn : 0 < n) :
    r ^ n Ôłł I Ôćö r Ôłł I :=
  ÔčĘhI.mem_of_pow_mem n, fun hr => I.pow_mem_of_mem hr n hnÔčę

theorem pow_multiset_sum_mem_span_pow [DecidableEq ╬▒] (s : Multiset ╬▒) (n : ÔäĽ) :
    s.sum ^ (Multiset.card s * n + 1) Ôłł
    span ((s.map fun (x : ╬▒) ÔćŽ x ^ (n + 1)).toFinset : Set ╬▒) := by
  induction' s using Multiset.induction_on with a s hs
  ┬Ě simp
  simp only [Finset.coe_insert, Multiset.map_cons, Multiset.toFinset_cons, Multiset.sum_cons,
    Multiset.card_cons, add_pow]
  refine Submodule.sum_mem _ ?_
  intro c _hc
  rw [mem_span_insert]
  by_cases h : n + 1 ÔëĄ c
  ┬Ě refine ÔčĘa ^ (c - (n + 1)) * s.sum ^ ((Multiset.card s + 1) * n + 1 - c) *
      ((Multiset.card s + 1) * n + 1).choose c, 0, Submodule.zero_mem _, ?_Ôčę
    rw [mul_comm _ (a ^ (n + 1))]
    simp_rw [ÔćÉ mul_assoc]
    rw [ÔćÉ pow_add, add_zero, add_tsub_cancel_of_le h]
  ┬Ě use 0
    simp_rw [zero_mul, zero_add]
    refine ÔčĘ_, ?_, rflÔčę
    replace h : c ÔëĄ n := Nat.lt_succ_iff.mp (not_le.mp h)
    have : (Multiset.card s + 1) * n + 1 - c = Multiset.card s * n + 1 + (n - c) := by
      rw [add_mul, one_mul, add_assoc, add_comm n 1, ÔćÉ add_assoc, add_tsub_assoc_of_le h]
    rw [this, pow_add]
    simp_rw [mul_assoc, mul_comm (s.sum ^ (Multiset.card s * n + 1)), ÔćÉ mul_assoc]
    exact mul_mem_left _ _ hs

theorem sum_pow_mem_span_pow {╬╣} (s : Finset ╬╣) (f : ╬╣ Ôćĺ ╬▒) (n : ÔäĽ) :
    (ÔłĹ i Ôłł s, f i) ^ (s.card * n + 1) Ôłł span ((fun i => f i ^ (n + 1)) '' s) := by
  classical
  simpa only [Multiset.card_map, Multiset.map_map, comp_apply, Multiset.toFinset_map,
    Finset.coe_image, Finset.val_toFinset] using pow_multiset_sum_mem_span_pow (s.1.map f) n

theorem span_pow_eq_top (s : Set ╬▒) (hs : span s = ÔŐĄ) (n : ÔäĽ) :
    span ((fun (x : ╬▒) => x ^ n) '' s) = ÔŐĄ := by
  rw [eq_top_iff_one]
  cases' n with n
  ┬Ě obtain rfl | ÔčĘx, hxÔčę := eq_empty_or_nonempty s
    ┬Ě rw [Set.image_empty, hs]
      trivial
    ┬Ě exact subset_span ÔčĘ_, hx, pow_zero _Ôčę
  rw [eq_top_iff_one, span, Finsupp.mem_span_iff_linearCombination] at hs
  rcases hs with ÔčĘf, hfÔčę
  have hf : (f.support.sum fun a => f a * a) = 1 := hf -- Porting note: was `change ... at hf`
  have := sum_pow_mem_span_pow f.support (fun a => f a * a) n
  rw [hf, one_pow] at this
  refine span_le.mpr ?_ this
  rintro _ hx
  simp_rw [Set.mem_image] at hx
  rcases hx with ÔčĘx, _, rflÔčę
  have : span ({(x : ╬▒) ^ (n + 1)} : Set ╬▒) ÔëĄ span ((fun x : ╬▒ => x ^ (n + 1)) '' s) := by
    rw [span_le, Set.singleton_subset_iff]
    exact subset_span ÔčĘx, x.prop, rflÔčę
  refine this ?_
  rw [mul_pow, mem_span_singleton]
  exact ÔčĘf x ^ (n + 1), mul_comm _ _Ôčę

lemma isPrime_of_maximally_disjoint (I : Ideal ╬▒)
    (S : Submonoid ╬▒)
    (disjoint : Disjoint (I : Set ╬▒) S)
    (maximally_disjoint : ÔłÇ (J : Ideal ╬▒), I < J Ôćĺ ┬Č Disjoint (J : Set ╬▒) S) :
    I.IsPrime where
  ne_top' := by
    rintro rfl
    have : 1 Ôłł (S : Set ╬▒) := S.one_mem
    aesop
  mem_or_mem' {x y} hxy := by
    by_contra! rid
    have hx := maximally_disjoint (I ÔŐö span {x}) (Submodule.lt_sup_iff_not_mem.mpr rid.1)
    have hy := maximally_disjoint (I ÔŐö span {y}) (Submodule.lt_sup_iff_not_mem.mpr rid.2)
    simp only [Set.not_disjoint_iff, mem_inter_iff, SetLike.mem_coe, Submodule.mem_sup,
      mem_span_singleton] at hx hy
    obtain ÔčĘsÔéü, ÔčĘiÔéü, hiÔéü, ÔčĘ_, ÔčĘrÔéü, rflÔčę, hrÔéüÔčęÔčę, hsÔéüÔčę := hx
    obtain ÔčĘsÔéé, ÔčĘiÔéé, hiÔéé, ÔčĘ_, ÔčĘrÔéé, rflÔčę, hrÔééÔčęÔčę, hsÔééÔčę := hy
    refine disjoint.ne_of_mem
      (I.add_mem (I.mul_mem_left (iÔéü + x * rÔéü) hiÔéé) <| I.add_mem (I.mul_mem_right (y * rÔéé) hiÔéü) <|
        I.mul_mem_right (rÔéü * rÔéé) hxy)
      (S.mul_mem hsÔéü hsÔéé) ?_
    rw [ÔćÉ hrÔéü, ÔćÉ hrÔéé]
    ring

end Ideal

