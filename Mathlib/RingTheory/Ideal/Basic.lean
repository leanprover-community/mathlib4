/-- An ideal is maximal if it is maximal in the collection of proper ideals. -/
class IsMaximal (I : Ideal ╬▒) : Prop where
  /-- The maximal ideal is a coatom in the ordering on ideals; that is, it is not the entire ring,
  and there are no other proper ideals strictly containing it. -/
  out : IsCoatom I

theorem isMaximal_def {I : Ideal ╬▒} : I.IsMaximal Ôćö IsCoatom I :=
  ÔčĘfun h => h.1, fun h => ÔčĘhÔčęÔčę

theorem IsMaximal.ne_top {I : Ideal ╬▒} (h : I.IsMaximal) : I Ôëá ÔŐĄ :=
  (isMaximal_def.1 h).1

theorem isMaximal_iff {I : Ideal ╬▒} :
    I.IsMaximal Ôćö (1 : ╬▒) Ôłë I Ôłž ÔłÇ (J : Ideal ╬▒) (x), I ÔëĄ J Ôćĺ x Ôłë I Ôćĺ x Ôłł J Ôćĺ (1 : ╬▒) Ôłł J :=
  isMaximal_def.trans <|
    and_congr I.ne_top_iff_one <|
      forall_congr' fun J => by
        rw [lt_iff_le_not_le]
        exact
          ÔčĘfun H x h hxÔéü hxÔéé => J.eq_top_iff_one.1 <| H ÔčĘh, not_subset.2 ÔčĘ_, hxÔéé, hxÔéüÔčęÔčę,
            fun H ÔčĘhÔéü, hÔééÔčę =>
            let ÔčĘx, xJ, xIÔčę := not_subset.1 hÔéé
            J.eq_top_iff_one.2 <| H x hÔéü xI xJÔčę

theorem IsMaximal.eq_of_le {I J : Ideal ╬▒} (hI : I.IsMaximal) (hJ : J Ôëá ÔŐĄ) (IJ : I ÔëĄ J) : I = J :=
  eq_iff_le_not_lt.2 ÔčĘIJ, fun h => hJ (hI.1.2 _ h)Ôčę

instance : IsCoatomic (Ideal ╬▒) := by
  apply CompleteLattice.coatomic_of_top_compact
  rw [ÔćÉ span_singleton_one]
  exact Submodule.singleton_span_isCompactElement 1

theorem IsMaximal.coprime_of_ne {M M' : Ideal ╬▒} (hM : M.IsMaximal) (hM' : M'.IsMaximal)
    (hne : M Ôëá M') : M ÔŐö M' = ÔŐĄ := by
  contrapose! hne with h
  exact hM.eq_of_le hM'.ne_top (le_sup_left.trans_eq (hM'.eq_of_le h le_sup_right).symm)

/-- **Krull's theorem**: if `I` is an ideal that is not the whole ring, then it is included in some
    maximal ideal. -/
theorem exists_le_maximal (I : Ideal ╬▒) (hI : I Ôëá ÔŐĄ) : Ôłâ M : Ideal ╬▒, M.IsMaximal Ôłž I ÔëĄ M :=
  let ÔčĘm, hmÔčę := (eq_top_or_exists_le_coatom I).resolve_left hI
  ÔčĘm, ÔčĘÔčĘhm.1Ôčę, hm.2ÔčęÔčę

variable (╬▒)

/-- Krull's theorem: a nontrivial ring has a maximal ideal. -/
theorem exists_maximal [Nontrivial ╬▒] : Ôłâ M : Ideal ╬▒, M.IsMaximal :=
  let ÔčĘI, ÔčĘhI, _ÔčęÔčę := exists_le_maximal (ÔŐą : Ideal ╬▒) bot_ne_top
  ÔčĘI, hIÔčę

variable {╬▒}

instance [Nontrivial ╬▒] : Nontrivial (Ideal ╬▒) := by
  rcases@exists_maximal ╬▒ _ _ with ÔčĘM, hM, _Ôčę
  exact nontrivial_of_ne M ÔŐĄ hM

/-- If P is not properly contained in any maximal ideal then it is not properly contained
  in any proper ideal -/
theorem maximal_of_no_maximal {P : Ideal ╬▒}
    (hmax : ÔłÇ m : Ideal ╬▒, P < m Ôćĺ ┬ČIsMaximal m) (J : Ideal ╬▒) (hPJ : P < J) : J = ÔŐĄ := by
  by_contra hnonmax
  rcases exists_le_maximal J hnonmax with ÔčĘM, hM1, hM2Ôčę
  exact hmax M (lt_of_lt_of_le hPJ hM2) hM1

theorem span_pair_comm {x y : ╬▒} : (span {x, y} : Ideal ╬▒) = span {y, x} := by
