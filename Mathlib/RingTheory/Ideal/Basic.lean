/-- The set of non-invertible elements of a monoid. -/
def nonunits (╬▒ : Type u) [Monoid ╬▒] : Set ╬▒ :=
  { a | ┬ČIsUnit a }

@[simp]
theorem mem_nonunits_iff [Monoid ╬▒] : a Ôłł nonunits ╬▒ Ôćö ┬ČIsUnit a :=
  Iff.rfl

theorem mul_mem_nonunits_right [CommMonoid ╬▒] : b Ôłł nonunits ╬▒ Ôćĺ a * b Ôłł nonunits ╬▒ :=
  mt isUnit_of_mul_isUnit_right

theorem mul_mem_nonunits_left [CommMonoid ╬▒] : a Ôłł nonunits ╬▒ Ôćĺ a * b Ôłł nonunits ╬▒ :=
  mt isUnit_of_mul_isUnit_left

theorem zero_mem_nonunits [Semiring ╬▒] : 0 Ôłł nonunits ╬▒ Ôćö (0 : ╬▒) Ôëá 1 :=
  not_congr isUnit_zero_iff

@[simp 1001] -- increased priority to appease `simpNF`
theorem one_not_mem_nonunits [Monoid ╬▒] : (1 : ╬▒) Ôłë nonunits ╬▒ :=
  not_not_intro isUnit_one

-- Porting note : as this can be proved by other `simp` lemmas, this is marked as high priority.
@[simp (high)]
theorem map_mem_nonunits_iff [Monoid ╬▒] [Monoid ╬▓] [FunLike F ╬▒ ╬▓] [MonoidHomClass F ╬▒ ╬▓] (f : F)
    [IsLocalHom f] (a) : f a Ôłł nonunits ╬▓ Ôćö a Ôłł nonunits ╬▒ :=
  ÔčĘfun h ha => h <| ha.map f, fun h ha => h <| ha.of_mapÔčę

theorem coe_subset_nonunits [Semiring ╬▒] {I : Ideal ╬▒} (h : I Ôëá ÔŐĄ) : (I : Set ╬▒) ÔŐć nonunits ╬▒ :=
