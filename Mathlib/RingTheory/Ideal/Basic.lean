section DivisionSemiring

variable {K : Type u} [DivisionSemiring K] (I : Ideal K)

namespace Ideal

/-- All ideals in a division (semi)ring are trivial. -/
theorem eq_bot_or_top : I = ÔŐą ÔłĘ I = ÔŐĄ := by
  rw [or_iff_not_imp_right]
  change _ Ôëá _ Ôćĺ _
  rw [Ideal.ne_top_iff_one]
  intro h1
  rw [eq_bot_iff]
  intro r hr
  by_cases H : r = 0; ┬Ě simpa
  simpa [H, h1] using I.mul_mem_left rÔü╗┬╣ hr

variable (K) in
/-- A bijection between (left) ideals of a division ring and `{0, 1}`, sending `ÔŐą` to `0`
and `ÔŐĄ` to `1`. -/
def equivFinTwo [DecidableEq (Ideal K)] : Ideal K Ôëâ Fin 2 where
  toFun := fun I ÔćŽ if I = ÔŐą then 0 else 1
  invFun := ![ÔŐą, ÔŐĄ]
  left_inv := fun I ÔćŽ by rcases eq_bot_or_top I with rfl | rfl <;> simp
  right_inv := fun i ÔćŽ by fin_cases i <;> simp

instance : Finite (Ideal K) := let _i := Classical.decEq (Ideal K); ÔčĘequivFinTwo KÔčę

/-- Ideals of a `DivisionSemiring` are a simple order. Thanks to the way abbreviations work,
this automatically gives an `IsSimpleModule K` instance. -/
instance isSimpleOrder : IsSimpleOrder (Ideal K) :=
  ÔčĘeq_bot_or_topÔčę

theorem eq_bot_of_prime [h : I.IsPrime] : I = ÔŐą :=
  or_iff_not_imp_right.mp I.eq_bot_or_top h.1

theorem bot_isMaximal : IsMaximal (ÔŐą : Ideal K) :=
  ÔčĘÔčĘfun h => absurd ((eq_top_iff_one (ÔŐĄ : Ideal K)).mp rfl) (by rw [ÔćÉ h]; simp), fun I hI =>
      or_iff_not_imp_left.mp (eq_bot_or_top I) (ne_of_gt hI)ÔčęÔčę

end Ideal

end DivisionSemiring

section CommRing

namespace Ideal

theorem mul_sub_mul_mem {R : Type*} [CommRing R] (I : Ideal R) {a b c d : R} (h1 : a - b Ôłł I)
    (h2 : c - d Ôłł I) : a * c - b * d Ôłł I := by
  rw [show a * c - b * d = (a - b) * c + b * (c - d) by rw [sub_mul, mul_sub]; abel]
  exact I.add_mem (I.mul_mem_right _ h1) (I.mul_mem_left _ h2)

end Ideal

end CommRing

