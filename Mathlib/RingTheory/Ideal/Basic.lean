theorem sInf_isPrime_of_isChain {s : Set (Ideal ╬▒)} (hs : s.Nonempty) (hs' : IsChain (┬Ě ÔëĄ ┬Ě) s)
    (H : ÔłÇ p Ôłł s, Ideal.IsPrime p) : (sInf s).IsPrime :=
  ÔčĘfun e =>
    let ÔčĘx, hxÔčę := hs
    (H x hx).ne_top (eq_top_iff.mpr (e.symm.trans_le (sInf_le hx))),
    fun e =>
    or_iff_not_imp_left.mpr fun hx => by
      rw [Ideal.mem_sInf] at hx e ÔŐó
      push_neg at hx
      obtain ÔčĘI, hI, hI'Ôčę := hx
      intro J hJ
      cases' hs'.total hI hJ with h h
      ┬Ě exact h (((H I hI).mem_or_mem (e hI)).resolve_left hI')
      ┬Ě exact ((H J hJ).mem_or_mem (e hJ)).resolve_left fun x => hI' <| h xÔčę

end Ideal

