/-- An ideal `P` of a ring `R` is prime if `P Ôëá R` and `xy Ôłł P Ôćĺ x Ôłł P ÔłĘ y Ôłł P` -/
class IsPrime (I : Ideal ╬▒) : Prop where
  /-- The prime ideal is not the entire ring. -/
  ne_top' : I Ôëá ÔŐĄ
  /-- If a product lies in the prime ideal, then at least one element lies in the prime ideal. -/
  mem_or_mem' : ÔłÇ {x y : ╬▒}, x * y Ôłł I Ôćĺ x Ôłł I ÔłĘ y Ôłł I

theorem isPrime_iff {I : Ideal ╬▒} : IsPrime I Ôćö I Ôëá ÔŐĄ Ôłž ÔłÇ {x y : ╬▒}, x * y Ôłł I Ôćĺ x Ôłł I ÔłĘ y Ôłł I :=
  ÔčĘfun h => ÔčĘh.1, h.2Ôčę, fun h => ÔčĘh.1, h.2ÔčęÔčę

theorem IsPrime.ne_top {I : Ideal ╬▒} (hI : I.IsPrime) : I Ôëá ÔŐĄ :=
  hI.1

theorem IsPrime.mem_or_mem {I : Ideal ╬▒} (hI : I.IsPrime) {x y : ╬▒} : x * y Ôłł I Ôćĺ x Ôłł I ÔłĘ y Ôłł I :=
  hI.2

theorem IsPrime.mem_or_mem_of_mul_eq_zero {I : Ideal ╬▒} (hI : I.IsPrime) {x y : ╬▒} (h : x * y = 0) :
    x Ôłł I ÔłĘ y Ôłł I :=
  hI.mem_or_mem (h.symm ÔľŞ I.zero_mem)

theorem IsPrime.mem_of_pow_mem {I : Ideal ╬▒} (hI : I.IsPrime) {r : ╬▒} (n : ÔäĽ) (H : r ^ n Ôłł I) :
    r Ôłł I := by
  induction n with
  | zero =>
    rw [pow_zero] at H
    exact (mt (eq_top_iff_one _).2 hI.1).elim H
  | succ n ih =>
    rw [pow_succ] at H
    exact Or.casesOn (hI.mem_or_mem H) ih id

theorem not_isPrime_iff {I : Ideal ╬▒} :
    ┬ČI.IsPrime Ôćö I = ÔŐĄ ÔłĘ Ôłâ (x : ╬▒) (_hx : x Ôłë I) (y : ╬▒) (_hy : y Ôłë I), x * y Ôłł I := by
  simp_rw [Ideal.isPrime_iff, not_and_or, Ne, Classical.not_not, not_forall, not_or]
