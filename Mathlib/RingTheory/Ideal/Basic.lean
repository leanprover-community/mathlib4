namespace Ring

variable {R : Type*} [CommSemiring R]

theorem exists_not_isUnit_of_not_isField [Nontrivial R] (hf : ┬ČIsField R) :
    Ôłâ (x : R) (_hx : x Ôëá (0 : R)), ┬ČIsUnit x := by
  have : ┬Č_ := fun h => hf ÔčĘexists_pair_ne R, mul_comm, hÔčę
  simp_rw [isUnit_iff_exists_inv]
  push_neg at this ÔŐó
  obtain ÔčĘx, hx, not_unitÔčę := this
  exact ÔčĘx, hx, not_unitÔčę

theorem not_isField_iff_exists_ideal_bot_lt_and_lt_top [Nontrivial R] :
    ┬ČIsField R Ôćö Ôłâ I : Ideal R, ÔŐą < I Ôłž I < ÔŐĄ := by
  constructor
  ┬Ě intro h
    obtain ÔčĘx, nz, nuÔčę := exists_not_isUnit_of_not_isField h
    use Ideal.span {x}
    rw [bot_lt_iff_ne_bot, lt_top_iff_ne_top]
    exact ÔčĘmt Ideal.span_singleton_eq_bot.mp nz, mt Ideal.span_singleton_eq_top.mp nuÔčę
  ┬Ě rintro ÔčĘI, bot_lt, lt_topÔčę hf
    obtain ÔčĘx, mem, ne_zeroÔčę := SetLike.exists_of_lt bot_lt
    rw [Submodule.mem_bot] at ne_zero
    obtain ÔčĘy, hyÔčę := hf.mul_inv_cancel ne_zero
    rw [lt_top_iff_ne_top, Ne, Ideal.eq_top_iff_one, ÔćÉ hy] at lt_top
    exact lt_top (I.mul_mem_right _ mem)

theorem not_isField_iff_exists_prime [Nontrivial R] :
    ┬ČIsField R Ôćö Ôłâ p : Ideal R, p Ôëá ÔŐą Ôłž p.IsPrime :=
  not_isField_iff_exists_ideal_bot_lt_and_lt_top.trans
    ÔčĘfun ÔčĘI, bot_lt, lt_topÔčę =>
      let ÔčĘp, hp, le_pÔčę := I.exists_le_maximal (lt_top_iff_ne_top.mp lt_top)
      ÔčĘp, bot_lt_iff_ne_bot.mp (lt_of_lt_of_le bot_lt le_p), hp.isPrimeÔčę,
      fun ÔčĘp, ne_bot, PrimeÔčę => ÔčĘp, bot_lt_iff_ne_bot.mpr ne_bot, lt_top_iff_ne_top.mpr Prime.1ÔčęÔčę

/-- Also see `Ideal.isSimpleOrder` for the forward direction as an instance when `R` is a
division (semi)ring.

This result actually holds for all division semirings, but we lack the predicate to state it. -/
theorem isField_iff_isSimpleOrder_ideal : IsField R Ôćö IsSimpleOrder (Ideal R) := by
  cases subsingleton_or_nontrivial R
  ┬Ě exact
      ÔčĘfun h => (not_isField_of_subsingleton _ h).elim, fun h =>
        (false_of_nontrivial_of_subsingleton <| Ideal R).elimÔčę
  rw [ÔćÉ not_iff_not, Ring.not_isField_iff_exists_ideal_bot_lt_and_lt_top, ÔćÉ not_iff_not]
  push_neg
  simp_rw [lt_top_iff_ne_top, bot_lt_iff_ne_bot, ÔćÉ or_iff_not_imp_left, not_ne_iff]
  exact ÔčĘfun h => ÔčĘhÔčę, fun h => h.2Ôčę

/-- When a ring is not a field, the maximal ideals are nontrivial. -/
theorem ne_bot_of_isMaximal_of_not_isField [Nontrivial R] {M : Ideal R} (max : M.IsMaximal)
    (not_field : ┬ČIsField R) : M Ôëá ÔŐą := by
  rintro h
  rw [h] at max
  rcases max with ÔčĘÔčĘ_h1, h2ÔčęÔčę
  obtain ÔčĘI, hIbot, hItopÔčę := not_isField_iff_exists_ideal_bot_lt_and_lt_top.mp not_field
  exact ne_of_lt hItop (h2 I hIbot)

end Ring

namespace Ideal

variable {R : Type u} [CommSemiring R] [Nontrivial R]

theorem bot_lt_of_maximal (M : Ideal R) [hm : M.IsMaximal] (non_field : ┬ČIsField R) : ÔŐą < M := by
  rcases Ring.not_isField_iff_exists_ideal_bot_lt_and_lt_top.1 non_field with ÔčĘI, Ibot, ItopÔčę
  constructor; ┬Ě simp
  intro mle
  apply lt_irrefl (ÔŐĄ : Ideal R)
  have : M = ÔŐą := eq_bot_iff.mpr mle
  rw [ÔćÉ this] at Ibot
  rwa [hm.1.2 I Ibot] at Itop

end Ideal

