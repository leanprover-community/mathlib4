module

public import Mathlib.Algebra.RingQuot
public import Mathlib.RingTheory.GradedAlgebra.Homogeneous.Ideal
public import Mathlib.RingTheory.Ideal.Quotient.Operations

/-! # Graded structures on quotients

## Quotients of graded modules by homogeneous submodules

* Let `R` be a commutative ring, `M` an `R`-module, `P` a submodule of `M`
and `ℳ : ι → Submodule R M` a grading on `M`.

If `P` is homogeneous with respect to `ℳ`, then `M ⧸ P`
is naturally graded by `Submodule.quotSubmodules ℳ P`.

## Quotient of graded rings and algebras

* Let `R` be a commutative semiring, `A` a commutative `R`-algebra
`𝒜 : ι → Submodule R A` a grading on `A` indexed by an additive monoid `ι`.

* `SetLike.Rel.IsPureHomogeneous`:
  a relation `r` is `PureHomogeneous` iff `r a b` implies that
  `a` and `b` are homogeneous of the same degree.

* `SetLike.Rel.IsHomogeneous`: a relation is `Homogeneous` iff
  `r a b` implies that the components of `a` and `b` are related by `r`.

* `RingConGen.Rel.isHomogeneous_of`: the equivalence ring relation
  generated by a homogeneous relation is homogeneous.

* `Rel.quotGradedAlgebra`: if the relation `r` is homogeneous,
  this is the graded algebra structure on `RingQuot r`,
  the corresponding submodules are given by `Rel.quotSubmodules`.

Let `I` be an homogeneous ideal of a commutative ring `A`.

* `Ideal.quotSubmodules`: the graded pieces of `A ⧸ I`.

* `Ideal.quotDecomposition` : the decomposition of `A ⧸ I` as the direct sum of its graded
  components.

* `Ideal.gradedQuotAlg`: the quotient of a graded algebra by a homogeneous ideal,
  as a graded algebra

-/

@[expose] public section

section AdditiveRelations

variable {A : Type*} [AddCommMonoid A] {r : A → A → Prop}
    {ι : Type*}
    {β : ι → Type*} [∀ i, AddCommMonoid (β i)]
    {s : Finset ι}

lemma Finset.rel_sum_sum
    (hr_zero : r 0 0)
    (hr_add : ∀ {a b c d}, r a c → r b d → r (a + b) (c + d))
    {f g : ι → A} (H : ∀ i ∈ s, r (f i) (g i)) :
    r (∑ i ∈ s, f i) (∑ i ∈ s, g i) := by
  classical
  induction s using Finset.induction_on with
  | empty => exact hr_zero
  | @insert i s hi hs =>
    simp only [Finset.sum_insert hi]
    exact hr_add (H _ (Finset.mem_insert_self _ _))
      (hs (fun _ hi ↦ H _ (Finset.mem_insert_of_mem hi)))

lemma DFinsupp.rel_sum_sum
    (hr_zero : r 0 0)
    (hr_add : ∀ {a b c d}, r a c → r b d → r (a + b) (c + d))
    [DecidableEq ι] [∀ i (y : β i), Decidable (y ≠ 0)]
    (h : (i : ι) → (β i →+ A)) (h' : (i : ι) → (β i →+ A))
    {f g : Π₀ i, β i} (H : ∀ i, r (h i (f i)) (h' i (g i))) :
    r (f.sum fun i y => h i y) (g.sum fun i y => h' i y) := by
  rw [sum_of_support_le (Finset.subset_union_left (s₁ := f.support) (s₂ := g.support)),
    sum_of_support_le (Finset.subset_union_right (s₁ := f.support) (s₂ := g.support))]
  exact Finset.rel_sum_sum hr_zero hr_add (fun i _ ↦ H i)

end AdditiveRelations


open DirectSum Function

section Semiring

variable -- {R : Type*} [CommSemiring R]
  {A : Type*} [Semiring A] -- [Algebra R A]
  {ι : Type*} [DecidableEq ι] [AddCommMonoid ι]
  {σ : Type*} [SetLike σ A] [AddSubmonoidClass σ A]
  (𝒜 : ι → σ) (r : A → A → Prop)

/-- The graded components of the multiplication of a graded algebra,
  as biadditive maps. -/
private def gMul (n i j : ι) : 𝒜 i →+ 𝒜 j →+ A where
  toFun x := {
    toFun y   := if i + j = n then x * y else (0 : A)
    map_add' a a' := by split_ifs <;> simp [mul_add]
    map_zero' := by simp }
  map_add' b b' := by ext; split_ifs <;> simp [add_mul]
  map_zero' := by ext; simp

/-- The multiplication by a given element of the direct sum, as an additive map -/
private def gMulRight [DecidableEq A] (n : ι) (y : ⨁ i, 𝒜 i) (i : ι) :
    (𝒜 i) →+ A where
  toFun a       := y.sum (fun j b => gMul 𝒜 n i j a b)
  map_add' a a' := by simp only [map_add, AddMonoidHom.add_apply, DFinsupp.sum_add]
  map_zero'     := by simp only [map_zero, AddMonoidHom.zero_apply, DFinsupp.sum_zero]

/-- The equivalence ring relation generated by a homogeneous relation is homogeneous. -/
theorem RingConGen.Rel.isHomogeneous_of [GradedRing 𝒜] (hr : Rel.IsHomogeneous 𝒜 r) :
    Rel.IsHomogeneous 𝒜 (RingConGen.Rel r) := by
  classical
  intro a b h
  induction h with
  | of x y h => exact fun i =>  RingConGen.Rel.of _ _ (hr h i)
  | refl x => exact fun _ => RingConGen.Rel.refl _
  | symm _ h' => exact fun i => RingConGen.Rel.symm (h' i)
  | trans _ _ k k' => exact fun i => RingConGen.Rel.trans (k i) (k' i)
  | add _ _  k k' =>
    intro i
    simp only [decompose_add]
    exact RingConGen.Rel.add (k i) (k' i)
  | @mul a b c d _ _ k k' =>
    intro n
    simp only [decompose_mul, coe_mul_apply_eq_dfinsuppSum]
    apply DFinsupp.rel_sum_sum
       (RingConGen.Rel.refl 0) (RingConGen.Rel.add) --
       (gMulRight 𝒜 n (decompose 𝒜 c))
       (gMulRight 𝒜 n (decompose 𝒜 d))
    intro i
    apply DFinsupp.rel_sum_sum (RingConGen.Rel.refl 0) (RingConGen.Rel.add)
    intro j
    by_cases hn : i + j = n
    · simp only [gMul, if_pos hn]
      exact RingConGen.Rel.mul (k i) (k' j)
    · simp only [gMul, if_neg hn]
      exact RingConGen.Rel.refl _

/-- The ideal generated by a pure homogeneous relation is homogeneous -/
theorem Rel.IsPureHomogeneous.ideal_ofRel_isHomogeneous [GradedRing 𝒜]
    (hr : Rel.IsPureHomogeneous 𝒜 r) :
    Ideal.IsHomogeneous 𝒜 (Ideal.ofRel r):= by
  apply Ideal.homogeneous_span
  rintro x  ⟨a, b, ⟨h, heq⟩⟩
  obtain ⟨i, hi⟩ := hr h
  use i
  rw [DirectSum.mem_iff_forall_ne_decompose_eq_zero]
  intro j hj
  have := congr(decompose 𝒜 $heq j)
  simp only [decompose_add, add_apply] at this
  have that : decompose 𝒜 a j = 0 := by
    rw [← ZeroMemClass.coe_eq_zero, decompose_of_mem_ne _ hi.1 (Ne.symm hj)]
  have thut : decompose 𝒜 b j = 0 := by
    rw [← ZeroMemClass.coe_eq_zero, decompose_of_mem_ne _ hi.2 (Ne.symm hj)]
  simpa [that, thut] using this

-- used?
/-- The ideal generated by a homogeneous relation is homogeneous -/
theorem Rel.IsHomogeneous.ideal_ofRel_isHomogeneous [h𝒜 : GradedRing 𝒜]
    (hr : Rel.IsHomogeneous 𝒜 r) : Ideal.IsHomogeneous 𝒜 (Ideal.ofRel r):= by
  classical
  let r' (a b : A) : Prop := ∃ i, a ∈ 𝒜 i ∧ b ∈ 𝒜 i ∧ r a b
  suffices Ideal.ofRel r = Ideal.ofRel r' by
    rw [this]
    apply Rel.IsPureHomogeneous.ideal_ofRel_isHomogeneous
    rintro a b ⟨i, h⟩
    exact ⟨i, h.1, h.2.1⟩
  apply le_antisymm
  · intro x hx
    refine Submodule.span_induction ?_ ?_ ?_ ?_ hx
    · rintro x ⟨a, b, h', h⟩
      rw [← h𝒜.left_inv x, ← sum_support_of (Decomposition.decompose' x),
        map_sum]
      apply Ideal.sum_mem
      intro i _
      rw [coeAddMonoidHom_of]
      apply Ideal.subset_span
      use h𝒜.decompose' a i, h𝒜.decompose' b i
      constructor
      · use i
        simp only [Rel.IsHomogeneous] at hr
        simp [hr h' i]
      · simp [← h]
    · simp
    · intro x y _ _
      exact Ideal.add_mem _
    · intro a x _ hx
      simp only [smul_eq_mul]
      apply Ideal.mul_mem_left _ _ hx
  · intro x hx'
    exact Submodule.span_induction
      (fun x ⟨a, b, ⟨i, _, _, h'⟩, h⟩ ↦ Ideal.subset_span ⟨a, b, h', h⟩)
      (Submodule.zero_mem _) (fun _ _ _ _ ↦ Ideal.add_mem _)
      (fun a _ _ ↦ Ideal.mul_mem_left _ a) hx'

end Semiring

namespace Rel

open DirectSum Function

variable {R ι A : Type*} [CommSemiring R] [DecidableEq ι] [CommSemiring A] [Algebra R A]
  (𝒜 : ι → Submodule R A) (rel : A → A → Prop)

/-- The graded pieces of `RingQuot rel`. -/
def quotSubmodules (i : ι) : Submodule R (RingQuot rel) :=
  Submodule.map (RingQuot.mkAlgHom R rel).toLinearMap (𝒜 i)

instance [AddMonoid ι] [SetLike.GradedMonoid 𝒜] :
  SetLike.GradedMonoid (quotSubmodules 𝒜 rel) where
    one_mem :=  ⟨1, SetLike.GradedOne.one_mem, by simp [map_one]⟩
    mul_mem := fun i j x y => by
      rintro ⟨a, ha, rfl⟩ ⟨b, hb, rfl⟩
      exact ⟨a * b, ⟨SetLike.GradedMul.mul_mem ha hb, by simp [map_mul]⟩⟩

/-- The canonical LinearMap from the graded pieces of A to that of RingQuot rel. -/
def quotSubmodulesMap (i : ι) : 𝒜 i →ₗ[R] quotSubmodules 𝒜 rel i :=
  (RingQuot.mkAlgHom R rel).toLinearMap.submoduleMap (𝒜 i)

theorem coeLinearMap_quotSubmodules_comp_lmap_quotSubmodulesMap :
    (coeLinearMap (quotSubmodules 𝒜 rel)).comp (lmap (quotSubmodulesMap 𝒜 rel)) =
      (RingQuot.mkAlgHom R rel).toLinearMap.comp (coeLinearMap 𝒜) := by
  apply linearMap_ext
  intro i
  ext ⟨x, hx⟩
  simp only [quotSubmodulesMap, LinearMap.coe_comp, comp_apply, AlgHom.toLinearMap_apply, lmap_lof]
  simp only [lof_eq_of, coeLinearMap_of]
  rfl

@[simp]
theorem coeLinearMap_quotSubmodules_lmap_quotSubmodulesMap_apply (x) :
    coeLinearMap (quotSubmodules 𝒜 rel) (lmap (quotSubmodulesMap 𝒜 rel) x) =
      (RingQuot.mkAlgHom R rel) (coeLinearMap 𝒜 x) := by
  let e := coeLinearMap_quotSubmodules_comp_lmap_quotSubmodulesMap 𝒜 rel
  simp only [LinearMap.ext_iff, LinearMap.comp_apply, AlgHom.toLinearMap_apply] at e
  apply e

section AddCommMonoid

variable [AddCommMonoid ι] [GradedAlgebra 𝒜]

lemma lmap_quotSubmodulesMap_apply (i : ι) (a : ⨁ i, 𝒜 i) :
    ((lmap (quotSubmodulesMap 𝒜 rel)) a) i =
      RingQuot.mkAlgHom R rel (((decompose 𝒜) (coeLinearMap 𝒜 a)) i) := by
  have : (decompose 𝒜) ((DirectSum.coeLinearMap 𝒜) a) = a := DirectSum.Decomposition.right_inv a
  simp only [lmap_apply, quotSubmodulesMap, this]
  congr

theorem coeLinearMap_quotSubmodules_surjective :
    Surjective (coeLinearMap (quotSubmodules 𝒜 rel)) := by
  intro x
  obtain ⟨a, rfl⟩ := RingQuot.mkAlgHom_surjective R rel x
  let e : (coeLinearMap 𝒜) ((decomposeAlgEquiv 𝒜).toLinearMap a) = a :=
    DirectSum.Decomposition.left_inv a
  use (lmap (quotSubmodulesMap 𝒜 rel)) ((decomposeAlgEquiv 𝒜).toLinearMap a)
  conv_rhs => rw [← e]
  apply coeLinearMap_quotSubmodules_lmap_quotSubmodulesMap_apply

theorem coeLinearMap_quotSubmodules_injective (hrel : Rel.IsHomogeneous 𝒜 rel) :
    Injective (coeLinearMap (quotSubmodules 𝒜 rel)) := by
  have surj : Surjective (lmap (quotSubmodulesMap 𝒜 rel)) := by
    rw [lmap_surjective]
    rintro i ⟨x, ⟨a, ha, rfl⟩⟩
    exact ⟨⟨a, ha⟩, rfl⟩
  intro x y hxy
  obtain ⟨a, ha, rfl⟩ := surj x
  obtain ⟨b, hb, rfl⟩ := surj y
  simp only [coeLinearMap_quotSubmodules_lmap_quotSubmodulesMap_apply] at hxy
  ext i
  suffices (RingQuot.mkAlgHom R rel) ((Decomposition.decompose' ((coeLinearMap 𝒜) a)) i : 𝒜 i) =
    (RingQuot.mkAlgHom R rel) ((Decomposition.decompose' ((coeLinearMap 𝒜) b)) i : 𝒜 i) by
    simpa [Decomposition.decompose'_eq, ← lmap_quotSubmodulesMap_apply]
      using this
  replace hxy : RingConGen.Rel rel (coeLinearMap 𝒜 a) (coeLinearMap 𝒜 b) := by
    simpa [← AlgHom.coe_toRingHom, RingQuot.mkAlgHom_coe, RingQuot.mkRingHom,
      Quot.eq, RingQuot.eqvGen_rel_eq] using hxy
  simpa [← AlgHom.coe_toRingHom, RingQuot.mkAlgHom_coe, RingQuot.mkRingHom,
    Quot.eq, RingQuot.eqvGen_rel_eq]
    using RingConGen.Rel.isHomogeneous_of 𝒜 _ hrel hxy i

lemma coeLinearMap_quotSubmodules_bijective (hrel : Rel.IsHomogeneous 𝒜 rel) :
    Bijective (coeLinearMap (quotSubmodules 𝒜 rel)) :=
  ⟨coeLinearMap_quotSubmodules_injective 𝒜 rel hrel, coeLinearMap_quotSubmodules_surjective 𝒜 rel⟩

/-- The decomposition of the quotient ring is an internal direct sum -/
lemma quotDecomposition_IsInternal (hrel : Rel.IsHomogeneous 𝒜 rel) :
    IsInternal (quotSubmodules 𝒜 rel) :=
  coeLinearMap_quotSubmodules_bijective 𝒜 rel hrel

/-- The decomposition of `RingQuot rel` as a direct sum of its graded pieces. -/
@[reducible]
noncomputable def quotDecomposition [GradedAlgebra 𝒜] (hrel : Rel.IsHomogeneous 𝒜 rel) :
    Decomposition (quotSubmodules 𝒜 rel) where
  decompose' := invFun (coeLinearMap (quotSubmodules 𝒜 rel))
  left_inv   := rightInverse_invFun (coeLinearMap_quotSubmodules_surjective 𝒜 rel)
  right_inv  := leftInverse_invFun (coeLinearMap_quotSubmodules_injective 𝒜 rel hrel)

/-- The graded algebra structure on `RingQuot rel`. -/
@[reducible]
noncomputable def quotGradedAlgebra [GradedAlgebra 𝒜] (hrel : Rel.IsHomogeneous 𝒜 rel) :
    GradedAlgebra (quotSubmodules 𝒜 rel) where
  toGradedMonoid  := inferInstance
  toDecomposition := quotDecomposition 𝒜 rel hrel

end AddCommMonoid

end Rel

section Submodule

variable {R : Type*} [CommRing R]
  {M : Type*} [AddCommGroup M] [Module R M]
  {ι : Type*} (ℳ : ι → Submodule R M)
  (P : Submodule R M)

/-- The graded pieces of `M ⧸ P` under a graduation `ℳ` of `M`.

They are only meaningful when `P` is homogeneous with respect to `ℳ` -/
def Submodule.quotSubmodules (i : ι) : Submodule R (M ⧸ P) :=
  (ℳ i).map P.mkQ

/-- The canonical `LinearMap` from the graded pieces of `M` to those of `M ⧸ P`

It is only meaningful when `I` is homogeneous -/
def Submodule.quotCompMap (i : ι) : ℳ i →ₗ[R] (quotSubmodules ℳ P i) where
  toFun u := ⟨P.mkQ u, by
    rw [quotSubmodules, Submodule.mem_map]
    exact ⟨u, u.prop, rfl⟩⟩
  map_add' _ _ := by simp
  map_smul' := by simp

private theorem Submodule.quotDecomposition_left_inv'_aux [DecidableEq ι] :
    coeLinearMap (P.quotSubmodules ℳ) ∘ₗlmap (P.quotCompMap ℳ) =
      P.mkQ ∘ₗcoeLinearMap ℳ := by
  ext i x
  simp only [LinearMap.comp_apply, lof_eq_of]
  rfl

variable {ℳ P} in
theorem Submodule.mem_quotSubmodules_iff {i : ι} {g : M ⧸ P} :
    g ∈ P.quotSubmodules ℳ i ↔ ∃ m ∈ ℳ i, P.mkQ m = g := by
  simp [Submodule.quotSubmodules]

variable [DecidableEq ι] [DirectSum.Decomposition ℳ] (hP : P.IsHomogeneous ℳ)

/-- The decomposition at the higher level -/
def Submodule.quotDecomposeLaux :
    M →ₗ[R] ⨁ i, P.quotSubmodules ℳ i :=
  lmap (P.quotCompMap ℳ) ∘ₗ (decomposeLinearEquiv ℳ)

include hP in
theorem Submodule.quotDecomposeLaux_of_mem_eq_zero {x : M} (hx : x ∈ P) (i : ι) :
    (P.quotDecomposeLaux ℳ) x i = 0 := by
  rw [Submodule.quotDecomposeLaux, LinearMap.comp_apply, lmap_apply, quotCompMap]
  simp only [LinearMap.coe_mk, AddHom.coe_mk, mk_eq_zero, ← LinearMap.mem_ker, ker_mkQ]
  exact hP i hx

include hP in
theorem Submodule.quotDecomposeLaux_ker :
    P ≤ LinearMap.ker (P.quotDecomposeLaux ℳ) :=
  fun _ hx =>  LinearMap.mem_ker.mpr (DFinsupp.ext (P.quotDecomposeLaux_of_mem_eq_zero ℳ hP hx))

/-- The `R`-linear map from `M ⧸ P` to the direct sum of its graded components. -/
def Submodule.quotDecompose :
    M ⧸ P →ₗ[R] DirectSum ι fun i ↦ P.quotSubmodules ℳ i :=
  @Submodule.liftQ R M _ _ _ P R (⨁ i, P.quotSubmodules ℳ i)
    _ _ instModule (RingHom.id R) (quotDecomposeLaux ℳ P)
    (P.quotDecomposeLaux_ker ℳ hP)

theorem Submodule.quotDecomposeLaux_apply_mk (m : M) :
    P.quotDecompose ℳ hP (P.mkQ m) = P.quotDecomposeLaux ℳ m :=
  @Submodule.liftQ_apply R M _ _ _ P R
    (⨁ i, P.quotSubmodules ℳ i) _ _ instModule _ (quotDecomposeLaux ℳ P) _ m

theorem Submodule.quotDecomposition_left_inv' :
    LeftInverse (coeLinearMap (P.quotSubmodules ℳ)) (P.quotDecompose ℳ hP) := by
  rename_i _ _ hℳ
  intro x
  obtain ⟨(m : M), rfl⟩ := Submodule.mkQ_surjective P x
  conv_lhs =>
    rw [quotDecomposeLaux_apply_mk, quotDecomposeLaux, LinearMap.comp_apply]
    simp only [AlgEquiv.toLinearMap_apply, ← LinearMap.comp_apply]
  rw [← LinearMap.comp_assoc, Submodule.quotDecomposition_left_inv'_aux]
  simp only [LinearMap.comp_apply]
  conv_rhs =>
    rw [← hℳ.left_inv m]
    simp only [← LinearMap.comp_apply, Decomposition.decompose'_eq]
  rfl

theorem Submodule.quotDecomposition_left_inv :
    LeftInverse (DirectSum.coeAddMonoidHom (P.quotSubmodules ℳ)) (P.quotDecompose ℳ hP) :=
  P.quotDecomposition_left_inv' ℳ hP

theorem Submodule.quotDecomposition_right_inv' :
    RightInverse (coeLinearMap (P.quotSubmodules ℳ)) (P.quotDecompose ℳ hP) := by
  rw [rightInverse_iff_comp, ← LinearMap.coe_comp, ← @LinearMap.id_coe R]
  apply congr_arg
  apply linearMap_ext
  intro i
  ext1 y
  obtain ⟨x, hx, hxy⟩ := y.prop
  simp only [LinearMap.coe_comp, comp_apply, LinearMap.id_comp, lof_eq_of, coeLinearMap_of]
  rw [← hxy]
  simp only [Submodule.quotDecomposeLaux_apply_mk, Submodule.quotDecomposeLaux]
  simp only [LinearMap.coe_comp, comp_apply, LinearEquiv.coe_coe]
  rw [DirectSum.decomposeLinearEquiv_apply, ← Subtype.coe_mk x hx, decompose_coe, lmap_of]
  congr
  rw [← Subtype.coe_inj, Subtype.coe_mk, ← hxy]
  simp [quotCompMap]

theorem Submodule.quotDecomposition_right_inv :
    RightInverse (DirectSum.coeAddMonoidHom (P.quotSubmodules ℳ)) (P.quotDecompose ℳ hP) :=
  P.quotDecomposition_right_inv' ℳ hP

include hP in
/-- The decomposition of `M ⧸ P` as the direct sum of its graded components. -/
@[reducible]
def Submodule.quotDecomposition : Decomposition (P.quotSubmodules ℳ) where
  decompose' := P.quotDecompose ℳ hP
  left_inv   := P.quotDecomposition_left_inv ℳ hP
  right_inv  := P.quotDecomposition_right_inv ℳ hP

end Submodule

section Ideal

variable {R : Type*} [CommRing R]
  {A : Type*} [CommRing A] [Algebra R A]
  {ι : Type*} (𝒜 : ι → Submodule R A)
  (I : Ideal A)

/-- The graded pieces of `A ⧸ I` under a graduation `𝒜` of `A`.

They are only meaningful when `I` is homogeneous -/
def Ideal.quotSubmodules (i : ι) : Submodule R (A ⧸ I) :=
  Submodule.quotSubmodules 𝒜 (I.restrictScalars R) i

/-- The canonical `LinearMap` from the graded pieces of `A` to those of `A/I`

It is only meaningful when `I` is homogeneous -/
def Ideal.quotCompMap (i : ι) : 𝒜 i →ₗ[R] (quotSubmodules 𝒜 I i) :=
  Submodule.quotCompMap 𝒜 (I.restrictScalars R) i

private theorem Ideal.quotDecomposition_left_inv'_aux [DecidableEq ι] :
    coeLinearMap (I.quotSubmodules 𝒜) ∘ₗlmap (I.quotCompMap 𝒜) =
      (I.restrictScalars R).mkQ ∘ₗcoeLinearMap 𝒜 :=
  Submodule.quotDecomposition_left_inv'_aux 𝒜 (I.restrictScalars R)

variable {𝒜 I} in
theorem Ideal.mem_quotSubmodule_iff {i : ι} {g : A ⧸ I} :
    g ∈ I.quotSubmodules 𝒜 i ↔ ∃ a ∈ 𝒜 i, Ideal.Quotient.mk I a = g :=
  Submodule.mem_quotSubmodules_iff

variable [DecidableEq ι] [AddMonoid ι] [GradedAlgebra 𝒜] (hI : I.IsHomogeneous 𝒜)

variable {𝒜 I} in
theorem Ideal.isHomogeneous_restrictScalars_iff :
    I.IsHomogeneous 𝒜 ↔ (I.restrictScalars R).IsHomogeneous 𝒜 :=
  Iff.rfl

/-- The decomposition at the higher level -/
def Ideal.quotDecomposeLaux :
    A →ₗ[R] ⨁ i, I.quotSubmodules 𝒜 i :=
  Submodule.quotDecomposeLaux 𝒜 (I.restrictScalars R)

include hI in
theorem Ideal.quotDecomposeLaux_of_mem_eq_zero {x : A} (hx : x ∈ I) (i : ι) :
    (I.quotDecomposeLaux 𝒜) x i = 0 := by
  apply Submodule.quotDecomposeLaux_of_mem_eq_zero
  · simpa
  · rwa [Submodule.restrictScalars_mem R I x]

include hI in
theorem Ideal.quotDecomposeLaux_ker :
    I.restrictScalars R ≤ LinearMap.ker (I.quotDecomposeLaux 𝒜) := fun x hx ↦ by
  simp only [Submodule.restrictScalars_mem] at hx
  simp only [LinearMap.mem_ker]
  apply Submodule.quotDecomposeLaux_ker 𝒜 (I.restrictScalars R) <;> simpa
  -- fun _ hx =>  LinearMap.mem_ker.mpr (DFinsupp.ext (I.quotDecomposeLaux_of_mem_eq_zero 𝒜 hI hx))

/-- The `R`-linear map from `A/I` to the direct sum of its graded components. -/
def Ideal.quotDecompose :
    A ⧸ I →ₗ[R] DirectSum ι fun (i : ι) ↦ (I.quotSubmodules 𝒜 i) :=
  @Submodule.liftQ R A _ _ _ (I.restrictScalars R) R (⨁ i, I.quotSubmodules 𝒜 i)
    _ _ instModule (RingHom.id R) (quotDecomposeLaux 𝒜 I)
    (I.quotDecomposeLaux_ker 𝒜 hI)

theorem Ideal.quotDecomposeLaux_apply_mk (a : A) :
    I.quotDecompose 𝒜 hI (Ideal.Quotient.mk I a) = I.quotDecomposeLaux 𝒜 a :=
  @Submodule.liftQ_apply R A _ _ _ (I.restrictScalars R) R
    (⨁ i, I.quotSubmodules 𝒜 i) _ _ instModule _ (quotDecomposeLaux 𝒜 I) _ a

theorem Ideal.quotDecomposition_left_inv' :
    LeftInverse (coeLinearMap (I.quotSubmodules 𝒜)) (I.quotDecompose 𝒜 hI) := by
  apply Submodule.quotDecomposition_left_inv'
  simpa

theorem Ideal.quotDecomposition_left_inv :
    LeftInverse (DirectSum.coeAddMonoidHom (I.quotSubmodules 𝒜)) (I.quotDecompose 𝒜 hI) :=
  I.quotDecomposition_left_inv' 𝒜 hI

theorem Ideal.quotDecomposition_right_inv' :
    RightInverse (coeLinearMap (I.quotSubmodules 𝒜)) (I.quotDecompose 𝒜 hI) := by
  apply Submodule.quotDecomposition_right_inv'
  simpa

theorem Ideal.quotDecomposition_right_inv :
    RightInverse (DirectSum.coeAddMonoidHom (I.quotSubmodules 𝒜)) (I.quotDecompose 𝒜 hI) :=
  I.quotDecomposition_right_inv' 𝒜 hI

include hI in
/-- The decomposition of `A ⧸ I` as the direct sum of its graded components. -/
@[reducible]
def Ideal.quotDecomposition : Decomposition (I.quotSubmodules 𝒜) :=
  Submodule.quotDecomposition 𝒜 (Submodule.restrictScalars R I) hI

/-- The quotient of a graded algebra by a homogeneous ideal, as a graded algebra -/
@[reducible]
def Ideal.gradedQuotAlg :
  GradedAlgebra (I.quotSubmodules 𝒜) where
  toDecomposition := I.quotDecomposition 𝒜 hI
  toGradedMonoid :=
    { one_mem := by
        rw [Ideal.quotSubmodules]
        exact ⟨1, SetLike.one_mem_graded 𝒜, rfl⟩
      mul_mem := fun i j gi gj hgi hgj ↦ by
        obtain ⟨ai, hai, rfl⟩ := hgi
        obtain ⟨aj, haj, rfl⟩ := hgj
        have (a : A) : (I.restrictScalars R).mkQ a = Ideal.Quotient.mk I a := rfl
        exact ⟨ai * aj, ⟨SetLike.mul_mem_graded hai haj, by simp only [this, map_mul]⟩⟩ }

end Ideal
