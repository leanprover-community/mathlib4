/-!
# Order of vanishing

This file defines the order of vanishing of an element of a ring as the length of the quotient of
the ring by the ideal generated by that element. We also define the extension of this notion to the
field of fractions
-/
@[expose] public section

open LinearMap Pointwise IsLocalization Ideal WithZero

variable {R : Type*} {M : Type*} [AddCommMonoid M]

namespace Ring

variable (R) [Ring R]
/--
Order of vanishing function for elements of a ring.
-/
@[stacks 02MD]
noncomputable
def ord (x : R) : ‚Ąē‚ąě := Module.length R (R ‚ßł Ideal.span {x})

@[simp]
lemma ord_one : ord R 1 = 0 := by
  simp_all [ord,
    Ideal.span_singleton_one, Submodule.Quotient.subsingleton_iff]

end Ring

variable [CommRing R] [Module R M]

/--
The map `R ‚ßł I ‚Üí‚āó[R] R ‚ßł (a ‚ÄĘ I)` defined by multiplication by `a`
-/
def Ideal.mulQuot (a : R) (I : Ideal R) :
    R ‚ßł I ‚Üí‚āó[R] R ‚ßł (a ‚ÄĘ I) :=
  Submodule.mapQ _ _ (LinearMap.mul R R a) (Submodule.le_comap_map _ _)

/--
The map `R ‚ßł I ‚Üí‚āó[R] R ‚ßł (a ‚ÄĘ I)` defined by multiplication by `a` is injective if `a` is
a nonzero divisor.
-/
lemma Ideal.mulQuot_injective {a : R} (I : Ideal R) (ha : a ‚ąą nonZeroDivisors R) :
    Function.Injective (Ideal.mulQuot a I) := by
  simp only [mulQuot, Submodule.mapQ, ‚Üź ker_eq_bot]
  apply Submodule.ker_liftQ_eq_bot'
  apply le_antisymm
  ¬∑ have : Submodule.map (mul R R a) I = a ‚ÄĘ I := rfl
    rw [le_ker_iff_map, Submodule.map_comp, this, Submodule.mkQ_map_self]
  ¬∑ have m : I = Submodule.comap (mul R R a) (a ‚ÄĘ I) := by
      ext b
      exact (Submodule.mul_mem_smul_iff ha).symm
    simp [‚Üź m, ker_comp]

/--
The quotient map `(R ‚ßł a ‚ÄĘ I) ‚Üí‚āó[R] (R ‚ßł Ideal.span {a})`.
-/
def Ideal.quotOfMul (a : R) (I : Ideal R) :
    (R ‚ßł a ‚ÄĘ I) ‚Üí‚āó[R] (R ‚ßł Ideal.span {a}) :=
  Submodule.factor <| Submodule.singleton_set_smul I a ‚Ėł Submodule.smul_le_span {a} I

/--
The quotient map `(R ‚ßł a ‚ÄĘ I) ‚Üí‚āó[R] (R ‚ßł Ideal.span {a})` is surjective.
-/
lemma Ideal.quotOfMul_surjective {a : R} (I : Ideal R) :
    Function.Surjective (Ideal.quotOfMul a I) := by
  simp only [Ideal.quotOfMul]
  exact Submodule.factor_surjective <|
    Submodule.singleton_set_smul I a ‚Ėł Submodule.smul_le_span {a} I

/--
The sequence `R ‚ßł I ‚Üí‚āó[R] R ‚ßł (a ‚ÄĘ I) ‚Üí‚āó[R] R ‚ßł (Ideal.span {a})` given by multiplication
by `a` then quotienting by the ideal generated by `a` is exact.
-/
lemma Ideal.exact_mulQuot_quotOfMul {a : R} (I : Ideal R) :
    Function.Exact (Ideal.mulQuot a I) (Ideal.quotOfMul a I) := by
  simp only [exact_iff]
  have : ker (Ideal.quotOfMul a I) = a ‚ÄĘ ‚ä§ := by
    simp only [‚Üź submodule_span_eq, quotOfMul, Submodule.factor, Submodule.mapQ, comp_id,
      Submodule.ker_liftQ, Submodule.ker_mkQ, Submodule.map_span, Submodule.mkQ_apply,
      Quotient.mk_eq_mk, Set.image_singleton, Quotient.smul_top]
  simp [this, Ideal.mulQuot, Submodule.mapQ.eq_1, Submodule.range_liftQ,
    range_comp, Ideal.Quotient.smul_top, ‚Üź Ideal.submodule_span_eq, LinearMap.map_span]

namespace Ring
variable (R)
/--
The order of vanishing of `a * b` is the order of vanishing of `a` plus the order
of vanishing of `b`.
-/
theorem ord_mul {a b : R} (hb : b ‚ąą nonZeroDivisors R) :
    ord R (a * b) = ord R a + ord R b := by
  have := Module.length_eq_add_of_exact (Ideal.mulQuot b (Ideal.span {a}))
          (Ideal.quotOfMul b (Ideal.span {a})) (Ideal.mulQuot_injective (Ideal.span {a}) hb)
          (Ideal.quotOfMul_surjective (Ideal.span {a}))
          (Ideal.exact_mulQuot_quotOfMul (Ideal.span {a}))
  simp only [Ring.ord, ‚Üź this]
  have lem : (({b} : Set R) ‚ÄĘ Ideal.span {a}) = Ideal.span {b * a} := by
    simp [‚Üź Ideal.submodule_span_eq, Submodule.set_smul_span]
  have : (({b} : Set R) ‚ÄĘ Ideal.span {a}) = b ‚ÄĘ Ideal.span {a} := Submodule.singleton_set_smul
    (Ideal.span {a}) b
  rw [this] at lem
  rw [lem, mul_comm]

/--
Variation of `ord_mul` where the user has to show the first input is a non
zero divisor rather than the second.
-/
lemma ord_mul' {a b : R} (ha : a ‚ąą nonZeroDivisors R) :
    ord R (a * b) = ord R a + ord R b := by
  rw [mul_comm, ord_mul R ha, add_comm]

/--
The order of zero is `Module.length R R`. Use this when it is necessary to unfold the definition
of `ord` to avoid annoyances of working with `R ‚ßł Ideal.span {0}` instead of `R`.
-/
lemma ord_zero : ord R 0 = Module.length R R := by
  simp only [ord]
  let m := (Submodule.quotEquivOfEqBot (Ideal.span {0} : Submodule R R) (span_singleton_zero))
  exact le_antisymm (Module.length_le_of_injective m m.injective)
      (Module.length_le_of_surjective m m.surjective)

variable {R}
/--
For `x : R` a non zero divisor, `ord R (x ^ n) = n ‚ÄĘ ord R x`.
-/
@[simp]
theorem ord_pow {x : R} (hx : x ‚ąą nonZeroDivisors R) (n : ‚Ąē) : ord R (x ^ n) = n ‚ÄĘ ord R x := by
  induction n with
  | zero => simp
  | succ n ih =>
    rw [pow_succ, ord_mul, ih, succ_nsmul]
    exact hx

@[simp]
lemma ord_mul_of_isUnit_left {a : R} (h : IsUnit a) (x : R) : ord R (a * x) = ord R x := by
  rw [ord, ord, Ideal.span_singleton_mul_left_unit h x]

@[simp]
lemma ord_mul_of_isUnit_right {a : R} (h : IsUnit a) (x : R) : ord R (x * a) = ord R x := by
  rw [ord, ord, Ideal.span_singleton_mul_right_unit h x]

lemma ord_eq_of_associated {x y : R} (h : Associated x y) : ord R x = ord R y := by
  obtain ‚ü®a, rfl‚ü© := h
  simp

@[simp]
lemma ord_neg (x : R) : ord R (-x) = ord R x:= by
    simp [ord_eq_of_associated (x := -x) (y := x) (by simp)]

/--
In an `S` algebra `R`, the order of vanishing of `x : R` is equal to the order of vanishing
of `a ‚ÄĘ x` for `a` a unit in `S`.
-/
@[simp]
lemma ord_smul_of_isUnit {S : Type*} [CommRing S] [Algebra S R]
    {a : S} (h : IsUnit a) (x : R) : ord R (a ‚ÄĘ x) = ord R x := by
  rw [Algebra.smul_def a x]
  exact ord_mul_of_isUnit_left (RingHom.isUnit_map (algebraMap S R) h) x

/-
Note that the order here is the order on `‚Ąē‚ąě` where `‚ąě` is a top element, rather than the order on
`‚Ą§ŠĶź‚Āį` which also comes up when working with orders of vanishing.
-/
lemma ord_le_ord_mul (a : R) (x : R) : ord R x ‚Č§ ord R (a * x) := by
  simp only [ord]
  suffices Ideal.span {a * x} ‚Č§ Ideal.span {x} by
    let g : (R ‚ßł Ideal.span {a * x}) ‚Üí‚āó[R] (R ‚ßł Ideal.span {x}) := Submodule.factor this
    refine Module.length_le_of_surjective (Submodule.factor this) (Submodule.factor_surjective this)
  rw [Ideal.span_singleton_le_span_singleton]
  exact Dvd.intro_left (Algebra.algebraMap a) rfl

lemma ord_le_ord_of_dvd {a x : R} (h : a ‚ą£ x) : ord R a ‚Č§ ord R x := by
  obtain ‚ü®b, rfl‚ü© := h
  rw [mul_comm]
  exact ord_le_ord_mul b a

/--
In an `S` algebra `R`, the order of vanishing of `x : R` is less than or equal
to the order of vanishing of `a ‚ÄĘ x` for any `a : S`. One should note that the order here
is the order on `‚Ąē‚ąě` where `‚ąě` is a top element.
-/
lemma ord_le_smul {S : Type*} [CommRing S] [Algebra S R] (a : S) (x : R) :
    ord R x ‚Č§ ord R (a ‚ÄĘ x) := by simp [Algebra.smul_def, ord_le_ord_mul]

/--
The order of vanishing of a unit is `0`.
-/
@[simp]
lemma ord_of_isUnit {x : R} (hx : IsUnit x) : ord R x = 0 := by
  simpa using ord_smul_of_isUnit hx (1 : R)

section IsPrincipalIdealRing

variable [IsPrincipalIdealRing R]

/--
In a principal ideal ring, the order of vanishing of an irreducible element is `1`.
-/
theorem ord_of_irreducible {ŌĖ : R} (hŌĖ : Irreducible ŌĖ) : ord R ŌĖ = 1 := by
  rw [Ring.ord, Module.length_eq_one_iff]
  have : (Ideal.span {ŌĖ}).IsMaximal :=
    PrincipalIdealRing.isMaximal_of_irreducible hŌĖ
  rw [isSimpleModule_iff_isSimpleModule_of_algebraMap_surjective (S := R ‚ßł Ideal.span {ŌĖ})
    Ideal.Quotient.mk_surjective]
  letI := Ideal.Quotient.field (Ideal.span {ŌĖ})
  exact instIsSimpleModule _

end IsPrincipalIdealRing

variable (R)

open Classical in
/--
Zero-preserving monoid homomorphism from a nontrivial commutative ring `R` to `‚Ą§ŠĶź‚Āį`.

Note that we cannot just use `fun x ‚Ü¶ ord R x` without further assumptions on `R`.
This is because if R is finite length, then ord R 0 will be some non-top value,
meaning in this case `0` will not be mapped to `‚ä§`.
-/
@[stacks 02MD]
noncomputable
def ordMonoidWithZeroHom [Nontrivial R] : R ‚Üí*‚āÄ ‚Ą§ŠĶź‚Āį where
  toFun x := if x ‚ąą nonZeroDivisors R
             then (ENat.recTopCoe 0 (WithZero.coe <| Multiplicative.ofAdd ¬∑) (Ring.ord R x))
             else 0
  map_zero' := by simp [nonZeroDivisors, exists_ne]
  map_one' := by simp [nonZeroDivisors]
  map_mul' := by
    intro x y
    split_ifs with _ _ b
    ¬∑ rw [ord_mul _ b]
      generalize ord R x = x'
      generalize ord R y = y'
      cases x' <;> cases y'
      on_goal 4 =>
        simp only [‚Üź ENat.coe_add, ENat.recTopCoe_coe, Nat.cast_add (R := ‚Ą§),
          ofAdd_add, WithZero.coe_mul]
      all_goals simp
    all_goals simp_all [mul_mem_nonZeroDivisors]

lemma ordMonoidWithZeroHom_eq_zero_iff [Nontrivial R] (y : nonZeroDivisors R) :
    ordMonoidWithZeroHom R y = 0 ‚ÜĒ ord R y = ‚ä§ := by
  simp only [ordMonoidWithZeroHom, MonoidWithZeroHom.coe_mk, ZeroHom.coe_mk, SetLike.coe_mem,
    ‚ÜďreduceIte]
  generalize ord R y = k
  cases k
  all_goals simp

variable {R} in
/--
If `x` is a non zero divisor, `ordMonoidWithZeroHom` is equal to the canonical embedding
of `Ring.ord R x` into `WithZero (Multiplicative ‚Ą§)`.
-/
theorem ordMonoidWithZeroHom_eq_ord [Nontrivial R] {x : R} (h : x ‚ąą nonZeroDivisors R) :
    ordMonoidWithZeroHom R x =
  (ENat.recTopCoe 0 (WithZero.coe <| Multiplicative.ofAdd ¬∑) (Ring.ord R x)) := dif_pos h

lemma ordMonoidWithZeroHom_eq_coe
    [Nontrivial R] {x : R} (hx : x ‚ąą nonZeroDivisors R) {n : ‚Ąē} (hn : Ring.ord R x = n) :
    ordMonoidWithZeroHom R x = Multiplicative.ofAdd (n : ‚Ą§) := by
  simp [ordMonoidWithZeroHom_eq_ord hx, hn]

variable {R} in
/--
If `x` is not a non zero divisor, `ordMonoidWithZeroHom` is equal to `0`.
-/
@[simp]
theorem ordMonoidWithZeroHom_eq_zero [Nontrivial R] {x : R} (h : x ‚ąČ nonZeroDivisors R) :
    ordMonoidWithZeroHom R x = 0 := dif_neg h

set_option backward.isDefEq.respectTransparency false in
/--
The quotient of a Noetherian ring of krull dimension less than or equal to `1` by a principal ideal
is of finite length.
-/
theorem _root_.isFiniteLength_quotient_span_singleton [IsNoetherianRing R]
    [Ring.KrullDimLE 1 R] {x : R} (hx : x ‚ąą nonZeroDivisors R) :
    IsFiniteLength R (R ‚ßł Ideal.span {x}) := by
  rw [isFiniteLength_iff_isNoetherian_isArtinian]
  suffices IsArtinianRing (R ‚ßł Ideal.span {x}) from
    ‚ü®isNoetherian_quotient (Ideal.span {x}),
      isArtinian_of_surjective_algebraMap (Ideal.Quotient.mk_surjective (I := .span {x}))‚ü©
  rw [isArtinianRing_iff_krullDimLE_zero, Ring.KrullDimLE, Order.krullDimLE_iff,
    ‚Üź WithBot.add_le_add_iff_right' (c := 1) (by simp) (WithBot.coe_eq_coe.not.mpr (by simp)),
    Nat.cast_zero, zero_add]
  exact (ringKrullDim_quotient_succ_le_of_nonZeroDivisor hx).trans (Order.KrullDimLE.krullDim_le)

variable [IsNoetherianRing R] [Ring.KrullDimLE 1 R]
variable {K : Type*} [Field K] [Algebra R K] [IsFractionRing R K]

variable {R} in
lemma ord_ne_top {a : R} (ha : a ‚ąą nonZeroDivisors R) : ord R a ‚Č† ‚ä§ := by
  simp [isFiniteLength_quotient_span_singleton R ha, Ring.ord, Module.length_ne_top_iff]

variable {R} in
lemma ord_lt_top {a : R} (ha : a ‚ąą nonZeroDivisors R) : ord R a < ‚ä§ := (ord_ne_top ha).lt_top

variable [Nontrivial R]

lemma ordMonoidWithZeroHom_isUnit (y : nonZeroDivisors R) : IsUnit (ordMonoidWithZeroHom R y) := by
  simp [ordMonoidWithZeroHom_eq_zero_iff, ord_ne_top]

/--
Order of vanishing function for elements of the fraction field defined as the extension of
`CommRing.ordMonoidWithZeroHom` to the field of fractions.
-/
@[stacks 02MD]
noncomputable
def ordFrac : K ‚Üí*‚āÄ ‚Ą§ŠĶź‚Āį :=
  (toLocalizationMap (nonZeroDivisors R) K).lift‚āÄ (ordMonoidWithZeroHom R) <|
  ordMonoidWithZeroHom_isUnit R

lemma ordFrac_eq_ord {x : R} (hx : x ‚Č† 0) :
    ordFrac R (algebraMap R K x) = ordMonoidWithZeroHom R x := by
  have := (FaithfulSMul.algebraMap_injective R K).isDomain
  refine (Submonoid.LocalizationMap.lift_eq ..).trans ?_
  simp [ordMonoidWithZeroHom, mem_nonZeroDivisors_iff_ne_zero.mpr hx]

lemma ordFrac_eq_div (a : nonZeroDivisors R) (b : nonZeroDivisors R) :
    ordFrac R (IsLocalization.mk' K a.1 b) =
      ordMonoidWithZeroHom R a / ordMonoidWithZeroHom R b := by
  simp [ordFrac_eq_ord]

end Ring
