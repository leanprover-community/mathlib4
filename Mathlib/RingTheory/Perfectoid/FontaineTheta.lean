public import Mathlib.RingTheory.Perfectoid.Untilt
public import Mathlib.RingTheory.WittVector.TeichmullerSeries

/-!
# Fontaine's Оё map
In this file, we define Fontaine's `Оё` map, which is a ring
homomorphism from the Witt vector `рқ•Һ Rвҷӯ` of the tilt of a perfectoid ring `R`
to `R` itself. Our definition of `Оё` does not require that `R` is perfectoid in the first place.
We only need `R` to be `p`-adically complete.

## Main Definitions
* `fontaineTheta` : Fontaine's Оё map, which is a ring homomorphism from `рқ•Һ Rвҷӯ` to `R`.

## Main Theorems
* `fontaineTheta_teichmuller` : `Оё([x])` is the untilt of `x`.
* `fontaineTheta_surjective` : Fontaine's Оё map is surjective.

## TODO
Establish that our definition (explicit construction of `Оё mod p ^ n`) agrees with the
deformation-theoretic approach via the cotangent complex, as in
[Bhatt, *Lecture notes for a class on perfectoid spaces*.
Remark 6.1.7](https://www.math.ias.edu/~bhatt/teaching/mat679w17/lectures.pdf).

## Tags
Fontaine's theta map, perfectoid theory, p-adic Hodge theory

## Reference

* [Fontaine, *Sur Certains Types de ReprГ©sentations p-Adiques du Groupe de Galois d'un Corps Local;
  Construction d'un Anneau de Barsotti-Tate*][fontaine1982certains]
* [Fontaine, *Le corps des pГ©riodes p-adiques*][fontaine1994corps]

-/

@[expose] public section

universe u

open Ideal Quotient PreTilt WittVector

noncomputable section

variable {R : Type u} [CommRing R] {p : в„•} [Fact p.Prime]

local notation "рқ•Һ " A:100 => WittVector p A
local notation A "вҷӯ" => PreTilt A p
local notation3 "рқ”ӯ" => span {(p : R)}

namespace WittVector

/-!
## Оё as a ring homomorphism
Let `рқ”ӯ` denote the ideal of `R` generated by the prime number `p`. In this section, we first
define the ring homomorphism `fontaineThetaModPPow : рқ•Һ Rвҷӯ вҶ’+* R в§ё рқ”ӯ ^ (n + 1)`.
Then we show they are compatible with each other and lift to a
ring homomorphism `fontaineTheta : рқ•Һ Rвҷӯ вҶ’+* R`.

To prove this, we define `fontaineThetaModPPow` as a composition of the following ring
homomorphisms.

`рқ•Һ Rвҷӯ --рқ•Һ(Frob^-n)-> рқ•Һ Rвҷӯ --рқ•Һ(coeff 0)-> рқ•Һ(R/рқ”ӯ) --gh_n-> R/рқ”ӯ^(n+1)`

Here, the ring map `gh_n` fits in the following diagram.

```
рқ•Һ(R)  --ghost_n->   R
|                   |
v                   v
рқ•Һ(R/рқ”ӯ) --gh_n-> R/рқ”ӯ^(n+1)
```
-/

set_option backward.isDefEq.respectTransparency false in
theorem ker_map_le_ker_mk_comp_ghostComponent (n : в„•) :
    RingHom.ker (WittVector.map (Ideal.Quotient.mk рқ”ӯ)) вүӨ
    RingHom.ker (((Ideal.Quotient.mk (рқ”ӯ ^ (n + 1)))).comp
    (WittVector.ghostComponent (p := p) n)) := by
  intro x
  simp only [RingHom.mem_ker, map_eq_zero_iff, RingHom.comp_apply]
  intro h
  simp only [ghostComponent]
  apply_fun Ideal.quotEquivOfEq (Ideal.span_singleton_pow _ (n + 1))
  simp only [RingHom.coe_comp, Function.comp_apply, Pi.evalRingHom_apply, ghostMap_apply,
    quotEquivOfEq_mk, map_zero]
  simp only [eq_zero_iff_dvd] at h вҠў
  exact pow_dvd_ghostComponent_of_dvd_coeff (fun _ _ вҶҰ h _)

/--
The lift ring map `gh_n : рқ•Һ(R/рқ”ӯ) вҶ’+* R/рқ”ӯ^(n+1)` of the `n`-th ghost component
`рқ•Һ(R) вҶ’+* R` along the surjective ring map `рқ•Һ(R) вҶ’+* рқ•Һ(R/рқ”ӯ)`.
-/
def ghostComponentModPPow (n : в„•) : рқ•Һ (R в§ё рқ”ӯ) вҶ’+* R в§ё рқ”ӯ ^ (n + 1) :=
  RingHom.liftOfSurjective (WittVector.map (Ideal.Quotient.mk рқ”ӯ))
    (map_surjective _ Ideal.Quotient.mk_surjective) вҹЁ((Ideal.Quotient.mk (рқ”ӯ ^ (n + 1)))).comp
      (WittVector.ghostComponent n), ker_map_le_ker_mk_comp_ghostComponent nвҹ©

@[simp]
theorem ghostComponentModPPow_map_mk (n : в„•) (x : рқ•Һ R) :
    ghostComponentModPPow n (WittVector.map (Ideal.Quotient.mk рқ”ӯ) x) =
    WittVector.ghostComponent n x :=
  RingHom.liftOfSurjective_comp_apply ..

@[simp]
theorem quotEquivOfEq_ghostComponentModPPow (x : рқ•Һ (R в§ё рқ”ӯ)) (h : рқ”ӯ ^ (0 + 1) = рқ”ӯ) :
    quotEquivOfEq h (ghostComponentModPPow 0 x) = ghostComponent 0 x := by
  obtain вҹЁy, hyвҹ© := map_surjective _ Ideal.Quotient.mk_surjective x
  simp [вҶҗ hy, ghostComponent_apply]

variable [Fact В¬IsUnit (p : R)] [IsAdicComplete (span {(p : R)}) R]
-- local notation рқ”ӯ does not work in [IsAdicComplete (span {(p : R)}) R]

@[simp]
theorem ghostComponentModPPow_teichmuller_coeff (n : в„•) (x : Rвҷӯ) :
    ghostComponentModPPow n (teichmuller p (PreTilt.coeff n x)) =
    Ideal.Quotient.mk (рқ”ӯ ^ (n + 1)) x.untilt := by
  simpa using ghostComponentModPPow_map_mk n
    (teichmuller p ((((_root_.frobeniusEquiv _ p).symm ^ n) x).untilt))

variable (R p) in
/--
The Fontaine's theta map modulo `p^(n+1)`.
It is the composition of the following ring homomorphisms.
`рқ•Һ Rвҷӯ --рқ•Һ(Frob^-n)-> рқ•Һ Rвҷӯ --рқ•Һ(coeff 0)-> рқ•Һ(R/p) --gh_n-> R/p^(n+1)`
-/
def fontaineThetaModPPow (n : в„•) : рқ•Һ Rвҷӯ вҶ’+* R в§ё рқ”ӯ ^ (n + 1) :=
  (ghostComponentModPPow n).comp (((WittVector.map (PreTilt.coeff 0))).comp
    (WittVector.map ((_root_.frobeniusEquiv (Rвҷӯ) p).symm ^ n : Rвҷӯ вҶ’+* Rвҷӯ)))

@[simp]
theorem fontaineThetaModPPow_teichmuller (n : в„•) (x : Rвҷӯ) :
    fontaineThetaModPPow R p n (teichmuller p x) = Ideal.Quotient.mk _ x.untilt := by
  simp [fontaineThetaModPPow]

set_option backward.isDefEq.respectTransparency false in
theorem factorPowSucc_comp_fontaineThetaModPPow (n : в„•) :
    (factorPowSucc _ _).comp (fontaineThetaModPPow R p (n + 1)) = fontaineThetaModPPow R p n := by
  apply eq_of_apply_teichmuller_eq ((factorPowSucc _ _).comp (fontaineThetaModPPow R p (n + 1)))
    (fontaineThetaModPPow R p n)
  В· use n + 1
    have : p = Ideal.Quotient.mk (рқ”ӯ ^ (n + 1)) p := by
      simp [map_natCast]
    rw [this, вҶҗ map_pow, Ideal.Quotient.eq_zero_iff_mem]
    exact Ideal.pow_mem_pow (mem_span_singleton_self _) _
  simp [fontaineThetaModPPow]

theorem factorPowSucc_fontaineThetaModPPow_eq (n : в„•) (x : рқ•Һ Rвҷӯ) :
    factorPowSucc _ _ ((fontaineThetaModPPow R p (n + 1)) x) = fontaineThetaModPPow R p n x := by
  simp [вҶҗ factorPowSucc_comp_fontaineThetaModPPow n]

open IsAdicComplete

variable (R p) in
/--
The Fontaine's Оё map from `рқ•Һ Rвҷӯ` to `R`.
It is the limit of the ring maps `fontaineThetaModPPow n` from `рқ•Һ Rвҷӯ` to `R/p^(n+1)`.
-/
def fontaineTheta : рқ•Һ Rвҷӯ вҶ’+* R :=
  Order.succ_strictMono.liftRingHom рқ”ӯ _ (factorPowSucc_comp_fontaineThetaModPPow _)

theorem mk_pow_fontaineTheta (n : в„•) (x : рқ•Һ Rвҷӯ) :
    Ideal.Quotient.mk (рқ”ӯ ^ (n + 1)) (fontaineTheta R p x) = fontaineThetaModPPow R p n x :=
  Order.succ_strictMono.mk_liftRingHom рқ”ӯ _ (factorPowSucc_comp_fontaineThetaModPPow _) x

theorem mk_fontaineTheta (x : рқ•Һ Rвҷӯ) :
    Ideal.Quotient.mk рқ”ӯ (fontaineTheta R p x) = PreTilt.coeff 0 (x.coeff 0) := by
  have := mk_pow_fontaineTheta 0 x
  simp only [Nat.reduceAdd] at this
  apply_fun Ideal.quotEquivOfEq (pow_one (p : R) в–ё Ideal.span_singleton_pow (p : R) 1) at this
  simp only [quotEquivOfEq_mk] at this
  rw [this]
  simp [fontaineThetaModPPow, ghostComponent_apply, RingHom.one_def]

@[simp]
theorem fontaineTheta_teichmuller (x : Rвҷӯ) : fontaineTheta R p (teichmuller p x) = x.untilt := by
  rw [IsHausdorff.eq_iff_smodEq (I := рқ”ӯ)]
  simp only [smul_eq_mul, mul_top]
  intro n
  cases n
  В· simp
  В· simp [SModEq, mk_pow_fontaineTheta]

end WittVector

variable [Fact В¬IsUnit (p : R)] [IsAdicComplete (span {(p : R)}) R]

/-- If the Frobenius map is surjective on `R/pR`, then the Fontaine's Оё map is surjective. -/
theorem surjective_fontaineTheta (hF : Function.Surjective (frobenius (ModP R p) p)) :
    Function.Surjective (fontaineTheta R p) := by
  have : Ideal.map (fontaineTheta R p) (span {(p : рқ•Һ Rвҷӯ)}) = рқ”ӯ := by
    simp [map_span]
  have _ : IsHausdorff ((span {(p : рқ•Һ Rвҷӯ)}).map (fontaineTheta R p)) R := by
    rw [this]
    infer_instance
  apply surjective_of_mk_map_comp_surjective (fontaineTheta R p) (I := span {(p : рқ•Һ Rвҷӯ)})
  simp only [RingHom.coe_comp]
  suffices h : Function.Surjective (Ideal.Quotient.mk рқ”ӯ вҲҳ fontaineTheta R p) by
    rwa [Ideal.map_span, Set.image_singleton, map_natCast]
  have : Ideal.Quotient.mk рқ”ӯ вҲҳ fontaineTheta R p = (fun x вҶҰ
      PreTilt.coeff 0 x) вҲҳ fun (x : рқ•Һ Rвҷӯ) вҶҰ (x.coeff 0) := by
    ext
    simp [mk_fontaineTheta]
  rw [this]
  apply Function.Surjective.comp
  В· exact Perfection.coeff_surjective hF 0
  В· exact WittVector.coeff_surjective 0
