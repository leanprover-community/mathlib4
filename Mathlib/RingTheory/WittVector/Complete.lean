/-!
# The ring of Witt vectors is p-torsion free and p-adically complete

In this file, we prove that the ring of Witt vectors `ЁЭХО k` is p-torsion free and p-adically complete
when `k` is a perfect ring of characteristic `p`.

## Main declarations

* `WittVector.eq_zero_of_p_mul_eq_zero` : If `k` is a perfect ring of characteristic `p`,
  then the Witt vector `ЁЭХО k` is `p`-torsion free.
* `isAdicCompleteIdealSpanP` : If `k` is a perfect ring of characteristic `p`,
  then the Witt vector `ЁЭХО k` is `p`-adically complete.
-/

@[expose] public section

namespace WittVector

variable {p : тДХ} [hp : Fact (Nat.Prime p)] {k : Type*} [CommRing k]

local notation "ЁЭХО" => WittVector p

theorem le_coeff_eq_iff_le_sub_coeff_eq_zero {x y : ЁЭХО k} {n : тДХ} :
    (тИА i < n, x.coeff i = y.coeff i) тЖФ тИА i < n, (x - y).coeff i = 0 := by
  calc
  _ тЖФ x.truncate n = y.truncate n := by
    refine тЯиfun h => ?_, fun h i hi => ?_тЯй
    ┬╖ ext i
      simp [h i]
    ┬╖ rw [тЖР coeff_truncate x тЯиi, hiтЯй, тЖР coeff_truncate y тЯиi, hiтЯй, h]
  _ тЖФ (x - y).truncate n = 0 := by
    simp only [map_sub, sub_eq_zero]
  _ тЖФ _ := by simp only [тЖР mem_ker_truncate, RingHom.mem_ker]

section PerfectRing

variable [CharP k p] [PerfectRing k p]

/--
If `k` is a perfect ring of characteristic `p`, then the ring of Witt vectors `ЁЭХО k` is
`p`-torsion free.
-/
theorem eq_zero_of_p_mul_eq_zero (x : ЁЭХО k) (h : x * p = 0) : x = 0 := by
  rwa [тЖР frobenius_verschiebung, _root_.map_eq_zero_iff _ (frobenius_bijective p k).injective,
      _root_.map_eq_zero_iff _ (verschiebung_injective p k)] at h

/--
If `k` is a perfect ring of characteristic `p`, a Witt vector `x : ЁЭХО k` falls in ideal generated by
`p` if and only if its zeroth coefficient is `0`.
-/
theorem mem_span_p_iff_coeff_zero_eq_zero (x : ЁЭХО k) :
    x тИИ (Ideal.span {(p : ЁЭХО k)}) тЖФ x.coeff 0 = 0 := by
  simp_rw [Ideal.mem_span_singleton, dvd_def, mul_comm]
  refine тЯиfun тЯиu, huтЯй тЖж ?_, fun h тЖж ?_тЯй
  ┬╖ rw [hu, mul_charP_coeff_zero]
  ┬╖ use (frobeniusEquiv p k).symm (x.shift 1)
    calc
    _ = verschiebung (x.shift 1) := by
      simpa using eq_iterate_verschiebung (n := 1) (by simp [h])
    _ = _ := by
      rw [тЖР verschiebung_frobenius, тЖР frobeniusEquiv_apply,
          RingEquiv.apply_symm_apply (frobeniusEquiv p k) _]

/--
If `k` is a perfect ring of characteristic `p`, a Witt vector `x : ЁЭХО k` falls in ideal generated by
`p ^ n` if and only if its initial `n` coefficients are `0`.
-/
theorem mem_span_p_pow_iff_le_coeff_eq_zero (x : ЁЭХО k) (n : тДХ) :
    x тИИ (Ideal.span {(p ^ n : ЁЭХО k)}) тЖФ тИА m, m < n тЖТ x.coeff m = 0 := by
  simp_rw [Ideal.mem_span_singleton, dvd_def, mul_comm]
  refine тЯиfun тЯиu, huтЯй m hm тЖж ?_, fun h тЖж ?_тЯй
  ┬╖ rw [hu, mul_pow_charP_coeff_zero _ hm]
  ┬╖ use (frobeniusEquiv p k).symm^[n] (x.shift n)
    rw [тЖР iterate_verschiebung_iterate_frobenius]
    calc
    _ = verschiebung^[n] (x.shift n) := by
      simpa using eq_iterate_verschiebung (x := x) (n := n) h
    _ = _ := by
      congr
      rw [тЖР Function.comp_apply (f := frobenius^[n]), тЖР Function.Commute.comp_iterate]
      ┬╖ rw [тЖР WittVector.frobeniusEquiv_apply, тЖР RingEquiv.coe_trans]
        simp
      ┬╖ rw [Function.Commute, Function.Semiconj, тЖР WittVector.frobeniusEquiv_apply]
        simp only [RingEquiv.apply_symm_apply, RingEquiv.symm_apply_apply, implies_true]

lemma ker_constantCoeff : RingHom.ker constantCoeff = Ideal.span {(p : ЁЭХО k)} := by
  ext
  simp [mem_span_p_iff_coeff_zero_eq_zero]

/-- If `k` is a perfect ring of characteristic `p`, there is an isomorphism between the quotient
`ЁЭХО k / p` and `k`.
-/
noncomputable def quotientPEquiv : ЁЭХО k тз╕ Ideal.span {(p : ЁЭХО k)} тЙГ+* k :=
  (Ideal.quotEquivOfEq ker_constantCoeff.symm).trans
    (RingHom.quotientKerEquivOfSurjective (constantCoeff_surjective p))

@[simp]
lemma quotientPEquiv_mk (x : ЁЭХО k) : quotientPEquiv (Quot.mk _ x) = constantCoeff x := rfl

/--
If `k` is a perfect ring of characteristic `p`, then the ring of Witt vectors `ЁЭХО k`
is `p`-adically complete.
-/
instance isAdicCompleteIdealSpanP : IsAdicComplete (Ideal.span {(p : ЁЭХО k)}) (ЁЭХО k) where
  haus' := by
    intro _ h
    ext n
    simp only [smul_eq_mul, Ideal.mul_top] at h
    have := h (n + 1)
    simp only [Ideal.span_singleton_pow, SModEq.zero,
        mem_span_p_pow_iff_le_coeff_eq_zero] at this
    simpa using this n
  prec' := by
    intro x h
    -- construct the limit Witt vector w diagonally
    use .mk p (fun n тЖж (x (n + 1)).coeff n)
    intro n
    simp only [Ideal.span_singleton_pow, smul_eq_mul, Ideal.mul_top, SModEq.sub_mem,
      mem_span_p_pow_iff_le_coeff_eq_zero, тЖР le_coeff_eq_iff_le_sub_coeff_eq_zero] at h тКв
    intro i hi
    exact (h hi i (Nat.lt_succ_self i)).symm

end PerfectRing

end WittVector
