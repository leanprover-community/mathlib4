namespace Localization

open IsLocalization

variable {M}

/-- Given a map `f : R Ôćĺ+* S` and an element `r : R`, such that `f r` is invertible,
  we may construct a map `RßÁú Ôćĺ+* S`. -/
noncomputable abbrev awayLift (f : R Ôćĺ+* P) (r : R) (hr : IsUnit (f r)) :
    Localization.Away r Ôćĺ+* P :=
  IsLocalization.Away.lift r hr

lemma awayLift_mk {A : Type*} [CommRing A] (f : R Ôćĺ+* A) (r : R)
    (a : R) (v : A) (hv : f r * v = 1) (j : ÔäĽ) :
    Localization.awayLift f r (isUnit_iff_exists_inv.mpr ÔčĘv, hvÔčę)
      (Localization.mk a ÔčĘr ^ j, j, rflÔčę) = f a * v ^ j := by
  simp [Localization.mk_eq_mk', awayLift, Away.lift, IsLocalization.lift_mk',
    Units.mul_inv_eq_iff_eq_mul, IsUnit.liftRight, mul_assoc, ÔćÉ mul_pow, (mul_comm _ _).trans hv]

/-- Given a map `f : R Ôćĺ+* S` and an element `r : R`, we may construct a map `RßÁú Ôćĺ+* SßÁú`. -/
noncomputable abbrev awayMap (f : R Ôćĺ+* P) (r : R) :
    Localization.Away r Ôćĺ+* Localization.Away (f r) :=
  IsLocalization.Away.map _ _ f r

variable {A : Type*} [CommSemiring A] [Algebra R A]
variable {B : Type*} [CommSemiring B] [Algebra R B]

/-- Given a map `f : A ÔćĺÔéÉ[R] B` and an element `a : A`, we may construct a map `AÔéÉ ÔćĺÔéÉ[R] BÔéÉ`. -/
noncomputable abbrev awayMapÔéÉ (f : A ÔćĺÔéÉ[R] B) (a : A) :
    Localization.Away a ÔćĺÔéÉ[R] Localization.Away (f a) :=
  IsLocalization.Away.mapÔéÉ _ _ f a

theorem algebraMap_injective_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = ÔŐĄ) :
    Function.Injective (algebraMap R <| ╬á a : s, Away a.1) := fun x y eq ÔćŽ by
  suffices Module.eqIdeal R x y = ÔŐĄ by simpa [Module.eqIdeal] using (Ideal.eq_top_iff_one _).mp this
  by_contra ne
  have ÔčĘr, hrs, disjÔčę := Ideal.exists_disjoint_powers_of_span_eq_top s span_eq _ ne
  let r : s := ÔčĘr, hrsÔčę
  have ÔčĘÔčĘ_, n, rflÔčę, eqÔčę := (IsLocalization.eq_iff_exists (.powers r.1) _).mp (congr_fun eq r)
  exact Set.disjoint_left.mp disj eq ÔčĘn, rflÔčę

/-- The sheaf condition for the structure sheaf on `Spec R`
for a covering of the whole prime spectrum by basic opens. -/
theorem existsUnique_algebraMap_eq_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = ÔŐĄ)
    (f : ╬á a : s, Away a.1) (h : ÔłÇ a b : s,
      Away.awayToAwayRight (P := Away (a * b : R)) a.1 b (f a) = Away.awayToAwayLeft b.1 a (f b)) :
    Ôłâ! r : R, ÔłÇ a : s, algebraMap R _ r = f a := by
  have mem := (Ideal.eq_top_iff_one _).mp span_eq; clear span_eq
  wlog finset_eq : Ôłâ t : Finset R, t = s generalizing s
  ┬Ě have ÔčĘt, hts, memÔčę := Submodule.mem_span_finite_of_mem_span mem
    have ÔčĘr, eq, uniqÔčę := this t (fun a ÔćŽ f ÔčĘa, hts a.2Ôčę)
      (fun a b ÔćŽ h ÔčĘa, hts a.2Ôčę ÔčĘb, hts b.2Ôčę) mem ÔčĘ_, rflÔčę
    refine ÔčĘr, fun a ÔćŽ ?_, fun _ eq ÔćŽ uniq _ fun a ÔćŽ eq ÔčĘa, hts a.2ÔčęÔčę
