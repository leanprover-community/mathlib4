    в€ѓ! r : R, в€Ђ a : s, algebraMap R _ r = f a := by
  have mem := (Ideal.eq_top_iff_one _).mp span_eq; clear span_eq
  wlog finset_eq : в€ѓ t : Finset R, t = s generalizing s
  В· have вџЁt, hts, memвџ© := Submodule.mem_span_finite_of_mem_span mem
    have вџЁr, eq, uniqвџ© := this t (fun a в†¦ f вџЁa, hts a.2вџ©)
      (fun a b в†¦ h вџЁa, hts a.2вџ© вџЁb, hts b.2вџ©) mem вџЁ_, rflвџ©
    refine вџЁr, fun a в†¦ ?_, fun _ eq в†¦ uniq _ fun a в†¦ eq вџЁa, hts a.2вџ©вџ©
    replace hts := Set.insert_subset a.2 hts
