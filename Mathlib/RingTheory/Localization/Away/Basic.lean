open Localization

variable {R : Type*} [CommSemiring R]

section NumDen

open IsLocalization

variable (x : R)
variable (B : Type*) [CommSemiring B] [Algebra R B] [IsLocalization.Away x B]

/-- `selfZPow x (m : ÔäĄ)` is `x ^ m` as an element of the localization away from `x`. -/
noncomputable def selfZPow (m : ÔäĄ) : B :=
  if _ : 0 ÔëĄ m then algebraMap _ _ x ^ m.natAbs else mk' _ (1 : R) (Submonoid.pow x m.natAbs)

theorem selfZPow_of_nonneg {n : ÔäĄ} (hn : 0 ÔëĄ n) : selfZPow x B n = algebraMap R B x ^ n.natAbs :=
  dif_pos hn

@[simp]
theorem selfZPow_natCast (d : ÔäĽ) : selfZPow x B d = algebraMap R B x ^ d :=
  selfZPow_of_nonneg _ _ (Int.natCast_nonneg d)

@[simp]
theorem selfZPow_zero : selfZPow x B 0 = 1 := by
  simp [selfZPow_of_nonneg _ _ le_rfl]

theorem selfZPow_of_neg {n : ÔäĄ} (hn : n < 0) :
    selfZPow x B n = mk' _ (1 : R) (Submonoid.pow x n.natAbs) :=
  dif_neg hn.not_le

theorem selfZPow_of_nonpos {n : ÔäĄ} (hn : n ÔëĄ 0) :
    selfZPow x B n = mk' _ (1 : R) (Submonoid.pow x n.natAbs) := by
  by_cases hn0 : n = 0
  ┬Ě simp [hn0, selfZPow_zero, Submonoid.pow_apply]
  ┬Ě simp [selfZPow_of_neg _ _ (lt_of_le_of_ne hn hn0)]

@[simp]
theorem selfZPow_neg_natCast (d : ÔäĽ) : selfZPow x B (-d) = mk' _ (1 : R) (Submonoid.pow x d) := by
  simp [selfZPow_of_nonpos _ _ (neg_nonpos.mpr (Int.natCast_nonneg d))]

@[simp]
theorem selfZPow_sub_natCast {n m : ÔäĽ} :
    selfZPow x B (n - m) = mk' _ (x ^ n) (Submonoid.pow x m) := by
  by_cases h : m ÔëĄ n
  ┬Ě rw [IsLocalization.eq_mk'_iff_mul_eq, Submonoid.pow_apply, Subtype.coe_mk, ÔćÉ Int.ofNat_sub h,
      selfZPow_natCast, ÔćÉ map_pow, ÔćÉ map_mul, ÔćÉ pow_add, Nat.sub_add_cancel h]
  ┬Ě rw [ÔćÉ neg_sub, ÔćÉ Int.ofNat_sub (le_of_not_le h), selfZPow_neg_natCast,
      IsLocalization.mk'_eq_iff_eq]
    simp [Submonoid.pow_apply, ÔćÉ pow_add, Nat.sub_add_cancel (le_of_not_le h)]

@[simp]
theorem selfZPow_add {n m : ÔäĄ} : selfZPow x B (n + m) = selfZPow x B n * selfZPow x B m := by
  rcases le_or_lt 0 n with hn | hn <;> rcases le_or_lt 0 m with hm | hm
  ┬Ě rw [selfZPow_of_nonneg _ _ hn, selfZPow_of_nonneg _ _ hm,
      selfZPow_of_nonneg _ _ (add_nonneg hn hm), Int.natAbs_add_of_nonneg hn hm, pow_add]
  ┬Ě have : n + m = n.natAbs - m.natAbs := by
      rw [Int.natAbs_of_nonneg hn, Int.ofNat_natAbs_of_nonpos hm.le, sub_neg_eq_add]
    rw [selfZPow_of_nonneg _ _ hn, selfZPow_of_neg _ _ hm, this, selfZPow_sub_natCast,
      IsLocalization.mk'_eq_mul_mk'_one, map_pow]
  ┬Ě have : n + m = m.natAbs - n.natAbs := by
      rw [Int.natAbs_of_nonneg hm, Int.ofNat_natAbs_of_nonpos hn.le, sub_neg_eq_add, add_comm]
    rw [selfZPow_of_nonneg _ _ hm, selfZPow_of_neg _ _ hn, this, selfZPow_sub_natCast,
      IsLocalization.mk'_eq_mul_mk'_one, map_pow, mul_comm]
  ┬Ě rw [selfZPow_of_neg _ _ hn, selfZPow_of_neg _ _ hm, selfZPow_of_neg _ _ (add_neg hn hm),
      Int.natAbs_add_of_nonpos hn.le hm.le, ÔćÉ mk'_mul, one_mul]
    congr
    ext
    simp [pow_add]

theorem selfZPow_mul_neg (d : ÔäĄ) : selfZPow x B d * selfZPow x B (-d) = 1 := by
  by_cases hd : d ÔëĄ 0
  ┬Ě rw [selfZPow_of_nonpos x B hd, selfZPow_of_nonneg, ÔćÉ map_pow, Int.natAbs_neg,
      Submonoid.pow_apply, IsLocalization.mk'_spec, map_one]
    apply nonneg_of_neg_nonpos
    rwa [neg_neg]
  ┬Ě rw [selfZPow_of_nonneg x B (le_of_not_le hd), selfZPow_of_nonpos, ÔćÉ map_pow, Int.natAbs_neg,
      Submonoid.pow_apply, IsLocalization.mk'_spec'_mk, map_one]
    refine nonpos_of_neg_nonneg (le_of_lt ?_)
    rwa [neg_neg, ÔćÉ not_le]

theorem selfZPow_neg_mul (d : ÔäĄ) : selfZPow x B (-d) * selfZPow x B d = 1 := by
  rw [mul_comm, selfZPow_mul_neg x B d]

theorem selfZPow_pow_sub (a : R) (b : B) (m d : ÔäĄ) :
    selfZPow x B (m - d) * mk' B a (1 : Submonoid.powers x) = b Ôćö
      selfZPow x B m * mk' B a (1 : Submonoid.powers x) = selfZPow x B d * b := by
  rw [sub_eq_add_neg, selfZPow_add, mul_assoc, mul_comm _ (mk' B a 1), ÔćÉ mul_assoc]
  constructor
  ┬Ě intro h
    have := congr_arg (fun s : B => s * selfZPow x B d) h
    simp only at this
    rwa [mul_assoc, mul_assoc, selfZPow_neg_mul, mul_one, mul_comm b _] at this
  ┬Ě intro h
    have := congr_arg (fun s : B => s * selfZPow x B (-d)) h
    simp only at this
    rwa [mul_comm _ b, mul_assoc b _ _, selfZPow_mul_neg, mul_one] at this

variable {R : Type*} [CommRing R] (x : R) (B : Type*) [CommRing B]
variable [Algebra R B] [IsLocalization.Away x B] [IsDomain R] [WfDvdMonoid R]

theorem exists_reduced_fraction' {b : B} (hb : b Ôëá 0) (hx : Irreducible x) :
    Ôłâ (a : R) (n : ÔäĄ), ┬Čx Ôłú a Ôłž selfZPow x B n * algebraMap R B a = b := by
  obtain ÔčĘÔčĘaÔéÇ, yÔčę, HÔčę := surj (Submonoid.powers x) b
  obtain ÔčĘd, hyÔčę := (Submonoid.mem_powers_iff y.1 x).mp y.2
  have haÔéÇ : aÔéÇ Ôëá 0 := by
    haveI :=
      @isDomain_of_le_nonZeroDivisors B _ R _ _ _ (Submonoid.powers x) _
        (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
    simp only [map_zero, ÔćÉ hy, map_pow] at H
    apply ((injective_iff_map_eq_zero' (algebraMap R B)).mp _ aÔéÇ).mpr.mt
    ┬Ě rw [ÔćÉ H]
      apply mul_ne_zero hb (pow_ne_zero _ _)
      exact
        IsLocalization.to_map_ne_zero_of_mem_nonZeroDivisors B
          (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
          (mem_nonZeroDivisors_iff_ne_zero.mpr hx.ne_zero)
    ┬Ě exact IsLocalization.injective B (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
  simp only [ÔćÉ hy] at H
  obtain ÔčĘm, a, hyp1, hyp2Ôčę := WfDvdMonoid.max_power_factor haÔéÇ hx
  refine ÔčĘa, m - d, ?_Ôčę
  rw [ÔćÉ mk'_one (M := Submonoid.powers x) B, selfZPow_pow_sub, selfZPow_natCast, selfZPow_natCast,
    ÔćÉ map_pow _ _ d, mul_comm _ b, H, hyp2, map_mul, map_pow _ _ m]
  exact ÔčĘhyp1, congr_arg _ (IsLocalization.mk'_one _ _)Ôčę

end NumDen
