/-!
# Localizations away from an element

## Main definitions

* `IsLocalization.Away (x : R) S` expresses that `S` is a localization away from `x`, as an
  abbreviation of `IsLocalization (Submonoid.powers x) S`.
* `exists_reduced_fraction' (hb : b ‚Č† 0)` produces a reduced fraction of the form `b = a * x^n` for
  some `n : ‚Ą§` and some `a : R` that is not divisible by `x`.

## Implementation notes

See `Mathlib/RingTheory/Localization/Basic.lean` for a design overview.

## Tags
localization, ring localization, commutative ring localization, characteristic predicate,
commutative ring, field of fractions
-/

@[expose] public section


section CommSemiring

variable {R : Type*} [CommSemiring R] (M : Submonoid R) {S : Type*} [CommSemiring S]
variable [Algebra R S] {P : Type*} [CommSemiring P]

namespace IsLocalization

section Away

variable (x : R)

/-- Given `x : R`, the typeclass `IsLocalization.Away x S` states that `S` is
isomorphic to the localization of `R` at the submonoid generated by `x`.
See `IsLocalization.Away.mk` for a specialized constructor. -/
abbrev Away (S : Type*) [CommSemiring S] [Algebra R S] :=
  IsLocalization (Submonoid.powers x) S

namespace Away

variable [IsLocalization.Away x S]

/-- Given `x : R` and a localization map `F : R ‚Üí+* S` away from `x`, `invSelf` is `(F x)‚ĀĽ¬Ļ`. -/
noncomputable def invSelf : S :=
  mk' S (1 : R) ‚ü®x, Submonoid.mem_powers _‚ü©

@[simp]
theorem mul_invSelf : algebraMap R S x * invSelf x = 1 := by
  convert! IsLocalization.mk'_mul_mk'_eq_one (M := Submonoid.powers x) (S := S) _ 1
  symm
  apply IsLocalization.mk'_one

/-- For `s : S` with `S` being the localization of `R` away from `x`,
this is a choice of `(r, n) : R √ó ‚Ąē` such that `s * algebraMap R S (x ^ n) = algebraMap R S r`. -/
noncomputable def sec (s : S) : R √ó ‚Ąē :=
  ‚ü®(IsLocalization.sec (Submonoid.powers x) s).1,
   (IsLocalization.sec (Submonoid.powers x) s).2.property.choose‚ü©

lemma sec_spec (s : S) : s * (algebraMap R S) (x ^ (IsLocalization.Away.sec x s).2) =
    algebraMap R S (IsLocalization.Away.sec x s).1 := by
  simp only [IsLocalization.Away.sec, ‚Üź IsLocalization.sec_spec]
  congr
  exact (IsLocalization.sec (Submonoid.powers x) s).2.property.choose_spec

lemma algebraMap_pow_isUnit (n : ‚Ąē) : IsUnit (algebraMap R S x ^ n) :=
  IsUnit.pow _ <| IsLocalization.map_units _ (‚ü®x, 1, by simp‚ü© : Submonoid.powers x)

lemma algebraMap_isUnit : IsUnit (algebraMap R S x) :=
  IsLocalization.map_units _ (‚ü®x, 1, by simp‚ü© : Submonoid.powers x)

theorem associated_sec_fst (s : S) :
    Associated (algebraMap R S (IsLocalization.Away.sec x s).1) s := by
  rw [‚Üź IsLocalization.Away.sec_spec, map_pow]
  exact associated_mul_unit_left _ _ <| .pow _ <| IsLocalization.Away.algebraMap_isUnit _

lemma algebraMap_isUnit_iff {y : R} : IsUnit (algebraMap R S y) ‚ÜĒ ‚ąÉ n, y ‚ą£ x ^ n :=
  (IsLocalization.algebraMap_isUnit_iff <| .powers x).trans <| by simp [Submonoid.mem_powers_iff]

lemma surj (z : S) : ‚ąÉ (n : ‚Ąē) (a : R), z * algebraMap R S x ^ n = algebraMap R S a := by
  obtain ‚ü®‚ü®a, ‚ü®-, n, rfl‚ü©‚ü©, h‚ü© := IsLocalization.surj (Submonoid.powers x) z
  use n, a
  simpa using h

lemma exists_of_eq {a b : R} (h : algebraMap R S a = algebraMap R S b) :
    ‚ąÉ (n : ‚Ąē), x ^ n * a = x ^ n * b := by
  obtain ‚ü®‚ü®-, n, rfl‚ü©, hx‚ü© := IsLocalization.exists_of_eq (M := Submonoid.powers x) h
  use n

/-- Specialized constructor for `IsLocalization.Away`. -/
lemma mk (r : R) (map_unit : IsUnit (algebraMap R S r))
    (surj : ‚ąÄ s, ‚ąÉ (n : ‚Ąē) (a : R), s * algebraMap R S r ^ n = algebraMap R S a)
    (exists_of_eq : ‚ąÄ a b, algebraMap R S a = algebraMap R S b ‚Üí ‚ąÉ (n : ‚Ąē), r ^ n * a = r ^ n * b) :
    IsLocalization.Away r S where
  map_units := by
    rintro ‚ü®-, n, rfl‚ü©
    simp only [map_pow]
    exact IsUnit.pow _ map_unit
  surj z := by
    obtain ‚ü®n, a, hn‚ü© := surj z
    use ‚ü®a, ‚ü®r ^ n, n, rfl‚ü©‚ü©
    simpa using hn
  exists_of_eq {x y} h := by
    obtain ‚ü®n, hn‚ü© := exists_of_eq x y h
    use ‚ü®r ^ n, n, rfl‚ü©

lemma of_associated {r r' : R} (h : Associated r r') [IsLocalization.Away r S] :
    IsLocalization.Away r' S := by
  obtain ‚ü®u, rfl‚ü© := h
  refine mk _ ?_ (fun s ‚Ü¶ ?_) (fun a b hab ‚Ü¶ ?_)
  ¬∑ simp [algebraMap_isUnit r, IsUnit.map _ u.isUnit]
  ¬∑ obtain ‚ü®n, a, hn‚ü© := surj r s
    use n, a * u ^ n
    simp [mul_pow, ‚Üź mul_assoc, hn]
  ¬∑ obtain ‚ü®n, hn‚ü© := exists_of_eq r hab
    use n
    rw [mul_pow, mul_comm (r ^ n), mul_assoc, mul_assoc, hn]

/-- If `r` and `r'` are associated elements of `R`, an `R`-algebra `S`
is the localization of `R` away from `r` if and only if it is the localization of `R` away from
`r'`. -/
lemma iff_of_associated {r r' : R} (h : Associated r r') :
    IsLocalization.Away r S ‚ÜĒ IsLocalization.Away r' S :=
  ‚ü®fun _ ‚Ü¶ IsLocalization.Away.of_associated h, fun _ ‚Ü¶ IsLocalization.Away.of_associated h.symm‚ü©

lemma isUnit_of_dvd {r : R} (h : r ‚ą£ x) : IsUnit (algebraMap R S r) :=
  isUnit_of_dvd_unit (map_dvd _ h) (algebraMap_isUnit x)

variable {g : R ‚Üí+* P}

/-- Given `x : R`, a localization map `F : R ‚Üí+* S` away from `x`, and a map of `CommSemiring`s
`g : R ‚Üí+* P` such that `g x` is invertible, the homomorphism induced from `S` to `P` sending
`z : S` to `g y * (g x)‚ĀĽ‚ĀŅ`, where `y : R, n : ‚Ąē` are such that `z = F y * (F x)‚ĀĽ‚ĀŅ`. -/
noncomputable def lift (hg : IsUnit (g x)) : S ‚Üí+* P :=
  IsLocalization.lift fun y : Submonoid.powers x =>
    show IsUnit (g y.1) by
      obtain ‚ü®n, hn‚ü© := y.2
      rw [‚Üź hn, g.map_pow]
      exact IsUnit.map (powMonoidHom n : P ‚Üí* P) hg

@[simp]
theorem lift_eq (hg : IsUnit (g x)) (a : R) : lift x hg (algebraMap R S a) = g a :=
  IsLocalization.lift_eq _ _

@[simp]
theorem lift_comp (hg : IsUnit (g x)) : (lift x hg).comp (algebraMap R S) = g :=
  IsLocalization.lift_comp _

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `y * x`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayLeft (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] : S ‚Üí+* P :=
  lift x <| isUnit_of_dvd (y * x) (dvd_mul_left _ _)

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `x * y`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayRight (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] : S ‚Üí+* P :=
  lift x <| isUnit_of_dvd (x * y) (dvd_mul_right _ _)

theorem awayToAwayLeft_eq (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] (a : R) :
    awayToAwayLeft x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

theorem awayToAwayRight_eq (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] (a : R) :
    awayToAwayRight x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

variable (S) (Q : Type*) [CommSemiring Q] [Algebra P Q]

/-- Given a map `f : R ‚Üí+* S` and an element `r : R`, we may construct a map `RŠĶ£ ‚Üí+* SŠĶ£`. -/
noncomputable def map (f : R ‚Üí+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] : S ‚Üí+* Q :=
  IsLocalization.map Q f
    (show Submonoid.powers r ‚Č§ (Submonoid.powers (f r)).comap f by
      rintro x ‚ü®n, rfl‚ü©
      use n
      simp)

lemma map_injective_iff {S : Type*} [CommRing S] [Algebra R S]
    (f : R ‚Üí+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] :
    Function.Injective (map S Q f r) ‚ÜĒ ‚ąÄ a, f a = 0 ‚Üí ‚ąÉ n, r ^ n * a = 0 := by
  rw [injective_iff_map_eq_zero]
  trans ‚ąÄ a n, f r ^ n * f a = 0 ‚Üí ‚ąÉ m, r ^ m * a = 0
  ¬∑ simp [(IsLocalization.mk'_surjective (.powers r)).forall, Submonoid.mem_powers_iff,
      IsLocalization.Away.map, IsLocalization.map_mk', IsLocalization.mk'_eq_zero_iff]
  ¬∑ refine ‚ü®fun H x hx ‚Ü¶ H x 0 (by simpa), fun H a n ha ‚Ü¶ ?_‚ü©
    obtain ‚ü®m, hm‚ü© := H (r ^ n * a) (by simpa)
    exact ‚ü®m + n, by simp [pow_add, mul_assoc, *]‚ü©

lemma map_surjective_iff (f : R ‚Üí+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] :
    Function.Surjective (map S Q f r) ‚ÜĒ ‚ąÄ a, ‚ąÉ b m, f b = f r ^ m * a := by
  trans ‚ąÄ a n, ‚ąÉ b m k, f (r ^ (k + n) * b) = f r ^ (k + m) * a
  ¬∑ simp [Function.Surjective, (IsLocalization.mk'_surjective (.powers (f r))).forall, ‚Üź map_pow,
      (IsLocalization.mk'_surjective (.powers r)).exists, Submonoid.mem_powers_iff, pow_add,
      IsLocalization.Away.map, IsLocalization.map_mk', ‚Üź mul_assoc,
      IsLocalization.mk'_eq_iff_eq, ‚Üź map_mul, IsLocalization.eq_iff_exists (.powers (f r))]
  ¬∑ refine ‚ü®fun H x ‚Ü¶ ‚ü®_, _, (H x 0).choose_spec.choose_spec.choose_spec‚ü©, fun H a n ‚Ü¶ ?_‚ü©
    obtain ‚ü®b, m, e‚ü© := H a
    exact ‚ü®b, n + m, 0, by simp [e, pow_add]; ring_nf‚ü©

section Algebra

variable {A : Type*} [CommSemiring A] [Algebra R A]
variable {B : Type*} [CommSemiring B] [Algebra R B]
variable (A‚āö : Type*) [CommSemiring A‚āö] [Algebra A A‚āö] [Algebra R A‚āö] [IsScalarTower R A A‚āö]
variable (B‚āö : Type*) [CommSemiring B‚āö] [Algebra B B‚āö] [Algebra R B‚āö] [IsScalarTower R B B‚āö]

instance {f : A ‚Üí+* B} (a : A) [Away (f a) B‚āö] : IsLocalization (.map f (.powers a)) B‚āö := by
  simpa

instance (x : R) [IsLocalization.Away (algebraMap R A x) A‚āö] :
    IsLocalization (Algebra.algebraMapSubmonoid A (.powers x)) A‚āö := by
  simpa

/-- Given an algebra map `f : A ‚Üí‚āź[R] B` and an element `a : A`, we may construct a map
`A‚āź ‚Üí‚āź[R] B‚āź`. -/
noncomputable def map‚āź (f : A ‚Üí‚āź[R] B) (a : A) [Away a A‚āö] [Away (f a) B‚āö] : A‚āö ‚Üí‚āź[R] B‚āö :=
  ‚ü®map A‚āö B‚āö f.toRingHom a, fun r ‚Ü¶ by
    dsimp only [AlgHom.toRingHom_eq_coe, map, RingHom.coe_coe, OneHom.toFun_eq_coe]
    rw [IsScalarTower.algebraMap_apply R A A‚āö, IsScalarTower.algebraMap_eq R B B‚āö]
    simp‚ü©

@[simp]
lemma map‚āź_apply (f : A ‚Üí‚āź[R] B) (a : A) [Away a A‚āö] [Away (f a) B‚āö] (x : A‚āö) :
    map‚āź A‚āö B‚āö f a x = map A‚āö B‚āö f.toRingHom a x :=
  rfl

variable {A‚āö} {B‚āö}

lemma map‚āź_injective_of_injective {f : A ‚Üí‚āź[R] B} (a : A) [Away a A‚āö] [Away (f a) B‚āö]
    (hf : Function.Injective f) : Function.Injective (map‚āź A‚āö B‚āö f a) :=
  IsLocalization.map_injective_of_injective _ _ _ hf

lemma map‚āź_surjective_of_surjective {f : A ‚Üí‚āź[R] B} (a : A) [Away a A‚āö] [Away (f a) B‚āö]
    (hf : Function.Surjective f) : Function.Surjective (map‚āź A‚āö B‚āö f a) :=
  have : IsLocalization (Submonoid.map f.toRingHom (Submonoid.powers a)) B‚āö := by
    simp only [AlgHom.toRingHom_eq_coe, Submonoid.map_powers, RingHom.coe_coe]
    infer_instance
  IsLocalization.map_surjective_of_surjective _ _ _ hf

end Algebra

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. See `IsLocalization.Away.mul'` for the `x * y` version. -/
lemma mul (T : Type*) [CommSemiring T] [Algebra S T]
    [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (y * x) T := by
  refine mk _ ?_ (fun z ‚Ü¶ ?_) (fun a b h ‚Ü¶ ?_)
  ¬∑ simp only [map_mul, IsUnit.mul_iff, IsScalarTower.algebraMap_apply R S T]
    exact ‚ü®algebraMap_isUnit _, IsUnit.map _ (algebraMap_isUnit x)‚ü©
  ¬∑ obtain ‚ü®m, p, hpq‚ü© := surj (algebraMap R S y) z
    obtain ‚ü®n, a, hab‚ü© := surj x p
    use m + n, a * x ^ m * y ^ n
    simp only [mul_pow, pow_add, map_pow, map_mul, ‚Üź mul_assoc, hpq,
      IsScalarTower.algebraMap_apply R S T, ‚Üź hab]
    ring
  ¬∑ repeat rw [IsScalarTower.algebraMap_apply R S T] at h
    obtain ‚ü®n, hn‚ü© := exists_of_eq (algebraMap R S y) h
    simp only [‚Üź map_pow, ‚Üź map_mul, ‚Üź map_mul] at hn
    obtain ‚ü®m, hm‚ü© := exists_of_eq x hn
    use n + m
    convert_to y ^ m * x ^ n * (x ^ m * (y ^ n * a)) = y ^ m * x ^ n * (x ^ m * (y ^ n * b))
    ¬∑ ring
    ¬∑ ring
    ¬∑ rw [hm]

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. See `IsLocalization.Away.mul` for the `y * x` version. -/
lemma mul' (T : Type*) [CommSemiring T] [Algebra S T] [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (x * y) T :=
  mul_comm x y ‚Ėł mul S T x y

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (y * x) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul S (Localization.Away (algebraMap R S y)) _ _

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (x * y) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul' S (Localization.Away (algebraMap R S y)) _ _

/-- If `S‚āĀ` is the localization of `R` away from `f` and `S‚āā` is the localization away from `g`,
then any localization `T` of `S‚āā` away from `f` is also a localization of `S‚āĀ` away from `g`. -/
lemma commutes {R : Type*} [CommSemiring R] (S‚āĀ S‚āā T : Type*) [CommSemiring S‚āĀ]
    [CommSemiring S‚āā] [CommSemiring T] [Algebra R S‚āĀ] [Algebra R S‚āā] [Algebra R T] [Algebra S‚āĀ T]
    [Algebra S‚āā T] [IsScalarTower R S‚āĀ T] [IsScalarTower R S‚āā T] (x y : R)
    [IsLocalization.Away x S‚āĀ] [IsLocalization.Away y S‚āā]
    [IsLocalization.Away (algebraMap R S‚āā x) T] :
    IsLocalization.Away (algebraMap R S‚āĀ y) T := by
  convert! IsLocalization.commutes S‚āĀ S‚āā T (Submonoid.powers x) (Submonoid.powers y)
  ext x
  simp

end Away

end Away

variable [IsLocalization M S]

section AtUnits

variable (R) (S)

/-- The localization away from a unit is isomorphic to the ring. -/
noncomputable def atUnit (x : R) (e : IsUnit x) [IsLocalization.Away x S] : R ‚ČÉ‚āź[R] S :=
  atUnits R (Submonoid.powers x)
    (by rwa [Submonoid.powers_eq_closure, Submonoid.closure_le, Set.singleton_subset_iff])

/-- The localization at one is isomorphic to the ring. -/
noncomputable def atOne [IsLocalization.Away (1 : R) S] : R ‚ČÉ‚āź[R] S :=
  @atUnit R _ S _ _ (1 : R) isUnit_one _

theorem away_of_isUnit_of_bijective {R : Type*} (S : Type*) [CommSemiring R] [CommSemiring S]
    [Algebra R S] {r : R} (hr : IsUnit r) (H : Function.Bijective (algebraMap R S)) :
    IsLocalization.Away r S :=
  .of_le_isUnit_of_bijective (by simpa [Submonoid.powers_le] using! hr.map (algebraMap R S)) H

variable {R S}

lemma Away.mul_of_isUnit (x y : R) [IsLocalization.Away x S] (h : IsUnit (algebraMap R S y)) :
    IsLocalization.Away (x * y) S :=
  have : Away (algebraMap R S y) S := away_of_isUnit_of_bijective _ h Function.bijective_id
  .mul' S _ _ _

lemma Away.mul_of_isUnit' (x y : R) [IsLocalization.Away y S] (h : IsUnit (algebraMap R S x)) :
    IsLocalization.Away (x * y) S :=
  have : Away (algebraMap R S x) S := away_of_isUnit_of_bijective _ h Function.bijective_id
  .mul S _ _ _

lemma Away.mul_of_associated (x z : R) (y : S) [IsLocalization.Away x S]
    {T : Type*} [CommRing T] [Algebra S T] [Algebra R T] [IsScalarTower R S T]
    [IsLocalization.Away y T]
    (h : Associated (algebraMap R S z) y) : IsLocalization.Away (x * z) T := by
  have : Away (algebraMap R S z) T := by rwa [iff_of_associated h]
  exact .mul' S _ _ _

end AtUnits

section Prod

lemma Away.algebraMap_surjective_of_isIdempotentElem
    (e : R) (he : IsIdempotentElem e) [IsLocalization.Away e S] :
    Function.Surjective (algebraMap R S) := by
  intro x
  obtain ‚ü®x, ‚ü®_, n, rfl‚ü©, rfl‚ü© := IsLocalization.exists_mk'_eq (.powers e) x
  suffices ‚ąÉ a k, e ^ k * (a * e ^ n) = e ^ k * x by
    simpa [IsLocalization.eq_mk'_iff_mul_eq, ‚Üź map_pow, ‚Üź map_mul,
      IsLocalization.eq_iff_exists (.powers e), Submonoid.mem_powers_iff]
  refine ‚ü®x, 1, ?_‚ü©
  trans e ^ (n + 1) * x
  ¬∑ ring
  ¬∑ rw [he.pow_succ_eq]; ring

lemma away_of_isIdempotentElem_of_mul
    {e : R} (he : IsIdempotentElem e)
    (H : ‚ąÄ x y, algebraMap R S x = algebraMap R S y ‚ÜĒ e * x = e * y)
    (H' : Function.Surjective (algebraMap R S)) :
    IsLocalization.Away e S where
  map_units r := by
    obtain ‚ü®r, n, rfl‚ü© := r
    simp [show algebraMap R S e = 1 by rw [‚Üź (algebraMap R S).map_one, H, mul_one, he]]
  surj z := by
    obtain ‚ü®z, rfl‚ü© := H' z
    exact ‚ü®‚ü®z, 1‚ü©, by simp‚ü©
  exists_of_eq {x y} h := ‚ü®‚ü®e, Submonoid.mem_powers e‚ü©, (H x y).mp h‚ü©

lemma away_of_isIdempotentElem {R S} [CommRing R] [CommRing S] [Algebra R S]
    {e : R} (he : IsIdempotentElem e)
    (H : RingHom.ker (algebraMap R S) = Ideal.span {1 - e})
    (H' : Function.Surjective (algebraMap R S)) :
    IsLocalization.Away e S :=
  away_of_isIdempotentElem_of_mul he (fun x y ‚Ü¶ by
    rw [‚Üź sub_eq_zero, ‚Üź map_sub, ‚Üź RingHom.mem_ker, H, ‚Üź he.ker_toSpanSingleton_eq_span,
      LinearMap.mem_ker, LinearMap.toSpanSingleton_apply, sub_smul, sub_eq_zero]
    simp_rw [mul_comm e, smul_eq_mul]) H'

instance away_fst {R S} [CommSemiring R] [CommSemiring S] :
    letI := (RingHom.fst R S).toAlgebra
    IsLocalization.Away (R := R √ó S) (1, 0) R :=
  letI := (RingHom.fst R S).toAlgebra
  away_of_isIdempotentElem_of_mul (by ext <;> simp)
    (fun ‚ü®xR, xS‚ü© ‚ü®yR, yS‚ü© ‚Ü¶ show xR = yR ‚ÜĒ _ by simp) Prod.fst_surjective

instance away_snd {R S} [CommSemiring R] [CommSemiring S] :
    letI := (RingHom.snd R S).toAlgebra
    IsLocalization.Away (R := R √ó S) (0, 1) S :=
  letI := (RingHom.snd R S).toAlgebra
  away_of_isIdempotentElem_of_mul (by ext <;> simp)
    (fun ‚ü®xR, xS‚ü© ‚ü®yR, yS‚ü© ‚Ü¶ show xS = yS ‚ÜĒ _ by simp) Prod.snd_surjective

end Prod

