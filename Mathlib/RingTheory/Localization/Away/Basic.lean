  let r : s := вџЁr, hrsвџ©
  have вџЁвџЁ_, n, rflвџ©, eqвџ© := (IsLocalization.eq_iff_exists (.powers r.1) _).mp (congr_fun eq r)
  exact Set.disjoint_left.mp disj eq вџЁn, rflвџ©

/-- The sheaf condition for the structure sheaf on `Spec R`
for a covering of the whole prime spectrum by basic opens. -/
theorem existsUnique_algebraMap_eq_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = вЉ¤)
