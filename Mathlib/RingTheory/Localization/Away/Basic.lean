variable {S T : Type*} [CommRing S] [CommRing T] [Algebra S T]

open scoped Pointwise in
/-- Suppose `I` is an ideal of `R`, then `R / I` is the localization away from `r : R`
if `r - 1 ‚ąą I` and for some `n`, `r ^ n ‚ÄĘ I = ‚ä•`.
For sake of usability, we state this for surjective ring maps instead of ideals.
For a version with two ideals, see `Away.of_sub_one_mem_ker'`. -/
lemma Away.of_surjective (h‚āĀ : Function.Surjective (algebraMap S T))
    {r : S} (hr : IsUnit (algebraMap S T r))
    (n : ‚Ąē) (hn : r ^ n ‚ÄĘ RingHom.ker (algebraMap S T) ‚Č§ ‚ä•) :
    IsLocalization.Away r T := by
  refine .mk _ hr (fun t ‚Ü¶ ?_) fun x y h ‚Ü¶ ‚ü®n, ?_‚ü©
  ¬∑ obtain ‚ü®s, rfl‚ü© := h‚āĀ t
    exact ‚ü®0, by simp‚ü©
  ¬∑ rw [‚Üź sub_eq_zero, ‚Üź mul_sub]
    exact hn ‚ü®x - y, by simp [h]‚ü©

open scoped Pointwise in
/-- Suppose `J ‚Č§ I` are ideals of `R`, then `R / I` is the localization away from `r : R / J`
if `r - 1 ‚ąą I` and for some `n`, `r ^ n ‚ÄĘ I ‚Č§ J`.
For sake of usability, we state this for surjective ring maps instead of ideals. -/
lemma Away.of_surjective_of_isScalarTower {R : Type*}
    [CommRing R] [Algebra R S] [Algebra R T] [IsScalarTower R S T]
    (h‚āĀ : Function.Surjective (algebraMap S T))
    (h‚āā : Function.Surjective (algebraMap R S))
    (r : R) (hr : IsUnit (algebraMap R T r))
    {n : ‚Ąē} (hn : r ^ n ‚ÄĘ RingHom.ker (algebraMap R T) ‚Č§ RingHom.ker (algebraMap R S)) :
    IsLocalization.Away (algebraMap R S r) T := by
  refine Away.of_surjective h‚āĀ ?_ n ?_
  ¬∑ rwa [‚Üź IsScalarTower.algebraMap_apply]
  ¬∑ rw [‚Üź (RingHom.ker (algebraMap S T)).map_comap_of_surjective _ h‚āā, ‚Üź map_pow,
      ‚Üź Ideal.map_pointwise_smul, RingHom.comap_ker, ‚Üź IsScalarTower.algebraMap_eq]
    rwa [RingHom.ker_eq_comap_bot (algebraMap R S), ‚Üź Ideal.map_le_iff_le_comap] at hn

end

