/-!
# Localizations away from an element

## Main definitions

 * `IsLocalization.Away (x : R) S` expresses that `S` is a localization away from `x`, as an
   abbreviation of `IsLocalization (Submonoid.powers x) S`.
 * `exists_reduced_fraction' (hb : b Ôëá 0)` produces a reduced fraction of the form `b = a * x^n` for
   some `n : ÔäĄ` and some `a : R` that is not divisible by `x`.

## Implementation notes

See `Mathlib/RingTheory/Localization/Basic.lean` for a design overview.

## Tags
localization, ring localization, commutative ring localization, characteristic predicate,
commutative ring, field of fractions
-/


section CommSemiring

variable {R : Type*} [CommSemiring R] (M : Submonoid R) {S : Type*} [CommSemiring S]
variable [Algebra R S] {P : Type*} [CommSemiring P]

namespace IsLocalization

section Away

variable (x : R)

/-- Given `x : R`, the typeclass `IsLocalization.Away x S` states that `S` is
isomorphic to the localization of `R` at the submonoid generated by `x`.
See `IsLocalization.Away.mk` for a specialized constructor. -/
abbrev Away (S : Type*) [CommSemiring S] [Algebra R S] :=
  IsLocalization (Submonoid.powers x) S

namespace Away

variable [IsLocalization.Away x S]

/-- Given `x : R` and a localization map `F : R Ôćĺ+* S` away from `x`, `invSelf` is `(F x)Ôü╗┬╣`. -/
noncomputable def invSelf : S :=
  mk' S (1 : R) ÔčĘx, Submonoid.mem_powers _Ôčę

@[simp]
theorem mul_invSelf : algebraMap R S x * invSelf x = 1 := by
  convert IsLocalization.mk'_mul_mk'_eq_one (M := Submonoid.powers x) (S := S) _ 1
  symm
  apply IsLocalization.mk'_one

/-- For `s : S` with `S` being the localization of `R` away from `x`,
this is a choice of `(r, n) : R ├Ś ÔäĽ` such that `s * algebraMap R S (x ^ n) = algebraMap R S r`. -/
noncomputable def sec (s : S) : R ├Ś ÔäĽ :=
  ÔčĘ(IsLocalization.sec (Submonoid.powers x) s).1,
   (IsLocalization.sec (Submonoid.powers x) s).2.property.chooseÔčę

lemma sec_spec (s : S) : s * (algebraMap R S) (x ^ (IsLocalization.Away.sec x s).2) =
    algebraMap R S (IsLocalization.Away.sec x s).1 := by
  simp only [IsLocalization.Away.sec, ÔćÉ IsLocalization.sec_spec]
  congr
  exact (IsLocalization.sec (Submonoid.powers x) s).2.property.choose_spec

lemma algebraMap_pow_isUnit (n : ÔäĽ) : IsUnit (algebraMap R S x ^ n) :=
  IsUnit.pow _ <| IsLocalization.map_units _ (ÔčĘx, 1, by simpÔčę : Submonoid.powers x)

lemma algebraMap_isUnit : IsUnit (algebraMap R S x) :=
  IsLocalization.map_units _ (ÔčĘx, 1, by simpÔčę : Submonoid.powers x)

lemma algebraMap_isUnit_iff {y : R} : IsUnit (algebraMap R S y) Ôćö Ôłâ n, y Ôłú x ^ n :=
  (IsLocalization.algebraMap_isUnit_iff <| .powers x).trans <| by simp [Submonoid.mem_powers_iff]

lemma surj (z : S) : Ôłâ (n : ÔäĽ) (a : R), z * algebraMap R S x ^ n = algebraMap R S a := by
  obtain ÔčĘÔčĘa, ÔčĘ-, n, rflÔčęÔčę, hÔčę := IsLocalization.surj (Submonoid.powers x) z
  use n, a
  simpa using h

lemma exists_of_eq {a b : R} (h : algebraMap R S a = algebraMap R S b) :
    Ôłâ (n : ÔäĽ), x ^ n * a = x ^ n * b := by
  obtain ÔčĘÔčĘ-, n, rflÔčę, hxÔčę := IsLocalization.exists_of_eq (M := Submonoid.powers x) h
  use n

/-- Specialized constructor for `IsLocalization.Away`. -/
lemma mk (r : R) (map_unit : IsUnit (algebraMap R S r))
    (surj : ÔłÇ s, Ôłâ (n : ÔäĽ) (a : R), s * algebraMap R S r ^ n = algebraMap R S a)
    (exists_of_eq : ÔłÇ a b, algebraMap R S a = algebraMap R S b Ôćĺ Ôłâ (n : ÔäĽ), r ^ n * a = r ^ n * b) :
    IsLocalization.Away r S where
  map_units' := by
    rintro ÔčĘ-, n, rflÔčę
    simp only [map_pow]
    exact IsUnit.pow _ map_unit
  surj' z := by
    obtain ÔčĘn, a, hnÔčę := surj z
    use ÔčĘa, ÔčĘr ^ n, n, rflÔčęÔčę
    simpa using hn
  exists_of_eq {x y} h := by
    obtain ÔčĘn, hnÔčę := exists_of_eq x y h
    use ÔčĘr ^ n, n, rflÔčę

lemma of_associated {r r' : R} (h : Associated r r') [IsLocalization.Away r S] :
    IsLocalization.Away r' S := by
  obtain ÔčĘu, rflÔčę := h
  refine mk _ ?_ (fun s ÔćŽ ?_) (fun a b hab ÔćŽ ?_)
  ┬Ě simp [algebraMap_isUnit r, IsUnit.map _ u.isUnit]
  ┬Ě obtain ÔčĘn, a, hnÔčę := surj r s
    use n, a * u ^ n
    simp [mul_pow, ÔćÉ mul_assoc, hn]
  ┬Ě obtain ÔčĘn, hnÔčę := exists_of_eq r hab
    use n
    rw [mul_pow, mul_comm (r ^ n), mul_assoc, mul_assoc, hn]

/-- If `r` and `r'` are associated elements of `R`, an `R`-algebra `S`
is the localization of `R` away from `r` if and only of it is the localization of `R` away from
`r'`. -/
lemma iff_of_associated {r r' : R} (h : Associated r r') :
    IsLocalization.Away r S Ôćö IsLocalization.Away r' S :=
  ÔčĘfun _ ÔćŽ IsLocalization.Away.of_associated h, fun _ ÔćŽ IsLocalization.Away.of_associated h.symmÔčę

lemma isUnit_of_dvd {r : R} (h : r Ôłú x) : IsUnit (algebraMap R S r) :=
  isUnit_of_dvd_unit (map_dvd _ h) (algebraMap_isUnit x)

variable {g : R Ôćĺ+* P}

/-- Given `x : R`, a localization map `F : R Ôćĺ+* S` away from `x`, and a map of `CommSemiring`s
`g : R Ôćĺ+* P` such that `g x` is invertible, the homomorphism induced from `S` to `P` sending
`z : S` to `g y * (g x)Ôü╗Ôü┐`, where `y : R, n : ÔäĽ` are such that `z = F y * (F x)Ôü╗Ôü┐`. -/
noncomputable def lift (hg : IsUnit (g x)) : S Ôćĺ+* P :=
  IsLocalization.lift fun y : Submonoid.powers x =>
    show IsUnit (g y.1) by
      obtain ÔčĘn, hnÔčę := y.2
      rw [ÔćÉ hn, g.map_pow]
      exact IsUnit.map (powMonoidHom n : P Ôćĺ* P) hg

@[simp]
theorem lift_eq (hg : IsUnit (g x)) (a : R) : lift x hg (algebraMap R S a) = g a :=
  IsLocalization.lift_eq _ _

@[simp]
theorem lift_comp (hg : IsUnit (g x)) : (lift x hg).comp (algebraMap R S) = g :=
  IsLocalization.lift_comp _

@[deprecated (since := "2024-11-25")] alias AwayMap.lift_eq := lift_eq
@[deprecated (since := "2024-11-25")] alias AwayMap.lift_comp := lift_comp

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `y * x`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayLeft (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] : S Ôćĺ+* P :=
  lift x <| isUnit_of_dvd (y * x) (dvd_mul_left _ _)

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `x * y`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayRight (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] : S Ôćĺ+* P :=
  lift x <| isUnit_of_dvd (x * y) (dvd_mul_right _ _)

theorem awayToAwayLeft_eq (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] (a : R) :
    awayToAwayLeft x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

theorem awayToAwayRight_eq (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] (a : R) :
    awayToAwayRight x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

variable (S) (Q : Type*) [CommSemiring Q] [Algebra P Q]

/-- Given a map `f : R Ôćĺ+* S` and an element `r : R`, we may construct a map `RßÁú Ôćĺ+* SßÁú`. -/
noncomputable def map (f : R Ôćĺ+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] : S Ôćĺ+* Q :=
  IsLocalization.map Q f
    (show Submonoid.powers r ÔëĄ (Submonoid.powers (f r)).comap f by
      rintro x ÔčĘn, rflÔčę
      use n
      simp)

section Algebra

variable {A : Type*} [CommSemiring A] [Algebra R A]
variable {B : Type*} [CommSemiring B] [Algebra R B]
variable (AÔéÜ : Type*) [CommSemiring AÔéÜ] [Algebra A AÔéÜ] [Algebra R AÔéÜ] [IsScalarTower R A AÔéÜ]
variable (BÔéÜ : Type*) [CommSemiring BÔéÜ] [Algebra B BÔéÜ] [Algebra R BÔéÜ] [IsScalarTower R B BÔéÜ]

instance {f : A Ôćĺ+* B} (a : A) [Away (f a) BÔéÜ] : IsLocalization (.map f (.powers a)) BÔéÜ := by
  simpa

/-- Given a algebra map `f : A ÔćĺÔéÉ[R] B` and an element `a : A`, we may construct a map
`AÔéÉ ÔćĺÔéÉ[R] BÔéÉ`. -/
noncomputable def mapÔéÉ (f : A ÔćĺÔéÉ[R] B) (a : A) [Away a AÔéÜ] [Away (f a) BÔéÜ] : AÔéÜ ÔćĺÔéÉ[R] BÔéÜ :=
  ÔčĘmap AÔéÜ BÔéÜ f.toRingHom a, fun r ÔćŽ by
    dsimp only [AlgHom.toRingHom_eq_coe, map, RingHom.coe_coe, OneHom.toFun_eq_coe]
    rw [IsScalarTower.algebraMap_apply R A AÔéÜ, IsScalarTower.algebraMap_eq R B BÔéÜ]
    simpÔčę

@[simp]
lemma mapÔéÉ_apply (f : A ÔćĺÔéÉ[R] B) (a : A) [Away a AÔéÜ] [Away (f a) BÔéÜ] (x : AÔéÜ) :
    mapÔéÉ AÔéÜ BÔéÜ f a x = map AÔéÜ BÔéÜ f.toRingHom a x :=
  rfl

variable {AÔéÜ} {BÔéÜ}

lemma mapÔéÉ_injective_of_injective {f : A ÔćĺÔéÉ[R] B} (a : A) [Away a AÔéÜ] [Away (f a) BÔéÜ]
    (hf : Function.Injective f) : Function.Injective (mapÔéÉ AÔéÜ BÔéÜ f a) :=
  IsLocalization.map_injective_of_injective _ _ _ hf

lemma mapÔéÉ_surjective_of_surjective {f : A ÔćĺÔéÉ[R] B} (a : A) [Away a AÔéÜ] [Away (f a) BÔéÜ]
    (hf : Function.Surjective f) : Function.Surjective (mapÔéÉ AÔéÜ BÔéÜ f a) :=
  have : IsLocalization (Submonoid.map f.toRingHom (Submonoid.powers a)) BÔéÜ := by
    simp only [AlgHom.toRingHom_eq_coe, Submonoid.map_powers, RingHom.coe_coe]
    infer_instance
  IsLocalization.map_surjective_of_surjective _ _ _ hf

end Algebra

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. See `IsLocalization.Away.mul'` for the `x * y` version. -/
lemma mul (T : Type*) [CommSemiring T] [Algebra S T]
    [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (y * x) T := by
  refine mk _ ?_ (fun z ÔćŽ ?_) (fun a b h ÔćŽ ?_)
  ┬Ě simp only [map_mul, IsUnit.mul_iff, IsScalarTower.algebraMap_apply R S T]
    exact ÔčĘalgebraMap_isUnit _, IsUnit.map _ (algebraMap_isUnit x)Ôčę
  ┬Ě obtain ÔčĘm, p, hpqÔčę := surj (algebraMap R S y) z
    obtain ÔčĘn, a, habÔčę := surj x p
    use m + n, a * x ^ m * y ^ n
    simp only [mul_pow, pow_add, map_pow, map_mul, ÔćÉ mul_assoc, hpq,
      IsScalarTower.algebraMap_apply R S T, ÔćÉ hab]
    ring
  ┬Ě repeat rw [IsScalarTower.algebraMap_apply R S T] at h
    obtain ÔčĘn, hnÔčę := exists_of_eq (algebraMap R S y) h
    simp only [ÔćÉ map_pow, ÔćÉ map_mul, ÔćÉ map_mul] at hn
    obtain ÔčĘm, hmÔčę := exists_of_eq x hn
    use n + m
    convert_to y ^ m * x ^ n * (x ^ m * (y ^ n * a)) = y ^ m * x ^ n * (x ^ m * (y ^ n * b))
    ┬Ě ring
    ┬Ě ring
    ┬Ě rw [hm]

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. See `IsLocalization.Away.mul` for the `y * x` version. -/
lemma mul' (T : Type*) [CommSemiring T] [Algebra S T] [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (x * y) T :=
  mul_comm x y ÔľŞ mul S T x y

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (y * x) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul S (Localization.Away (algebraMap R S y)) _ _

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (x * y) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul' S (Localization.Away (algebraMap R S y)) _ _

/-- If `SÔéü` is the localization of `R` away from `f` and `SÔéé` is the localization away from `g`,
then any localization `T` of `SÔéé` away from `f` is also a localization of `SÔéü` away from `g`. -/
lemma commutes {R : Type*} [CommSemiring R] (SÔéü SÔéé T : Type*) [CommSemiring SÔéü]
    [CommSemiring SÔéé] [CommSemiring T] [Algebra R SÔéü] [Algebra R SÔéé] [Algebra R T] [Algebra SÔéü T]
    [Algebra SÔéé T] [IsScalarTower R SÔéü T] [IsScalarTower R SÔéé T] (x y : R)
    [IsLocalization.Away x SÔéü] [IsLocalization.Away y SÔéé]
    [IsLocalization.Away (algebraMap R SÔéé x) T] :
    IsLocalization.Away (algebraMap R SÔéü y) T := by
  haveI : IsLocalization (Algebra.algebraMapSubmonoid SÔéé (Submonoid.powers x)) T := by
    simp only [Algebra.algebraMapSubmonoid, Submonoid.map_powers]
    infer_instance
  convert IsLocalization.commutes SÔéü SÔéé T (Submonoid.powers x) (Submonoid.powers y)
  ext x
  simp [Algebra.algebraMapSubmonoid]

end Away

end Away

