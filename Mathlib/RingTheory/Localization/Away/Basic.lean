section NumDen

open IsLocalization

variable (x : R)
variable (B : Type*) [CommSemiring B] [Algebra R B] [IsLocalization.Away x B]

/-- `selfZPow x (m : ‚Ą§)` is `x ^ m` as an element of the localization away from `x`. -/
noncomputable def selfZPow (m : ‚Ą§) : B :=
  if _ : 0 ‚Č§ m then algebraMap _ _ x ^ m.natAbs else mk' _ (1 : R) (Submonoid.pow x m.natAbs)

theorem selfZPow_of_nonneg {n : ‚Ą§} (hn : 0 ‚Č§ n) : selfZPow x B n = algebraMap R B x ^ n.natAbs :=
  dif_pos hn

@[simp]
theorem selfZPow_natCast (d : ‚Ąē) : selfZPow x B d = algebraMap R B x ^ d :=
  selfZPow_of_nonneg _ _ (Int.natCast_nonneg d)

@[simp]
theorem selfZPow_zero : selfZPow x B 0 = 1 := by
  simp [selfZPow_of_nonneg _ _ le_rfl]

theorem selfZPow_of_neg {n : ‚Ą§} (hn : n < 0) :
    selfZPow x B n = mk' _ (1 : R) (Submonoid.pow x n.natAbs) :=
  dif_neg hn.not_ge

theorem selfZPow_of_nonpos {n : ‚Ą§} (hn : n ‚Č§ 0) :
    selfZPow x B n = mk' _ (1 : R) (Submonoid.pow x n.natAbs) := by
  by_cases hn0 : n = 0
  ¬∑ simp [hn0, selfZPow_zero, Submonoid.pow_apply]
  ¬∑ simp [selfZPow_of_neg _ _ (lt_of_le_of_ne hn hn0)]

@[simp]
theorem selfZPow_neg_natCast (d : ‚Ąē) : selfZPow x B (-d) = mk' _ (1 : R) (Submonoid.pow x d) := by
  simp [selfZPow_of_nonpos _ _ (neg_nonpos.mpr (Int.natCast_nonneg d))]

@[simp]
theorem selfZPow_sub_natCast {n m : ‚Ąē} :
    selfZPow x B (n - m) = mk' _ (x ^ n) (Submonoid.pow x m) := by
  by_cases! h : m ‚Č§ n
  ¬∑ rw [IsLocalization.eq_mk'_iff_mul_eq, Submonoid.pow_apply, Subtype.coe_mk, ‚Üź Int.ofNat_sub h,
      selfZPow_natCast, ‚Üź map_pow, ‚Üź map_mul, ‚Üź pow_add, Nat.sub_add_cancel h]
  ¬∑ rw [‚Üź neg_sub, ‚Üź Int.ofNat_sub h.le, selfZPow_neg_natCast, IsLocalization.mk'_eq_iff_eq]
    simp [Submonoid.pow_apply, ‚Üź pow_add, Nat.sub_add_cancel h.le]

@[simp]
theorem selfZPow_add {n m : ‚Ą§} : selfZPow x B (n + m) = selfZPow x B n * selfZPow x B m := by
  rcases le_or_gt 0 n with hn | hn <;> rcases le_or_gt 0 m with hm | hm
  ¬∑ rw [selfZPow_of_nonneg _ _ hn, selfZPow_of_nonneg _ _ hm,
      selfZPow_of_nonneg _ _ (add_nonneg hn hm), Int.natAbs_add_of_nonneg hn hm, pow_add]
  ¬∑ have : n + m = n.natAbs - m.natAbs := by
      rw [Int.natAbs_of_nonneg hn, Int.ofNat_natAbs_of_nonpos hm.le, sub_neg_eq_add]
    rw [selfZPow_of_nonneg _ _ hn, selfZPow_of_neg _ _ hm, this, selfZPow_sub_natCast,
      IsLocalization.mk'_eq_mul_mk'_one, map_pow]
  ¬∑ have : n + m = m.natAbs - n.natAbs := by
      rw [Int.natAbs_of_nonneg hm, Int.ofNat_natAbs_of_nonpos hn.le, sub_neg_eq_add, add_comm]
    rw [selfZPow_of_nonneg _ _ hm, selfZPow_of_neg _ _ hn, this, selfZPow_sub_natCast,
      IsLocalization.mk'_eq_mul_mk'_one, map_pow, mul_comm]
  ¬∑ rw [selfZPow_of_neg _ _ hn, selfZPow_of_neg _ _ hm, selfZPow_of_neg _ _ (add_neg hn hm),
      Int.natAbs_add_of_nonpos hn.le hm.le, ‚Üź mk'_mul, one_mul]
    congr
    ext
    simp [pow_add]

theorem selfZPow_mul_neg (d : ‚Ą§) : selfZPow x B d * selfZPow x B (-d) = 1 := by
  by_cases! hd : d ‚Č§ 0
  ¬∑ rw [selfZPow_of_nonpos x B hd, selfZPow_of_nonneg, ‚Üź map_pow, Int.natAbs_neg,
      Submonoid.pow_apply, IsLocalization.mk'_spec, map_one]
    apply nonneg_of_neg_nonpos
    rwa [neg_neg]
  ¬∑ rw [selfZPow_of_nonneg x B hd.le, selfZPow_of_nonpos, ‚Üź map_pow, Int.natAbs_neg,
      Submonoid.pow_apply, IsLocalization.mk'_spec'_mk, map_one]
    refine nonpos_of_neg_nonneg (le_of_lt ?_)
    rwa [neg_neg]

theorem selfZPow_neg_mul (d : ‚Ą§) : selfZPow x B (-d) * selfZPow x B d = 1 := by
  rw [mul_comm, selfZPow_mul_neg x B d]

theorem selfZPow_pow_sub (a : R) (b : B) (m d : ‚Ą§) :
    selfZPow x B (m - d) * mk' B a (1 : Submonoid.powers x) = b ‚ÜĒ
      selfZPow x B m * mk' B a (1 : Submonoid.powers x) = selfZPow x B d * b := by
  rw [sub_eq_add_neg, selfZPow_add, mul_assoc, mul_comm _ (mk' B a 1), ‚Üź mul_assoc]
  constructor
  ¬∑ intro h
    have := congr_arg (fun s : B => s * selfZPow x B d) h
    rwa [mul_assoc, mul_assoc, selfZPow_neg_mul, mul_one, mul_comm b _] at this
  ¬∑ intro h
    have := congr_arg (fun s : B => s * selfZPow x B (-d)) h
    rwa [mul_comm _ b, mul_assoc b _ _, selfZPow_mul_neg, mul_one] at this

variable {R : Type*} [CommRing R] (x : R) (B : Type*) [CommRing B]
variable [Algebra R B] [IsLocalization.Away x B] [IsDomain R] [WfDvdMonoid R]

theorem exists_reduced_fraction' {b : B} (hb : b ‚Č† 0) (hx : Irreducible x) :
    ‚ąÉ (a : R) (n : ‚Ą§), ¬¨x ‚ą£ a ‚ąß selfZPow x B n * algebraMap R B a = b := by
  obtain ‚ü®‚ü®a‚āÄ, y‚ü©, H‚ü© := surj (Submonoid.powers x) b
  obtain ‚ü®d, hy‚ü© := (Submonoid.mem_powers_iff y.1 x).mp y.2
  have ha‚āÄ : a‚āÄ ‚Č† 0 := by
    haveI := isDomain_of_le_nonZeroDivisors B
      (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
    simp only [‚Üź hy, map_pow] at H
    apply ((injective_iff_map_eq_zero' (algebraMap R B)).mp _ a‚āÄ).mpr.mt
    ¬∑ rw [‚Üź H]
      apply mul_ne_zero hb (pow_ne_zero _ _)
      exact
        IsLocalization.to_map_ne_zero_of_mem_nonZeroDivisors B
          (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
          (mem_nonZeroDivisors_iff_ne_zero.mpr hx.ne_zero)
    ¬∑ exact IsLocalization.injective B (powers_le_nonZeroDivisors_of_noZeroDivisors hx.ne_zero)
  simp only [‚Üź hy] at H
  obtain ‚ü®m, a, hyp1, hyp2‚ü© := WfDvdMonoid.max_power_factor ha‚āÄ hx
  refine ‚ü®a, m - d, ?_‚ü©
  rw [‚Üź mk'_one (M := Submonoid.powers x) B, selfZPow_pow_sub, selfZPow_natCast, selfZPow_natCast,
    ‚Üź map_pow _ _ d, mul_comm _ b, H, hyp2, map_mul, map_pow _ _ m]
  exact ‚ü®hyp1, congr_arg _ (IsLocalization.mk'_one _ _)‚ü©

end NumDen
