/-- Given a map `f : R ‚Üí+* S` and an element `r : R`, such that `f r` is invertible,
  we may construct a map `RŠĶ£ ‚Üí+* S`. -/
noncomputable abbrev awayLift (f : R ‚Üí+* P) (r : R) (hr : IsUnit (f r)) :
    Localization.Away r ‚Üí+* P :=
  IsLocalization.Away.lift r hr

lemma awayLift_mk {A : Type*} [CommSemiring A] (f : R ‚Üí+* A) (r : R)
    (a : R) (v : A) (hv : f r * v = 1) (j : ‚Ąē) :
    Localization.awayLift f r (isUnit_iff_exists_inv.mpr ‚ü®v, hv‚ü©)
      (Localization.mk a ‚ü®r ^ j, j, rfl‚ü©) = f a * v ^ j := by
  simp [Localization.mk_eq_mk', awayLift, Away.lift, IsLocalization.lift_mk',
    Units.mul_inv_eq_iff_eq_mul, IsUnit.liftRight, mul_assoc, ‚Üź mul_pow, (mul_comm _ _).trans hv]

/-- Given a map `f : R ‚Üí+* S` and an element `r : R`, we may construct a map `RŠĶ£ ‚Üí+* SŠĶ£`. -/
noncomputable abbrev awayMap (f : R ‚Üí+* P) (r : R) :
    Localization.Away r ‚Üí+* Localization.Away (f r) :=
  IsLocalization.Away.map _ _ f r

lemma awayMap_injective_iff {R : Type*} [CommRing R] {f : R ‚Üí+* S} {r : R} :
    Function.Injective (Localization.awayMap f r) ‚ÜĒ ‚ąÄ a, f a = 0 ‚Üí ‚ąÉ n, r ^ n * a = 0 :=
  IsLocalization.Away.map_injective_iff _ _ _

omit [Algebra R S] in
lemma awayMap_surjective_iff {f : R ‚Üí+* S} {r : R} :
    Function.Surjective (Localization.awayMap f r) ‚ÜĒ ‚ąÄ a, ‚ąÉ b m, f b = f r ^ m * a :=
  IsLocalization.Away.map_surjective_iff _ _ _ _

lemma awayMap_injective_of_dvd {R : Type*} [CommRing R] (f : R ‚Üí+* S)
    {a b : R} (h : a ‚ą£ b) (H : Function.Injective (awayMap f a)) :
    Function.Injective (awayMap f b) := by
  simp only [awayMap_injective_iff] at H ‚äĘ
  obtain ‚ü®b, rfl‚ü© := h
  refine fun x hx ‚Ü¶ ?_
  obtain ‚ü®n, hn‚ü© := H x hx
  exact ‚ü®n, by simp [mul_pow, mul_assoc, mul_left_comm (a ^ n), hn]‚ü©

omit [Algebra R S] in
lemma awayMap_surjective_of_dvd (f : R ‚Üí+* S)
    {a b : R} (h : a ‚ą£ b) (H : Function.Surjective (awayMap f a)) :
    Function.Surjective (awayMap f b) := by
  simp only [awayMap_surjective_iff] at H ‚äĘ
  obtain ‚ü®b, rfl‚ü© := h
  refine fun x ‚Ü¶ ?_
  obtain ‚ü®c, m, e‚ü© := H x
  exact ‚ü®b ^ m * c, m, by simp [mul_pow, e, mul_assoc, mul_left_comm]‚ü©

lemma awayMap_bijective_of_dvd {R : Type*} [CommRing R] (f : R ‚Üí+* S)
    {a b : R} (h : a ‚ą£ b) (H : Function.Bijective (awayMap f a)) :
    Function.Bijective (awayMap f b) :=
  ‚ü®awayMap_injective_of_dvd f h H.1, awayMap_surjective_of_dvd f h H.2‚ü©

omit [Algebra R S] in
lemma awayMap_awayMap_surjective (f : R ‚Üí+* S) (a b : R)
    (H : Function.Surjective (awayMap f (a * b))) :
    Function.Surjective (awayMap (awayMap f a) (algebraMap _ _ b)) := by
  rw [awayMap_surjective_iff] at H ‚äĘ
  suffices ‚ąÄ (s : S) (n : ‚Ąē), ‚ąÉ c l m k, f (a ^ (k + n) * c) =
      f (a ^ (k + l) * b ^ m) * s by
    simpa [Function.Surjective, (IsLocalization.mk'_surjective (.powers (f a))).forall, ‚Üź map_pow,
      (IsLocalization.mk'_surjective (.powers a)).exists, Submonoid.mem_powers_iff, pow_add,
      Localization.awayMap, IsLocalization.Away.map, IsLocalization.map_mk', ‚Üź mul_assoc,
      IsLocalization.mk'_eq_iff_eq, ‚Üź map_mul, IsLocalization.eq_iff_exists (.powers (f a)),
      IsLocalization.mul_mk'_eq_mk'_of_mul]
  intro s n
  obtain ‚ü®c, m, e‚ü© := H s
  exact ‚ü®c, n + m, m, 0, by simp [e, pow_add]; ring‚ü©

variable {A : Type*} [CommSemiring A] [Algebra R A]
variable {B : Type*} [CommSemiring B] [Algebra R B]

/-- Given a map `f : A ‚Üí‚āź[R] B` and an element `a : A`, we may construct a map `A‚āź ‚Üí‚āź[R] B‚āź`. -/
noncomputable abbrev awayMap‚āź (f : A ‚Üí‚āź[R] B) (a : A) :
    Localization.Away a ‚Üí‚āź[R] Localization.Away (f a) :=
  IsLocalization.Away.map‚āź _ _ f a

theorem algebraMap_injective_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = ‚ä§) :
    Function.Injective (algebraMap R <| ő† a : s, Away a.1) := fun x y eq ‚Ü¶ by
  suffices Module.eqIdeal R x y = ‚ä§ by simpa [Module.eqIdeal] using (Ideal.eq_top_iff_one _).mp this
  by_contra ne
  have ‚ü®r, hrs, disj‚ü© := Ideal.exists_disjoint_powers_of_span_eq_top s span_eq _ ne
  let r : s := ‚ü®r, hrs‚ü©
  have ‚ü®‚ü®_, n, rfl‚ü©, eq‚ü© := (IsLocalization.eq_iff_exists (.powers r.1) _).mp (congr_fun eq r)
  exact Set.disjoint_left.mp disj eq ‚ü®n, rfl‚ü©

/-- The sheaf condition for the structure sheaf on `Spec R`
for a covering of the whole prime spectrum by basic opens. -/
theorem existsUnique_algebraMap_eq_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = ‚ä§)
    (f : ő† a : s, Away a.1) (h : ‚ąÄ a b : s,
      Away.awayToAwayRight (P := Away (a * b : R)) a.1 b (f a) = Away.awayToAwayLeft b.1 a (f b)) :
    ‚ąÉ! r : R, ‚ąÄ a : s, algebraMap R _ r = f a := by
  have mem := (Ideal.eq_top_iff_one _).mp span_eq; clear span_eq
  wlog finset_eq : ‚ąÉ t : Finset R, t = s generalizing s
  ¬∑ have ‚ü®t, hts, mem‚ü© := Submodule.mem_span_finite_of_mem_span mem
    have ‚ü®r, eq, uniq‚ü© := this t (fun a ‚Ü¶ f ‚ü®a, hts a.2‚ü©)
      (fun a b ‚Ü¶ h ‚ü®a, hts a.2‚ü© ‚ü®b, hts b.2‚ü©) mem ‚ü®_, rfl‚ü©
    refine ‚ü®r, fun a ‚Ü¶ ?_, fun _ eq ‚Ü¶ uniq _ fun a ‚Ü¶ eq ‚ü®a, hts a.2‚ü©‚ü©
    replace hts := Set.insert_subset a.2 hts
    classical
    have ‚ü®r', eq, _‚ü© := this ({a.1} ‚ą™ t) (fun a ‚Ü¶ f ‚ü®a, hts a.2‚ü©) (fun a b ‚Ü¶
      h ‚ü®a, hts a.2‚ü© ‚ü®b, hts b.2‚ü©) (Ideal.span_mono (fun _ ‚Ü¶ .inr) mem) ‚ü®{a.1} ‚ą™ t, by simp‚ü©
    exact (congr_arg _ (uniq _ fun b ‚Ü¶ eq ‚ü®b, .inr b.2‚ü©).symm).trans (eq ‚ü®a, .inl rfl‚ü©)
  have span_eq := (Ideal.eq_top_iff_one _).mpr mem
  refine existsUnique_of_exists_of_unique ?_ fun x y hx hy ‚Ü¶
    algebraMap_injective_of_span_eq_top s span_eq (funext fun a ‚Ü¶ (hx a).trans (hy a).symm)
  obtain ‚ü®s, rfl‚ü© := finset_eq
  choose n r eq using fun a ‚Ü¶ Away.surj a.1 (f a)
  let N := s.attach.sup n
  let r a := a ^ (N - n a) * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, ‚Üź eq, mul_left_comm, ‚Üź map_pow, ‚Üź map_mul, ‚Üź pow_add,
      Nat.sub_add_cancel (Finset.le_sup <| s.mem_attach a)]
  have eq2 a b : ‚ąÉ N', (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) :=
    Away.exists_of_eq (S := Away (a * b : R)) _ <| by
      simp_rw [map_mul, ‚Üź Away.awayToAwayRight_eq (S := Away a.1) a.1 b (r a),
        ‚Üź Away.awayToAwayLeft_eq (S := Away b.1) b.1 a (r b), ‚Üź eq, map_mul,
        Away.awayToAwayRight_eq, Away.awayToAwayLeft_eq, h, mul_assoc, ‚Üź map_mul, mul_comm]
  choose N' hN' using eq2
  let N' := (s √óňĘ s).attach.sup fun a ‚Ü¶ N'
    ‚ü®_, (Finset.mem_product.mp a.2).1‚ü© ‚ü®_, (Finset.mem_product.mp a.2).2‚ü©
  have eq2 a b : (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) := by
    dsimp only [N']; rw [‚Üź Nat.sub_add_cancel (Finset.le_sup <| (Finset.mem_attach _ ‚ü®‚ü®a, b‚ü©,
      Finset.mk_mem_product a.2 b.2‚ü©)), pow_add, mul_assoc, hN', ‚Üź mul_assoc]
  let N := N' + N
  let r a := a ^ N' * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, ‚Üź eq, mul_left_comm, ‚Üź map_mul, ‚Üź pow_add]
  have eq2 a b : r a * b ^ N = r b * a ^ N := by
    rw [pow_add, mul_mul_mul_comm, ‚Üź mul_pow, eq2,
      mul_comm a.1, mul_pow, mul_mul_mul_comm, ‚Üź pow_add]
  have ‚ü®c, eq1‚ü© := (Submodule.mem_span_range_iff_exists_fun _).mp <|
    (Ideal.eq_top_iff_one _).mp <| (Set.image_eq_range _ _ ‚Ėł Ideal.span_pow_eq_top _ span_eq N)
  refine ‚ü®‚ąĎ b, c b * r b, fun a ‚Ü¶ ((Away.algebraMap_isUnit a.1).pow N).mul_left_inj.mp ?_‚ü©
  simp_rw [‚Üź map_pow, eq, ‚Üź map_mul, Finset.sum_mul, mul_assoc, eq2 _ a, mul_left_comm (c _),
    ‚Üź Finset.mul_sum, ‚Üź smul_eq_mul (a := c _), eq1, mul_one]

