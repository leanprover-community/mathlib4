theorem algebraMap_injective_of_span_eq_top (s : Set R) (span_eq : Ideal.span s = вЉ¤) :
    Function.Injective (algebraMap R <| О  a : s, Away a.1) := fun x y eq в†¦ by
  suffices Module.eqIdeal R x y = вЉ¤ by simpa [Module.eqIdeal] using (Ideal.eq_top_iff_one _).mp this
  by_contra ne
