    have вџЁr', eq, _вџ© := this ({a.1} в€Є t) (fun a в†¦ f вџЁa, hts a.2вџ©) (fun a b в†¦
      h вџЁa, hts a.2вџ© вџЁb, hts b.2вџ©) (Ideal.span_mono (fun _ в†¦ .inr) mem) вџЁ{a.1} в€Є t, by simpвџ©
    exact (congr_arg _ (uniq _ fun b в†¦ eq вџЁb, .inr b.2вџ©).symm).trans (eq вџЁa, .inl rflвџ©)
  have span_eq := (Ideal.eq_top_iff_one _).mpr mem
  refine existsUnique_of_exists_of_unique ?_ fun x y hx hy в†¦
    algebraMap_injective_of_span_eq_top s span_eq (funext fun a в†¦ (hx a).trans (hy a).symm)
  obtain вџЁs, rflвџ© := finset_eq
  choose n r eq using fun a в†¦ Away.surj a.1 (f a)
  let N := s.attach.sup n
  let r a := a ^ (N - n a) * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, в†ђ eq, mul_left_comm, в†ђ map_pow, в†ђ map_mul, в†ђ pow_add,
      Nat.sub_add_cancel (Finset.le_sup <| s.mem_attach a)]
  have eq2 a b : в€ѓ N', (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) :=
    Away.exists_of_eq (S := Away (a * b : R)) _ <| by
      simp_rw [map_mul, в†ђ Away.awayToAwayRight_eq (S := Away a.1) a.1 b (r a),
        в†ђ Away.awayToAwayLeft_eq (S := Away b.1) b.1 a (r b), в†ђ eq, map_mul,
        Away.awayToAwayRight_eq, Away.awayToAwayLeft_eq, h, mul_assoc, в†ђ map_mul, mul_comm]
  choose N' hN' using eq2
  let N' := (s Г—Лў s).attach.sup fun a в†¦ N'
    вџЁ_, (Finset.mem_product.mp a.2).1вџ© вџЁ_, (Finset.mem_product.mp a.2).2вџ©
  have eq2 a b : (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) := by
    dsimp only [N']; rw [в†ђ Nat.sub_add_cancel (Finset.le_sup <| (Finset.mem_attach _ вџЁвџЁa, bвџ©,
      Finset.mk_mem_product a.2 b.2вџ©)), pow_add, mul_assoc, hN', в†ђ mul_assoc]
  let N := N' + N
  let r a := a ^ N' * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, в†ђ eq, mul_left_comm, в†ђ map_mul, в†ђ pow_add]
  have eq2 a b : r a * b ^ N = r b * a ^ N := by
    rw [pow_add, mul_mul_mul_comm, в†ђ mul_pow, eq2,
      mul_comm a.1, mul_pow, mul_mul_mul_comm, в†ђ pow_add]
  have вџЁc, eq1вџ© := (Submodule.mem_span_range_iff_exists_fun _).mp <|
    (Ideal.eq_top_iff_one _).mp <| (Set.image_eq_range _ _ в–ё Ideal.span_pow_eq_top _ span_eq N)
  refine вџЁв€‘ b, c b * r b, fun a в†¦ ((Away.algebraMap_isUnit a.1).pow N).mul_left_inj.mp ?_вџ©
  simp_rw [в†ђ map_pow, eq, в†ђ map_mul, Finset.sum_mul, mul_assoc, eq2 _ a, mul_left_comm (c _),
    в†ђ Finset.mul_sum, в†ђ smul_eq_mul (a := c _), eq1, mul_one]

