    have ÔčĘr', eq, _Ôčę := this ({a.1} Ôł¬ t) (fun a ÔćŽ f ÔčĘa, hts a.2Ôčę) (fun a b ÔćŽ
      h ÔčĘa, hts a.2Ôčę ÔčĘb, hts b.2Ôčę) (Ideal.span_mono (fun _ ÔćŽ .inr) mem) ÔčĘ{a.1} Ôł¬ t, by simpÔčę
    exact (congr_arg _ (uniq _ fun b ÔćŽ eq ÔčĘb, .inr b.2Ôčę).symm).trans (eq ÔčĘa, .inl rflÔčę)
  have span_eq := (Ideal.eq_top_iff_one _).mpr mem
  refine existsUnique_of_exists_of_unique ?_ fun x y hx hy ÔćŽ
    algebraMap_injective_of_span_eq_top s span_eq (funext fun a ÔćŽ (hx a).trans (hy a).symm)
  obtain ÔčĘs, rflÔčę := finset_eq
  choose n r eq using fun a ÔćŽ Away.surj a.1 (f a)
  let N := s.attach.sup n
  let r a := a ^ (N - n a) * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, ÔćÉ eq, mul_left_comm, ÔćÉ map_pow, ÔćÉ map_mul, ÔćÉ pow_add,
      Nat.sub_add_cancel (Finset.le_sup <| s.mem_attach a)]
  have eq2 a b : Ôłâ N', (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) :=
    Away.exists_of_eq (S := Away (a * b : R)) _ <| by
      simp_rw [map_mul, ÔćÉ Away.awayToAwayRight_eq (S := Away a.1) a.1 b (r a),
        ÔćÉ Away.awayToAwayLeft_eq (S := Away b.1) b.1 a (r b), ÔćÉ eq, map_mul,
        Away.awayToAwayRight_eq, Away.awayToAwayLeft_eq, h, mul_assoc, ÔćÉ map_mul, mul_comm]
  choose N' hN' using eq2
  let N' := (s ├Ś╦ó s).attach.sup fun a ÔćŽ N'
    ÔčĘ_, (Finset.mem_product.mp a.2).1Ôčę ÔčĘ_, (Finset.mem_product.mp a.2).2Ôčę
  have eq2 a b : (a * b) ^ N' * (r a * b ^ N) = (a * b) ^ N' * (r b * a ^ N) := by
    dsimp only [N']; rw [ÔćÉ Nat.sub_add_cancel (Finset.le_sup <| (Finset.mem_attach _ ÔčĘÔčĘa, bÔčę,
      Finset.mk_mem_product a.2 b.2Ôčę)), pow_add, mul_assoc, hN', ÔćÉ mul_assoc]
  let N := N' + N
  let r a := a ^ N' * r a
  have eq a : f a * algebraMap R _ (a ^ N) = algebraMap R _ (r a) := by
    rw [map_mul, ÔćÉ eq, mul_left_comm, ÔćÉ map_mul, ÔćÉ pow_add]
  have eq2 a b : r a * b ^ N = r b * a ^ N := by
    rw [pow_add, mul_mul_mul_comm, ÔćÉ mul_pow, eq2,
      mul_comm a.1, mul_pow, mul_mul_mul_comm, ÔćÉ pow_add]
  have ÔčĘc, eq1Ôčę := (mem_span_range_iff_exists_fun _).mp <|
    (Ideal.eq_top_iff_one _).mp <| (Set.image_eq_range _ _ ÔľŞ Ideal.span_pow_eq_top _ span_eq N)
  refine ÔčĘÔłĹ b, c b * r b, fun a ÔćŽ ((Away.algebraMap_isUnit a.1).pow N).mul_left_inj.mp ?_Ôčę
  simp_rw [ÔćÉ map_pow, eq, ÔćÉ map_mul, Finset.sum_mul, mul_assoc, eq2 _ a, mul_left_comm (c _),
    ÔćÉ Finset.mul_sum, ÔćÉ smul_eq_mul (a := c _), eq1, mul_one]

