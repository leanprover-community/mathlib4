namespace IsLocalization

section Away

variable (x : R)

/-- Given `x : R`, the typeclass `IsLocalization.Away x S` states that `S` is
isomorphic to the localization of `R` at the submonoid generated by `x`.
See `IsLocalization.Away.mk` for a specialized constructor. -/
abbrev Away (S : Type*) [CommSemiring S] [Algebra R S] :=
  IsLocalization (Submonoid.powers x) S

namespace Away

variable [IsLocalization.Away x S]

/-- Given `x : R` and a localization map `F : R в†’+* S` away from `x`, `invSelf` is `(F x)вЃ»В№`. -/
noncomputable def invSelf : S :=
  mk' S (1 : R) вџЁx, Submonoid.mem_powers _вџ©

@[simp]
theorem mul_invSelf : algebraMap R S x * invSelf x = 1 := by
  convert IsLocalization.mk'_mul_mk'_eq_one (M := Submonoid.powers x) (S := S) _ 1
  symm
  apply IsLocalization.mk'_one

/-- For `s : S` with `S` being the localization of `R` away from `x`,
this is a choice of `(r, n) : R Г— в„•` such that `s * algebraMap R S (x ^ n) = algebraMap R S r`. -/
noncomputable def sec (s : S) : R Г— в„• :=
  вџЁ(IsLocalization.sec (Submonoid.powers x) s).1,
   (IsLocalization.sec (Submonoid.powers x) s).2.property.chooseвџ©

lemma sec_spec (s : S) : s * (algebraMap R S) (x ^ (IsLocalization.Away.sec x s).2) =
    algebraMap R S (IsLocalization.Away.sec x s).1 := by
  simp only [IsLocalization.Away.sec, в†ђ IsLocalization.sec_spec]
  congr
  exact (IsLocalization.sec (Submonoid.powers x) s).2.property.choose_spec

lemma algebraMap_pow_isUnit (n : в„•) : IsUnit (algebraMap R S x ^ n) :=
  IsUnit.pow _ <| IsLocalization.map_units _ (вџЁx, 1, by simpвџ© : Submonoid.powers x)

lemma algebraMap_isUnit : IsUnit (algebraMap R S x) :=
  IsLocalization.map_units _ (вџЁx, 1, by simpвџ© : Submonoid.powers x)

theorem associated_sec_fst (s : S) :
    Associated (algebraMap R S (IsLocalization.Away.sec x s).1) s := by
  rw [в†ђ IsLocalization.Away.sec_spec, map_pow]
  exact associated_mul_unit_left _ _ <| .pow _ <| IsLocalization.Away.algebraMap_isUnit _

lemma algebraMap_isUnit_iff {y : R} : IsUnit (algebraMap R S y) в†” в€ѓ n, y в€Ј x ^ n :=
  (IsLocalization.algebraMap_isUnit_iff <| .powers x).trans <| by simp [Submonoid.mem_powers_iff]

lemma surj (z : S) : в€ѓ (n : в„•) (a : R), z * algebraMap R S x ^ n = algebraMap R S a := by
  obtain вџЁвџЁa, вџЁ-, n, rflвџ©вџ©, hвџ© := IsLocalization.surj (Submonoid.powers x) z
  use n, a
  simpa using h

lemma exists_of_eq {a b : R} (h : algebraMap R S a = algebraMap R S b) :
    в€ѓ (n : в„•), x ^ n * a = x ^ n * b := by
  obtain вџЁвџЁ-, n, rflвџ©, hxвџ© := IsLocalization.exists_of_eq (M := Submonoid.powers x) h
  use n

/-- Specialized constructor for `IsLocalization.Away`. -/
lemma mk (r : R) (map_unit : IsUnit (algebraMap R S r))
    (surj : в€Ђ s, в€ѓ (n : в„•) (a : R), s * algebraMap R S r ^ n = algebraMap R S a)
    (exists_of_eq : в€Ђ a b, algebraMap R S a = algebraMap R S b в†’ в€ѓ (n : в„•), r ^ n * a = r ^ n * b) :
    IsLocalization.Away r S where
  map_units := by
    rintro вџЁ-, n, rflвџ©
    simp only [map_pow]
    exact IsUnit.pow _ map_unit
  surj z := by
    obtain вџЁn, a, hnвџ© := surj z
    use вџЁa, вџЁr ^ n, n, rflвџ©вџ©
    simpa using hn
  exists_of_eq {x y} h := by
    obtain вџЁn, hnвџ© := exists_of_eq x y h
    use вџЁr ^ n, n, rflвџ©

lemma of_associated {r r' : R} (h : Associated r r') [IsLocalization.Away r S] :
    IsLocalization.Away r' S := by
  obtain вџЁu, rflвџ© := h
  refine mk _ ?_ (fun s в†¦ ?_) (fun a b hab в†¦ ?_)
  В· simp [algebraMap_isUnit r, IsUnit.map _ u.isUnit]
  В· obtain вџЁn, a, hnвџ© := surj r s
    use n, a * u ^ n
    simp [mul_pow, в†ђ mul_assoc, hn]
  В· obtain вџЁn, hnвџ© := exists_of_eq r hab
    use n
    rw [mul_pow, mul_comm (r ^ n), mul_assoc, mul_assoc, hn]

/-- If `r` and `r'` are associated elements of `R`, an `R`-algebra `S`
is the localization of `R` away from `r` if and only if it is the localization of `R` away from
`r'`. -/
lemma iff_of_associated {r r' : R} (h : Associated r r') :
    IsLocalization.Away r S в†” IsLocalization.Away r' S :=
  вџЁfun _ в†¦ IsLocalization.Away.of_associated h, fun _ в†¦ IsLocalization.Away.of_associated h.symmвџ©

lemma isUnit_of_dvd {r : R} (h : r в€Ј x) : IsUnit (algebraMap R S r) :=
  isUnit_of_dvd_unit (map_dvd _ h) (algebraMap_isUnit x)

variable {g : R в†’+* P}

/-- Given `x : R`, a localization map `F : R в†’+* S` away from `x`, and a map of `CommSemiring`s
`g : R в†’+* P` such that `g x` is invertible, the homomorphism induced from `S` to `P` sending
`z : S` to `g y * (g x)вЃ»вЃї`, where `y : R, n : в„•` are such that `z = F y * (F x)вЃ»вЃї`. -/
noncomputable def lift (hg : IsUnit (g x)) : S в†’+* P :=
  IsLocalization.lift fun y : Submonoid.powers x =>
    show IsUnit (g y.1) by
      obtain вџЁn, hnвџ© := y.2
      rw [в†ђ hn, g.map_pow]
      exact IsUnit.map (powMonoidHom n : P в†’* P) hg

@[simp]
theorem lift_eq (hg : IsUnit (g x)) (a : R) : lift x hg (algebraMap R S a) = g a :=
  IsLocalization.lift_eq _ _

@[simp]
theorem lift_comp (hg : IsUnit (g x)) : (lift x hg).comp (algebraMap R S) = g :=
  IsLocalization.lift_comp _

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `y * x`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayLeft (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] : S в†’+* P :=
  lift x <| isUnit_of_dvd (y * x) (dvd_mul_left _ _)

/-- Given `x y : R` and localizations `S`, `P` away from `x` and `x * y`
respectively, the homomorphism induced from `S` to `P`. -/
noncomputable def awayToAwayRight (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] : S в†’+* P :=
  lift x <| isUnit_of_dvd (x * y) (dvd_mul_right _ _)

theorem awayToAwayLeft_eq (y : R) [Algebra R P] [IsLocalization.Away (y * x) P] (a : R) :
    awayToAwayLeft x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

theorem awayToAwayRight_eq (y : R) [Algebra R P] [IsLocalization.Away (x * y) P] (a : R) :
    awayToAwayRight x y (algebraMap R S a) = algebraMap R P a :=
  lift_eq _ _ _

variable (S) (Q : Type*) [CommSemiring Q] [Algebra P Q]

/-- Given a map `f : R в†’+* S` and an element `r : R`, we may construct a map `RбµЈ в†’+* SбµЈ`. -/
noncomputable def map (f : R в†’+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] : S в†’+* Q :=
  IsLocalization.map Q f
    (show Submonoid.powers r в‰¤ (Submonoid.powers (f r)).comap f by
      rintro x вџЁn, rflвџ©
      use n
      simp)

lemma map_injective_iff {S : Type*} [CommRing S] [Algebra R S]
    (f : R в†’+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] :
    Function.Injective (map S Q f r) в†” в€Ђ a, f a = 0 в†’ в€ѓ n, r ^ n * a = 0 := by
  rw [injective_iff_map_eq_zero]
  trans в€Ђ a n, f r ^ n * f a = 0 в†’ в€ѓ m, r ^ m * a = 0
  В· simp [(IsLocalization.mk'_surjective (.powers r)).forall, Submonoid.mem_powers_iff,
      IsLocalization.Away.map, IsLocalization.map_mk', IsLocalization.mk'_eq_zero_iff]
  В· refine вџЁfun H x hx в†¦ H x 0 (by simpa), fun H a n ha в†¦ ?_вџ©
    obtain вџЁm, hmвџ© := H (r ^ n * a) (by simpa)
    exact вџЁm + n, by simp [pow_add, mul_assoc, *]вџ©

lemma map_surjective_iff (f : R в†’+* P) (r : R) [IsLocalization.Away r S]
    [IsLocalization.Away (f r) Q] :
    Function.Surjective (map S Q f r) в†” в€Ђ a, в€ѓ b m, f b = f r ^ m * a := by
  trans в€Ђ a n, в€ѓ b m k, f (r ^ (k + n) * b) = f r ^ (k + m) * a
  В· simp [Function.Surjective, (IsLocalization.mk'_surjective (.powers (f r))).forall, в†ђ map_pow,
      (IsLocalization.mk'_surjective (.powers r)).exists, Submonoid.mem_powers_iff, pow_add,
      IsLocalization.Away.map, IsLocalization.map_mk', в†ђ mul_assoc,
      IsLocalization.mk'_eq_iff_eq, в†ђ map_mul, IsLocalization.eq_iff_exists (.powers (f r))]
  В· refine вџЁfun H x в†¦ вџЁ_, _, (H x 0).choose_spec.choose_spec.choose_specвџ©, fun H a n в†¦ ?_вџ©
    obtain вџЁb, m, eвџ© := H a
    exact вџЁb, n + m, 0, by simp [e, pow_add]; ring_nfвџ©

section Algebra

variable {A : Type*} [CommSemiring A] [Algebra R A]
variable {B : Type*} [CommSemiring B] [Algebra R B]
variable (Aв‚љ : Type*) [CommSemiring Aв‚љ] [Algebra A Aв‚љ] [Algebra R Aв‚љ] [IsScalarTower R A Aв‚љ]
variable (Bв‚љ : Type*) [CommSemiring Bв‚љ] [Algebra B Bв‚љ] [Algebra R Bв‚љ] [IsScalarTower R B Bв‚љ]

instance {f : A в†’+* B} (a : A) [Away (f a) Bв‚љ] : IsLocalization (.map f (.powers a)) Bв‚љ := by
  simpa

instance (x : R) [IsLocalization.Away (algebraMap R A x) Aв‚љ] :
    IsLocalization (Algebra.algebraMapSubmonoid A (.powers x)) Aв‚љ := by
  simpa

/-- Given an algebra map `f : A в†’в‚ђ[R] B` and an element `a : A`, we may construct a map
`Aв‚ђ в†’в‚ђ[R] Bв‚ђ`. -/
noncomputable def mapв‚ђ (f : A в†’в‚ђ[R] B) (a : A) [Away a Aв‚љ] [Away (f a) Bв‚љ] : Aв‚љ в†’в‚ђ[R] Bв‚љ :=
  вџЁmap Aв‚љ Bв‚љ f.toRingHom a, fun r в†¦ by
    dsimp only [AlgHom.toRingHom_eq_coe, map, RingHom.coe_coe, OneHom.toFun_eq_coe]
    rw [IsScalarTower.algebraMap_apply R A Aв‚љ, IsScalarTower.algebraMap_eq R B Bв‚љ]
    simpвџ©

@[simp]
lemma mapв‚ђ_apply (f : A в†’в‚ђ[R] B) (a : A) [Away a Aв‚љ] [Away (f a) Bв‚љ] (x : Aв‚љ) :
    mapв‚ђ Aв‚љ Bв‚љ f a x = map Aв‚љ Bв‚љ f.toRingHom a x :=
  rfl

variable {Aв‚љ} {Bв‚љ}

lemma mapв‚ђ_injective_of_injective {f : A в†’в‚ђ[R] B} (a : A) [Away a Aв‚љ] [Away (f a) Bв‚љ]
    (hf : Function.Injective f) : Function.Injective (mapв‚ђ Aв‚љ Bв‚љ f a) :=
  IsLocalization.map_injective_of_injective _ _ _ hf

lemma mapв‚ђ_surjective_of_surjective {f : A в†’в‚ђ[R] B} (a : A) [Away a Aв‚љ] [Away (f a) Bв‚љ]
    (hf : Function.Surjective f) : Function.Surjective (mapв‚ђ Aв‚љ Bв‚љ f a) :=
  have : IsLocalization (Submonoid.map f.toRingHom (Submonoid.powers a)) Bв‚љ := by
    simp only [AlgHom.toRingHom_eq_coe, Submonoid.map_powers, RingHom.coe_coe]
    infer_instance
  IsLocalization.map_surjective_of_surjective _ _ _ hf

end Algebra

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. See `IsLocalization.Away.mul'` for the `x * y` version. -/
lemma mul (T : Type*) [CommSemiring T] [Algebra S T]
    [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (y * x) T := by
  refine mk _ ?_ (fun z в†¦ ?_) (fun a b h в†¦ ?_)
  В· simp only [map_mul, IsUnit.mul_iff, IsScalarTower.algebraMap_apply R S T]
    exact вџЁalgebraMap_isUnit _, IsUnit.map _ (algebraMap_isUnit x)вџ©
  В· obtain вџЁm, p, hpqвџ© := surj (algebraMap R S y) z
    obtain вџЁn, a, habвџ© := surj x p
    use m + n, a * x ^ m * y ^ n
    simp only [mul_pow, pow_add, map_pow, map_mul, в†ђ mul_assoc, hpq,
      IsScalarTower.algebraMap_apply R S T, в†ђ hab]
    ring
  В· repeat rw [IsScalarTower.algebraMap_apply R S T] at h
    obtain вџЁn, hnвџ© := exists_of_eq (algebraMap R S y) h
    simp only [в†ђ map_pow, в†ђ map_mul, в†ђ map_mul] at hn
    obtain вџЁm, hmвџ© := exists_of_eq x hn
    use n + m
    convert_to y ^ m * x ^ n * (x ^ m * (y ^ n * a)) = y ^ m * x ^ n * (x ^ m * (y ^ n * b))
    В· ring
    В· ring
    В· rw [hm]

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. See `IsLocalization.Away.mul` for the `y * x` version. -/
lemma mul' (T : Type*) [CommSemiring T] [Algebra S T] [Algebra R T] [IsScalarTower R S T] (x y : R)
    [IsLocalization.Away x S] [IsLocalization.Away (algebraMap R S y) T] :
    IsLocalization.Away (x * y) T :=
  mul_comm x y в–ё mul S T x y

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `y * x`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (y * x) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul S (Localization.Away (algebraMap R S y)) _ _

/-- Localizing the localization of `R` at `x` at the image of `y` is the same as localizing
`R` at `x * y`. -/
instance (x y : R) [IsLocalization.Away x S] :
    IsLocalization.Away (x * y) (Localization.Away (algebraMap R S y)) :=
  IsLocalization.Away.mul' S (Localization.Away (algebraMap R S y)) _ _

/-- If `Sв‚Ѓ` is the localization of `R` away from `f` and `Sв‚‚` is the localization away from `g`,
then any localization `T` of `Sв‚‚` away from `f` is also a localization of `Sв‚Ѓ` away from `g`. -/
lemma commutes {R : Type*} [CommSemiring R] (Sв‚Ѓ Sв‚‚ T : Type*) [CommSemiring Sв‚Ѓ]
    [CommSemiring Sв‚‚] [CommSemiring T] [Algebra R Sв‚Ѓ] [Algebra R Sв‚‚] [Algebra R T] [Algebra Sв‚Ѓ T]
    [Algebra Sв‚‚ T] [IsScalarTower R Sв‚Ѓ T] [IsScalarTower R Sв‚‚ T] (x y : R)
    [IsLocalization.Away x Sв‚Ѓ] [IsLocalization.Away y Sв‚‚]
    [IsLocalization.Away (algebraMap R Sв‚‚ x) T] :
    IsLocalization.Away (algebraMap R Sв‚Ѓ y) T := by
  convert IsLocalization.commutes Sв‚Ѓ Sв‚‚ T (Submonoid.powers x) (Submonoid.powers y)
  ext x
  simp

end Away

end Away

