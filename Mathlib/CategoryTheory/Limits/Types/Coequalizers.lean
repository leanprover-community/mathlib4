/-!
# Coequalizers in Type

The coequalizer of a pair of maps `(f, g)` from `X` to `Y`
is the quotient of `Y` by `вҲҖ x : Y, f x ~ g x`

-/

@[expose] public section

universe v u

open CategoryTheory Limits ConcreteCategory

namespace CategoryTheory.Limits.Types

variable {X Y Z : Type u} (f g : X вҹ¶ Y)

/-- Show that the quotient by the relation generated by `f(x) ~ g(x)`
is a coequalizer for the pair `(f, g)`.
-/
def coequalizerColimit : Limits.ColimitCocone (parallelPair f g) where
  cocone :=
    Cofork.ofПҖ (вҶҫ(Function.Coequalizer.mk f g))
      (by ext x; exact Function.Coequalizer.condition f g x)
  isColimit :=
    Cofork.IsColimit.mk _
      (fun s вҶҰ вҶҫ(Function.Coequalizer.desc f g s.ПҖ
        (by ext x; exact ConcreteCategory.congr_hom s.condition x)))
      (fun _ вҶҰ rfl)
      (fun _ _ hm вҶҰ by ext x; exact Quot.inductionOn x (congr_hom hm))

/-- If `ПҖ : Y вҹ¶ Z` is a coequalizer for `(f, g)`, and `U вҠҶ Y` such that `f вҒ»В№' U = g вҒ»В№' U`,
then `ПҖ вҒ»В№' ПҖ '' U = U`.
-/
theorem coequalizer_preimage_image_eq_of_preimage_eq (ПҖ : Y вҹ¶ Z) (e : f вү« ПҖ = g вү« ПҖ)
    (h : IsColimit (Cofork.ofПҖ ПҖ e)) (U : Set Y) (H : f вҒ»В№' U = g вҒ»В№' U) : ПҖ вҒ»В№' ПҖ '' U = U := by
  have lem : вҲҖ x y, Function.Coequalizer.Rel f g x y вҶ’ (x вҲҲ U вҶ” y вҲҲ U) := by
    rintro _ _ вҹЁxвҹ©
    change x вҲҲ f вҒ»В№' U вҶ” x вҲҲ g вҒ»В№' U
    rw [H]
  have eqv : _root_.Equivalence fun x y => x вҲҲ U вҶ” y вҲҲ U := by
    aesop (add safe constructors _root_.Equivalence)
  ext
  constructor
  В· rw [вҶҗ
      show _ = ПҖ from
        h.comp_coconePointUniqueUpToIso_inv (coequalizerColimit f g).2
          WalkingParallelPair.one]
    rintro вҹЁy, hy, e'вҹ©
    dsimp at e'
    have e'' :=
      (mono_iff_injective
            (h.coconePointUniqueUpToIso (coequalizerColimit f g).isColimit).inv).mp
        inferInstance
    refine (eqv.eqvGen_iff.mp (Relation.EqvGen.mono lem (Quot.eqvGen_exact ?_))).mp hy
    apply e''
    convert e'
  В· exact fun hx => вҹЁ_, hx, rflвҹ©

/-- The categorical coequalizer in `Type u` is the quotient by `f g ~ g x`. -/
noncomputable def coequalizerIso : coequalizer f g вү… (Function.Coequalizer f g) :=
  colimit.isoColimitCocone (coequalizerColimit f g)

@[elementwise (attr := simp)]
theorem coequalizerIso_ПҖ_comp_hom :
    coequalizer.ПҖ f g вү« (coequalizerIso f g).hom = вҶҫ(Function.Coequalizer.mk f g) :=
  colimit.isoColimitCocone_О№_hom (coequalizerColimit f g) WalkingParallelPair.one

@[elementwise (attr := simp)]
theorem coequalizerIso_quot_comp_inv :
    вҶҫ(Function.Coequalizer.mk f g) вү« (coequalizerIso f g).inv = coequalizer.ПҖ f g :=
  rfl

end CategoryTheory.Limits.Types
