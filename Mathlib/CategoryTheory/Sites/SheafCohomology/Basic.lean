module

public import Mathlib.Algebra.Category.Grp.Abelian
public import Mathlib.Algebra.Category.Grp.Adjunctions
public import Mathlib.Algebra.Homology.DerivedCategory.Ext.Basic
public import Mathlib.CategoryTheory.Sites.Abelian
public import Mathlib.CategoryTheory.Sites.ConstantSheaf
public import Mathlib.Algebra.Homology.DerivedCategory.Ext.EnoughInjectives
public import Mathlib.Algebra.Category.Grp.Zero
public import Mathlib.CategoryTheory.Adjunction.Additive

/-!
# Sheaf cohomology

Let `C` be a category equipped with a Grothendieck topology `J`.
We define the cohomology types `Sheaf.H F n` of an abelian
sheaf `F` on the site `(C, J)` for all `n : ‚Ąē`. These abelian
groups are defined as the `Ext`-groups from the constant abelian
sheaf with values `‚Ą§` (actually `ULift ‚Ą§`) to `F`.

We also define `Sheaf.cohomologyPresheaf F n : CŠĶíŠĶĖ ‚•§ AddCommGrpCat`
which is the presheaf which sends `U` to the `n`th `Ext`-group
from the free abelian sheaf generated by the presheaf
of sets `yoneda.obj U` to `F`.

## TODO
* if `U` is a terminal object of `C`, define an isomorphism
  `(F.cohomologyPresheaf n).obj (Opposite.op U) ‚ČÉ+ Sheaf.H F n`.
* if `U : C`, define an isomorphism
  `(F.cohomologyPresheaf n).obj (Opposite.op U) ‚ČÉ+ Sheaf.H (F.over U) n`.

-/

@[expose] public section

assert_not_exists TwoSidedIdeal

universe w' w v u

namespace CategoryTheory

open Abelian

variable {C : Type u} [Category.{v} C] {J : GrothendieckTopology C}

namespace Sheaf

section

variable (F : Sheaf J AddCommGrpCat.{w})
  [HasSheafify J AddCommGrpCat.{w}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{w})]

/-- The cohomology of an abelian sheaf in degree `n`. -/
def H (n : ‚Ąē) : Type w' :=
  Ext ((constantSheaf J AddCommGrpCat.{w}).obj (AddCommGrpCat.of (ULift ‚Ą§))) F n

noncomputable instance (n : ‚Ąē) : AddCommGroup (F.H n) := by
  dsimp only [H]
  infer_instance

end

section

variable [HasSheafify J AddCommGrpCat.{v}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{v})]

variable (J) in
/-- The bifunctor which sends an abelian sheaf `F` and an object `U` to the
`n`th Ext-group from the free abelian sheaf generated by the
presheaf of sets `yoneda.obj U` to `F`. -/
noncomputable def cohomologyPresheafFunctor (n : ‚Ąē) :
    Sheaf J AddCommGrpCat.{v} ‚•§ CŠĶíŠĶĖ ‚•§ AddCommGrpCat.{w'} :=
  Functor.flip
    (Functor.op (yoneda ‚čô (Functor.whiskeringRight _ _ _).obj
      AddCommGrpCat.free ‚čô presheafToSheaf _ _) ‚čô extFunctor n)

/-- Given an abelian sheaf `F`, this is the presheaf which sends `U`
to the `n`th Ext-group from the free abelian sheaf generated by the
presheaf of sets `yoneda.obj U` to `F`. -/
noncomputable abbrev cohomologyPresheaf (F : Sheaf J AddCommGrpCat.{v}) (n : ‚Ąē) :
    CŠĶíŠĶĖ ‚•§ AddCommGrpCat.{w'} :=
  (cohomologyPresheafFunctor J n).obj F

end

section

variable [HasSheafify J AddCommGrpCat.{w}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{w})]

instance (F : Sheaf J AddCommGrpCat.{w}) {n : ‚Ąē} [Injective F] : Subsingleton (H F (n + 1)) :=
  subsingleton_of_forall_eq 0 fun x ‚Ü¶ (Ext.eq_zero_of_injective x)

variable {S : ShortComplex (Sheaf J AddCommGrpCat.{w})} (hS : S.ShortExact) (n‚āÄ n‚āĀ : ‚Ąē)
    (h : n‚āÄ + 1 = n‚āĀ)

/-- The long exact sequence on sheaf cohomology. -/
noncomputable abbrev H.longSequence (h : n‚āÄ + 1 = n‚āĀ := by lia) :
    ComposableArrows AddCommGrpCat 5 :=
  Ext.covariantSequence ((constantSheaf J AddCommGrpCat.{w}).obj (AddCommGrpCat.of.{w} (ULift ‚Ą§)))
    hS n‚āÄ n‚āĀ h

theorem H.longSequence_exact (h : n‚āÄ + 1 = n‚āĀ := by lia) : (H.longSequence hS n‚āÄ n‚āĀ h).Exact :=
  Ext.covariantSequence_exact _ hS n‚āÄ n‚āĀ h

variable (F : Sheaf J AddCommGrpCat.{w}) {T : C} (hT : Limits.IsTerminal T)

open AddCommGrpCat Opposite

/-- The additive equivalence between `H F 0` and the evaluation of `F` at the terminal object -/
noncomputable def H.equiv‚āÄ : H F 0 ‚ČÉ+ F.val.obj (op T) :=
    AddEquiv.trans Ext.addEquiv‚āÄ <|
      AddEquiv.trans ((constantSheafAdj J AddCommGrpCat hT).homAddEquiv _ F)
        (uliftZMultiplesAddEquiv _)

variable {F G : Sheaf J AddCommGrpCat.{w}} (f : F ‚ü∂ G)

/-- Given a morphism of sheaves `f : F ‚ü∂ G`, `H.map f n` is the induced additive map on cohomology
    groups `H F n ‚Üí+ H G n` -/
noncomputable def H.map (n : ‚Ąē) : H F n ‚Üí+ H G n :=
  ((Ext.mk‚āÄ f).postcomp ((constantSheaf J AddCommGrpCat).obj (of (ULift ‚Ą§))) (add_zero n))

lemma H.addEquiv‚āÄ_comp (x : H F 0) : Ext.addEquiv‚āÄ (H.map f 0 x) = Ext.addEquiv‚āÄ x ‚Čę f := by
  delta Ext.addEquiv‚āÄ H.map
  apply (Ext.mk‚āÄ_bijective _ G).injective
  simp only [AddEquiv.coe_mk, Ext.mk‚āÄ_homEquiv‚āÄ_apply, Ext.mk‚āÄ_homEquiv‚āÄ_apply, ‚Üź Ext.mk‚āÄ_comp_mk‚āÄ]
  rfl

/-- `H.equiv‚āÄ` is natural -/
theorem H.equiv‚āÄ_comp (x : H F 0) :
    f.val.app (op T) (H.equiv‚āÄ F hT x) = H.equiv‚āÄ G hT (H.map f 0 x) := by
  simp only [equiv‚āÄ, AddEquiv.trans_apply]
  erw[addEquiv‚āÄ_comp f x]
  rfl

theorem H.equiv‚āÄ_symm_comp (x : F.val.obj (op T)) :
    H.map f 0 ((H.equiv‚āÄ F hT).symm x) = (H.equiv‚āÄ G hT).symm (f.val.app (op T) x) := by
  apply (H.equiv‚āÄ G hT).injective
  simp [‚Üź H.equiv‚āÄ_comp]

variable (n : ‚Ąē)

/-- `H` as a functor. -/
noncomputable def Hfunctor (n : ‚Ąē) : Sheaf J AddCommGrpCat.{w} ‚•§ AddCommGrpCat.{w'} :=
    (extFunctor n).obj
      (op ((constantSheaf J AddCommGrpCat.{w}).obj (AddCommGrpCat.of.{w} (ULift ‚Ą§))))

theorem Hfunctor_obj (n : ‚Ąē) : (Hfunctor n).obj F = of (H F n) := rfl

theorem Hfunctor_map (n : ‚Ąē) :
    eqToHom (F.Hfunctor_obj n) ‚Čę ofHom (H.map f n) ‚Čę eqToHom (G.Hfunctor_obj n).symm =
    (Hfunctor n).map f := rfl

end

end Sheaf

end CategoryTheory
