module

public import Mathlib.Algebra.Category.Grp.Abelian
public import Mathlib.Algebra.Category.Grp.Adjunctions
public import Mathlib.Algebra.Homology.DerivedCategory.Ext.Basic
public import Mathlib.CategoryTheory.Sites.Abelian
public import Mathlib.CategoryTheory.Sites.ConstantSheaf
public import Mathlib.Algebra.Homology.DerivedCategory.Ext.EnoughInjectives
public import Mathlib.Algebra.Category.Grp.Zero
public import Mathlib.CategoryTheory.Adjunction.Additive

/-!
# Sheaf cohomology

Let `C` be a category equipped with a Grothendieck topology `J`.
We define the cohomology types `Sheaf.H F n` of an abelian
sheaf `F` on the site `(C, J)` for all `n : в„•`. These abelian
groups are defined as the `Ext`-groups from the constant abelian
sheaf with values `в„¤` (actually `ULift в„¤`) to `F`.

We also define `Sheaf.cohomologyPresheaf F n : Cбµ’бµ– вҐ¤ AddCommGrpCat`
which is the presheaf which sends `U` to the `n`th `Ext`-group
from the free abelian sheaf generated by the presheaf
of sets `yoneda.obj U` to `F`.

## TODO
* if `U` is a terminal object of `C`, define an isomorphism
  `(F.cohomologyPresheaf n).obj (Opposite.op U) в‰ѓ+ Sheaf.H F n`.
* if `U : C`, define an isomorphism
  `(F.cohomologyPresheaf n).obj (Opposite.op U) в‰ѓ+ Sheaf.H (F.over U) n`.

-/

@[expose] public section

assert_not_exists TwoSidedIdeal

universe w' w v u

namespace CategoryTheory

open Abelian

variable {C : Type u} [Category.{v} C] {J : GrothendieckTopology C}

namespace Sheaf

section

variable (F : Sheaf J AddCommGrpCat.{w})
  [HasSheafify J AddCommGrpCat.{w}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{w})]

/-- The cohomology of an abelian sheaf in degree `n`. -/
def H (n : в„•) : Type w' :=
  Ext ((constantSheaf J AddCommGrpCat.{w}).obj (AddCommGrpCat.of (ULift в„¤))) F n

noncomputable instance (n : в„•) : AddCommGroup (F.H n) := by
  dsimp only [H]
  infer_instance

end

section

variable [HasSheafify J AddCommGrpCat.{v}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{v})]

variable (J) in
/-- The bifunctor which sends an abelian sheaf `F` and an object `U` to the
`n`th Ext-group from the free abelian sheaf generated by the
presheaf of sets `yoneda.obj U` to `F`. -/
noncomputable def cohomologyPresheafFunctor (n : в„•) :
    Sheaf J AddCommGrpCat.{v} вҐ¤ Cбµ’бµ– вҐ¤ AddCommGrpCat.{w'} :=
  Functor.flip
    (Functor.op (yoneda в‹™ (Functor.whiskeringRight _ _ _).obj
      AddCommGrpCat.free в‹™ presheafToSheaf _ _) в‹™ extFunctor n)

/-- Given an abelian sheaf `F`, this is the presheaf which sends `U`
to the `n`th Ext-group from the free abelian sheaf generated by the
presheaf of sets `yoneda.obj U` to `F`. -/
noncomputable abbrev cohomologyPresheaf (F : Sheaf J AddCommGrpCat.{v}) (n : в„•) :
    Cбµ’бµ– вҐ¤ AddCommGrpCat.{w'} :=
  (cohomologyPresheafFunctor J n).obj F

end

section

variable [HasSheafify J AddCommGrpCat.{w}] [HasExt.{w'} (Sheaf J AddCommGrpCat.{w})]

theorem H.eq_zero_of_injective (F : Sheaf J AddCommGrpCat.{w}) (n : в„•) (x : H F (n + 1))
    [Injective F] : x = 0 :=
    Ext.eq_zero_of_injective x

variable {S : ShortComplex (Sheaf J AddCommGrpCat.{w})} (hS : S.ShortExact) (nв‚Ђ nв‚Ѓ : в„•)
    (h : nв‚Ђ + 1 = nв‚Ѓ)

/-- The long exact sequence on cohomology obtained from a short exact sequence of sheaves:
If `S` is a short exact sequence of abelian sheaves, then this is the sequence
`H S.Xв‚Ѓ nв‚Ђ в†’ H S.Xв‚‚ nв‚Ђ в†’ H S.Xв‚ѓ nв‚Ђ в†’ H S.Xв‚Ѓ nв‚Ѓ в†’ H S.Xв‚‚ nв‚Ѓ в†’ H S.Xв‚ѓ nв‚Ѓ` when `nв‚Ђ + 1 = nв‚Ѓ` -/
noncomputable def H.longSequence (h : nв‚Ђ + 1 = nв‚Ѓ := by lia) : ComposableArrows AddCommGrpCat 5 :=
  Ext.covariantSequence ((constantSheaf J AddCommGrpCat.{w}).obj (AddCommGrpCat.of.{w} (ULift в„¤)))
    hS nв‚Ђ nв‚Ѓ h

theorem H.longSequence.exact (h : nв‚Ђ + 1 = nв‚Ѓ := by lia) : (H.longSequence hS nв‚Ђ nв‚Ѓ h).Exact :=
  Ext.covariantSequence_exact ((constantSheaf J AddCommGrpCat).obj (AddCommGrpCat.of (ULift в„¤)))
    hS nв‚Ђ nв‚Ѓ h

instance : (Functor.const Cбµ’бµ– : AddCommGrpCat вҐ¤ Cбµ’бµ– вҐ¤ AddCommGrpCat).Additive where

instance : (constantSheaf J AddCommGrpCat).Additive := by
  delta constantSheaf
  infer_instance

variable (F : Sheaf J AddCommGrpCat.{w}) {T : C} (hT : Limits.IsTerminal T)

open AddCommGrpCat Opposite

/-- The additive equivalence between `H F 0` and the evaluation of `F` at the terminal object -/
noncomputable def H.Equivв‚Ђ : H F 0 в‰ѓ+ ((sheafSections J AddCommGrpCat).obj (op T)).obj F :=
    AddEquiv.trans Ext.addEquivв‚Ђ (
      AddEquiv.trans ((constantSheafAdj J AddCommGrpCat hT).homAddEquiv _ F)
        (uliftZMultiplesAddEquiv _))

variable {F G : Sheaf J AddCommGrpCat.{w}} (f : F вџ¶ G)

/-- Given a morphism of sheaves `f : F вџ¶ G`, `H.map f n` is the induced additive map on cohomology
    groups `H F n в†’+ H G n` -/
noncomputable def H.map (n : в„•) : H F n в†’+ H G n :=
  ((Ext.mkв‚Ђ f).postcomp ((constantSheaf J AddCommGrpCat).obj (of (ULift в„¤))) (add_zero n))

lemma H.addEquivв‚Ђ_comp (x : H F 0) : Ext.addEquivв‚Ђ (H.map f 0 x) = Ext.addEquivв‚Ђ x в‰« f := by
  delta Ext.addEquivв‚Ђ H.map
  apply (Ext.mkв‚Ђ_bijective _ G).injective
  simp only [AddEquiv.coe_mk, Ext.mkв‚Ђ_homEquivв‚Ђ_apply, Ext.mkв‚Ђ_homEquivв‚Ђ_apply, в†ђ Ext.mkв‚Ђ_comp_mkв‚Ђ]
  rfl

/-- `H.Equivв‚Ђ` is natural -/
theorem H.Equivв‚Ђ_comp (x : H F 0) :
    ((sheafSections J AddCommGrpCat).obj (op T)).map f (H.Equivв‚Ђ F hT x) =
    H.Equivв‚Ђ G hT (H.map f 0 x) := by
  delta Equivв‚Ђ
  simp only [Functor.flip_obj_obj, sheafToPresheaf_obj, Functor.flip_obj_map, sheafToPresheaf_map,
    AddEquiv.trans_apply]
  conv => rhs ; right ; right ; equals Ext.addEquivв‚Ђ x в‰« f => exact addEquivв‚Ђ_comp f x
  rfl

end

end Sheaf

end CategoryTheory
