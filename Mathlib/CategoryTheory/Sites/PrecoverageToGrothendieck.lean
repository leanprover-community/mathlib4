/-!

# Grothendieck topology generated by a precoverage

For any category `C`, we define the Grothendieck topology generated by a precoverage `J` on `C`.
It is the smallest Grothendieck topology containing all the sieves generated by the covering
presieves of `J`.

The main definitions and theorems are:
- `Precoverage.toGrothendieck`: The Grothendieck topology generated by the sieves generated by the
  covering presieves of `J`.
- `Precoverage.toGrothendieck_eq_sInf`: The Grothendieck topology generated by `J` is the infimum
  of the Grothendieck topologies containing all the sieves generated by the covering presieves
  of `J`.
- `Presieve.isSheaf_toGrothendieck_iff`: Given `J : Precoverage C` with associated Grothendieck
  topology `K`, a `Type*`-valued presheaf on `C` is a sheaf for `K` if and only if it is a sheaf
  for all pullbacks of the covering presieves of `J`.
-/

@[expose] public section

namespace CategoryTheory

variable {C : Type _} [Category C]

namespace Precoverage

variable {J : Precoverage C}

/--
An auxiliary definition used to define the Grothendieck topology associated to a precoverage.
See `Precoverage.toGrothendieck`.
-/
inductive Saturate (J : Precoverage C) : (X : C) â†’ Sieve X â†’ Prop where
  | of (X : C) (S : Presieve X) (hS : S âˆˆ J X) : J.Saturate X (Sieve.generate S)
  | top (X : C) : J.Saturate X âٹ¤
  | pullback (X : C) (S : Sieve X) : J.Saturate X S â†’ âˆ€ (Y : C) (f : Y âں¶ X),
      J.Saturate Y (S.pullback f)
  | transitive (X : C) (S R : Sieve X) : J.Saturate X S â†’
      (âˆ€ â¦ƒY : Câ¦„ â¦ƒf : Y âں¶ Xâ¦„, S f â†’ J.Saturate Y (R.pullback f)) â†’ J.Saturate X R

/--
The Grothendieck topology associated to a precoverage `J`.
It is defined *inductively* as follows:
1. If `S` is a covering presieve for `J`, then the sieve generated by `S` is a covering
  sieve for the associated Grothendieck topology.
2. The top sieves are in the associated Grothendieck topology.
3. Add all sieves required by the pullback stability condition of a Grothendieck topology.
4. Add all sieves required by the *local character* axiom of a Grothendieck topology.
-/
def toGrothendieck (J : Precoverage C) : GrothendieckTopology C where
  sieves X := setOf (J.Saturate X)
  top_mem' := .top
  pullback_stable' _ _ _ _ hS := .pullback _ _ hS _ _
  transitive' _ _ hS _ hR := .transitive _ _ _ hS hR

lemma mem_toGrothendieck_iff {X : C} {S : Sieve X} :
    S âˆˆ J.toGrothendieck X â†” J.Saturate X S := .rfl

@[grind .]
lemma generate_mem_toGrothendieck {X : C} {R : Presieve X} (hR : R âˆˆ J X) :
    Sieve.generate R âˆˆ J.toGrothendieck X :=
  .of _ _ hR

/--
An alternative characterization of the Grothendieck topology associated to a precoverage `J`:
it is the infimum of all Grothendieck topologies containing `Sieve.generate S` for all presieves
`S` in `J`.
-/
lemma toGrothendieck_eq_sInf (J : Precoverage C) :
    J.toGrothendieck =
      sInf { K | âˆ€ â¦ƒX : Câ¦„ (S : Presieve X), S âˆˆ J X â†’ Sieve.generate S âˆˆ K X } := by
  refine le_antisymm ?_ ?_
  آ· rw [le_sInf_iff]
    intro K hK _ _ hS
    induction hS with
    | of _ _ hS => exact hK _ hS
    | top => exact K.top_mem _
    | pullback _ _ _ _ _ ih => exact K.pullback_stable _ ih
    | transitive _ _ _ _ _ ih1 ih2 => exact K.transitive ih1 _ ih2
  آ· exact sInf_le (fun _ _ hS => .of _ _ hS)

/--
The main theorem of this file: given a precoverage `J` on `C`, a `Type*`-valued presheaf on `C` is
a sheaf for the associated Grothendieck topology if and only if it is a sheaf for all pullback
sieves of presieves in `J`.
-/
theorem isSheaf_toGrothendieck_iff (P : Cلµ’لµ– â¥¤ Type*) :
    Presieve.IsSheaf J.toGrothendieck P â†”
      (âˆ€ {X Y : C} {f : Y âں¶ X} (R : Presieve X), R âˆˆ J X â†’
        Presieve.IsSheafFor P ((Sieve.generate R).pullback f).arrows) := by
  constructor
  آ· refine fun H _ _ _ _ hR => ?_
    apply H.isSheafFor
    rw [Sieve.generate_sieve]
    exact J.toGrothendieck.pullback_stable _ (Saturate.of _ _ hR)
  آ· intro H X S hS
    -- This is the key point of the proof:
    -- We must generalize the induction in the correct way.
    suffices âˆ€ â¦ƒY : Câ¦„ (f : Y âں¶ X), Presieve.IsSheafFor P (S.pullback f).arrows by
      simpa using this (f := ً‌ں™ _)
    induction hS with
    | of X S hS =>
      exact fun _ _ => H S hS
    | top =>
      simp [Presieve.isSheafFor_top P]
    | pullback X S hS _ f ih =>
      intro Y f
      rw [â†گ S.pullback_comp]
      exact ih (f â‰« _)
    | transitive X R S hS h H1 H2 =>
      intro Y f
      simp only [â†گ Presieve.isSeparatedFor_and_exists_isAmalgamation_iff_isSheafFor] at *
      choose H1 H1' using H1
      choose H2 H2' using H2
      refine âں¨?_, fun x hx => ?_âں©
      آ· intro x tâ‚پ tâ‚‚ hâ‚پ hâ‚‚
        refine (H1 f).ext (fun Z g hg => ?_)
        refine (H2 hg (ً‌ں™ _)).ext (fun ZZ gg hgg => ?_)
        simp only [Sieve.pullback_id, Sieve.pullback_apply] at hgg
        simp only [â†گ comp_apply]
        rw [â†گ P.map_comp, â†گ op_comp, hâ‚پ, hâ‚‚]
        simpa only [Sieve.pullback_apply, Category.assoc] using hgg
      let y : âˆ€ â¦ƒZ : Câ¦„ (g : Z âں¶ Y),
        ((S.pullback (g â‰« f)).pullback (ً‌ں™ _)).arrows.FamilyOfElements P :=
        fun Z g ZZ gg hgg => x (gg â‰« g) (by simpa using hgg)
      have hy : âˆ€ â¦ƒZ : Câ¦„ (g : Z âں¶ Y), (y g).Compatible := by
        intro Z g Yâ‚پ Yâ‚‚ ZZ gâ‚پ gâ‚‚ fâ‚پ fâ‚‚ hâ‚پ hâ‚‚ h
        rw [hx]
        rw [reassoc_of% h]
      choose z hz using fun â¦ƒZ : Câ¦„ â¦ƒg : Z âں¶ Yâ¦„ (hg : R.pullback f g) =>
        H2' hg (ً‌ں™ _) (y g) (hy g)
      let q : (R.pullback f).arrows.FamilyOfElements P := fun Z g hg => z hg
      have hq : q.Compatible := by
        intro Yâ‚پ Yâ‚‚ Z gâ‚پ gâ‚‚ fâ‚پ fâ‚‚ hâ‚پ hâ‚‚ h
        apply (H2 hâ‚پ gâ‚پ).ext
        intro ZZ gg hgg
        simp only [â†گ comp_apply]
        rw [â†گ P.map_comp, â†گ P.map_comp, â†گ op_comp, â†گ op_comp, hz, hz]
        آ· dsimp [y]; congr 1; simp only [Category.assoc, h]
        آ· simpa [reassoc_of% h] using hgg
        آ· simpa using hgg
      obtain âں¨t, htâں© := H1' f q hq
      refine âں¨t, fun Z g hg => ?_âں©
      refine (H1 (g â‰« f)).ext (fun ZZ gg hgg => ?_)
      rw [â†گ comp_apply _ (P.map gg.op), â†گ P.map_comp, â†گ op_comp, ht]
      on_goal 2 => simpa using hgg
      refine (H2 hgg (ً‌ں™ _)).ext (fun ZZZ ggg hggg => ?_)
      rw [â†گ comp_apply _ (P.map ggg.op), â†گ P.map_comp, â†گ op_comp, hz]
      on_goal 2 => simpa using hggg
      refine (H2 hgg ggg).ext (fun ZZZZ gggg _ => ?_)
      rw [â†گ comp_apply _ (P.map gggg.op), â†گ P.map_comp, â†گ op_comp]
      apply hx
      simp

lemma mem_toGrothendieck_iff_of_isStableUnderComposition [IsStableUnderComposition J]
    [IsStableUnderBaseChange J] [J.HasPullbacks] [HasIsos J] {X : C} {S : Sieve X} :
    S âˆˆ J.toGrothendieck X â†” âˆƒ R âˆˆ J X, R â‰¤ S := by
  refine âں¨fun hS â†¦ ?_, fun âں¨R, hR, hleâں© â†¦ ?_âں©
  آ· induction hS with
    | of X R hR =>
      use R, hR
      exact Sieve.le_generate R
    | top X =>
      exact âں¨Presieve.singleton (ً‌ں™ X), mem_coverings_of_isIso (ً‌ں™ X), by simpâں©
    | pullback X S hS Y f h =>
      obtain âں¨R, hR, hleâں© := h
      have : R.HasPullbacks f := J.hasPullbacks_of_mem f hR
      refine âں¨R.pullbackArrows f, pullbackArrows_mem f hR, ?_âں©
      rw [â†گ Sieve.generate_le_iff, Sieve.pullbackArrows_comm]
      apply Sieve.pullback_monotone
      rwa [Sieve.generate_le_iff]
    | transitive X S T hS hT hleS hleT =>
      obtain âں¨R, hR, hleâں© := hleS
      rw [mem_iff_exists_zeroHypercover] at hR
      obtain âں¨E, rflâں© := hR
      replace hleT (i : E.Iâ‚€) : âˆƒ (F : J.ZeroHypercover (E.X i)),
          F.presieveâ‚€ â‰¤ (Sieve.pullback (E.f i) T).arrows := by
        obtain âں¨R', hR', hle'âں© := hleT (hle _ _ âں¨iâں©)
        rw [mem_iff_exists_zeroHypercover] at hR'
        obtain âں¨F, rflâں© := hR'
        use F
      choose F hle' using hleT
      refine âں¨(E.bind F).presieveâ‚€, (E.bind F).memâ‚€, ?_âں©
      rw [Presieve.ofArrows_le_iff]
      intro i
      exact hle' _ _ _ âں¨i.sndâں©
  آ· rw [â†گ Sieve.generate_le_iff] at hle
    apply GrothendieckTopology.superset_covering _ hle
    exact generate_mem_toGrothendieck hR

lemma toGrothendieck_toPretopology_eq_toGrothendieck [IsStableUnderComposition J]
    [IsStableUnderBaseChange J] [Limits.HasPullbacks C] [HasIsos J] :
    J.toPretopology.toGrothendieck = J.toGrothendieck := by
  ext
  exact J.mem_toGrothendieck_iff_of_isStableUnderComposition.symm

end Precoverage

@[grind .]
lemma Presieve.IsSheaf.isSheafFor_of_mem_precoverage {J : Precoverage C} {P : Cلµ’لµ– â¥¤ Type*}
    (h : Presieve.IsSheaf J.toGrothendieck P) {S : C} {R : Presieve S}
    (hR : R âˆˆ J S) : R.IsSheafFor P := by
  rw [J.isSheaf_toGrothendieck_iff] at h
  simpa [Presieve.isSheafFor_iff_generate] using h (f := ً‌ں™ S) R hR

lemma PreZeroHypercover.isSheafFor_iff_of_iso {F : Cلµ’لµ– â¥¤ Type*} {S : C}
    {ً‌’° ً‌’± : PreZeroHypercover S} (e : ً‌’° â‰… ً‌’±) :
    ً‌’°.presieveâ‚€.IsSheafFor F â†” ً‌’±.presieveâ‚€.IsSheafFor F := by
  rw [Presieve.isSheafFor_iff_generate, â†گ Sieve.ofArrows, â†گ PreZeroHypercover.sieveâ‚€,
    PreZeroHypercover.sieveâ‚€_eq_of_iso e, â†گ Presieve.isSheafFor_iff_generate]

lemma Presieve.isSheafFor_ofArrows_comp_iff {F : Cلµ’لµ– â¥¤ Type*} {X : C} {خ¹ : Type*} {Y Z : خ¹ â†’ C}
    (g : âˆ€ i, Z i âں¶ X) (e : âˆ€ i, Y i â‰… Z i) :
    IsSheafFor F (ofArrows _ (fun i â†¦ (e i).hom â‰« g i)) â†” IsSheafFor F (ofArrows _ g) := by
  let ً‌’° : PreZeroHypercover X := âں¨_, _, gâں©
  let ً‌’± : PreZeroHypercover X := âں¨_, _, fun i â†¦ (e i).hom â‰« g iâں©
  let e : ً‌’° â‰… ً‌’± := PreZeroHypercover.isoMk (.refl _) (fun i â†¦ (e i).symm)
  exact PreZeroHypercover.isSheafFor_iff_of_iso e.symm

lemma Presieve.isSheafFor_singleton_iff_of_iso {F : Cلµ’لµ– â¥¤ Type*} {S X Y : C} (f : X âں¶ S)
    (g : Y âں¶ S) (e : X â‰… Y) (he : e.hom â‰« g = f) :
    (singleton f).IsSheafFor F â†” (singleton g).IsSheafFor F := by
  subst he
  rw [â†گ Presieve.ofArrows_pUnit.{_, _, 0}, â†گ Presieve.ofArrows_pUnit,
    Presieve.isSheafFor_ofArrows_comp_iff]

open Limits

variable {D : Type*} [Category* D]

set_option backward.defeqAttrib.useBackward true in
set_option backward.isDefEq.respectTransparency false in
lemma Presieve.IsSheafFor.comp_iff_of_preservesPairwisePullbacks (F : C â¥¤ D) (P : Dلµ’لµ– â¥¤ Type*)
    {X : C} (R : Presieve X) [R.HasPairwisePullbacks]
    [F.PreservesPairwisePullbacks R] :
    Presieve.IsSheafFor (F.op â‹™ P) R â†” Presieve.IsSheafFor P (R.map F) := by
  have : (R.map F).HasPairwisePullbacks := .map_of_preservesPairwisePullbacks _ _
  obtain âں¨خ¹, Y, f, rflâں© := R.exists_eq_ofArrows
  rw [map_ofArrows] at this âٹ¢
  simp_rw [Presieve.isSheafFor_arrows_iff_pullbacks]
  dsimp [Arrows.PullbackCompatible]
  congr! with x
  rw [forallâ‚‚_congr]
  intro i j
  have : PreservesLimit (cospan (f i) (f j)) F :=
    F.preservesLimit_cospan_of_mem_presieve (ofArrows _ f) âں¨iâں© âں¨jâں©
  have : HasPullback (F.map (f i)) (F.map (f j)) := hasPullback_of_preservesPullback _ _ _
  rw [â†گ pullbackComparison_comp_fst, op_comp, Functor.map_comp,
    â†گ pullbackComparison_comp_snd, op_comp, Functor.map_comp]
  have : Function.Bijective (P.map (pullbackComparison F (f i) (f j)).op) := by
    rw [â†گ isIso_iff_bijective]
    infer_instance
  exact this.1.eq_iff

namespace GrothendieckTopology

/-- The induced coverage by a Grothendieck topology as a precoverage. -/
def toPrecoverage (J : GrothendieckTopology C) : Precoverage C where
  coverings S := { R | Sieve.generate R âˆˆ J S }

lemma mem_toPrecoverage_iff (J : GrothendieckTopology C) {S : C} (R : Presieve S) :
    R âˆˆ toPrecoverage J S â†” Sieve.generate R âˆˆ J S := .rfl

lemma arrows_mem_toPrecoverage_iff (J : GrothendieckTopology C) {S : C} (R : Sieve S) :
    R.arrows âˆˆ toPrecoverage J S â†” R âˆˆ J S := by
  rw [mem_toPrecoverage_iff, Sieve.generate_sieve]

instance (J : GrothendieckTopology C) : (toPrecoverage J).HasIsos where
  mem_coverings_of_isIso f hf := by simp [mem_toPrecoverage_iff]

instance (J : GrothendieckTopology C) : (toPrecoverage J).IsStableUnderComposition where
  comp_mem_coverings {خ¹} S X f hf دƒ Y g hg := by
    rw [mem_toPrecoverage_iff, â†گ Presieve.bindOfArrows_ofArrows]
    exact J.bindOfArrows hf hg

instance (J : GrothendieckTopology C) : (toPrecoverage J).IsStableUnderBaseChange where
  mem_coverings_of_isPullback {خ¹} S X f hf Y g P pâ‚پ pâ‚‚ h := by
    rw [mem_toPrecoverage_iff, â†گ Sieve.ofArrows, Sieve.ofArrows_eq_pullback_of_isPullback _ h]
    exact J.pullback_stable _ hf

end GrothendieckTopology

namespace Precoverage

variable {K : Precoverage C} {J : GrothendieckTopology C}

/-- `toGrothendieck` and `toPrecoverage` form a Galois connection. -/
lemma toGrothendieck_le_iff_le_toPrecoverage : K.toGrothendieck â‰¤ J â†” K â‰¤ J.toPrecoverage := by
  refine âں¨fun h X R hR â†¦ ?_, fun h â†¦ ?_âں©
  آ· rw [GrothendieckTopology.mem_toPrecoverage_iff]
    exact h _ (generate_mem_toGrothendieck hR)
  آ· intro X R hR
    induction hR with
    | of X S hS => exact h _ hS
    | top X => grind
    | pullback X S _ Y f _ => grind
    | transitive X S R _ _ _ _ => grind

variable (C) in
lemma galoisConnection_toGrothendieck_toPrecoverage :
    GaloisConnection (toGrothendieck (C := C)) GrothendieckTopology.toPrecoverage :=
  fun _ _ â†¦ toGrothendieck_le_iff_le_toPrecoverage

end Precoverage

@[simp, grind =]
lemma Precoverage.toGrothendieck_bot : toGrothendieck (âٹ¥ : Precoverage C) = âٹ¥ :=
  (galoisConnection_toGrothendieck_toPrecoverage C).l_bot

@[simp, grind =]
lemma GrothendieckTopology.toPrecoverage_top : toPrecoverage (âٹ¤ : GrothendieckTopology C) = âٹ¤ :=
  (Precoverage.galoisConnection_toGrothendieck_toPrecoverage C).u_top

lemma Precoverage.toGrothendieck_monotone : Monotone (toGrothendieck (C := C)) :=
  (galoisConnection_toGrothendieck_toPrecoverage C).monotone_l

@[gcongr]
lemma Precoverage.toGrothendieck_mono {J K : Precoverage C} (h : J â‰¤ K) :
    J.toGrothendieck â‰¤ K.toGrothendieck :=
  toGrothendieck_monotone h

lemma GrothendieckTopology.toPrecoverage_monotone : Monotone (toPrecoverage (C := C)) :=
  (Precoverage.galoisConnection_toGrothendieck_toPrecoverage C).monotone_u

lemma Precoverage.le_toPrecoverage_toGrothendieck (J : Precoverage C) :
    J â‰¤ J.toGrothendieck.toPrecoverage :=
  (galoisConnection_toGrothendieck_toPrecoverage C).le_u_l _

lemma GrothendieckTopology.toGrothendieck_toPrecoverage_le (J : GrothendieckTopology C) :
    J.toPrecoverage.toGrothendieck â‰¤ J :=
  (Precoverage.galoisConnection_toGrothendieck_toPrecoverage C).l_u_le _

end CategoryTheory
