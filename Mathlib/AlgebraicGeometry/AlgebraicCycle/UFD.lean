import Mathlib.RingTheory.UniqueFactorizationDomain.Ideal
import Mathlib.RingTheory.Localization.FractionRing
import Mathlib.RingTheory.Ideal.Height

/-!
# Algebraic Hartogs for unique factorization domains

This file records the elementary commutative algebra needed to compute stalks of the divisorial
sheaf `𝒪ₓ(D)` at points whose local ring is a UFD:

- `ufd_hartogs`: a fraction over a UFD which is `ϖ`-integral for every prime `ϖ` (i.e. admits a
  representation with denominator not divisible by `ϖ`) lies in the ring. This is "algebraic
  Hartogs" for UFDs; unlike the version for general normal Noetherian domains it is elementary,
  since fractions can be put in lowest terms.
- `Ideal.exists_prime_span_of_height_eq_one`: in a UFD, a height-one prime is generated by a
  prime element.

TODO: These are general facts and should be upstreamed to `Mathlib.RingTheory`.
-/

open UniqueFactorizationMonoid

/--
**Algebraic Hartogs for UFDs.** A fraction over a unique factorization domain which, for every
prime `ϖ`, admits a representation with denominator not divisible by `ϖ`, lies in the ring.
-/
theorem ufd_hartogs {A K : Type*} [CommRing A] [IsDomain A] [UniqueFactorizationMonoid A]
    [Field K] [Algebra A K] [IsFractionRing A K] {f : K}
    (h : ∀ ϖ : A, Prime ϖ → ∃ a b : A, ¬ ϖ ∣ b ∧ f * algebraMap A K b = algebraMap A K a) :
    f ∈ (algebraMap A K).range := by
  -- Write `f = a₀ / b₀` in lowest terms.
  obtain ⟨a₀', b₀', hb₀', H⟩ := IsFractionRing.div_surjective (A := A) f
  have hb₀'' : (b₀' : A) ≠ 0 := nonZeroDivisors.ne_zero hb₀'
  obtain ⟨a₀, b₀, c, hred, rfl, rfl⟩ := exists_reduced_factors' a₀' b₀' hb₀''
  have hc : c ≠ 0 := left_ne_zero_of_mul hb₀''
  have hb₀ : (b₀ : A) ≠ 0 := right_ne_zero_of_mul hb₀''
  have hf : f * algebraMap A K b₀ = algebraMap A K a₀ := by
    have hcK : algebraMap A K c ≠ 0 :=
      (map_ne_zero_iff _ (IsFractionRing.injective A K)).mpr hc
    have hbK : algebraMap A K (c * b₀) ≠ 0 :=
      (map_ne_zero_iff _ (IsFractionRing.injective A K)).mpr hb₀''
    apply mul_left_cancel₀ hcK
    rw [div_eq_iff hbK] at H
    rw [map_mul, map_mul] at H
    rw [H]; ring
  -- The reduced denominator is a unit: otherwise it has a prime factor `ϖ`, and comparing with
  -- the `ϖ`-integral representation of `f` shows `ϖ` divides both `a₀` and `b₀`.
  have hb₀u : IsUnit b₀ := by
    by_contra hbu
    obtain ⟨ϖ, hϖirr, hϖdvd⟩ := WfDvdMonoid.exists_irreducible_factor hbu hb₀
    have hϖ : Prime ϖ := irreducible_iff_prime.mp hϖirr
    obtain ⟨a, b, hϖb, hab⟩ := h ϖ hϖ
    -- Cross-multiply the two representations of `f` inside `A`.
    have key : a₀ * b = a * b₀ := by
      apply IsFractionRing.injective A K
      rw [map_mul, map_mul]
      calc algebraMap A K a₀ * algebraMap A K b
          = (f * algebraMap A K b₀) * algebraMap A K b := by rw [hf]
        _ = (f * algebraMap A K b) * algebraMap A K b₀ := by ring
        _ = algebraMap A K a * algebraMap A K b₀ := by rw [hab]
    have : ϖ ∣ a₀ * b := key ▸ (hϖdvd.mul_left a)
    exact hϖ.not_unit (hred ((hϖ.dvd_or_dvd this).resolve_right hϖb) hϖdvd)
  -- Hence `f = a₀ * b₀⁻¹` comes from `A`.
  obtain ⟨u, rfl⟩ := hb₀u
  refine ⟨a₀ * ↑u⁻¹, ?_⟩
  have hu : algebraMap A K ↑u * algebraMap A K (↑u⁻¹ : A) = 1 := by
    rw [← map_mul, Units.mul_inv, map_one]
  rw [map_mul]
  calc algebraMap A K a₀ * algebraMap A K (↑u⁻¹ : A)
      = f * algebraMap A K ↑u * algebraMap A K (↑u⁻¹ : A) := by rw [← hf]
    _ = f := by rw [mul_assoc, hu, mul_one]

/--
In a unique factorization domain, a height-one prime ideal is generated by a prime element:
it contains a prime element by Kaplansky's argument, and the span of that element is a nonzero
prime below a height-one prime, hence equal to it.
-/
lemma Ideal.exists_prime_span_of_height_eq_one {A : Type*} [CommRing A] [IsDomain A]
    [UniqueFactorizationMonoid A] {p : Ideal A} [hp : p.IsPrime] (h1 : p.height = 1) :
    ∃ ϖ : A, Prime ϖ ∧ p = Ideal.span {ϖ} := by
  obtain ⟨ϖ, hϖmem, hϖ⟩ := hp.exists_mem_prime_of_ne_bot (Ideal.ne_bot_of_height_eq_one h1)
  exact ⟨ϖ, hϖ, Ideal.eq_span_singleton_of_height_eq_one h1 hϖmem hϖ⟩
