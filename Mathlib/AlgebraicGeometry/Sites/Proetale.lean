module

public import Mathlib.AlgebraicGeometry.Morphisms.UniversallyOpen
public import Mathlib.AlgebraicGeometry.Morphisms.WeaklyEtale
public import Mathlib.AlgebraicGeometry.Sites.Etale
public import Mathlib.AlgebraicGeometry.Sites.QuasiCompact
public import Mathlib.AlgebraicGeometry.Sites.Fpqc
public import Mathlib.CategoryTheory.MorphismProperty.CommaSites
public import Mathlib.CategoryTheory.Sites.Subcanonical
public import Mathlib.CategoryTheory.Sites.SubcanonicalOver

/-!

# The pro-étale site

In this file we define the big and small pro-étale site. The big pro-étale site is
the category of schemes equipped with the pro-étale topology, which is the topology
generated by fpqc covers of weakly étale morphisms.

We prefer to work with weakly étale morphisms instead of pro-étale morphisms, since the property
of being pro-étale is not well-behaved: it is not local on the target.

We also define the small pro-étale site of a scheme `S` to be the category of schemes weakly-étale
over `S` and equip it with the induced topology.

## References

- [Bhatt, Bhargav and Scholze, Peter, The pro-étale topology for schemes][proetale2015]

-/

@[expose] public section

universe v u

open CategoryTheory MorphismProperty Limits

namespace AlgebraicGeometry.Scheme

/--
Big pro-étale site: the pro-étale precoverage on the category of schemes given
by fpqc covers of weakly étale morphisms.
[Definition 4.1.1][proetale2015]
-/
def proetalePrecoverage : Precoverage Scheme.{u} :=
  propQCPrecoverage @WeaklyEtale
  deriving Precoverage.IsStableUnderBaseChange, Precoverage.IsStableUnderComposition,
    Precoverage.HasIsos

lemma proetalePrecoverage_le_precoverage_weaklyEtale :
    proetalePrecoverage ≤ MorphismProperty.precoverage @WeaklyEtale :=
  le_trans inf_le_right inf_le_right

lemma proetalePrecoverage_le_fpqcPrecoverage : proetalePrecoverage ≤ fpqcPrecoverage :=
  propQCPrecoverage_monotone fun _ _ _ _ ↦ inferInstance

/-- Big pro-étale site: the pro-étale topology on the category of schemes is
generated by the pro-étale precoverage. -/
abbrev proetaleTopology : GrothendieckTopology Scheme.{u} :=
  proetalePrecoverage.toGrothendieck

lemma etalePrecoverage_le_proetalePrecoverage : etalePrecoverage ≤ proetalePrecoverage := by
  rw [proetalePrecoverage, propQCPrecoverage, etalePrecoverage, le_inf_iff]
  refine ⟨precoverage_le_qcPrecoverage_of_isOpenMap fun X Y f hf ↦ f.isOpenMap, ?_⟩
  apply precoverage_mono
  intro X Y f hf
  infer_instance

lemma etaleTopology_le_proetaleTopology : etaleTopology ≤ proetaleTopology :=
  Precoverage.toGrothendieck_mono etalePrecoverage_le_proetalePrecoverage

lemma proetaleTopology_le_fpqcTopology : proetaleTopology ≤ fpqcTopology :=
  Precoverage.toGrothendieck_mono proetalePrecoverage_le_fpqcPrecoverage

instance : proetaleTopology.Subcanonical :=
  .of_le proetaleTopology_le_fpqcTopology

instance {S : Scheme.{u}} (𝒰 : S.Cover (precoverage @WeaklyEtale)) (i : 𝒰.I₀) :
    WeaklyEtale (𝒰.f i) :=
  𝒰.map_prop i

/--
The (small) pro-étale site of a scheme `S`: Its objects are the schemes weakly étale over `S`.
We prefer to work with weakly étale morphisms instead of pro-étale morphisms, since the property
of being pro-étale is not well-behaved: it is not local on the target.
[Definition 4.1.1][proetale2015]
-/
@[stacks 098K]
protected def ProEt (S : Scheme.{u}) : Type _ :=
  MorphismProperty.Over @WeaklyEtale ⊤ S
  deriving Category, HasFiniteLimits

namespace ProEt

variable (S : Scheme.{u})

instance (U : S.ProEt) : WeaklyEtale U.hom := U.prop

variable {S} in
/-- Construct an object of the pro-étale site of `S` by giving a weakly étale morphism
`f : X ⟶ S`. -/
@[simps!]
protected def mk {X : Scheme.{u}} (f : X ⟶ S) [WeaklyEtale f] : S.ProEt :=
  MorphismProperty.Over.mk _ f ‹_›

/-- The forgetful functor the pro-étale site of `S` to schemes over `S`. -/
protected def forget : S.ProEt ⥤ Over S :=
  MorphismProperty.Over.forget @WeaklyEtale ⊤ S

/-- The forgetful functor from the pro-étale site of `S` to schemes over `S` is fully faithful. -/
def forgetFullyFaithful : (ProEt.forget S).FullyFaithful :=
  MorphismProperty.Comma.forgetFullyFaithful _ _ _

instance : (ProEt.forget S).Full :=
  inferInstanceAs <| (MorphismProperty.Over.forget _ _ _).Full

instance : (ProEt.forget S).Faithful :=
  inferInstanceAs <| (MorphismProperty.Over.forget _ _ _).Faithful

instance : PreservesFiniteLimits (ProEt.forget S) :=
  inferInstanceAs <| PreservesFiniteLimits (MorphismProperty.Over.forget _ _ _)

instance : RepresentablyFlat (ProEt.forget S) :=
  flat_of_preservesFiniteLimits _

instance : (ProEt.forget S).LocallyCoverDense (proetaleTopology.over S) := by
  apply MorphismProperty.locallyCoverDense_forget_of_le
  exact proetalePrecoverage_le_precoverage_weaklyEtale

/-- The pro-étale precoverage on the small pro-étale site. -/
def precoverage : Precoverage S.ProEt :=
  proetalePrecoverage.comap (ProEt.forget S ⋙ Over.forget S)

/-- The pro-étale topology on the small pro-étale site. -/
abbrev topology : GrothendieckTopology S.ProEt :=
  (precoverage S).toGrothendieck

lemma topology_eq_inducedTopology :
    topology S = (ProEt.forget S).inducedTopology (proetaleTopology.over S) := by
  apply MorphismProperty.toGrothendieck_comap_forget_eq_inducedTopology
  exact proetalePrecoverage_le_precoverage_weaklyEtale

instance : (ProEt.forget S).IsContinuous (topology S) (proetaleTopology.over S) := by
  rw [topology_eq_inducedTopology]
  refine Functor.isContinuous_of_coverPreserving (compatiblePreservingOfFlat _ _) ?_
  exact Functor.inducedTopology_coverPreserving _ _

instance : (ProEt.forget S ⋙ Over.forget S).IsContinuous (ProEt.topology S) proetaleTopology :=
  Functor.isContinuous_comp _ _ _ (proetaleTopology.over S) _

instance : (topology S).Subcanonical :=
  GrothendieckTopology.subcanonical_of_full_of_faithful (ProEt.forget S) _ (proetaleTopology.over S)

end ProEt

end AlgebraicGeometry.Scheme
