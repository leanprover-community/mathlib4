/-!
# The free product of $R$-algebras

We define the free product of an indexed collection of (noncommutative) $R$-algebras
`(i : Œπ) ‚Üí A i`, with `Algebra R (A i)` for all `i` and `R` a commutative
semiring, as the quotient of the tensor algebra on the direct sum
`‚®Å (i : Œπ), A i` by the relation generated by extending the relation

* `a·µ¢ ‚äó‚Çú a·µ¢' ~ a·µ¢ a·µ¢'` for all `i : Œπ` and `a·µ¢ a·µ¢' : A i`
* `1·µ¢ ~ 1‚±º` for `1·µ¢ := One.one (A i)` and for all `i, j : Œπ`.

to the whole tensor algebra in an `R`-linear way.

The main result of this file is the universal property of the free product,
which establishes the free product as the coproduct in the category of
general $R$-algebras.

## Main definitions

* `FreeProduct R A` is the free product of the `R`-algebras `A i`, defined as a quotient
  of the tensor algebra on the direct sum of the `A i`.
* `FreeProduct_ofPowers R A` is the free product of the `R`-algebras `A i`, defined as a quotient
  of the (infinite) direct sum of tensor powers of the `A i`.
* `lift` is the universal property of the free product.

## Main results

* `equivPowerAlgebra` establishes an equivalence between `FreeProduct R A` and
  `FreeProduct_ofPowers R A`.
* `FreeProduct` is the coproduct in the category of `R`-algebras.

## TODO
- Induction principle for `FreeProduct`

-/

@[expose] public section

universe u v w w'

namespace DirectSum
open scoped DirectSum

/-- A variant of `DirectSum.induction_on` that uses `DirectSum.lof` instead of `.of` -/
theorem induction_lon {R : Type*} [Semiring R] {Œπ : Type*} [DecidableEq Œπ]
    {M : Œπ ‚Üí Type*} [(i : Œπ) ‚Üí AddCommMonoid <| M i] [(i : Œπ) ‚Üí Module R (M i)]
    {motive : (‚®Å i, M i) ‚Üí Prop} (x : ‚®Å i, M i)
    (zero : motive 0)
    (lof : ‚àÄ i (x : M i), motive (lof R Œπ M i x))
    (add : ‚àÄ (x y : ‚®Å i, M i), motive x ‚Üí motive y ‚Üí motive (x + y)) : motive x := by
  induction x using DirectSum.induction_on with
  | zero => exact zero
  | of => exact lof _ _
  | add x y hx hy => exact add x y hx hy

end DirectSum

namespace RingQuot
universe uS uA uB

open scoped Function -- required for scoped `on` notation

/-- If two `R`-algebras are `R`-equivalent and their quotients by a relation `rel` are defined,
then their quotients are also `R`-equivalent.

(Special case of the third isomorphism theorem.) -/
def algEquivQuotAlgEquiv
    {R : Type u} [CommSemiring R] {A B : Type v} [Semiring A] [Semiring B]
    [Algebra R A] [Algebra R B] (f : A ‚âÉ‚Çê[R] B)
    (rel : RingCon A) (rel' : RingCon B) (h : rel = rel'.comap f) :
    rel.Quotient ‚âÉ‚Çê[R] (rel').Quotient :=
  AlgEquiv.ofAlgHom
    (RingCon.lift‚Çê _ ((RingCon.mk‚Çê _ _).comp f) fun x y h_rel ‚Ü¶ by subst rel; simpa)
    (RingCon.lift‚Çê _ ((RingCon.mk‚Çê _ _).comp f.symm) fun x y h_rel ‚Ü¶ by subst rel; simpa)
    (by ext b; simp) (by ext a; simp)

/-- If two (semi)rings are equivalent and their quotients by a relation `rel` are defined,
then their quotients are also equivalent.

(Special case of `algEquiv_quot_algEquiv` when `R = ‚Ñï`, which in turn is a special
case of the third isomorphism theorem.) -/
def equivQuotEquiv {A B : Type v} [Semiring A] [Semiring B] (f : A ‚âÉ+* B)
    (rel : RingCon A) (rel' : RingCon B) (h : rel = rel'.comap f) :
    rel.Quotient ‚âÉ+* rel'.Quotient :=
  let f_alg : A ‚âÉ‚Çê[‚Ñï] B :=
    AlgEquiv.ofRingEquiv (f := f) (fun n ‚Ü¶ by simp)
  algEquivQuotAlgEquiv f_alg rel rel' h |>.toRingEquiv

end RingQuot

open TensorAlgebra DirectSum TensorPower

variable {I : Type u} [DecidableEq I] {i : I} -- The type of the indexing set
  (R : Type v) [CommSemiring R] -- The commutative semiring `R`
  (A : I ‚Üí Type w) [‚àÄ i, Semiring (A i)] [‚àÄ i, Algebra R (A i)] -- The collection of `R`-algebras
  {B : Type w'} [Semiring B] [Algebra R B] -- Another `R`-algebra
  (maps : {i : I} ‚Üí A i ‚Üí‚Çê[R] B) -- A family of `R`algebra homomorphisms

namespace LinearAlgebra.FreeProduct

instance : Module R (‚®Å i, A i) := by infer_instance

/-- The free tensor algebra over a direct sum of `R`-algebras, before
taking the quotient by the free product relation -/
abbrev FreeTensorAlgebra := TensorAlgebra R (‚®Å i, A i)

/-- The direct sum of tensor powers of a direct sum of `R`-algebras,
before taking the quotient by the free product relation -/
abbrev PowerAlgebra := ‚®Å (n : ‚Ñï), TensorPower R n (‚®Å i, A i)

/-- The free tensor algebra and its representation as an infinite direct sum
of tensor powers are (noncomputably) equivalent as `R`-algebras. -/
@[reducible] noncomputable def powerAlgebraEquivFreeTensorAlgebra :
    PowerAlgebra R A ‚âÉ‚Çê[R] FreeTensorAlgebra R A :=
  TensorAlgebra.equivDirectSum.symm

/-- The generating equivalence relation for elements of the free tensor algebra
that are identified in the free product -/
inductive rel : FreeTensorAlgebra R A ‚Üí FreeTensorAlgebra R A ‚Üí Prop
  | id : ‚àÄ {i : I}, rel (Œπ R <| lof R I A i 1) 1
  | prod : ‚àÄ {i : I} {a‚ÇÅ a‚ÇÇ : A i},
      rel
        (tprod R (‚®Å i, A i) 2 (fun | 0 => lof R I A i a‚ÇÅ | 1 => lof R I A i a‚ÇÇ))
        (Œπ R <| lof R I A i (a‚ÇÅ * a‚ÇÇ))

/-- `rel` as a ring congruence. -/
def ringCon : RingCon (FreeTensorAlgebra R A) := ringConGen (rel R A)

open scoped Function

/-- The generating equivalence relation for elements of the power algebra
that are identified in the free product -/
@[reducible, simp] def rel' := rel R A on ofDirectSum

/-- `rel'` as a ring congruence. -/
def ringCon' : RingCon (PowerAlgebra R A) := ringConGen (rel' R A)

theorem rel_id (i : I) : rel R A (Œπ R <| lof R I A i 1) 1 := rel.id


/-- The free product of the collection of `R`-algebras `A i`, as a quotient of
`FreeTensorAlgebra R A` -/
@[reducible] def _root_.LinearAlgebra.FreeProduct := FreeProduct.ringCon R A |>.Quotient

/-- The free product of the collection of `R`-algebras `A i`,
as a quotient of `PowerAlgebra R A` -/
@[reducible] def asPowers := FreeProduct.ringCon' R A |>.Quotient

/-- The `R`-algebra equivalence relating `FreeProduct` and `FreeProduct.asPowers`. -/
noncomputable def asPowersEquiv : asPowers R A ‚âÉ‚Çê[R] FreeProduct R A :=
  RingQuot.algEquivQuotAlgEquiv
    (powerAlgebraEquivFreeTensorAlgebra R A |>.symm) _ _ (by

      sorry)
  |>.symm

open RingQuot Function

local infixr:60 " ‚àò‚Çê " => AlgHom.comp

instance instSemiring : Semiring (FreeProduct R A) := by infer_instance
instance instAlgebra : Algebra R (FreeProduct R A) := by infer_instance

/-- The canonical quotient map `FreeTensorAlgebra R A ‚Üí‚Çê[R] FreeProduct R A`,
as an `R`-algebra homomorphism -/
abbrev mkAlgHom : FreeTensorAlgebra R A ‚Üí‚Çê[R] FreeProduct R A :=
  RingCon.mk‚Çê _ _

/-- The canonical linear map from the direct sum of the `A i` to the free product -/
def Œπ' : (‚®Å i, A i) ‚Üí‚Çó[R] FreeProduct R A :=
  (mkAlgHom R A).toLinearMap ‚àò‚Çó TensorAlgebra.Œπ R (M := ‚®Å i, A i)

@[simp] theorem Œπ_apply (x : ‚®Å i, A i) :
    (TensorAlgebra.Œπ R x) = Œπ' R A x := by
  aesop (add simp [Œπ', mkAlgHom])

/-- The injection into the free product of any `1 : A i` is the 1 of the free product. -/
theorem identify_one (i : I) : Œπ' R A (DirectSum.lof R I A i 1) = 1 := by
  suffices Œπ' R A (DirectSum.lof R I A i 1) = mkAlgHom R A 1 by simpa [‚Üê Œπ_apply]
  exact Quotient.sound <| RingCon.le_ringConGen _ _ _ <| rel_id R A (i := i)

/-- Multiplication in the free product of the injections of any two `a·µ¢ a·µ¢': A i` for
the same `i` is just the injection of multiplication `a·µ¢ * a·µ¢'` in `A i`. -/
theorem mul_injections (a‚ÇÅ a‚ÇÇ : A i) :
    Œπ' R A (DirectSum.lof R I A i a‚ÇÅ) * Œπ' R A (DirectSum.lof R I A i a‚ÇÇ)
      = Œπ' R A (DirectSum.lof R I A i (a‚ÇÅ * a‚ÇÇ)) := by
  rw [‚Üê Œπ_apply, ‚Üê Œπ_apply, ‚Üê RingCon.coe_mul]
  refine Quotient.sound <| RingCon.le_ringConGen _ _ _ <| ?_
  convert! rel.prod
  simp

/-- The `i`th canonical injection, from `A i` to the free product, as
a linear map -/
abbrev lof (i : I) : A i ‚Üí‚Çó[R] FreeProduct R A :=
  Œπ' R A ‚àò‚Çó DirectSum.lof R I A i

/-- `lof R A i 1 = 1` for all `i`. -/
theorem lof_map_one (i : I) : lof R A i 1 = 1 := by
  rw [lof]; dsimp [mkAlgHom]; exact identify_one R A i

/-- The `i`th canonical injection, from `A i` to the free product -/
irreducible_def Œπ (i : I) : A i ‚Üí‚Çê[R] FreeProduct R A :=
  AlgHom.ofLinearMap (Œπ' R A ‚àò‚Çó DirectSum.lof R I A i)
    (lof_map_one R A i) (mul_injections R A ¬∑ ¬∑ |>.symm)

/-- The family of canonical injection maps, with `i` left implicit -/
irreducible_def of {i : I} : A i ‚Üí‚Çê[R] FreeProduct R A := Œπ R A i

/-- Universal property of the free product of algebras:
for every `R`-algebra `B`, every family of maps `maps : (i : I) ‚Üí (A i ‚Üí‚Çê[R] B)` lifts
to a unique arrow `œÄ` from `FreeProduct R A` such that  `œÄ ‚àò Œπ i = maps i`. -/
@[simps] def lift : ({i : I} ‚Üí A i ‚Üí‚Çê[R] B) ‚âÉ (FreeProduct R A ‚Üí‚Çê[R] B) where
  toFun maps :=
    RingCon.lift‚Çê _
      (TensorAlgebra.lift R <| DirectSum.toModule R I B <| (@maps ¬∑ |>.toLinearMap))
        <| RingCon.ringConGen_le fun x y r ‚Ü¶ by
          cases r with
          | id => simp
          | prod => simp
  invFun œÄ i := œÄ ‚àò‚Çê Œπ R A i
  left_inv œÄ := by
    ext i a·µ¢
    simp [Œπ, ‚Üê Œπ_apply]
  right_inv maps := by
    ext i a
    simp [Œπ, ‚Üê Œπ_apply]

/-- Universal property of the free product of algebras, property:
for every `R`-algebra `B`, every family of maps `maps : (i : I) ‚Üí (A i ‚Üí‚Çê[R] B)` lifts
to a unique arrow `œÄ` from `FreeProduct R A` such that  `œÄ ‚àò Œπ i = maps i`. -/
@[simp‚Üì] theorem lift_comp_Œπ : lift R A maps ‚àò‚Çê Œπ R A i = maps := by
  ext a
  simp [lift_apply, Œπ, ‚Üê Œπ_apply]

@[simp‚Üì] theorem lift_algebraMap (r : R) : lift R A maps (algebraMap R _ r) = algebraMap R _ r := by
  rw [lift_apply, AlgHom.commutes]

@[aesop safe destruct] theorem lift_unique
    (f : FreeProduct R A ‚Üí‚Çê[R] B) (h : ‚àÄ i, f ‚àò‚Çê Œπ R A i = maps) :
    f = lift R A maps := by
  ext i a; simp_rw [AlgHom.ext_iff] at h; specialize h i a
  simp [h.symm, Œπ, ‚Üê Œπ_apply]

end LinearAlgebra.FreeProduct
