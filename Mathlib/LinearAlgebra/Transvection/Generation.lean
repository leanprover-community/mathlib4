module

public import Mathlib.LinearAlgebra.Center
public import Mathlib.LinearAlgebra.Transvection.Basic

/-!
# Dilatransvections generate the special linear group

We prove the theorem of [dieudonne-1955][J. Dieudonn├ę, ÔÇťSur les g├ęn├ęrateurs
des groupes classiquesÔÇŁ].

Let `K` be a division ring and `V` be a `K`-module.

* `LinearEquiv.mem_transvections_pow_mul_dilatransvections_of_fixedReduce_eq_one`:
  If `e.fixedReduce = 1`, then `e` can be written as the product
  of `finrank K (V ÔžŞ e.fixedSubmodule) - 1` transvections
  and one dilatransvection.
  This is the first part of the non-exceptional case in Dieudonn├ę's theorem.
  (This statement is not interesting when `e = 1`.)

* `LinearEquiv.mem_transvections_pow_mul_dilatransvections_of_fixedReduce_ne_smul_id`:
  If `e.fixedReduce` is not a homothety, then `e` can be written as the product
  of `finrank K (V ÔžŞ e.fixedSubmodule) - 1` transvections and one dilatransvection.
  This is the second part of the non-exceptional case in Dieudonn├ę's theorem.

* `LinearEquiv.IsExceptional`:
  A linear equivalence `e : V ÔëâÔéŚ[K] V` is exceptional if `1 < finrank K (V ÔžŞ e.fixedSubmodule)`
  and if `e.fixedReduce` is a nontrivial homothety.

* `LinearEquiv.mem_dilatransvections_pow_of_not_isExceptional`:
  This is the non-exceptional case in Dieudonn├ę's theorem,
  as a combination of the two preceding statements.

## TODO

* Prove the third and fourth cases of Dieudonn├ę's theorem that
  concern the case where `e` is exceptional:
  `e` can be written as the product of `finrank K (V ÔžŞ e.fixedSubmodule)`
  transvections and one dilatransvection but not less.

* Prove that the general linear group is generated by dilatransvections.

* Prove that the special linear group is generated by transvections
  (with a bound on the minimal number of transvections needed).

* In the statements above, the dilatransvection is at the right of the product;
  show that it can be inserted anywhere.
  (The point is that transvections normalize dilatransvections.)

-/

@[expose] public section

namespace LinearEquiv

open Module.End Module MulAction Submodule LinearMap

open scoped Pointwise

variable {K : Type*} [DivisionRing K]
    {V : Type*} [AddCommGroup V] [Module K V] [Module.Finite K V]

variable (e f : V ÔëâÔéŚ[K] V)

theorem finrank_fixedSubmodule_add_le :
    finrank K e.fixedSubmodule + finrank K f.fixedSubmodule ÔëĄ
      finrank K Ôćą(e.fixedSubmodule ÔŐö f.fixedSubmodule) +
        finrank K (e * f).fixedSubmodule := by
  have := finrank_mono (fixedSubmodule_inf_fixedSubmodule_le_comp e.toLinearMap f.toLinearMap)
  rwa [ÔćÉ Nat.add_le_add_iff_left, finrank_sup_add_finrank_inf_eq] at this

theorem finrank_le_one_add_finrank_fixedSubmodule_dilatransvection
    (he : e Ôłł dilatransvections K V) :
    finrank K V ÔëĄ 1 + finrank K e.fixedSubmodule := by
  rw [fixedSubmodule_eq_ker, add_comm, ÔćÉ Nat.add_le_add_iff_left,
    ÔćÉ add_assoc, finrank_range_add_finrank_ker, add_comm]
  simpa [ÔćÉ mem_dilatransvections_iff_finrank]

theorem le_one_add_finrank_fixedSubmodule_dilatransvection_mul (hf : f Ôłł dilatransvections K V) :
    finrank K e.fixedSubmodule ÔëĄ 1 + finrank K (f * e).fixedSubmodule := by
  have := finrank_fixedSubmodule_add_le f e
  have := finrank_le_one_add_finrank_fixedSubmodule_dilatransvection f hf
  have : finrank K Ôćą(f.fixedSubmodule ÔŐö e.fixedSubmodule) ÔëĄ finrank K V :=
    finrank_le _
  linarith

theorem finrank_fixedSubmodule_dilatransvection_mul_le (hf : f Ôłł dilatransvections K V) :
    finrank K (f * e).fixedSubmodule ÔëĄ 1 + finrank K e.fixedSubmodule := by
  conv_rhs => rw [show e = fÔü╗┬╣ * (f * e) by simp]
  rw [ÔćÉ inv_mem_dilatransvections_iff] at hf
  exact le_one_add_finrank_fixedSubmodule_dilatransvection_mul (f * e) fÔü╗┬╣ hf

theorem le_one_add_finrank_fixedSubmodule_mul_dilatransvection (hf : f Ôłł dilatransvections K V) :
    finrank K e.fixedSubmodule ÔëĄ 1 + finrank K (e * f).fixedSubmodule := by
  have := finrank_fixedSubmodule_add_le e f
  have := finrank_le_one_add_finrank_fixedSubmodule_dilatransvection f hf
  have : finrank K Ôćą(e.fixedSubmodule ÔŐö f.fixedSubmodule) ÔëĄ finrank K V :=
    finrank_le _
  linarith

theorem finrank_fixedSubmodule_mul_dilatransvection_le (hf : f Ôłł dilatransvections K V) :
    finrank K (e * f).fixedSubmodule ÔëĄ 1 + finrank K e.fixedSubmodule := by
  conv_rhs => rw [show e = (e * f) * fÔü╗┬╣ by simp]
  rw [ÔćÉ inv_mem_dilatransvections_iff] at hf
  exact le_one_add_finrank_fixedSubmodule_mul_dilatransvection (e * f) fÔü╗┬╣ hf

theorem fixedSubmodule_transvection_mul {f : Dual K V} {v : V}
    (hv : v Ôłë e.fixedSubmodule) (hf : e.fixedSubmodule.map f = ÔŐą)
    (hfv : f (v - e v) = 0) (hfv' : f (e v) = 1) :
    (transvection hfv * e).fixedSubmodule = e.fixedSubmodule ÔŐö K ÔłÖ v := by
  symm
  suffices e.fixedSubmodule ÔŐö K ÔłÖ v ÔëĄ (transvection hfv * e).fixedSubmodule by
    apply Submodule.eq_of_le_of_finrank_le this
    rw [finrank_sup_span_singleton hv, add_comm]
    apply finrank_fixedSubmodule_dilatransvection_mul_le
    exact transvection_mem_dilatransvections hfv
  simp only [sup_le_iff, Submodule.span_singleton_le_iff_mem]
  have ht : e.fixedSubmodule ÔëĄ (transvection hfv).fixedSubmodule := fun x hx ÔćŽ by
    rw [mem_fixedSubmodule_transvection_iff, smul_eq_zero]
    left
    rw [ÔćÉ Submodule.mem_bot K, ÔćÉ hf]
    exact mem_map_of_mem hx
  constructor
  ┬Ě -- e.fixedSubmodule ÔëĄ e'.fixedSubmodule
    intro x hx
    simp only [mem_fixedSubmodule_iff, LinearEquiv.coe_toLinearMap, LinearEquiv.mul_apply]
    suffices transvection hfv x = x by
      simp only [mem_fixedSubmodule_iff, LinearEquiv.coe_toLinearMap] at hx
      simp only [hx, this]
    rw [ÔćÉ LinearEquiv.coe_toLinearMap, ÔćÉ mem_fixedSubmodule_iff]
    exact ht hx
  ┬Ě -- u Ôłł e.fixedSubmodule
    simp only [mem_fixedSubmodule_iff, LinearEquiv.coe_toLinearMap,
      LinearEquiv.mul_apply, transvection.apply]
    simp [hfv']

/-- A linear equivalence `u : V ÔëâÔéŚ[K] V` is exceptional if
it is a nontrivial homothety modulo `u.fixedSubmodule`. -/
abbrev IsExceptional (e : V ÔëâÔéŚ[K] V) : Prop :=
  1 < finrank K (V ÔžŞ e.fixedSubmodule) Ôłž
    e.fixedReduce Ôëá 1 Ôłž Ôłâ a : K, ÔłÇ x, fixedReduce e x = a ÔÇó x

/- Private auxiliary construction and lemmas to handle the non-exceptional cases. -/

variable {e} in
private def auxTransvection {f : Dual K V} {u : V}
    (hf : e.fixedSubmodule ÔŐö K ÔłÖ (e u - u) ÔëĄ LinearMap.ker f) :
    V ÔëâÔéŚ[K] V :=
  transvection (f := f) (v := u - e u) (by
    simp only [ÔćÉ LinearMap.mem_ker]
    apply hf
    apply Submodule.mem_sup_right
    rw [mem_span_singleton]
    exact ÔčĘ-1, by simpÔčę)

omit [Module.Finite K V] in
variable {e} in
private theorem auxTransvection_fixed {f : Dual K V} {u : V}
    (hf : e.fixedSubmodule ÔŐö K ÔłÖ (e u - u) ÔëĄ LinearMap.ker f) :
    e.fixedSubmodule ÔëĄ (auxTransvection hf).fixedSubmodule := fun x hx ÔćŽ by
  simp [auxTransvection, LinearMap.transvection.apply, ÔćÉ LinearMap.mem_ker, hf (mem_sup_left hx)]

variable {e} in
private theorem auxTransvection_mul_fixed {f : Dual K V} {u : V}
    {hf : e.fixedSubmodule ÔŐö K ÔłÖ (e u - u) ÔëĄ LinearMap.ker f} (hfu : f u = 1) :
    (auxTransvection hf * e).fixedSubmodule = e.fixedSubmodule ÔŐö K ÔłÖ u := by
  apply fixedSubmodule_transvection_mul
  ┬Ě intro hu'
    replace hu' := hf (mem_sup_left hu')
    rw [mem_ker] at hu'
    simp [hu'] at hfu
  ┬Ě rw [eq_bot_iff]
    rw [gc_map_comap, Submodule.comap_bot]
    exact le_trans le_sup_left hf
  ┬Ě rw [ÔćÉ hfu, ÔćÉ sub_eq_zero, ÔćÉ map_sub, ÔćÉ mem_ker]
    refine hf (mem_sup_right ?_)
    simp

theorem finrank_quotient_sup_span_singleton {W : Submodule K V} {v : V} (hv : v Ôłë W) :
    finrank K (V ÔžŞ (W ÔŐö K ÔłÖ v)) + 1 = finrank K (V ÔžŞ W) := by
  have h1 := finrank_quotient_add_finrank (W ÔŐö K ÔłÖ v)
  have h2 := finrank_quotient_add_finrank W
  rw [finrank_sup_span_singleton hv] at h1
  omega

theorem sup_span_singleton_lt_top {W : Submodule K V} (v : V)
    (hW : 1 < finrank K (V ÔžŞ W)) : W ÔŐö K ÔłÖ v < ÔŐĄ := by
  rw [lt_top_iff_ne_top]
  intro htop
  have h1 := finrank_quotient_add_finrank W
  have h2 : finrank K Ôćą(W ÔŐö K ÔłÖ v) ÔëĄ finrank K W + 1 := by
    refine le_trans (Submodule.finrank_add_le_finrank_add_finrank _ _) ?_
    simp only [add_le_add_iff_left]
    exact le_trans (finrank_span_le_card {v}) (by simp)
  rw [htop, finrank_top] at h2
  omega

variable {e} in
private theorem finrank_mod_auxTransvection_mul_fixed {f : Dual K V} {u : V}
    {hf : e.fixedSubmodule ÔŐö K ÔłÖ (e u - u) ÔëĄ LinearMap.ker f}
    (hfu : f u = 1) (hu : u Ôłë e.fixedSubmodule) :
    finrank K (V ÔžŞ (auxTransvection hf * e).fixedSubmodule) + 1 = finrank K (V ÔžŞ e.fixedSubmodule)
    := by
  rw [auxTransvection_mul_fixed hfu]
  exact finrank_quotient_sup_span_singleton hu

/-- If `e : V ÔëâÔéŚ[K] V` is such that `e.fixedReduce = 1`, then `e` is the product of
at most `finrank K (V ÔžŞ e.fixedSubmodule) - 1` transvections and one dilatransvection.

This is the first non-exceptional case in Dieudonn├ę's theorem. -/
theorem mem_transvections_pow_mul_dilatransvections_of_fixedReduce_eq_one
    {e : V ÔëâÔéŚ[K] V} (he : e.fixedReduce = 1) :
    e Ôłł transvections K V ^ (finrank K (V ÔžŞ e.fixedSubmodule) - 1) * dilatransvections K V := by
  induction h : finrank K (V ÔžŞ e.fixedSubmodule) generalizing e he with
  | zero => simp [mem_dilatransvections_iff_finrank_quotient, h]
  | succ n hind =>
    match n with
    | 0 => simp [mem_dilatransvections_iff_finrank_quotient, h]
    | n + 1 =>
      simp only [add_assoc, Nat.reduceAdd] at h
      simp only [add_tsub_cancel_right] at hind
      simp only [add_tsub_cancel_right, pow_succ', mul_assoc, Set.mem_mul]
      /- We construct a linear form `f` which vanishes on `e.fixedSubmodule`,
        and a vector `v` such that `f v = 1`.
        Consider the transvection `t = transvection f v`.
        Then `t * e` satisfies the induction hypothesis and
        the relation `e = tÔü╗┬╣ * (t * e)` implies that `e` satisfies the theorem.
        This transvection is given by `auxTransvection`. -/
      have : Ôłâ f : Dual K V, Ôłâ v : V, e.fixedSubmodule ÔëĄ ker f Ôłž f v = 1 := by
        have : Ôłâ u : V, u Ôłë e.fixedSubmodule := by
          by_contra! he
          rw [ÔćÉ Submodule.eq_top_iff'] at he
          rw [he, ÔćÉ Nat.add_left_inj, Submodule.finrank_quotient_add_finrank, finrank_top] at h
          simp at h
        obtain ÔčĘu, huÔčę := this
        obtain ÔčĘf, hfu, hfÔčę := Submodule.exists_dual_map_eq_bot_of_notMem hu inferInstance
        let v := (f u)Ôü╗┬╣ ÔÇó u
        have hv : f v = 1 := by simp [v, inv_mul_cancelÔéÇ hfu]
        exact ÔčĘf, v, by rwa [LinearMap.le_ker_iff_map], hvÔčę
      obtain ÔčĘf, v, hf, hvÔčę := this
      -- We have chosen `f` and `v`.
      -- Since `f v = 1`, one has `v Ôłë e.fixedSubmodule`.
      have hv_notMem : v Ôłë e.fixedSubmodule := fun hv' ÔćŽ by
        apply one_ne_zero' K
        rw [ÔćÉ hv, ÔćÉ LinearMap.mem_ker]
        exact hf hv'
      -- Using that `e.fixedReduce = 1`, we have `v - e v Ôłł e.fixedSubmodule`.
      have hv' : v - e v Ôłł e.fixedSubmodule := by
        rw [ÔćÉ e.fixedSubmodule.ker_mkQ, LinearMap.mem_ker, map_sub, sub_eq_zero]
        simp [ÔćÉ fixedReduce_mk, he]
      set t := auxTransvection (e := e) (f := f) (u := v) (by
        simpa [hf] using hf (sub_mem_comm_iff.mp hv')) with ht
      refine ÔčĘtÔü╗┬╣, ?_, t * e, ?_, by simpÔčę
      ┬Ě -- We prove that `tÔü╗┬╣` is a transvection
        rw [inv_mem_transvections_iff, ht]
        apply mem_transvections
      -- It remains to prove that `t * e` satisfies the induction hypothesis
      apply hind
      ┬Ě -- We prove that `(t * e).fixedReduce = 1`.
        simp only [ht, one_eq_refl, fixedReduce_eq_one, auxTransvection_mul_fixed hv] at he ÔŐó
        intro w
        simp only [auxTransvection, LinearEquiv.mul_apply, transvection.apply, add_sub_right_comm]
        apply mem_sup_left
        apply Submodule.add_mem _ (he w)
        exact smul_mem _ _ hv'
      ┬Ě -- `finrank` condition
        rw [ÔćÉ Nat.add_left_inj, finrank_mod_auxTransvection_mul_fixed hv hv_notMem, h]

/- Private lemmas for the second non-exceptional case. -/

omit [Module.Finite K V] in
variable {e} in
/-- If the images of `u` and `e u` in `V ÔžŞ e.fixedSubmodule` are linearly independent,
then `e u` does not belong to `e.fixedSubmodule ÔŐö K ÔłÖ (e u - u)`. -/
private theorem apply_notMem_sup_of_linearIndependent {u : V}
    (hu : LinearIndependent K
      ![e.fixedSubmodule.mkQ u, e.fixedReduce (e.fixedSubmodule.mkQ u)]) :
    e u Ôłë e.fixedSubmodule ÔŐö K ÔłÖ (e u - u) := fun hu' ÔćŽ by
  rw [Submodule.mem_sup] at hu'
  obtain ÔčĘy, hy, z, hz, hu'Ôčę := hu'
  rw [Submodule.mem_span_singleton] at hz
  obtain ÔčĘa, rflÔčę := hz
  simp only [LinearIndependent.pair_iff] at hu
  specialize hu a (1 - a) ?_
  ┬Ě simp only [ÔćÉ LinearMap.map_smul, ÔćÉ LinearEquiv.map_smul]
    simp only [Submodule.mkQ_apply, fixedReduce_mk]
    simp only [ÔćÉ Submodule.mkQ_apply, ÔćÉ map_add, ÔćÉ mem_ker, Submodule.ker_mkQ]
    convert hy
    grind [smul_sub, sub_smul, one_smul, map_smul]
  aesop

omit [Module.Finite K V] in
variable {e} in
/-- If `e.fixedReduce` is not a homothety, then there are a linear form `f` and
a vector `v` such that `f` vanishes on `e.fixedSubmodule ÔŐö K ÔłÖ (e v - v)`, `f v = 1`,
and the images of `v` and `e v` in `V ÔžŞ e.fixedSubmodule` are linearly independent. -/
private theorem exists_dual_of_fixedReduce_ne_smul
    (he : ÔłÇ a : K, Ôłâ x, e.fixedReduce x Ôëá a ÔÇó x)
    (h : 1 < finrank K (V ÔžŞ e.fixedSubmodule)) :
    Ôłâ (f : Dual K V) (v : V),
      LinearIndependent K ![e.fixedSubmodule.mkQ v, e.fixedReduce (e.fixedSubmodule.mkQ v)] Ôłž
        e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔëĄ LinearMap.ker f Ôłž f v = 1 := by
  -- Since `e.fixedReduce` is not a homothety, there is `v : V ÔžŞ e.fixedSubmodule` such
  -- that `v` and `e.fixedReduce v` are linearly independent.
  have : Ôłâ v, LinearIndependent K ![v, e.fixedReduce v] := by
    contrapose! he
    obtain ÔčĘa, haÔčę :=
      LinearMap.exists_mem_center_apply_eq_smul_of_forall_notLinearIndependent h.ne' he
    refine ÔčĘa, fun x ÔćŽ by
      simp only [ÔćÉ coe_toLinearMap, ha, LinearMap.smul_apply, one_apply, Subring.smul_def]Ôčę
  obtain ÔčĘv, huÔčę := this
  -- We lift `v` to `u : V`.
  obtain ÔčĘu, rflÔčę := e.fixedSubmodule.mkQ_surjective v
  -- We can take `f : Dual K V` which vanishes on `e.fixedSubmodule ÔŐö K ÔłÖ (e u - u)`
  -- and satisfies `f u Ôëá 0`, and we rescale `u` to `v` so that `f v = 1`.
  obtain ÔčĘf, hfu, hfÔčę :=
    exists_dual_map_eq_bot_of_notMem (apply_notMem_sup_of_linearIndependent hu) inferInstance
  replace hfu : f u Ôëá 0 := by
    contrapose hfu
    rw [ÔćÉ hfu, ÔćÉ sub_eq_zero, ÔćÉ map_sub, ÔćÉ Submodule.mem_bot K, ÔćÉ hf]
    exact mem_map_of_mem (mem_sup_right (mem_span_singleton_self _))
  set v := (f u)Ôü╗┬╣ ÔÇó u with v_def
  have hspan : K ÔłÖ (e v - v) = K ÔłÖ (e u - u) := by
    simp only [Submodule.span_singleton_eq_span_singleton]
    use (Ne.isUnit hfu).unit
    simp [v_def, _root_.map_smul, Units.smul_isUnit, smul_sub, ÔćÉ mul_smul, mul_inv_cancelÔéÇ hfu]
  rw [ÔćÉ hspan, ÔćÉ le_ker_iff_map] at hf
  refine ÔčĘf, v, ?_, hf,
    by simp only [_root_.map_smul, smul_eq_mul, v_def, inv_mul_cancelÔéÇ hfu]Ôčę
  rw [ÔćÉ LinearIndependent.pair_smul_smul_iff (Ne.isUnit hfu).inv (Ne.isUnit hfu).inv] at hu
  simpa only [ÔćÉ LinearMap.map_smul, ÔćÉ LinearEquiv.map_smul, ÔćÉ v_def] using hu

variable {e} in
/-- Auxiliary lemma for the second non-exceptional case in Dieudonn├ę's theorem:
with the notation of the proof of
`mem_transvections_pow_mul_dilatransvections_of_fixedReduce_ne_smul_id`,
the reductions of `auxTransvection hf * e` and `auxTransvection hg * e`
cannot both be homotheties. -/
private theorem not_forall_fixedReduce_eq_smul {f g : Dual K V} {v : V} {a b : K}
    (hv : LinearIndependent K
      ![e.fixedSubmodule.mkQ v, e.fixedReduce (e.fixedSubmodule.mkQ v)])
    {hf : e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔëĄ LinearMap.ker f} (hfv : f v = 1)
    {hg : e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔëĄ LinearMap.ker (f + g)} (hfgv : (f + g) v = 1)
    (hg0 : g Ôëá 0) (hne_top : e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔŐö K ÔłÖ v < ÔŐĄ)
    (ha : ÔłÇ x, (auxTransvection hf * e).fixedReduce x = a ÔÇó x)
    (hb : ÔłÇ x, (auxTransvection hg * e).fixedReduce x = b ÔÇó x) :
    False := by
  simp only [fixedReduce_eq_smul_iff, auxTransvection_mul_fixed hfv] at ha
  simp only [fixedReduce_eq_smul_iff, auxTransvection_mul_fixed hfgv] at hb
  /- Since `auxTransvection hf = transvection f (v - e v)` and
    `auxTransvection hg = transvection (f + g) (v - e v)`,
    subtracting the relations `ha` and `hb` gives the following: -/
  set c := b - a with hc
  have key (x : V) : g (e x) ÔÇó (v - e v) - c ÔÇó x Ôłł e.fixedSubmodule ÔŐö K ÔłÖ v := by
    have ha := ha x
    have hb := hb x
    simp only [LinearEquiv.mul_apply, transvection.apply, auxTransvection] at ha hb
    rw [LinearMap.add_apply, add_smul, ÔćÉ add_assoc] at hb
    convert Submodule.sub_mem _ hb ha using 1
    -- should be taken care by a `module` tactic that handles noncommutative rings
    simp only [add_comm _ (g (e x) ÔÇó _), ÔćÉ add_assoc]
    rw [sub_eq_add_neg]
    simp only [add_sub_assoc, add_assoc, add_right_inj, sub_smul, smul_sub, hc]
    abel
  -- To get the contradiction, we distinguish whether `a = b` or not.
  rcases eq_or_ne c 0 with hc0 | hc0
  ┬Ě -- When `c = 0`, we contradict the linear independence given by `hv`
    apply one_ne_zero (╬▒ := K)
    rw [LinearIndependent.pair_iff] at hv
    have hmem : v - e v Ôłł e.fixedSubmodule ÔŐö K ÔłÖ v := by
      simp only [hc0, zero_smul, sub_zero] at key
      obtain ÔčĘw, hwÔčę : Ôłâ w, g w Ôëá 0 := by
        contrapose! hg0
        exact LinearMap.ext hg0
      simpa [hw] using key ((g w)Ôü╗┬╣ ÔÇó eÔü╗┬╣ w)
    simp only [mem_sup, mem_span_singleton, exists_exists_eq_and] at hmem
    obtain ÔčĘy, hy, k, hkÔčę := hmem
    refine (hv (k - 1) 1 ?_).right
    simp only [Submodule.mkQ_apply, fixedReduce_mk]
    simp only [ÔćÉ e.fixedSubmodule.mkQ_apply, ÔćÉ LinearMap.map_smul, ÔćÉ map_add,
      ÔćÉ LinearMap.mem_ker, Submodule.ker_mkQ]
    rw [ÔćÉ Submodule.neg_mem_iff] at hy
    convert hy using 1
    rw [eq_comm, ÔćÉ sub_eq_iff_eq_add] at hk
    rw [ÔćÉ hk]
    simp only [sub_smul, one_smul]
    abel
  ┬Ě -- When `c Ôëá 0`, we contradict `hne_top`
    refine hne_top.ne ?_
    rw [eq_top_iff]
    intro x _
    have h1 : g (e x) ÔÇó (v - e v) Ôłł K ÔłÖ (e v - v) :=
      mem_span_singleton.mpr ÔčĘ-g (e x), by rw [neg_smul, smul_sub, smul_sub, neg_sub]Ôčę
    have hle : e.fixedSubmodule ÔŐö K ÔłÖ v ÔëĄ e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔŐö K ÔłÖ v :=
      sup_le_sup_right le_sup_left _
    have h2 : c ÔÇó x Ôłł e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔŐö K ÔłÖ v := by
      rw [show c ÔÇó x = g (e x) ÔÇó (v - e v) - (g (e x) ÔÇó (v - e v) - c ÔÇó x) by abel]
      exact Submodule.sub_mem _ (mem_sup_left (mem_sup_right h1)) (hle (key x))
    simpa [smul_smul, inv_mul_cancelÔéÇ hc0] using Submodule.smul_mem _ cÔü╗┬╣ h2

/-- If an element `e : V ÔëâÔéŚ[K] V` is such that `e.fixedReduce`
is not a homothety, then `e` is the product of at
most `finrank K (V ÔžŞ e.fixedSubmodule) - 1` transvections
and one dilatransvection.

This is the second non-exceptional case in Dieudonn├ę's theorem. -/
theorem mem_transvections_pow_mul_dilatransvections_of_fixedReduce_ne_smul_id
    {e : V ÔëâÔéŚ[K] V}
    (he : ÔłÇ a : K, Ôłâ x, e.fixedReduce x Ôëá a ÔÇó x) :
    e Ôłł transvections K V ^ (finrank K (V ÔžŞ e.fixedSubmodule) - 1) * dilatransvections K V := by
  induction h : finrank K (V ÔžŞ e.fixedSubmodule) generalizing e he with
  | zero => simp [mem_dilatransvections_iff_finrank_quotient, h]
  | succ n hind =>
    match n with
    | 0 => simp [mem_dilatransvections_iff_finrank_quotient, h]
    | n + 1 =>
      simp only [ne_eq, add_tsub_cancel_right] at hind ÔŐó
      simp only [add_assoc, Nat.reduceAdd] at h
      rw [pow_succ', mul_assoc, Set.mem_mul]
      /- The strategy is similar to the first non-exceptional case:
        we construct `f : Dual K V` and `v : V` such that,
        setting `t = auxTransvection hf`, we have `e = tÔü╗┬╣ * (t * e)`
        and `t * e` satisfies the induction hypothesis,
        after possibly replacing `f` by `f + g` for a suitable `g`. -/
      obtain ÔčĘf, v, hv, hf, hfvÔčę := exists_dual_of_fixedReduce_ne_smul he (by omega)
      have hv_notMem : v Ôłë e.fixedSubmodule := by
        simpa [Submodule.Quotient.mk_eq_zero] using hv.ne_zero 0
      have hrank : finrank K (V ÔžŞ (e.fixedSubmodule ÔŐö K ÔłÖ v)) = n + 1 := by
        have := finrank_quotient_sup_span_singleton hv_notMem
        omega
      -- The case `n = 0` is easy
      rcases Nat.eq_zero_or_pos n with hn0 | hn_pos
      ┬Ě simp only [hn0, pow_zero, one_mul]
        refine ÔčĘ(auxTransvection hf)Ôü╗┬╣, ?_, auxTransvection hf * e, ?_, by simpÔčę
        ┬Ě rw [inv_mem_transvections_iff]
          apply mem_transvections
        ┬Ě rw [mem_dilatransvections_iff_finrank_quotient,
            auxTransvection_mul_fixed hfv, hrank, hn0, zero_add]
      by_cases he' : auxTransvection hf * e Ôłł transvections K V ^ n * dilatransvections K V
      ┬Ě -- This is the easy case where one knows that `auxTransvection hf * e` is
        -- the product of at most `n + 1` transvections
        refine ÔčĘ(auxTransvection hf)Ôü╗┬╣, ?_, auxTransvection hf * e, he', by simpÔčę
        rw [inv_mem_transvections_iff]
        apply mem_transvections
      -- Otherwise, we will need to modify `auxTransvection hf` by changing `f`.
      have hne_top : e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔŐö K ÔłÖ v < ÔŐĄ := by
        rw [sup_right_comm]
        exact sup_span_singleton_lt_top _ (by rw [hrank]; omega)
      obtain ÔčĘg : Dual K V, hg0 : g Ôëá 0, hg2Ôčę :=
        Submodule.exists_dual_map_eq_bot_of_lt_top hne_top inferInstance
      rw [ÔćÉ le_ker_iff_map] at hg2
      have hg : e.fixedSubmodule ÔŐö K ÔłÖ (e v - v) ÔëĄ ker (f + g) := fun x hx ÔćŽ by
        rw [mem_ker, LinearMap.add_apply, mem_ker.mp (hf hx),
          mem_ker.mp (hg2 (mem_sup_left hx)), add_zero]
      have hfgv : (f + g) v = 1 := by
        rw [LinearMap.add_apply, hfv,
          mem_ker.mp (hg2 (mem_sup_right (mem_span_singleton_self v))), add_zero]
      refine ÔčĘ(auxTransvection hg)Ôü╗┬╣, ?_, auxTransvection hg * e, ?_, by simpÔčę
      ┬Ě rw [inv_mem_transvections_iff]
        apply mem_transvections
      -- It remains to prove that `auxTransvection hg * e` satisfies the induction hypothesis
      apply hind ?_ (by rw [auxTransvection_mul_fixed hfgv, hrank])
      -- The induction hypothesis implies that `(auxTransvection hf * e).fixedReduce`
      -- is a homothety, for otherwise the previous case would apply.
      obtain ÔčĘa, haÔčę : Ôłâ a : K, ÔłÇ x, (auxTransvection hf * e).fixedReduce x = a ÔÇó x := by
        contrapose! he'
        exact hind he' (by rw [auxTransvection_mul_fixed hfv, hrank])
      -- Then `(auxTransvection hg * e).fixedReduce` cannot also be a homothety.
      intro b
      by_contra! hb
      exact not_forall_fixedReduce_eq_smul hv hfv hfgv hg0 hne_top ha hb

/-- If an element `e : V ÔëâÔéŚ[K] V` is not exceptional,
then it is the product of at most `finrank K (V ÔžŞ e.fixedSubmodule)` dilatransvections.

This is the non-exceptional case in Dieudonn├ę's theorem. -/
theorem mem_transvections_pow_mul_dilatransvections_of_not_isExceptional
    {e : V ÔëâÔéŚ[K] V} (he : ┬Č IsExceptional e) :
    e Ôłł transvections K V ^ (finrank K (V ÔžŞ e.fixedSubmodule) - 1) * dilatransvections K V := by
  simp only [not_and_or] at he
  push Not at he
  rcases he with he | he | he
  ┬Ě simpa [Nat.sub_eq_zero_of_le he, mem_dilatransvections_iff_finrank_quotient] using he
  ┬Ě exact mem_transvections_pow_mul_dilatransvections_of_fixedReduce_eq_one he
  ┬Ě exact mem_transvections_pow_mul_dilatransvections_of_fixedReduce_ne_smul_id he

end LinearEquiv

