variable (R M)

/-- `span` forms a Galois insertion with the coercion from submodule to set. -/
protected def gi : GaloisInsertion (@span R M _ _ _) (έΗΣ) where
  choice s _ := span R s
  gc _ _ := span_le
  le_l_u _ := subset_span
  choice_eq _ _ := rfl

end

@[simp]
theorem span_empty : span R (έΙΖ : Set M) = έΛξ :=
  (Submodule.gi R M).gc.l_bot

@[simp]
theorem span_univ : span R (univ : Set M) = έΛν :=
  eq_top_iff.2 <| SetLike.le_def.2 <| subset_span

@[simp]
theorem span_inter (S S' : Submodule R M) : span R (S έΙσ S') = S έΛΥ S' :=
  (Submodule.gi R M).l_inf_u S S'

theorem span_sInf_le (s : Set (Set M)) : span R (έΜΓέΓΑ s) έΚν sInf (span R '' s) :=
  le_sInf fun _ έθρ_, hTs, hέθσ έΗο h έΨ╕ span_mono (sInter_subset_of_mem hTs)

theorem span_sInf (s : Set (Submodule R M)) : span R (sInf s : Submodule R M) = sInf s :=
  span_eq (sInf s)

theorem span_biInter (s : Set (Submodule R M)) : span R (έΜΓ S έΙΙ s, S) = sInf s := by
  rw [έΗΡ Submodule.coe_sInf, span_eq]

@[simp]
theorem span_union (s t : Set M) : span R (s έΙς t) = span R s έΛΦ span R t :=
  (Submodule.gi R M).gc.l_sup

theorem span_sSup (s : Set (Set M)) : span R (έΜΔέΓΑ s) = sSup (span R '' s) := by
  refine le_antisymm ?_ (sSup_le fun P έθρt, ht, hέθσ έΗο h έΨ╕ span_mono (subset_sUnion_of_mem ht))
  rw [span_le]
  exact fun x έθρt, hts, hxtέθσ έΗο le_sSup (mem_image_of_mem (span R) hts) (subset_span hxt)

theorem span_sSup' (s : Set (Submodule R M)) :
    span R (sSup s : Submodule R M) = sSup s := Submodule.span_eq (sSup s)

theorem span_iUnion {╬╣} (s : ╬╣ έΗΤ Set M) : span R (έΜΔ i, s i) = έρΗ i, span R (s i) :=
  (Submodule.gi R M).gc.l_iSup

theorem span_iUnionέΓΓ {╬╣} {╬║ : ╬╣ έΗΤ Sort*} (s : έΙΑ i, ╬║ i έΗΤ Set M) :
    span R (έΜΔ (i) (j), s i j) = έρΗ (i) (j), span R (s i j) :=
  (Submodule.gi R M).gc.l_iSupέΓΓ

theorem span_biUnion (s : Set (Submodule R M)) : span R (έΜΔ S έΙΙ s, S) = sSup s := by
  simpa using (Submodule.gi R M).l_sSup_u_image s

theorem span_attach_biUnion [DecidableEq M] {╬▒ : Type*} (s : Finset ╬▒) (f : s έΗΤ Finset M) :
    span R (s.attach.biUnion f : Set M) = έρΗ x, span R (f x) := by simp [span_iUnion]

theorem sup_span : p έΛΦ span R s = span R (p έΙς s) := by rw [Submodule.span_union, p.span_eq]

theorem span_sup : span R s έΛΦ p = span R (s έΙς p) := by rw [Submodule.span_union, p.span_eq]

