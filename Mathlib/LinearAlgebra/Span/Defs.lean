  simp_rw [тЖР iSup_span, span_eq]

theorem iSup_eq_span' {╬╣ : Sort*} (p : ╬╣ тЖТ Submodule R M) (h : ╬╣ тЖТ Prop) :
    (тиЖ (i : ╬╣) (_ : h i), p i) = Submodule.span R (тЛГ (i : ╬╣) (_ : h i), тЖС(p i)) := by
  simp_rw [тЖР Submodule.iSup_span, Submodule.span_eq]

/-- A submodule is equal to the supremum of the spans of the submodule's nonzero elements. -/
theorem submodule_eq_sSup_le_nonzero_spans (p : Submodule R M) :
    p = sSup { T : Submodule R M | тИГ m тИИ p, m тЙа 0 тИз T = span R {m} } := by
  let S := { T : Submodule R M | тИГ m тИИ p, m тЙа 0 тИз T = span R {m} }
  apply le_antisymm
  ┬╖ intro m hm
    by_cases h : m = 0
    ┬╖ rw [h]
      simp
    ┬╖ exact @le_sSup _ _ S _ тЯиm, тЯиhm, тЯиh, rflтЯйтЯйтЯй m (mem_span_singleton_self m)
  ┬╖ rw [sSup_le_iff]
    rintro S тЯи_, тЯи_, тЯи_, rflтЯйтЯйтЯй
    rwa [span_singleton_le_iff_mem]

theorem lt_sup_iff_notMem {I : Submodule R M} {a : M} : I < I тКФ R тИЩ a тЖФ a тИЙ I := by simp

theorem mem_iSup {╬╣ : Sort*} (p : ╬╣ тЖТ Submodule R M) {m : M} :
    (m тИИ тиЖ i, p i) тЖФ тИА N, (тИА i, p i тЙд N) тЖТ m тИИ N := by
