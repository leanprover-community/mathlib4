variable (R M) [Semiring R] [AddCommMonoid M] [Module R M] [AddCommMonoid MтВВ] [Module R MтВВ]

/-- A module is principal if it is generated by a single element. -/
abbrev Module.IsPrincipal := (тКд : Submodule R M).IsPrincipal

variable {R M}

theorem Module.isPrincipal_def : IsPrincipal R M тЖФ (тКд : Submodule R M).IsPrincipal := .rfl

open Submodule

theorem Module.isPrincipal_submodule_iff {p : Submodule R M} :
    IsPrincipal R p тЖФ p.IsPrincipal := by
  simp_rw [IsPrincipal, isPrincipal_iff]
  constructor <;> rintro тЯиa, haтЯй
  ┬╖ refine тЯиa, le_antisymm (fun m hm тЖж ?_) <| (span_singleton_le_iff_mem ..).mpr a.2тЯй
    have тЯиr, hrтЯй := mem_span_singleton.mp (ha тЦ╕ (trivial : (тЯиm, hmтЯй : p) тИИ тКд))
    exact mem_span_singleton.mpr тЯиr, congr($hr)тЯй
  ┬╖ refine тЯитЯиa, ha тЦ╕ mem_span_singleton_self aтЯй, .symm <| top_unique fun x _ тЖж ?_тЯй
    have тЯиr, hrтЯй := mem_span_singleton.mp (ha.le x.2)
    exact mem_span_singleton.mpr тЯиr, Subtype.ext hrтЯй

theorem Module.IsPrincipal.of_surjective (f : M тЖТтВЧ[R] MтВВ) (hf : Function.Surjective f)
    [IsPrincipal R M] : IsPrincipal R MтВВ where
  principal := by
    have тЯиm, hmтЯй := IsPrincipal.principal (тКд : Submodule R M)
    refine тЯиf m, .symm <| top_unique fun y _ тЖж ?_тЯй
    obtain тЯиx, rflтЯй := hf y
    obtain тЯиr, rflтЯй := mem_span_singleton.mp (hm.le (trivial : x тИИ тКд))
    simpa only [map_smul] using smul_mem _ r (mem_span_singleton_self _)

theorem LinearEquiv.isPrincipal_iff (e : M тЙГтВЧ[R] MтВВ) :
    Module.IsPrincipal R M тЖФ Module.IsPrincipal R MтВВ where
  mp := (┬╖.of_surjective _ e.surjective)
  mpr := (┬╖.of_surjective _ e.symm.surjective)
