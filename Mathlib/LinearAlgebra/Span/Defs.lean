variable [Semiring RέΓΓ] {╧ΔέΓΒέΓΓ : R έΗΤ+* RέΓΓ}
variable [AddCommMonoid MέΓΓ] [Module RέΓΓ MέΓΓ]
variable {F : Type*} [FunLike F M MέΓΓ] [SemilinearMapClass F ╧ΔέΓΒέΓΓ M MέΓΓ]

