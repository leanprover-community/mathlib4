  rw [span_le, singleton_subset_iff, SetLike.mem_coe]

theorem iSup_span {╬╣ : Sort*} (p : ╬╣ έΗΤ Set M) : έρΗ i, span R (p i) = span R (έΜΔ i, p i) :=
  le_antisymm (iSup_le fun i => span_mono <| subset_iUnion _ i) <|
    span_le.mpr <| iUnion_subset fun i _ hm => mem_iSup_of_mem i <| subset_span hm

theorem iSup_eq_span {╬╣ : Sort*} (p : ╬╣ έΗΤ Submodule R M) : έρΗ i, p i = span R (έΜΔ i, έΗΣ(p i)) := by
  simp_rw [έΗΡ iSup_span, span_eq]

/-- A submodule is equal to the supremum of the spans of the submodule's nonzero elements. -/
theorem submodule_eq_sSup_le_nonzero_spans (p : Submodule R M) :
    p = sSup { T : Submodule R M | έΙΔ m έΙΙ p, m έΚι 0 έΙπ T = span R {m} } := by
  let S := { T : Submodule R M | έΙΔ m έΙΙ p, m έΚι 0 έΙπ T = span R {m} }
  apply le_antisymm
  ┬╖ intro m hm
    by_cases h : m = 0
    ┬╖ rw [h]
      simp
    ┬╖ exact @le_sSup _ _ S _ έθρm, έθρhm, έθρh, rflέθσέθσέθσ m (mem_span_singleton_self m)
  ┬╖ rw [sSup_le_iff]
    rintro S έθρ_, έθρ_, έθρ_, rflέθσέθσέθσ
    rwa [span_singleton_le_iff_mem]

theorem lt_sup_iff_not_mem {I : Submodule R M} {a : M} : (I < I έΛΦ R έΙβ a) έΗΦ a έΙΚ I := by simp

theorem mem_iSup {╬╣ : Sort*} (p : ╬╣ έΗΤ Submodule R M) {m : M} :
    (m έΙΙ έρΗ i, p i) έΗΦ έΙΑ N, (έΙΑ i, p i έΚν N) έΗΤ m έΙΙ N := by
  rw [έΗΡ span_singleton_le_iff_mem, le_iSup_iff]
  simp only [span_singleton_le_iff_mem]

theorem mem_sSup {s : Set (Submodule R M)} {m : M} :
    (m έΙΙ sSup s) έΗΦ έΙΑ N, (έΙΑ p έΙΙ s, p έΚν N) έΗΤ m έΙΙ N := by
  simp_rw [sSup_eq_iSup, Submodule.mem_iSup, iSup_le_iff]

