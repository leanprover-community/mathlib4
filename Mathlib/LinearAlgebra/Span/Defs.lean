variable {p p'}

theorem mem_sup : x тИИ p тКФ p' тЖФ тИГ y тИИ p, тИГ z тИИ p', y + z = x :=
  тЯиfun h => by
    rw [тЖР span_eq p, тЖР span_eq p', тЖР span_union] at h
    refine span_induction ?_ ?_ ?_ ?_ h
    ┬╖ rintro y (h | h)
      ┬╖ exact тЯиy, h, 0, by simp, by simpтЯй
      ┬╖ exact тЯи0, by simp, y, h, by simpтЯй
    ┬╖ exact тЯи0, by simp, 0, by simpтЯй
    ┬╖ rintro _ _ - - тЯиyтВБ, hyтВБ, zтВБ, hzтВБ, rflтЯй тЯиyтВВ, hyтВВ, zтВВ, hzтВВ, rflтЯй
      exact тЯи_, add_mem hyтВБ hyтВВ, _, add_mem hzтВБ hzтВВ, by
        rw [add_assoc, add_assoc, тЖР add_assoc yтВВ, тЖР add_assoc zтВБ, add_comm yтВВ]тЯй
    ┬╖ rintro a - _ тЯиy, hy, z, hz, rflтЯй
      exact тЯи_, smul_mem _ a hy, _, smul_mem _ a hz, by simp [smul_add]тЯй, by
    rintro тЯиy, hy, z, hz, rflтЯй
    exact add_mem ((le_sup_left : p тЙд p тКФ p') hy) ((le_sup_right : p' тЙд p тКФ p') hz)тЯй

theorem mem_sup' : x тИИ p тКФ p' тЖФ тИГ (y : p) (z : p'), (y : M) + z = x :=
  mem_sup.trans <| by simp only [Subtype.exists, exists_prop]

theorem codisjoint_iff_exists_add_eq :
    Codisjoint p p' тЖФ тИА z, тИГ x y, x тИИ p тИз y тИИ p' тИз x + y = z := by
  rw [codisjoint_iff, eq_top_iff']
  exact forall_congr' (fun z => mem_sup.trans <| by simp)

variable (p p')

theorem coe_sup : тЖС(p тКФ p') = (p + p' : Set M) := by
  ext
  rw [SetLike.mem_coe, mem_sup, Set.mem_add]
  simp

theorem sup_toAddSubmonoid : (p тКФ p').toAddSubmonoid = p.toAddSubmonoid тКФ p'.toAddSubmonoid := by
  ext x
  rw [mem_toAddSubmonoid, mem_sup, AddSubmonoid.mem_sup]
  rfl

theorem sup_eq_top_iff : p тКФ p' = тКд тЖФ тИА m : M, тИГ u тИИ p, тИГ v тИИ p', m = u + v := by
  rw [eq_top_iff']
