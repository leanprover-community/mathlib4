@[simp]
theorem coe_iSup_of_directed {╬╣} [Nonempty ╬╣] (S : ╬╣ έΗΤ Submodule R M)
    (H : Directed (┬╖ έΚν ┬╖) S) : ((iSup S : Submodule R M) : Set M) = έΜΔ i, S i :=
  let s : Submodule R M :=
    { __ := AddSubmonoid.copy _ _ (AddSubmonoid.coe_iSup_of_directed H).symm
      smul_mem' := fun r _ hx έΗο have έθρi, hiέθσ := Set.mem_iUnion.mp hx
        Set.mem_iUnion.mpr έθρi, (S i).smul_mem' r hiέθσ }
  have : iSup S = s := le_antisymm
    (iSup_le fun i έΗο le_iSup (fun i έΗο (S i : Set M)) i) (Set.iUnion_subset fun _ έΗο le_iSup S _)
  this.symm έΨ╕ rfl

@[simp]
theorem mem_iSup_of_directed {╬╣} [Nonempty ╬╣] (S : ╬╣ έΗΤ Submodule R M) (H : Directed (┬╖ έΚν ┬╖) S) {x} :
    x έΙΙ iSup S έΗΦ έΙΔ i, x έΙΙ S i := by
  rw [έΗΡ SetLike.mem_coe, coe_iSup_of_directed S H, mem_iUnion]
  rfl

theorem mem_sSup_of_directed {s : Set (Submodule R M)} {z} (hs : s.Nonempty)
    (hdir : DirectedOn (┬╖ έΚν ┬╖) s) : z έΙΙ sSup s έΗΦ έΙΔ y έΙΙ s, z έΙΙ y := by
  have : Nonempty s := hs.to_subtype
  simp only [sSup_eq_iSup', mem_iSup_of_directed _ hdir.directed_val, SetCoe.exists,
    exists_prop]

@[norm_cast, simp]
theorem coe_iSup_of_chain (a : έΕΧ έΗΤo Submodule R M) : (έΗΣ(έρΗ k, a k) : Set M) = έΜΔ k, (a k : Set M) :=
  coe_iSup_of_directed a a.monotone.directed_le

