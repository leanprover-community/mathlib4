/-- For every element in the span of a set, there exists a finite subset of the set
such that the element is contained in the span of the subset. -/
theorem mem_span_finite_of_mem_span {S : Set M} {x : M} (hx : x тИИ span R S) :
    тИГ T : Finset M, тЖСT тКЖ S тИз x тИИ span R (T : Set M) := by
  classical
  refine span_induction (fun x hx => ?_) ?_ ?_ ?_ hx
  ┬╖ refine тЯи{x}, ?_, ?_тЯй
    ┬╖ rwa [Finset.coe_singleton, Set.singleton_subset_iff]
    ┬╖ rw [Finset.coe_singleton]
      exact Submodule.mem_span_singleton_self x
  ┬╖ use тИЕ
    simp
  ┬╖ rintro x y - - тЯиX, hX, hxXтЯй тЯиY, hY, hyYтЯй
    refine тЯиX тИк Y, ?_, ?_тЯй
    ┬╖ rw [Finset.coe_union]
      exact Set.union_subset hX hY
    rw [Finset.coe_union, span_union, mem_sup]
    exact тЯиx, hxX, y, hyY, rflтЯй
  ┬╖ rintro a x - тЯиT, hT, h2тЯй
    exact тЯиT, hT, smul_mem _ _ h2тЯй

theorem subset_span_finite_of_subset_span {s : Set M} {t : Finset M} (ht : (t : Set M) тКЖ span R s) :
    тИГ T : Finset M, тЖСT тКЖ s тИз (t : Set M) тКЖ span R (T : Set M) := by
  classical
  induction t using Finset.induction_on with
  | empty => exact тЯитИЕ, by simpтЯй
  | insert a t hat IH =>
    obtain тЯиT, hTs, htTтЯй := IH (by simp_all [Set.insert_subset_iff])
    obtain тЯиT', hT's, haT'тЯй := mem_span_finite_of_mem_span (ht (Finset.mem_insert_self _ _))
    refine тЯиT тИк T', by simp_all, ?_тЯй
    simp only [Finset.coe_insert, Finset.coe_union, span_union, insert_subset_iff, SetLike.mem_coe]
    exact тЯиmem_sup_right haT', htT.trans (le_sup_left (a := span R _))тЯй

end

