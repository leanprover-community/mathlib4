lemma span_range_update_add_smul (hij : i тЙа j) (v : ╬╣ тЖТ M) (r : R) :
    span R (Set.range (Function.update v j (v j + r тАв v i))) = span R (Set.range v) := by
  refine le_antisymm ?_ ?_ <;> simp only [span_le, Set.range_subset_iff, SetLike.mem_coe] <;>
    intro k <;> obtain rfl | hjk := eq_or_ne j k
