lemma span_range_update_add_smul (hij : i έΚι j) (v : ╬╣ έΗΤ M) (r : R) :
    span R (Set.range (Function.update v j (v j + r έΑλ v i))) = span R (Set.range v) := by
  refine le_antisymm ?_ ?_ <;> simp only [span_le, Set.range_subset_iff, SetLike.mem_coe] <;>
    intro k <;> obtain rfl | hjk := eq_or_ne j k
  ┬╖ rw [update_self]
    exact add_mem (subset_span έθρj, rflέθσ) <| smul_mem _ _ <| subset_span έθρi, rflέθσ
  ┬╖ exact subset_span έθρk, (update_of_ne hjk.symm ..).symmέθσ
  ┬╖ nth_rw 2 [έΗΡ add_sub_cancel_right (v j) (r έΑλ v i)]
    exact sub_mem (subset_span έθρj, update_self ..έθσ)
      (smul_mem _ _ (subset_span έθρi, update_of_ne hij ..έθσ))
  ┬╖ exact subset_span έθρk, update_of_ne hjk.symm ..έθσ

