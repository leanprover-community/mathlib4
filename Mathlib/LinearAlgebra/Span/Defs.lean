theorem mem_span_insert' {x y} {s : Set M} :
    x έΙΙ span R (insert y s) έΗΦ έΙΔ a : R, x + a έΑλ y έΙΙ span R s := by
  rw [mem_span_insert]; constructor
  ┬╖ rintro έθρa, z, hz, rflέθσ
