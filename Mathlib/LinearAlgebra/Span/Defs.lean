/-- A module is principal if it is generated by a single element. -/
abbrev Module.IsPrincipal := (έΛν : Submodule R M).IsPrincipal

variable {R M}

theorem Module.isPrincipal_def : IsPrincipal R M έΗΦ (έΛν : Submodule R M).IsPrincipal := .rfl

open Submodule

theorem Module.isPrincipal_submodule_iff {p : Submodule R M} :
    IsPrincipal R p έΗΦ p.IsPrincipal := by
  simp_rw [IsPrincipal, isPrincipal_iff]
  constructor <;> rintro έθρa, haέθσ
  ┬╖ refine έθρa, le_antisymm (fun m hm έΗο ?_) <| (span_singleton_le_iff_mem ..).mpr a.2έθσ
    have έθρr, hrέθσ := mem_span_singleton.mp (ha έΨ╕ (trivial : (έθρm, hmέθσ : p) έΙΙ έΛν))
    exact mem_span_singleton.mpr έθρr, congr($hr)έθσ
  ┬╖ refine έθρέθρa, ha έΨ╕ mem_span_singleton_self aέθσ, .symm <| top_unique fun x _ έΗο ?_έθσ
    have έθρr, hrέθσ := mem_span_singleton.mp (ha.le x.2)
    exact mem_span_singleton.mpr έθρr, Subtype.ext hrέθσ

theorem Module.IsPrincipal.of_surjective (f : M έΗΤέΓΩ[R] MέΓΓ) (hf : Function.Surjective f)
    [IsPrincipal R M] : IsPrincipal R MέΓΓ where
  principal := by
    have έθρm, hmέθσ := IsPrincipal.principal (έΛν : Submodule R M)
    refine έθρf m, .symm <| top_unique fun y _ έΗο ?_έθσ
    obtain έθρx, rflέθσ := hf y
    obtain έθρr, rflέθσ := mem_span_singleton.mp (hm.le (trivial : x έΙΙ έΛν))
    simpa only [map_smul] using smul_mem _ r (mem_span_singleton_self _)

theorem LinearEquiv.isPrincipal_iff (e : M έΚΔέΓΩ[R] MέΓΓ) :
    Module.IsPrincipal R M έΗΦ Module.IsPrincipal R MέΓΓ where
  mp := (┬╖.of_surjective _ e.surjective)
  mpr := (┬╖.of_surjective _ e.symm.surjective)
