theorem mem_span_singleton_trans {x y z : M} (hxy : x έΙΙ R έΙβ y) (hyz : y έΙΙ R έΙβ z) : x έΙΙ R έΙβ z := by
  rw [έΗΡ SetLike.mem_coe, έΗΡ singleton_subset_iff] at *
