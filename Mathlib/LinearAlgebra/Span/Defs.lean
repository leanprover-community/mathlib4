theorem mem_sup : x έΙΙ p έΛΦ p' έΗΦ έΙΔ y έΙΙ p, έΙΔ z έΙΙ p', y + z = x :=
  έθρfun h => by
    rw [έΗΡ span_eq p, έΗΡ span_eq p', έΗΡ span_union] at h
    refine span_induction ?_ ?_ ?_ ?_ h
    ┬╖ rintro y (h | h)
      ┬╖ exact έθρy, h, 0, by simp, by simpέθσ
      ┬╖ exact έθρ0, by simp, y, h, by simpέθσ
    ┬╖ exact έθρ0, by simp, 0, by simpέθσ
    ┬╖ rintro _ _ - - έθρyέΓΒ, hyέΓΒ, zέΓΒ, hzέΓΒ, rflέθσ έθρyέΓΓ, hyέΓΓ, zέΓΓ, hzέΓΓ, rflέθσ
      exact έθρ_, add_mem hyέΓΒ hyέΓΓ, _, add_mem hzέΓΒ hzέΓΓ, by
        rw [add_assoc, add_assoc, έΗΡ add_assoc yέΓΓ, έΗΡ add_assoc zέΓΒ, add_comm yέΓΓ]έθσ
    ┬╖ rintro a - _ έθρy, hy, z, hz, rflέθσ
      exact έθρ_, smul_mem _ a hy, _, smul_mem _ a hz, by simp [smul_add]έθσ, by
    rintro έθρy, hy, z, hz, rflέθσ
    exact add_mem ((le_sup_left : p έΚν p έΛΦ p') hy) ((le_sup_right : p' έΚν p έΛΦ p') hz)έθσ

