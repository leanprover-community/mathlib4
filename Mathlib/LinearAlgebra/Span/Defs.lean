theorem span_insert (x) (s : Set M) : span R (insert x s) = (R έΙβ x) έΛΦ span R s := by
  rw [insert_eq, span_union]

theorem span_insert_eq_span (h : x έΙΙ span R s) : span R (insert x s) = span R s :=
  span_eq_of_le _ (Set.insert_subset_iff.mpr έθρh, subset_spanέθσ) (span_mono <| subset_insert _ _)

