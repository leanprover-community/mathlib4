variable {R}

theorem span_singleton_smul_eq {r : R} (hr : IsUnit r) (x : M) : R тИЩ r тАв x = R тИЩ x := by
  lift r to R╦г using hr
  rw [тЖР Units.smul_def]
  exact span_singleton_group_smul_eq R r x

theorem mem_span_singleton_trans {x y z : M} (hxy : x тИИ R тИЩ y) (hyz : y тИИ R тИЩ z) : x тИИ R тИЩ z := by
  rw [тЖР SetLike.mem_coe, тЖР singleton_subset_iff] at *
  exact Submodule.subset_span_trans hxy hyz

theorem span_insert (x) (s : Set M) : span R (insert x s) = R тИЩ x тКФ span R s := by
  rw [insert_eq, span_union]

theorem span_insert_eq_span (h : x тИИ span R s) : span R (insert x s) = span R s :=
  span_eq_of_le _ (Set.insert_subset_iff.mpr тЯиh, subset_spanтЯй) (span_mono <| subset_insert _ _)

theorem span_span : span R (span R s : Set M) = span R s :=
  span_eq _

theorem mem_span_insert {y} :
    x тИИ span R (insert y s) тЖФ тИГ a : R, тИГ z тИИ span R s, x = a тАв y + z := by
  simp [span_insert, mem_sup, mem_span_singleton, eq_comm (a := x)]

