variable (R) in
/-- The span of a set `s έΛΗ M` is the smallest submodule of M that contains `s`. -/
def span (s : Set M) : Submodule R M :=
  sInf { p | s έΛΗ p }

-- Porting note: renamed field to `principal'` and added `principal` to fix explicit argument
/-- An `R`-submodule of `M` is principal if it is generated by one element. -/
@[mk_iff]
class IsPrincipal (S : Submodule R M) : Prop where
  principal' : έΙΔ a, S = span R {a}

theorem IsPrincipal.principal (S : Submodule R M) [S.IsPrincipal] :
    έΙΔ a, S = span R {a} :=
  Submodule.IsPrincipal.principal'

end

variable {s t : Set M}

theorem mem_span : x έΙΙ span R s έΗΦ έΙΑ p : Submodule R M, s έΛΗ p έΗΤ x έΙΙ p :=
  mem_iInterέΓΓ

@[aesop safe 20 apply (rule_sets := [SetLike])]
theorem subset_span : s έΛΗ span R s := fun _ h => mem_span.2 fun _ hp => hp h

theorem span_le {p} : span R s έΚν p έΗΦ s έΛΗ p :=
  έθρSubset.trans subset_span, fun ss _ h => mem_span.1 h _ ssέθσ

@[gcongr] theorem span_mono (h : s έΛΗ t) : span R s έΚν span R t :=
  span_le.2 <| Subset.trans h subset_span

theorem span_monotone : Monotone (span R : Set M έΗΤ Submodule R M) := fun _ _ => span_mono

theorem span_eq_of_le (hέΓΒ : s έΛΗ p) (hέΓΓ : p έΚν span R s) : span R s = p :=
  le_antisymm (span_le.2 hέΓΒ) hέΓΓ

theorem span_eq : span R (p : Set M) = p :=
  span_eq_of_le _ (Subset.refl _) subset_span

theorem span_eq_span (hs : s έΛΗ span R t) (ht : t έΛΗ span R s) : span R s = span R t :=
  le_antisymm (span_le.2 hs) (span_le.2 ht)

/-- A version of `Submodule.span_eq` for subobjects closed under addition and scalar multiplication
and containing zero. In general, this should not be used directly, but can be used to quickly
generate proofs for specific types of subobjects. -/
lemma coe_span_eq_self [SetLike S M] [AddSubmonoidClass S M] [SMulMemClass S R M] (s : S) :
    (span R (s : Set M) : Set M) = s := by
  refine le_antisymm ?_ subset_span
  let s' : Submodule R M :=
    { carrier := s
      add_mem' := add_mem
      zero_mem' := zero_mem _
      smul_mem' := SMulMemClass.smul_mem }
  exact span_le (p := s') |>.mpr le_rfl

@[simp]
theorem span_insert_zero : span R (insert (0 : M) s) = span R s := by
  refine le_antisymm ?_ (Submodule.span_mono (Set.subset_insert 0 s))
  rw [span_le, Set.insert_subset_iff]
  exact έθρby simp only [SetLike.mem_coe, Submodule.zero_mem], Submodule.subset_spanέθσ

theorem closure_subset_span {s : Set M} : (AddSubmonoid.closure s : Set M) έΛΗ span R s :=
  (@AddSubmonoid.closure_le _ _ _ (span R s).toAddSubmonoid).mpr subset_span

theorem closure_le_toAddSubmonoid_span {s : Set M} :
    AddSubmonoid.closure s έΚν (span R s).toAddSubmonoid :=
  closure_subset_span

@[simp]
theorem span_closure {s : Set M} : span R (AddSubmonoid.closure s : Set M) = span R s :=
  le_antisymm (span_le.mpr closure_subset_span) (span_mono AddSubmonoid.subset_closure)

/-- An induction principle for span membership. If `p` holds for 0 and all elements of `s`, and is
preserved under addition and scalar multiplication, then `p` holds for all elements of the span of
`s`. -/
@[elab_as_elim]
theorem span_induction {p : (x : M) έΗΤ x έΙΙ span R s έΗΤ Prop}
    (mem : έΙΑ (x) (h : x έΙΙ s), p x (subset_span h))
    (zero : p 0 (Submodule.zero_mem _))
    (add : έΙΑ x y hx hy, p x hx έΗΤ p y hy έΗΤ p (x + y) (Submodule.add_mem _ έΑ╣_έΑ║ έΑ╣_έΑ║))
    (smul : έΙΑ (a : R) (x hx), p x hx έΗΤ p (a έΑλ x) (Submodule.smul_mem _ _ έΑ╣_έΑ║)) {x}
    (hx : x έΙΙ span R s) : p x hx := by
  let p : Submodule R M :=
    { carrier := { x | έΙΔ hx, p x hx }
      add_mem' := fun έθρ_, hpxέθσ έθρ_, hpyέθσ έΗο έθρ_, add _ _ _ _ hpx hpyέθσ
      zero_mem' := έθρ_, zeroέθσ
      smul_mem' := fun r έΗο fun έθρ_, hpxέθσ έΗο έθρ_, smul r _ _ hpxέθσ }
  exact span_le (p := p) |>.mpr (fun y hy έΗο έθρsubset_span hy, mem y hyέθσ) hx |>.elim fun _ έΗο id

@[deprecated span_induction (since := "2024-10-10")]
alias span_induction' := span_induction

/-- An induction principle for span membership. This is a version of `Submodule.span_induction`
for binary predicates. -/
theorem span_inductionέΓΓ {N : Type*} [AddCommMonoid N] [Module R N] {t : Set N}
    {p : (x : M) έΗΤ (y : N) έΗΤ x έΙΙ span R s έΗΤ y έΙΙ span R t έΗΤ Prop}
    (mem_mem : έΙΑ (x) (y) (hx : x έΙΙ s) (hy : y έΙΙ t), p x y (subset_span hx) (subset_span hy))
    (zero_left : έΙΑ y hy, p 0 y (zero_mem _) hy) (zero_right : έΙΑ x hx, p x 0 hx (zero_mem _))
    (add_left : έΙΑ x y z hx hy hz, p x z hx hz έΗΤ p y z hy hz έΗΤ p (x + y) z (add_mem hx hy) hz)
    (add_right : έΙΑ x y z hx hy hz, p x y hx hy έΗΤ p x z hx hz έΗΤ p x (y + z) hx (add_mem hy hz))
    (smul_left : έΙΑ (r : R) x y hx hy, p x y hx hy έΗΤ p (r έΑλ x) y (smul_mem _ r hx) hy)
    (smul_right : έΙΑ (r : R) x y hx hy, p x y hx hy έΗΤ p x (r έΑλ y) hx (smul_mem _ r hy))
    {a : M} {b : N} (ha : a έΙΙ Submodule.span R s)
    (hb : b έΙΙ Submodule.span R t) : p a b ha hb := by
  induction hb using span_induction with
  | mem z hz => induction ha using span_induction with
    | mem _ h => exact mem_mem _ _ h hz
    | zero => exact zero_left _ _
    | add _ _ _ _ hέΓΒ hέΓΓ => exact add_left _ _ _ _ _ _ hέΓΒ hέΓΓ
    | smul _ _ _ h => exact smul_left _ _ _ _ _ h
  | zero => exact zero_right a ha
  | add _ _ _ _ hέΓΒ hέΓΓ => exact add_right _ _ _ _ _ _ hέΓΒ hέΓΓ
  | smul _ _ _ h => exact smul_right _ _ _ _ _ h

open AddSubmonoid in
theorem span_eq_closure {s : Set M} : (span R s).toAddSubmonoid = closure (@univ R έΑλ s) := by
  refine le_antisymm (fun x (hx : x έΙΙ span R s) έΗο ?of_mem_span) (fun x hx έΗο ?of_mem_closure)
  case of_mem_span =>
    induction hx using span_induction with
    | mem x hx => exact subset_closure έθρ1, trivial, x, hx, one_smul R xέθσ
    | zero => exact zero_mem _
    | add _ _ _ _ hέΓΒ hέΓΓ => exact add_mem hέΓΒ hέΓΓ
    | smul rέΓΒ y _h hy =>
      clear _h
      induction hy using AddSubmonoid.closure_induction with
      | mem _ h =>
        obtain έθρrέΓΓ, -, x, hx, rflέθσ := h
        exact subset_closure έθρrέΓΒ * rέΓΓ, trivial, x, hx, mul_smul ..έθσ
      | one => simpa only [smul_zero] using zero_mem _
      | mul _ _ _ _ hέΓΒ hέΓΓ => simpa only [smul_add] using add_mem hέΓΒ hέΓΓ
  case of_mem_closure =>
    refine closure_le.2 ?_ hx
    rintro - έθρr, -, x, hx, rflέθσ
    exact smul_mem _ _ (subset_span hx)

open AddSubmonoid in
/-- A variant of `span_induction` that combines `έΙΑ x έΙΙ s, p x` and `έΙΑ r x, p x έΗΤ p (r έΑλ x)`
into a single condition `έΙΑ r, έΙΑ x έΙΙ s, p (r έΑλ x)`, which can be easier to verify. -/
@[elab_as_elim]
theorem closure_induction {p : (x : M) έΗΤ x έΙΙ span R s έΗΤ Prop}
    (zero : p 0 (Submodule.zero_mem _))
    (add : έΙΑ x y hx hy, p x hx έΗΤ p y hy έΗΤ p (x + y) (Submodule.add_mem _ έΑ╣_έΑ║ έΑ╣_έΑ║))
    (smul_mem : έΙΑ (r x) (h : x έΙΙ s), p (r έΑλ x) (Submodule.smul_mem _ _ <| subset_span h)) {x}
    (hx : x έΙΙ span R s) : p x hx := by
  have key {v} : v έΙΙ span R s έΗΦ v έΙΙ closure (@univ R έΑλ s) := by simp [έΗΡ span_eq_closure]
  refine AddSubmonoid.closure_induction (p := fun x hx έΗο p x (key.mpr hx))
    ?_ zero (by simpa only [key] using add) (key.mp hx)
  rintro - έθρr, -, x, hx, rflέθσ
  exact smul_mem r x hx

