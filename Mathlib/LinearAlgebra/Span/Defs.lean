/-- For every element in the span of a set, there exists a finite subset of the set
such that the element is contained in the span of the subset. -/
theorem mem_span_finite_of_mem_span {S : Set M} {x : M} (hx : x έΙΙ span R S) :
    έΙΔ T : Finset M, έΗΣT έΛΗ S έΙπ x έΙΙ span R (T : Set M) := by
  classical
  refine span_induction (fun x hx => ?_) ?_ ?_ ?_ hx
  ┬╖ refine έθρ{x}, ?_, ?_έθσ
    ┬╖ rwa [Finset.coe_singleton, Set.singleton_subset_iff]
    ┬╖ rw [Finset.coe_singleton]
      exact Submodule.mem_span_singleton_self x
  ┬╖ use έΙΖ
    simp
  ┬╖ rintro x y - - έθρX, hX, hxXέθσ έθρY, hY, hyYέθσ
    refine έθρX έΙς Y, ?_, ?_έθσ
    ┬╖ rw [Finset.coe_union]
      exact Set.union_subset hX hY
    rw [Finset.coe_union, span_union, mem_sup]
    exact έθρx, hxX, y, hyY, rflέθσ
  ┬╖ rintro a x - έθρT, hT, h2έθσ
    exact έθρT, hT, smul_mem _ _ h2έθσ

theorem subset_span_finite_of_subset_span {s : Set M} {t : Finset M} (ht : (t : Set M) έΛΗ span R s) :
    έΙΔ T : Finset M, έΗΣT έΛΗ s έΙπ (t : Set M) έΛΗ span R (T : Set M) := by
  classical
  induction t using Finset.induction_on with
  | empty => exact έθρέΙΖ, by simpέθσ
  | insert a t hat IH =>
    obtain έθρT, hTs, htTέθσ := IH (by simp_all [Set.insert_subset_iff])
    obtain έθρT', hT's, haT'έθσ := mem_span_finite_of_mem_span (ht (Finset.mem_insert_self _ _))
    refine έθρT έΙς T', by simp_all, ?_έθσ
    simp only [Finset.coe_insert, Finset.coe_union, span_union, insert_subset_iff, SetLike.mem_coe]
    exact έθρmem_sup_right haT', htT.trans (le_sup_left (a := span R _))έθσ

end

