  simp_rw [mem_span_insert, mem_span_singleton, exists_exists_eq_and, eq_comm]

@[simp]
theorem span_eq_bot : span R (s : Set M) = έΛξ έΗΦ έΙΑ x έΙΙ s, (x : M) = 0 :=
  eq_bot_iff.trans
    έθρfun H _ h => (mem_bot R).1 <| H <| subset_span h, fun H =>
      span_le.2 fun x h => (mem_bot R).2 <| H x hέθσ

