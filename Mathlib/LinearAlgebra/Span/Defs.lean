/-!
# The span of a set of vectors, as a submodule

* `Submodule.span s` is defined to be the smallest submodule containing the set `s`.

## Notation

* We introduce the notation `R тИЩ v` for the span of a singleton, `Submodule.span R {v}`.  This is
  `\span`, not the same as the scalar multiplication `тАв`/`\bub`.

-/

@[expose] public section

assert_not_exists Field

variable {R RтВВ K M MтВВ V S : Type*}

namespace Submodule

open Function Set

open scoped Pointwise

section AddCommMonoid

variable [Semiring R] [AddCommMonoid M] [Module R M]
variable {x : M} (p p' : Submodule R M)
variable [Semiring RтВВ] {╧ГтВБтВВ : R тЖТ+* RтВВ}
variable [AddCommMonoid MтВВ] [Module RтВВ MтВВ]
variable {F : Type*} [FunLike F M MтВВ] [SemilinearMapClass F ╧ГтВБтВВ M MтВВ]

section

variable (R) in
/-- The span of a set `s тКЖ M` is the smallest submodule of M that contains `s`. -/
def span (s : Set M) : Submodule R M :=
  sInf { p | s тКЖ p }

/-- An `R`-submodule of `M` is principal if it is generated by one element. -/
@[mk_iff]
class IsPrincipal (S : Submodule R M) : Prop where
  principal (S) : тИГ a, S = span R {a}

instance (x : R) : (span R {x}).IsPrincipal := тЯиx, rflтЯй

namespace IsPrincipal

/-- `generator I`, if `I` is a principal submodule, is an `x тИИ M` such that `span R {x} = I` -/
noncomputable def generator (S : Submodule R M) [S.IsPrincipal] : M :=
  Classical.choose (principal S)

theorem span_singleton_generator (S : Submodule R M) [S.IsPrincipal] : span R {generator S} = S :=
  (Classical.choose_spec (principal S)).symm

end IsPrincipal

end

variable {s t : Set M}

theorem mem_span : x тИИ span R s тЖФ тИА p : Submodule R M, s тКЖ p тЖТ x тИИ p :=
  mem_iInterтВВ

@[simp, aesop safe 20 (rule_sets := [SetLike])]
theorem subset_span : s тКЖ span R s := fun _ h => mem_span.2 fun _ hp => hp h

@[aesop 80% (rule_sets := [SetLike])]
theorem mem_span_of_mem {s : Set M} {x : M} (hx : x тИИ s) : x тИИ span R s := subset_span hx

theorem span_le {p} : span R s тЙд p тЖФ s тКЖ p :=
  тЯиSubset.trans subset_span, fun ss _ h => mem_span.1 h _ ssтЯй

@[gcongr] theorem span_mono (h : s тКЖ t) : span R s тЙд span R t :=
  span_le.2 <| Subset.trans h subset_span

theorem span_monotone : Monotone (span R : Set M тЖТ Submodule R M) := fun _ _ => span_mono

theorem span_eq_of_le (hтВБ : s тКЖ p) (hтВВ : p тЙд span R s) : span R s = p :=
  le_antisymm (span_le.2 hтВБ) hтВВ

theorem span_eq : span R (p : Set M) = p :=
  span_eq_of_le _ (Subset.refl _) subset_span

theorem span_eq_span (hs : s тКЖ span R t) (ht : t тКЖ span R s) : span R s = span R t :=
  le_antisymm (span_le.2 hs) (span_le.2 ht)

/-- A version of `Submodule.span_eq` for subobjects closed under addition and scalar multiplication
and containing zero. In general, this should not be used directly, but can be used to quickly
generate proofs for specific types of subobjects. -/
lemma coe_span_eq_self [SetLike S M] [AddSubmonoidClass S M] [SMulMemClass S R M] (s : S) :
    (span R (s : Set M) : Set M) = s := by
  refine le_antisymm ?_ subset_span
  let s' : Submodule R M :=
    { carrier := s
      add_mem' := add_mem
      zero_mem' := zero_mem _
      smul_mem' := SMulMemClass.smul_mem }
  exact span_le (p := s') |>.mpr le_rfl

@[simp]
theorem span_insert_zero : span R (insert (0 : M) s) = span R s := by
  refine le_antisymm ?_ (Submodule.span_mono (Set.subset_insert 0 s))
  rw [span_le, Set.insert_subset_iff]
  exact тЯиby simp only [SetLike.mem_coe, Submodule.zero_mem], Submodule.subset_spanтЯй

@[simp]
lemma span_sdiff_singleton_zero : span R (s \ {0}) = span R s := by
  by_cases h : 0 тИИ s
  ┬╖ rw [тЖР span_insert_zero, show insert 0 (s \ {0}) = s by simp [h]]
  ┬╖ simp [h]

theorem closure_subset_span {s : Set M} : (AddSubmonoid.closure s : Set M) тКЖ span R s :=
  (@AddSubmonoid.closure_le _ _ _ (span R s).toAddSubmonoid).mpr subset_span

theorem closure_le_toAddSubmonoid_span {s : Set M} :
    AddSubmonoid.closure s тЙд (span R s).toAddSubmonoid :=
  closure_subset_span

@[simp]
theorem span_closure {s : Set M} : span R (AddSubmonoid.closure s : Set M) = span R s :=
  le_antisymm (span_le.mpr closure_subset_span) (span_mono AddSubmonoid.subset_closure)

/-- An induction principle for span membership. If `p` holds for 0 and all elements of `s`, and is
preserved under addition and scalar multiplication, then `p` holds for all elements of the span of
`s`. -/
@[elab_as_elim]
theorem span_induction {p : (x : M) тЖТ x тИИ span R s тЖТ Prop}
    (mem : тИА (x) (h : x тИИ s), p x (subset_span h))
    (zero : p 0 (Submodule.zero_mem _))
    (add : тИА x y hx hy, p x hx тЖТ p y hy тЖТ p (x + y) (Submodule.add_mem _ тА╣_тА║ тА╣_тА║))
    (smul : тИА (a : R) (x hx), p x hx тЖТ p (a тАв x) (Submodule.smul_mem _ _ тА╣_тА║)) {x}
    (hx : x тИИ span R s) : p x hx := by
  let p : Submodule R M :=
    { carrier := { x | тИГ hx, p x hx }
      add_mem' := fun тЯи_, hpxтЯй тЯи_, hpyтЯй тЖж тЯи_, add _ _ _ _ hpx hpyтЯй
      zero_mem' := тЯи_, zeroтЯй
      smul_mem' := fun r тЖж fun тЯи_, hpxтЯй тЖж тЯи_, smul r _ _ hpxтЯй }
  exact span_le (p := p) |>.mpr (fun y hy тЖж тЯиsubset_span hy, mem y hyтЯй) hx |>.elim fun _ тЖж id

/-- An induction principle for span membership. This is a version of `Submodule.span_induction`
for binary predicates. -/
theorem span_inductionтВВ {N : Type*} [AddCommMonoid N] [Module R N] {t : Set N}
    {p : (x : M) тЖТ (y : N) тЖТ x тИИ span R s тЖТ y тИИ span R t тЖТ Prop}
    (mem_mem : тИА (x) (y) (hx : x тИИ s) (hy : y тИИ t), p x y (subset_span hx) (subset_span hy))
    (zero_left : тИА y hy, p 0 y (zero_mem _) hy) (zero_right : тИА x hx, p x 0 hx (zero_mem _))
    (add_left : тИА x y z hx hy hz, p x z hx hz тЖТ p y z hy hz тЖТ p (x + y) z (add_mem hx hy) hz)
    (add_right : тИА x y z hx hy hz, p x y hx hy тЖТ p x z hx hz тЖТ p x (y + z) hx (add_mem hy hz))
    (smul_left : тИА (r : R) x y hx hy, p x y hx hy тЖТ p (r тАв x) y (smul_mem _ r hx) hy)
    (smul_right : тИА (r : R) x y hx hy, p x y hx hy тЖТ p x (r тАв y) hx (smul_mem _ r hy))
    {a : M} {b : N} (ha : a тИИ Submodule.span R s)
    (hb : b тИИ Submodule.span R t) : p a b ha hb := by
  induction hb using span_induction with
  | mem z hz => induction ha using span_induction with
    | mem _ h => exact mem_mem _ _ h hz
    | zero => exact zero_left _ _
    | add _ _ _ _ hтВБ hтВВ => exact add_left _ _ _ _ _ _ hтВБ hтВВ
    | smul _ _ _ h => exact smul_left _ _ _ _ _ h
  | zero => exact zero_right a ha
  | add _ _ _ _ hтВБ hтВВ => exact add_right _ _ _ _ _ _ hтВБ hтВВ
  | smul _ _ _ h => exact smul_right _ _ _ _ _ h

open AddSubmonoid in
theorem span_eq_closure {s : Set M} : (span R s).toAddSubmonoid = closure (@univ R тАв s) := by
  refine le_antisymm (fun x (hx : x тИИ span R s) тЖж ?of_mem_span) (fun x hx тЖж ?of_mem_closure)
  case of_mem_span =>
    induction hx using span_induction with
    | mem x hx => exact subset_closure тЯи1, trivial, x, hx, one_smul R xтЯй
    | zero => exact zero_mem _
    | add _ _ _ _ hтВБ hтВВ => exact add_mem hтВБ hтВВ
    | smul rтВБ y _h hy =>
      clear _h
      induction hy using closure_induction with
      | mem _ h =>
        obtain тЯиrтВВ, -, x, hx, rflтЯй := h
        exact subset_closure тЯиrтВБ * rтВВ, trivial, x, hx, mul_smul ..тЯй
      | zero => simp only [smul_zero, zero_mem]
      | add _ _ _ _ hтВБ hтВВ => simpa only [smul_add] using add_mem hтВБ hтВВ
  case of_mem_closure =>
    refine closure_le.2 ?_ hx
    rintro - тЯиr, -, x, hx, rflтЯй
    exact smul_mem _ _ (subset_span hx)

open AddSubmonoid in
/-- A variant of `span_induction` that combines `тИА x тИИ s, p x` and `тИА r x, p x тЖТ p (r тАв x)`
into a single condition `тИА r, тИА x тИИ s, p (r тАв x)`, which can be easier to verify. -/
@[elab_as_elim]
theorem closure_induction {p : (x : M) тЖТ x тИИ span R s тЖТ Prop}
    (zero : p 0 (Submodule.zero_mem _))
    (add : тИА x y hx hy, p x hx тЖТ p y hy тЖТ p (x + y) (Submodule.add_mem _ тА╣_тА║ тА╣_тА║))
    (smul_mem : тИА (r x) (h : x тИИ s), p (r тАв x) (Submodule.smul_mem _ _ <| subset_span h)) {x}
    (hx : x тИИ span R s) : p x hx := by
  have key {v} : v тИИ span R s тЖФ v тИИ closure (@univ R тАв s) := by simp [тЖР span_eq_closure]
  refine AddSubmonoid.closure_induction (motive := fun x hx тЖж p x (key.mpr hx))
    ?_ zero (by simpa only [key] using add) (key.mp hx)
  rintro - тЯиr, -, x, hx, rflтЯй
  exact smul_mem r x hx

@[simp]
theorem span_span_coe_preimage : span R (((тЖС) : span R s тЖТ M) тБ╗┬╣' s) = тКд :=
  eq_top_iff.2 fun x _ тЖж Subtype.recOn x fun _ hx' тЖж
    span_induction (fun _ h тЖж subset_span h) (zero_mem _) (fun _ _ _ _ тЖж add_mem)
      (fun _ _ _ тЖж smul_mem _ _) hx'

@[simp]
lemma span_setOf_mem_eq_top :
    span R {x : span R s | (x : M) тИИ s} = тКд :=
  span_span_coe_preimage

theorem span_nat_eq_addSubmonoidClosure (s : Set M) :
    (span тДХ s).toAddSubmonoid = AddSubmonoid.closure s := by
  refine Eq.symm (AddSubmonoid.closure_eq_of_le subset_span ?_)
  apply (OrderIso.to_galoisConnection (AddSubmonoid.toNatSubmodule (M := M)).symm).l_le
     (a := span тДХ s) (b := AddSubmonoid.closure s)
  rw [span_le]
  exact AddSubmonoid.subset_closure

@[simp]
theorem span_nat_eq (s : AddSubmonoid M) : (span тДХ (s : Set M)).toAddSubmonoid = s := by
  rw [span_nat_eq_addSubmonoidClosure, s.closure_eq]

theorem span_int_eq_addSubgroupClosure {M : Type*} [AddCommGroup M] (s : Set M) :
    (span тДд s).toAddSubgroup = AddSubgroup.closure s :=
  Eq.symm <|
    AddSubgroup.closure_eq_of_le _ subset_span fun _ hx =>
      span_induction (fun _ hx => AddSubgroup.subset_closure hx) (AddSubgroup.zero_mem _)
        (fun _ _ _ _ => AddSubgroup.add_mem _) (fun _ _ _ _ => AddSubgroup.zsmul_mem _ тА╣_тА║ _) hx

@[simp]
theorem span_int_eq {M : Type*} [AddCommGroup M] (s : AddSubgroup M) :
    (span тДд (s : Set M)).toAddSubgroup = s := by rw [span_int_eq_addSubgroupClosure, s.closure_eq]

theorem _root_.Disjoint.of_span (hst : Disjoint (span R s) (span R t)) :
    Disjoint (s \ {0}) t := by
  rw [disjoint_iff_forall_ne]
  rintro v тЯиhvs, hv0 : v тЙа 0тЯй _ hvt rfl
  exact hv0 <| (disjoint_def.1 hst) v (subset_span hvs) (subset_span hvt)

theorem _root_.Disjoint.of_spanтВА (hst : Disjoint (span R s) (span R t)) (h0s : 0 тИЙ s) :
    Disjoint s t := by
  rw [тЖР diff_singleton_eq_self h0s]
  exact hst.of_span

