@[simp]
theorem mem_span_singleton_self (x : M) : x тИИ R тИЩ x :=
  subset_span rfl

theorem nontrivial_span_singleton {x : M} (h : x тЙа 0) : Nontrivial (R тИЩ x) :=
  тЯиby
    use 0, тЯиx, Submodule.mem_span_singleton_self xтЯй
    intro H
    rw [eq_comm, Submodule.mk_eq_zero] at H
    exact h HтЯй

theorem mem_span_singleton {y : M} : x тИИ R тИЩ y тЖФ тИГ a : R, a тАв y = x :=
  тЯиfun h => by
    refine span_induction ?_ ?_ ?_ ?_ h
    ┬╖ rintro y (rfl | тЯитЯи_тЯйтЯй)
      exact тЯи1, by simpтЯй
    ┬╖ exact тЯи0, by simpтЯй
    ┬╖ rintro _ _ - - тЯиa, rflтЯй тЯиb, rflтЯй
      exact тЯиa + b, by simp [add_smul]тЯй
    ┬╖ rintro a _ - тЯиb, rflтЯй
      exact тЯиa * b, by simp [smul_smul]тЯй, by
    rintro тЯиa, y, rflтЯй; exact smul_mem _ _ (subset_span <| by simp)тЯй

theorem le_span_singleton_iff {s : Submodule R M} {vтВА : M} :
    s тЙд R тИЩ vтВА тЖФ тИА v тИИ s, тИГ r : R, r тАв vтВА = v := by simp_rw [SetLike.le_def, mem_span_singleton]

theorem eq_span_singleton_of_surjective {s : Submodule R M}
    {f : R тЖТтВЧ[R] s} (hf : Surjective f) : s = span R {(f 1 : M)} := by
  refine le_antisymm (fun x hx тЖж mem_span_singleton.mpr ?_)
    (span_le.mpr <| by rintro _ rfl; exact (f 1).2)
  have тЯиr, eqтЯй := hf тЯиx, hxтЯй
  exact тЯиr, by rw [тЖР coe_smul, тЖР map_smul, smul_eq_mul, mul_one, eq]тЯй

variable (R)

theorem span_singleton_eq_top_iff (x : M) : R тИЩ x = тКд тЖФ тИА v, тИГ r : R, r тАв x = v := by
  rw [eq_top_iff, le_span_singleton_iff]
