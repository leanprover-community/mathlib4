    z тИИ span R ({x, y} : Set M) тЖФ тИГ a b : R, a тАв x + b тАв y = z := by
  simp_rw [mem_span_insert, mem_span_singleton, exists_exists_eq_and, eq_comm]

theorem mem_span_triple {w x y z : M} :
    w тИИ span R ({x, y, z} : Set M) тЖФ тИГ a b c : R, a тАв x + b тАв y + c тАв z = w := by
  rw [mem_span_insert]
  simp_rw [mem_span_pair]
  refine exists_congr fun a тЖж тЯи?_, ?_тЯй
  ┬╖ rintro тЯиu, тЯиb, c, rflтЯй, rflтЯй
    exact тЯиb, c, by rw [add_assoc]тЯй
  ┬╖ rintro тЯиb, c, rflтЯй
    exact тЯиb тАв y + c тАв z, тЯиb, c, rflтЯй, by rw [add_assoc]тЯй

@[simp]
theorem span_eq_bot : span R (s : Set M) = тКе тЖФ тИА x тИИ s, (x : M) = 0 :=
  eq_bot_iff.trans
    тЯиfun H _ h => (mem_bot R).1 <| H <| subset_span h, fun H =>
      span_le.2 fun x h => (mem_bot R).2 <| H x hтЯй

theorem span_singleton_eq_bot : R тИЩ x = тКе тЖФ x = 0 := by simp

@[simp]
theorem span_zero : span R (0 : Set M) = тКе := by rw [тЖР singleton_zero, span_singleton_eq_bot]

@[simp]
theorem span_singleton_le_iff_mem (m : M) (p : Submodule R M) : R тИЩ m тЙд p тЖФ m тИИ p := by
  rw [span_le, singleton_subset_iff, SetLike.mem_coe]

theorem iSup_span {╬╣ : Sort*} (p : ╬╣ тЖТ Set M) : тиЖ i, span R (p i) = span R (тЛГ i, p i) :=
  le_antisymm (iSup_le fun i => span_mono <| subset_iUnion _ i) <|
    span_le.mpr <| iUnion_subset fun i _ hm => mem_iSup_of_mem i <| subset_span hm

