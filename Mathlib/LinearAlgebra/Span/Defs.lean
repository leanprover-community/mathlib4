variable (R M)

/-- `span` forms a Galois insertion with the coercion from submodule to set. -/
protected def gi : GaloisInsertion (@span R M _ _ _) (тЖС) where
  choice s _ := span R s
  gc _ _ := span_le
  le_l_u _ := subset_span
  choice_eq _ _ := rfl

end

@[simp]
theorem span_empty : span R (тИЕ : Set M) = тКе :=
  (Submodule.gi R M).gc.l_bot

@[simp]
theorem span_univ : span R (univ : Set M) = тКд :=
  eq_top_iff.2 <| SetLike.le_def.2 <| subset_span

@[simp]
theorem span_inter (S S' : Submodule R M) : span R (S тИй S') = S тКУ S' :=
  (Submodule.gi R M).l_inf_u S S'

theorem span_sInf_le (s : Set (Set M)) : span R (тЛВтВА s) тЙд sInf (span R '' s) :=
  le_sInf fun _ тЯи_, hTs, hтЯй тЖж h тЦ╕ span_mono (sInter_subset_of_mem hTs)

theorem span_sInf (s : Set (Submodule R M)) : span R (sInf s : Submodule R M) = sInf s :=
  span_eq (sInf s)

theorem span_biInter (s : Set (Submodule R M)) : span R (тЛВ S тИИ s, S) = sInf s := by
  rw [тЖР Submodule.coe_sInf, span_eq]

@[simp]
theorem span_union (s t : Set M) : span R (s тИк t) = span R s тКФ span R t :=
  (Submodule.gi R M).gc.l_sup

theorem span_sSup (s : Set (Set M)) : span R (тЛГтВА s) = sSup (span R '' s) := by
  refine le_antisymm ?_ (sSup_le fun P тЯиt, ht, hтЯй тЖж h тЦ╕ span_mono (subset_sUnion_of_mem ht))
  rw [span_le]
  exact fun x тЯиt, hts, hxtтЯй тЖж le_sSup (mem_image_of_mem (span R) hts) (subset_span hxt)

theorem span_sSup' (s : Set (Submodule R M)) :
    span R (sSup s : Submodule R M) = sSup s := Submodule.span_eq (sSup s)

theorem span_iUnion {╬╣} (s : ╬╣ тЖТ Set M) : span R (тЛГ i, s i) = тиЖ i, span R (s i) :=
  (Submodule.gi R M).gc.l_iSup

theorem span_iUnionтВВ {╬╣} {╬║ : ╬╣ тЖТ Sort*} (s : тИА i, ╬║ i тЖТ Set M) :
    span R (тЛГ (i) (j), s i j) = тиЖ (i) (j), span R (s i j) :=
  (Submodule.gi R M).gc.l_iSupтВВ

theorem span_biUnion (s : Set (Submodule R M)) : span R (тЛГ S тИИ s, S) = sSup s := by
  simpa using (Submodule.gi R M).l_sSup_u_image s

theorem span_attach_biUnion [DecidableEq M] {╬▒ : Type*} (s : Finset ╬▒) (f : s тЖТ Finset M) :
    span R (s.attach.biUnion f : Set M) = тиЖ x, span R (f x) := by simp [span_iUnion]

theorem sup_span : p тКФ span R s = span R (p тИк s) := by rw [Submodule.span_union, p.span_eq]

theorem span_sup : span R s тКФ p = span R (s тИк p) := by rw [Submodule.span_union, p.span_eq]

/- Note that the character `тИЩ` U+2219 used below is different from the scalar multiplication
character `тАв` U+2022. -/
notation:70 R:70 " тИЩ " x:70 => span R (singleton x)

/-- Unexpander for `R тИЩ x` notation. This needs to be defined separately because the `{_}`
notation is ambiguous, so we have to specify that it is the `┬лterm{_}┬╗` notation. -/
@[app_unexpander span]
meta def span.unexpander : Lean.PrettyPrinter.Unexpander
  | `($_ $R $s) => match s with
    | `(┬лterm{_}┬╗| {$a}) => `($R тИЩ $a)
    | _ => throw ()
  | _ => throw ()

theorem span_eq_iSup_of_singleton_spans (s : Set M) : span R s = тиЖ x тИИ s, R тИЩ x := by
  simp only [тЖР span_iUnion, Set.biUnion_of_singleton s]

theorem span_range_eq_iSup {╬╣ : Sort*} {v : ╬╣ тЖТ M} : span R (range v) = тиЖ i, R тИЩ v i := by
  rw [span_eq_iSup_of_singleton_spans, iSup_range]

theorem span_smul_le (s : Set M) (r : R) : span R (r тАв s) тЙд span R s := by
  rw [span_le]
  rintro _ тЯиx, hx, rflтЯй
  exact smul_mem (span R s) r (subset_span hx)

theorem subset_span_trans {U V W : Set M} (hUV : U тКЖ Submodule.span R V)
    (hVW : V тКЖ Submodule.span R W) : U тКЖ Submodule.span R W :=
  (Submodule.gi R M).gc.le_u_l_trans hUV hVW

@[simp]
theorem coe_iSup_of_directed {╬╣} [Nonempty ╬╣] (S : ╬╣ тЖТ Submodule R M)
    (H : Predirected (┬╖ тЙд ┬╖) S) : ((iSup S : Submodule R M) : Set M) = тЛГ i, S i :=
  let s : Submodule R M :=
    { __ := AddSubmonoid.copy _ _ (AddSubmonoid.coe_iSup_of_directed H).symm
      smul_mem' := fun r _ hx тЖж have тЯиi, hiтЯй := Set.mem_iUnion.mp hx
        Set.mem_iUnion.mpr тЯиi, (S i).smul_mem' r hiтЯй }
  have : iSup S = s := le_antisymm
    (iSup_le fun i тЖж le_iSup (fun i тЖж (S i : Set M)) i) (Set.iUnion_subset fun _ тЖж le_iSup S _)
  this.symm тЦ╕ rfl

@[simp]
theorem mem_iSup_of_directed {╬╣} [Nonempty ╬╣] (S : ╬╣ тЖТ Submodule R M) (H : Predirected (┬╖ тЙд ┬╖) S) {x} :
    x тИИ iSup S тЖФ тИГ i, x тИИ S i := by
  rw [тЖР SetLike.mem_coe, coe_iSup_of_directed S H, mem_iUnion]
  rfl

theorem mem_sSup_of_directed {s : Set (Submodule R M)} {z} (hs : s.Nonempty)
    (hdir : DirectedOn (┬╖ тЙд ┬╖) s) : z тИИ sSup s тЖФ тИГ y тИИ s, z тИИ y := by
  have : Nonempty s := hs.to_subtype
  simp only [sSup_eq_iSup', mem_iSup_of_directed _ hdir.directed_val, SetCoe.exists,
    exists_prop]

@[norm_cast, simp]
theorem coe_iSup_of_chain (a : тДХ тЖТo Submodule R M) : (тЖС(тиЖ k, a k) : Set M) = тЛГ k, (a k : Set M) :=
  coe_iSup_of_directed a a.monotone.directed_le

@[simp]
theorem mem_iSup_of_chain (a : тДХ тЖТo Submodule R M) (m : M) : (m тИИ тиЖ k, a k) тЖФ тИГ k, m тИИ a k :=
  mem_iSup_of_directed a a.monotone.directed_le

