  exact (inv_smul_smul g x).symm

variable {R}

theorem span_singleton_smul_eq {r : R} (hr : IsUnit r) (x : M) : (R έΙβ r έΑλ x) = R έΙβ x := by
  lift r to R╦μ using hr
  rw [έΗΡ Units.smul_def]
