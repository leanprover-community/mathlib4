/-!
# Focal Subgroup Theorem

This file defines the focal subgroup and proves the Focal Subgroup Theorem.

## Main definitions

* `focalSubgroup H` : The focal subgroup `H*` of a subgroup `H`, generated by elements
  of the form `‚ÅÖx, u‚ÅÜ` where `x ‚àà H` and `‚ÅÖx, u‚ÅÜ ‚àà H`.
* `focalSubgroupOf H` : The focal subgroup of `H` considered as a subgroup of `H`,
  i.e., `(focalSubgroup H).subgroupOf H`.
* `transferFocal H` : The transfer homomorphism `V : G ‚Üí* H ‚ß∏ H*`, defined using the
  abelian quotient `H / H*`.

## Main Theorems

* `transferFocal_eq_pow`:
  The restriction of the transfer map to `H` acts like the power map `x ‚Ü¶ x ^ [G : H]` mod `H*`.
* `commutator_inf_eq_focalSubgroup`: The **Focal Subgroup Theorem**.
  For a Sylow `p`-subgroup `P` of a finite group `G`, `G' ‚äì P = P*`,
  where `P*` is the focal subgroup of `P`.

## References

* [D. Gorenstein, *Finite Groups*][gorenstein1968]
-/
set_option backward.defeqAttrib.useBackward true

@[expose] public section

open scoped commutatorElement

open Function Sylow

namespace Subgroup

section Definitions

variable {G : Type*} [Group G] (H : Subgroup G)

/--
The **Focal Subgroup** of a subgroup `H` (denoted `H*` or `foc(H)`).
It is generated by elements of the form `x‚Åª¬π * (u * x * u‚Åª¬π)` where both `x` and `x^u` are in `H`.
-/
@[to_additive /-- The **Focal Subgroup** of a subgroup `H` (denoted `H*` or `foc(H)`). It is
generated by elements of the form `x‚Åª¬π * (u * x * u‚Åª¬π)` where both `x` and `x^u` are in `H`. -/]
def focalSubgroup : Subgroup G :=
  closure { g | g ‚àà H ‚àß ‚àÉ x ‚àà H, ‚àÉ u : G, g = ‚ÅÖx, u‚ÅÜ }

/--
The focal subgroup considered as a subgroup of `H`.
Note that `focalSubgroup H` is always contained in `H`.
-/
@[to_additive /-- The focal subgroup considered as a subgroup of `H`.
Note that `focalSubgroup H` is always contained in `H`. -/]
def focalSubgroupOf : Subgroup H :=
  (focalSubgroup H).subgroupOf H

@[to_additive]
theorem focalSubgroup_def :
    focalSubgroup H = closure { g | g ‚àà H ‚àß ‚àÉ x ‚àà H, ‚àÉ u : G, g = ‚ÅÖx, u‚ÅÜ } := rfl

@[to_additive]
theorem focalSubgroupOf_def :
    focalSubgroupOf H = (focalSubgroup H).subgroupOf H := rfl

/-- Lemma: The focal subgroup is indeed a subgroup of H. -/
@[to_additive /-- Lemma: The focal subgroup is indeed a subgroup of H. -/]
lemma focalSubgroup_le : focalSubgroup H ‚â§ H := by
  rw [focalSubgroup_def, closure_le]
  rintro g ‚ü®h, -, -, -, -‚ü©
  exact h

@[to_additive (attr := simp)]
theorem map_focalSubgroupOf : H.focalSubgroupOf.map H.subtype = H.focalSubgroup :=
  map_subgroupOf_eq_of_le H.focalSubgroup_le


/-- Lemma: H* is a normal subgroup of H. -/
@[to_additive /-- Lemma: H* is a normal subgroup of H. -/]
instance : Normal (focalSubgroupOf H) := by
  rw [focalSubgroupOf_def, normal_subgroupOf_iff (focalSubgroup_le H)]
  intro n g hn hg
  induction hn using closure_induction with
  | mem z hz =>
    obtain ‚ü®hzH, x, hxP, u, rfl‚ü© := hz
    exact subset_closure ‚ü®by aesop, g * x * g‚Åª¬π, by aesop, g * u * g‚Åª¬π, by group‚ü©
  | one => simp
  | mul _ _ _ _ IHa IHb => simpa using mul_mem IHa IHb
  | inv _ _ IH => simpa [mul_assoc] using inv_mem IH

/-- Lemma: The focal subgroup is contained in the commutator subgroup G'. -/
@[to_additive /-- Lemma: The focal subgroup is contained in the commutator subgroup G'. -/]
lemma focalSubgroup_le_commutator : focalSubgroup H ‚â§ _root_.commutator G := by
  rw [focalSubgroup_def, closure_le]
  rintro g ‚ü®_, x, _, u, rfl‚ü©
  exact commutator_mem_commutator (mem_top x) (mem_top u)

/--
In the quotient `H / H*`, conjugation by any element of `G` preserves equivalence classes.
If `h ‚àà H` and `g‚Åª¬π * h * g ‚àà H`, then `g‚Åª¬πhg ‚â° h (mod H*)`.
-/
@[to_additive /-- In the quotient `H / H*`, conjugation by any element of `G` preserves equivalence
classes. If `h ‚àà H` and `g‚Åª¬π * h * g ‚àà H`, then `g‚Åª¬πhg ‚â° h (mod H*)`. -/]
lemma focalSubgroupOf.mk'_conj_eq {h : G} (hh : h ‚àà H) (g : G)
    (hconj : g‚Åª¬π * h * g ‚àà H) :
    (QuotientGroup.mk' (focalSubgroupOf H)) ‚ü®g‚Åª¬π * h * g, hconj‚ü© =
    (QuotientGroup.mk' (focalSubgroupOf H)) ‚ü®h, hh‚ü© := by
  apply QuotientGroup.eq.mpr
  rw [focalSubgroupOf_def, mem_subgroupOf]
  apply subset_closure
  simp only [coe_mul, coe_inv]
  exact ‚ü®H.mul_mem (H.inv_mem hconj) hh, _, H.inv_mem hconj, g, by group‚ü©

@[to_additive]
theorem focalSubgroupOf_eq_closure :
    focalSubgroupOf H = closure { g : H | ‚àÉ x ‚àà H, ‚àÉ u : G, g = ‚ÅÖx, u‚ÅÜ } := by
  rw [‚Üê map_subtype_inj, map_focalSubgroupOf, MonoidHom.map_closure, focalSubgroup_def]
  congr
  simp
  grind

@[to_additive]
lemma commutator_le_focalSubgroupOf : _root_.commutator H ‚â§ focalSubgroupOf H := by
  rw [focalSubgroupOf_eq_closure]
  apply closure_mono
  rintro - ‚ü®a, -, b, -, -, rfl‚ü©
  exact ‚ü®a, a.2, b, rfl‚ü©

@[to_additive]
lemma commutator_le_focalSubgroup : ‚ÅÖH, H‚ÅÜ ‚â§ focalSubgroup H := by
  grw [‚Üê map_subtype_commutator, H.commutator_le_focalSubgroupOf, map_focalSubgroupOf]

@[to_additive]
instance : IsMulCommutative (H ‚ß∏ focalSubgroupOf H) :=
  Normal.quotient_commutative_iff_commutator_le.mpr H.commutator_le_focalSubgroupOf

open scoped IsMulCommutative

/-- The transfer homomorphism `V : G ‚Üí H/H*` from `G` the abelian quotient `H/H*`. -/
@[to_additive /-- The transfer homomorphism `V : G ‚Üí H/H*` from `G` the abelian quotient `H/H*`. -/]
noncomputable def transferFocal [H.FiniteIndex] : G ‚Üí* H ‚ß∏ focalSubgroupOf H :=
  MonoidHom.transfer (QuotientGroup.mk' (focalSubgroupOf H))

/--
The restriction of the transfer map to `H` acts like the power map `x ‚Ü¶ x^n` mod `H*`,
where `n = [G:H]`.
-/
theorem transferFocal_eq_pow [H.FiniteIndex] (x : H) :
    transferFocal H x = (x : H ‚ß∏ H.focalSubgroupOf) ^ H.index := by
  have : Fintype (Quotient (MulAction.orbitRel (zpowers (x : G)) (G ‚ß∏ H))) :=
    Fintype.ofFinite _
  rw [transferFocal, index_eq_sum_minimalPeriod H x, ‚Üê Finset.prod_pow_eq_pow_sum,
    MonoidHom.transfer_eq_prod_quotient_orbitRel_zpowers_quot]
  apply Finset.prod_congr rfl
  intros
  apply focalSubgroupOf.mk'_conj_eq H

end Definitions

section FocalSubgroupTheorem

variable {G : Type*} [Group G] {p : ‚Ñï} [Fact p.Prime] (P : Sylow p G) [P.FiniteIndex]

/-- The power map `y ‚Ü¶ y^n` is surjective on `P/P*` because `gcd(n, p) = 1`. -/
lemma focalSubgroupOf.pow_index_surjective :
    Surjective fun y : P ‚ß∏ P.focalSubgroupOf ‚Ü¶ y ^ P.index :=
  ((P.2.to_quotient P.focalSubgroupOf).powEquiv' P.not_dvd_index).surjective

/-- The Transfer homomorphism is surjective from `G` to `P/P*`. -/
lemma transferFocal_surjective : Surjective P.transferFocal := by
  intro x
  obtain ‚ü®x, rfl‚ü© := focalSubgroupOf.pow_index_surjective P x
  obtain ‚ü®x, rfl‚ü© := QuotientGroup.mk'_surjective _ x
  exact ‚ü®x, P.transferFocal_eq_pow x‚ü©

/-- Isomorphism theorem: `G / ker(V) ‚âÖ P / P*`. -/
noncomputable def transferFocal.quotientKerMulEquivQuotientFocalSubroupOf :
    G ‚ß∏ P.transferFocal.ker ‚âÉ* P ‚ß∏ P.focalSubgroupOf :=
  QuotientGroup.quotientKerEquivOfSurjective P.transferFocal (transferFocal_surjective P)

lemma ker_restrict_transferFocal_eq_focalSubgroupOf :
    (P.transferFocal.restrict P).ker = P.focalSubgroupOf := by
  ext g
  have hQ : IsPGroup p (P ‚ß∏ P.focalSubgroupOf) := P.2.to_quotient P.focalSubgroupOf
  rw [MonoidHom.mem_ker, MonoidHom.restrict_apply, transferFocal_eq_pow]
  simpa using (hQ.powEquiv' P.not_dvd_index).apply_eq_iff_eq (x := g) (y := 1)

lemma ker_transferFocal_inf_eq_focalSubgroup : P.transferFocal.ker ‚äì P = P.focalSubgroup := by
  rw [‚Üê subgroupOf_map_subtype, ‚Üê MonoidHom.ker_restrict, ‚Üê map_focalSubgroupOf]
  exact congr_arg _ (ker_restrict_transferFocal_eq_focalSubgroupOf P)

open scoped IsMulCommutative in
/--
**The Focal Subgroup Theorem**

For a Sylow p-subgroup P of a finite group G, `P ‚à© G' = P*`,
where `P*` is the focal subgroup of `P`.
-/
theorem commutator_inf_eq_focalSubgroup : _root_.commutator G ‚äì P = P.focalSubgroup := by
  apply le_antisymm
  ¬∑ apply le_trans ?_ (ker_transferFocal_inf_eq_focalSubgroup P).le
    exact inf_le_inf_right _ (Abelianization.commutator_subset_ker P.transferFocal)
  ¬∑ exact le_inf P.focalSubgroup_le_commutator P.focalSubgroup_le

end FocalSubgroupTheorem

end Subgroup

end
