/-!
# Focal Subgroup Theorem

This file defines the focal subgroup and proves the Focal Subgroup Theorem.

## Main Theorem

* `inf_commutator_eq_focalSubgroup`: The Focal Subgroup Theorem.
  It states that for a Sylow p-subgroup `P`, `P ‚ą© G' = P*`, where `P*` is the focal subgroup.

## References

* [D. Gorenstein, *Finite Groups*][gorenstein1968]
-/

@[expose] public section

noncomputable section

open Function Sylow

namespace Subgroup

section Definitions

variable {G : Type*} [Group G] (H : Subgroup G)

/--
The **Focal Subgroup** of a subgroup `H` (denoted `H*` or `foc(H)`).
It is generated by elements of the form `x‚ĀĽ¬Ļ * (u * x * u‚ĀĽ¬Ļ)` where both `x` and `x^u` are in `H`.
-/
def focalSubgroup : Subgroup G :=
  closure { g | g ‚ąą H ‚ąß ‚ąÉ x ‚ąą H, ‚ąÉ u : G, g = ‚ĀÖx, u‚ĀÜ }

/--
The focal subgroup considered as a subgroup of `H`.
Note that `focalSubgroup H` is always contained in `H`.
-/
def focalSubgroupOf : Subgroup H :=
  (focalSubgroup H).subgroupOf H

theorem focalSubgroup_def :
    focalSubgroup H = closure { g | g ‚ąą H ‚ąß ‚ąÉ x ‚ąą H, ‚ąÉ u : G, g = ‚ĀÖx, u‚ĀÜ } := rfl

theorem focalSubgroupOf_def :
    focalSubgroupOf H = (focalSubgroup H).subgroupOf H := rfl

/-- Lemma: The focal subgroup is indeed a subgroup of H. -/
lemma focalSubgroup_le : focalSubgroup H ‚Č§ H := by
  rw [focalSubgroup_def, closure_le]
  rintro g ‚ü®h, -, -, -, -‚ü©
  exact h

theorem map_focalSubgroupOf : H.focalSubgroupOf.map H.subtype = H.focalSubgroup :=
  map_subgroupOf_eq_of_le H.focalSubgroup_le

/-- Lemma: H* is a normal subgroup of H. -/
instance : Normal (focalSubgroupOf H) := by
  rw [focalSubgroupOf_def, normal_subgroupOf_iff (focalSubgroup_le H)]
  intro n g hn hg
  induction hn using closure_induction with
  | mem z hz =>
    obtain ‚ü®hzH, x, hxP, u, rfl‚ü© := hz
    exact subset_closure ‚ü®by aesop, g * x * g‚ĀĽ¬Ļ, by aesop, g * u * g‚ĀĽ¬Ļ, by group‚ü©
  | one => simp
  | mul _ _ _ _ IHa IHb => simpa using mul_mem IHa IHb
  | inv _ _ IH => simpa [mul_assoc] using inv_mem IH

/-- Lemma: The focal subgroup is contained in the commutator subgroup G'. -/
lemma focalSubgroup_le_commutator : focalSubgroup H ‚Č§ _root_.commutator G := by
  rw [focalSubgroup_def, closure_le]
  rintro g ‚ü®_, x, _, u, rfl‚ü©
  exact commutator_mem_commutator (mem_top x) (mem_top u)

/--
In the quotient `H / H*`, conjugation by any element of `G` preserves equivalence classes.
If `h ‚ąą H` and `g‚ĀĽ¬Ļ * h * g ‚ąą H`, then `g‚ĀĽ¬Ļhg ‚Č° h (mod H*)`.
-/
lemma focalSubgroupOf_mk'_conj_eq {h : G} (hh : h ‚ąą H) (g : G)
    (hconj : g‚ĀĽ¬Ļ * h * g ‚ąą H) :
    (QuotientGroup.mk' (focalSubgroupOf H)) ‚ü®g‚ĀĽ¬Ļ * h * g, hconj‚ü© =
    (QuotientGroup.mk' (focalSubgroupOf H)) ‚ü®h, hh‚ü© := by
  apply QuotientGroup.eq.mpr
  rw [focalSubgroupOf, mem_subgroupOf]
  apply subset_closure
  simp only [Subgroup.coe_mul, Subgroup.coe_inv]
  exact ‚ü®H.mul_mem (H.inv_mem hconj) hh, _, H.inv_mem hconj, g, by group‚ü©

theorem focalSubgroupOf_eq_closure :
    focalSubgroupOf H = closure { g : H | ‚ąÉ x ‚ąą H, ‚ąÉ u : G, g = ‚ĀÖx, u‚ĀÜ } := by
  rw [‚Üź (map_injective H.subtype_injective).eq_iff, map_focalSubgroupOf,
    MonoidHom.map_closure, focalSubgroup_def]
  congr
  simp
  grind

lemma commutator_le_focalSubgroupOf : _root_.commutator H ‚Č§ focalSubgroupOf H := by
  rw [focalSubgroupOf_eq_closure]
  apply closure_mono
  rintro - ‚ü®a, -, b, -, -, rfl‚ü©
  exact ‚ü®a, a.2, b, rfl‚ü©

lemma commutator_le_focalSubgroup : ‚ĀÖH, H‚ĀÜ ‚Č§ focalSubgroup H := by
  grw [‚Üź map_subtype_commutator, H.commutator_le_focalSubgroupOf, map_focalSubgroupOf]

instance : IsMulCommutative (H ‚ßł focalSubgroupOf H) :=
  ‚ü®‚ü®(Normal.quotient_commutative_iff_commutator_le.mpr H.commutator_le_focalSubgroupOf).comm‚ü©‚ü©

/--
The Transfer homomorphism `V : G ‚Üí H/H*`.
Defined using the abelian quotient H/H*.
-/
def transferFocal [H.FiniteIndex] : G ‚Üí* H ‚ßł focalSubgroupOf H :=
  MonoidHom.transfer (QuotientGroup.mk' (focalSubgroupOf H))

/--
The restriction of the Transfer map to `H` acts like the power map `x ‚Ü¶ x^n` mod `H*`,
where `n = [G:H]`.
-/
theorem transfer_focal_eq_pow [H.FiniteIndex] (x : H) :
    transferFocal H x = (x : H ‚ßł H.focalSubgroupOf) ^ H.index := by
  haveI : Fintype (Quotient (MulAction.orbitRel (zpowers (x : G)) (G ‚ßł H))) :=
    Fintype.ofFinite _
  rw [transferFocal, index_eq_sum_minimalPeriod H x, ‚Üź Finset.prod_pow_eq_pow_sum,
    MonoidHom.transfer_eq_prod_quotient_orbitRel_zpowers_quot]
  apply Finset.prod_congr rfl
  intros
  apply focalSubgroupOf_mk'_conj_eq H

end Definitions

section FocalSubgroupTheorem

variable {G : Type*} [Group G] [Finite G] {p : ‚Ąē} [Fact (Nat.Prime p)] (P : Sylow p G)

/-- The power map `y ‚Ü¶ y^n` is surjective on `P/P*` because `gcd(n, p) = 1`. -/
lemma focalSubgroupOf.pow_index_surjective : Surjective fun y : P ‚ßł P.focalSubgroupOf ‚Ü¶ y ^ P.index :=
  ((P.2.to_quotient P.focalSubgroupOf).powEquiv' P.not_dvd_index).surjective

/-- The Transfer homomorphism is surjective from `G` to `P/P*`. -/
lemma transfer_restrict_surjective :
    Surjective (transferFocal P.toSubgroup) := by
  intro x
  obtain ‚ü®x, rfl‚ü© := pow_n_surjective_on_p_quotient P x
  obtain ‚ü®x, rfl‚ü© := QuotientGroup.mk'_surjective _ x
  exact ‚ü®x, P.transfer_focal_eq_pow x‚ü©

/-- Isomorphism theorem: `G / ker(V) ‚ČÖ P / P*`. -/
def quotientKerIsoQuotientFocal : G ‚ßł P.transferFocal.ker ‚ČÉ* P ‚ßł P.focalSubgroupOf :=
  QuotientGroup.quotientKerEquivOfSurjective P.transferFocal (transfer_restrict_surjective P)

lemma ker_restrict_transferFocal_eq_focalSubgroupOf :
    (P.transferFocal.restrict P).ker = P.focalSubgroupOf := by
  ext g
  have hQ : IsPGroup p (P ‚ßł P.focalSubgroupOf) := P.2.to_quotient P.focalSubgroupOf
  rw [MonoidHom.mem_ker, MonoidHom.restrict_apply, transfer_focal_eq_pow]
  simpa using (hQ.powEquiv' P.not_dvd_index).apply_eq_iff_eq (x := g) (y := 1)

lemma inf_ker_transferFocal_eq_focalSubgroup : P.transferFocal.ker ‚äď P = P.focalSubgroup := by
  rw [‚Üź subgroupOf_map_subtype, ‚Üź MonoidHom.ker_restrict, ‚Üź map_focalSubgroupOf]
  exact congr_arg _ (ker_restrict_transferFocal_eq_focalSubgroupOf P)

/--
**The Focal Subgroup Theorem**

For a Sylow p-subgroup P of a finite group G, `P ‚ą© G' = P*`,
where `P*` is the focal subgroup of `P`.
-/
theorem commutator_inf_eq_focalSubgroup :  _root_.commutator G ‚äď P = P.focalSubgroup :=
  le_antisymm ((inf_le_inf_right _ (Abelianization.commutator_subset_ker P.transferFocal)).trans
    (inf_ker_transferFocal_eq_focalSubgroup P).le)
      (le_inf P.focalSubgroup_le_commutator P.focalSubgroup_le)

end FocalSubgroupTheorem

end Subgroup

end
