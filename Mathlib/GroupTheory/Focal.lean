/-!
# Focal Subgroup Theorem

This file defines the focal subgroup and proves the Focal Subgroup Theorem.

## Main definitions

* `focalSubgroup H` : The focal subgroup `H*` of a subgroup `H`, generated by elements
  of the form `Ôüůx, uÔüć` where `x Ôłł H` and `Ôüůx, uÔüć Ôłł H`.
* `focalSubgroupOf H` : The focal subgroup of `H` considered as a subgroup of `H`,
  i.e., `(focalSubgroup H).subgroupOf H`.
* `transferFocal H` : The transfer homomorphism `V : G Ôćĺ* H ÔžŞ H*`, defined using the
  abelian quotient `H / H*`.

## Main Theorems

* `transferFocal_eq_pow`:
  The restriction of the transfer map to `H` acts like the power map `x ÔćŽ x ^ [G : H]` mod `H*`.
* `commutator_inf_eq_focalSubgroup`: The **Focal Subgroup Theorem**.
  For a Sylow `p`-subgroup `P` of a finite group `G`, `G' ÔŐô P = P*`,
  where `P*` is the focal subgroup of `P`.

## References

* [D. Gorenstein, *Finite Groups*][gorenstein1968]
-/

@[expose] public section

open scoped commutatorElement

open Function Sylow

namespace Subgroup

section Definitions

variable {G : Type*} [Group G] (H : Subgroup G)

/--
The **Focal Subgroup** of a subgroup `H` (denoted `H*` or `foc(H)`).
It is generated by elements of the form `xÔü╗┬╣ * (u * x * uÔü╗┬╣)` where both `x` and `x^u` are in `H`.
-/
@[to_additive /-- The **Focal Subgroup** of a subgroup `H` (denoted `H*` or `foc(H)`). It is
generated by elements of the form `xÔü╗┬╣ * (u * x * uÔü╗┬╣)` where both `x` and `x^u` are in `H`. -/]
def focalSubgroup : Subgroup G :=
  closure { g | g Ôłł H Ôłž Ôłâ x Ôłł H, Ôłâ u : G, g = Ôüůx, uÔüć }

/--
The focal subgroup considered as a subgroup of `H`.
Note that `focalSubgroup H` is always contained in `H`.
-/
@[to_additive /-- The focal subgroup considered as a subgroup of `H`.
Note that `focalSubgroup H` is always contained in `H`. -/]
def focalSubgroupOf : Subgroup H :=
  (focalSubgroup H).subgroupOf H

@[to_additive]
theorem focalSubgroup_def :
    focalSubgroup H = closure { g | g Ôłł H Ôłž Ôłâ x Ôłł H, Ôłâ u : G, g = Ôüůx, uÔüć } := rfl

@[to_additive]
theorem focalSubgroupOf_def :
    focalSubgroupOf H = (focalSubgroup H).subgroupOf H := rfl

/-- Lemma: The focal subgroup is indeed a subgroup of H. -/
@[to_additive /-- Lemma: The focal subgroup is indeed a subgroup of H. -/]
lemma focalSubgroup_le : focalSubgroup H ÔëĄ H := by
  rw [focalSubgroup_def, closure_le]
  rintro g ÔčĘh, -, -, -, -Ôčę
  exact h

@[to_additive (attr := simp)]
theorem map_focalSubgroupOf : H.focalSubgroupOf.map H.subtype = H.focalSubgroup :=
  map_subgroupOf_eq_of_le H.focalSubgroup_le


/-- Lemma: H* is a normal subgroup of H. -/
@[to_additive /-- Lemma: H* is a normal subgroup of H. -/]
instance : Normal (focalSubgroupOf H) := by
  rw [focalSubgroupOf_def, normal_subgroupOf_iff (focalSubgroup_le H)]
  intro n g hn hg
  induction hn using closure_induction with
  | mem z hz =>
    obtain ÔčĘhzH, x, hxP, u, rflÔčę := hz
    exact subset_closure ÔčĘby aesop, g * x * gÔü╗┬╣, by aesop, g * u * gÔü╗┬╣, by groupÔčę
  | one => simp
  | mul _ _ _ _ IHa IHb => simpa using mul_mem IHa IHb
  | inv _ _ IH => simpa [mul_assoc] using inv_mem IH

/-- Lemma: The focal subgroup is contained in the commutator subgroup G'. -/
@[to_additive /-- Lemma: The focal subgroup is contained in the commutator subgroup G'. -/]
lemma focalSubgroup_le_commutator : focalSubgroup H ÔëĄ _root_.commutator G := by
  rw [focalSubgroup_def, closure_le]
  rintro g ÔčĘ_, x, _, u, rflÔčę
  exact commutator_mem_commutator (mem_top x) (mem_top u)

/--
In the quotient `H / H*`, conjugation by any element of `G` preserves equivalence classes.
If `h Ôłł H` and `gÔü╗┬╣ * h * g Ôłł H`, then `gÔü╗┬╣hg Ôëí h (mod H*)`.
-/
@[to_additive /-- In the quotient `H / H*`, conjugation by any element of `G` preserves equivalence
classes. If `h Ôłł H` and `gÔü╗┬╣ * h * g Ôłł H`, then `gÔü╗┬╣hg Ôëí h (mod H*)`. -/]
lemma focalSubgroupOf.mk'_conj_eq {h : G} (hh : h Ôłł H) (g : G)
    (hconj : gÔü╗┬╣ * h * g Ôłł H) :
    (QuotientGroup.mk' (focalSubgroupOf H)) ÔčĘgÔü╗┬╣ * h * g, hconjÔčę =
    (QuotientGroup.mk' (focalSubgroupOf H)) ÔčĘh, hhÔčę := by
  apply QuotientGroup.eq.mpr
  rw [focalSubgroupOf_def, mem_subgroupOf]
  apply subset_closure
  simp only [coe_mul, coe_inv]
  exact ÔčĘH.mul_mem (H.inv_mem hconj) hh, _, H.inv_mem hconj, g, by groupÔčę

@[to_additive]
theorem focalSubgroupOf_eq_closure :
    focalSubgroupOf H = closure { g : H | Ôłâ x Ôłł H, Ôłâ u : G, g = Ôüůx, uÔüć } := by
  rw [ÔćÉ map_subtype_inj, map_focalSubgroupOf, MonoidHom.map_closure, focalSubgroup_def]
  congr
  simp
  grind

@[to_additive]
lemma commutator_le_focalSubgroupOf : _root_.commutator H ÔëĄ focalSubgroupOf H := by
  rw [focalSubgroupOf_eq_closure]
  apply closure_mono
  rintro - ÔčĘa, -, b, -, -, rflÔčę
  exact ÔčĘa, a.2, b, rflÔčę

@[to_additive]
lemma commutator_le_focalSubgroup : ÔüůH, HÔüć ÔëĄ focalSubgroup H := by
  grw [ÔćÉ map_subtype_commutator, H.commutator_le_focalSubgroupOf, map_focalSubgroupOf]

@[to_additive]
instance : IsMulCommutative (H ÔžŞ focalSubgroupOf H) :=
  Normal.quotient_commutative_iff_commutator_le.mpr H.commutator_le_focalSubgroupOf

open scoped IsMulCommutative

/-- The transfer homomorphism `V : G Ôćĺ H/H*` from `G` the abelian quotient `H/H*`. -/
@[to_additive /-- The transfer homomorphism `V : G Ôćĺ H/H*` from `G` the abelian quotient `H/H*`. -/]
noncomputable def transferFocal [H.FiniteIndex] : G Ôćĺ* H ÔžŞ focalSubgroupOf H :=
  MonoidHom.transfer (QuotientGroup.mk' (focalSubgroupOf H))

/--
The restriction of the transfer map to `H` acts like the power map `x ÔćŽ x^n` mod `H*`,
where `n = [G:H]`.
-/
theorem transferFocal_eq_pow [H.FiniteIndex] (x : H) :
    transferFocal H x = (x : H ÔžŞ H.focalSubgroupOf) ^ H.index := by
  have : Fintype (Quotient (MulAction.orbitRel (zpowers (x : G)) (G ÔžŞ H))) :=
    Fintype.ofFinite _
  rw [transferFocal, index_eq_sum_minimalPeriod H x, ÔćÉ Finset.prod_pow_eq_pow_sum,
    MonoidHom.transfer_eq_prod_quotient_orbitRel_zpowers_quot]
  apply Finset.prod_congr rfl
  intros
  apply focalSubgroupOf.mk'_conj_eq H

end Definitions

section FocalSubgroupTheorem

variable {G : Type*} [Group G] {p : ÔäĽ} [Fact p.Prime] (P : Sylow p G) [P.FiniteIndex]

/-- The power map `y ÔćŽ y^n` is surjective on `P/P*` because `gcd(n, p) = 1`. -/
lemma focalSubgroupOf.pow_index_surjective :
    Surjective fun y : P ÔžŞ P.focalSubgroupOf ÔćŽ y ^ P.index :=
  ((P.2.to_quotient P.focalSubgroupOf).powEquiv' P.not_dvd_index).surjective

/-- The Transfer homomorphism is surjective from `G` to `P/P*`. -/
lemma transferFocal_surjective : Surjective P.transferFocal := by
  intro x
  obtain ÔčĘx, rflÔčę := focalSubgroupOf.pow_index_surjective P x
  obtain ÔčĘx, rflÔčę := QuotientGroup.mk'_surjective _ x
  exact ÔčĘx, P.transferFocal_eq_pow xÔčę

/-- Isomorphism theorem: `G / ker(V) Ôëů P / P*`. -/
noncomputable def transferFocal.quotientKerMulEquivQuotientFocalSubroupOf :
    G ÔžŞ P.transferFocal.ker Ôëâ* P ÔžŞ P.focalSubgroupOf :=
  QuotientGroup.quotientKerEquivOfSurjective P.transferFocal (transferFocal_surjective P)

lemma ker_restrict_transferFocal_eq_focalSubgroupOf :
    (P.transferFocal.restrict P).ker = P.focalSubgroupOf := by
  ext g
  have hQ : IsPGroup p (P ÔžŞ P.focalSubgroupOf) := P.2.to_quotient P.focalSubgroupOf
  rw [MonoidHom.mem_ker, MonoidHom.restrict_apply, transferFocal_eq_pow]
  simpa using (hQ.powEquiv' P.not_dvd_index).apply_eq_iff_eq (x := g) (y := 1)

lemma ker_transferFocal_inf_eq_focalSubgroup : P.transferFocal.ker ÔŐô P = P.focalSubgroup := by
  rw [ÔćÉ subgroupOf_map_subtype, ÔćÉ MonoidHom.ker_restrict, ÔćÉ map_focalSubgroupOf]
  exact congr_arg _ (ker_restrict_transferFocal_eq_focalSubgroupOf P)

open scoped IsMulCommutative in
/--
**The Focal Subgroup Theorem**

For a Sylow p-subgroup P of a finite group G, `P Ôłę G' = P*`,
where `P*` is the focal subgroup of `P`.
-/
theorem commutator_inf_eq_focalSubgroup : _root_.commutator G ÔŐô P = P.focalSubgroup := by
  apply le_antisymm
  ┬Ě apply le_trans ?_ (ker_transferFocal_inf_eq_focalSubgroup P).le
    exact inf_le_inf_right _ (Abelianization.commutator_subset_ker P.transferFocal)
  ┬Ě exact le_inf P.focalSubgroup_le_commutator P.focalSubgroup_le

end FocalSubgroupTheorem

end Subgroup

