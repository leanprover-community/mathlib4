/-!
# Quotients of groups by normal subgroups

This file defines the group structure on the quotient by a normal subgroup.

## Main definitions

* `QuotientGroup.Quotient.Group`: the group structure on `G/N` given a normal subgroup `N` of `G`.
* `mk'`: the canonical group homomorphism `G вҶ’* G/N` given a normal subgroup `N` of `G`.
* `lift ПҶ`: the group homomorphism `G/N вҶ’* H` given a group homomorphism `ПҶ : G вҶ’* H` such that
  `N вҠҶ ker ПҶ`.
* `map f`: the group homomorphism `G/N вҶ’* H/M` given a group homomorphism `f : G вҶ’* H` such that
  `N вҠҶ fвҒ»В№(M)`.

## Tags

quotient groups
-/

@[expose] public section

open Function
open scoped Pointwise

namespace QuotientGroup

variable {G H I M : Type*} [Group G] [Group H] [Monoid M] {N : Subgroup G}

@[to_additive (attr := simp)] lemma leftRel_eq_top : leftRel N = вҠӨ вҶ” N = вҠӨ := by
  simpa [leftRel, MulAction.orbitRel, funext_iff, MulAction.mem_orbit_iff,
    MulAction.subgroup_smul_def, вҶҗ eq_inv_mul_iff_mul_eq]
    using вҹЁfun h вҶҰ by ext; simpa using h _ 1, fun h вҶҰ by simp [h]вҹ©

@[to_additive (attr := simp)] lemma rightRel_eq_top : rightRel N = вҠӨ вҶ” N = вҠӨ := by
  simpa [rightRel, MulAction.orbitRel, funext_iff, MulAction.mem_orbit_iff,
    MulAction.subgroup_smul_def, вҶҗ eq_mul_inv_iff_mul_eq]
    using вҹЁfun h вҶҰ by ext; simpa using h _ 1, fun h вҶҰ by simp [h]вҹ©

@[to_additive (attr := simp)] protected lemma subsingleton_iff : Subsingleton (G в§ё N) вҶ” N = вҠӨ := by
  simp [HasQuotient.Quotient]

@[to_additive (attr := simp)] protected lemma nontrivial_iff : Nontrivial (G в§ё N) вҶ” N вү  вҠӨ := by
  simp [вҶҗ not_subsingleton_iff_nontrivial]

variable (N) [nN : N.Normal]

/-- The congruence relation generated by a normal subgroup. -/
@[to_additive /-- The additive congruence relation generated by a normal additive subgroup. -/]
protected def con : Con G where
  toSetoid := leftRel N
  mul' := fun {a b c d} hab hcd => by
    rw [leftRel_eq] at hab hcd вҠў
    dsimp only
    calc
      cвҒ»В№ * (aвҒ»В№ * b) * cвҒ»В№вҒ»В№ * (cвҒ»В№ * d) вҲҲ N := N.mul_mem (nN.conj_mem _ hab _) hcd
      _ = (a * c)вҒ»В№ * (b * d) := by
        simp only [mul_inv_rev, mul_assoc, inv_mul_cancel_left]

set_option backward.inferInstanceAs.wrap.data false in
@[to_additive]
instance Quotient.group : Group (G в§ё N) :=
  inferInstanceAs <| Group (QuotientGroup.con N).Quotient

/--
The congruence relation defined by the kernel of a group homomorphism is equal to its kernel
as a congruence relation.
-/
@[to_additive QuotientAddGroup.con_ker_eq_addConKer
/-- The additive congruence relation defined by the kernel of an additive group homomorphism is
equal to its kernel as an additive congruence relation. -/]
theorem con_ker_eq_conKer (f : G вҶ’* M) : QuotientGroup.con f.ker = Con.ker f := by
  ext
  rw [QuotientGroup.con, Con.rel_mk, Setoid.comm', leftRel_apply, Con.ker_rel, MonoidHom.eq_iff]

/-- The group homomorphism from `G` to `G/N`. -/
@[to_additive /-- The additive group homomorphism from `G` to `G/N`. -/]
def mk' : G вҶ’* G в§ё N :=
  MonoidHom.mk' QuotientGroup.mk fun _ _ => rfl

@[to_additive (attr := simp)]
theorem coe_mk' : (mk' N : G вҶ’ G в§ё N) = mk :=
  rfl

@[to_additive (attr := simp)]
theorem mk'_apply (x : G) : mk' N x = x :=
  rfl

@[to_additive]
theorem mk'_surjective : Surjective <| mk' N :=
  @mk_surjective _ _ N

@[to_additive]
theorem mk'_eq_mk' {x y : G} : mk' N x = mk' N y вҶ” вҲғ z вҲҲ N, x * z = y :=
  QuotientGroup.eq.trans <| by
    simp only [вҶҗ _root_.eq_inv_mul_iff_mul_eq, exists_eq_right]

/-- Two `MonoidHom`s from a quotient group are equal if their compositions with
`QuotientGroup.mk'` are equal.

See note [partially-applied ext lemmas]. -/
@[to_additive (attr := ext 1100) /-- Two `AddMonoidHom`s from an additive quotient group are equal
if their compositions with `AddQuotientGroup.mk'` are equal.

See note [partially-applied ext lemmas]. -/]
theorem monoidHom_ext вҰғf g : G в§ё N вҶ’* MвҰ„ (h : f.comp (mk' N) = g.comp (mk' N)) : f = g :=
  MonoidHom.ext fun x => QuotientGroup.induction_on x <| (DFunLike.congr_fun h :)

@[to_additive (attr := simp)]
theorem eq_one_iff {N : Subgroup G} [N.Normal] (x : G) : (x : G в§ё N) = 1 вҶ” x вҲҲ N := by
  refine QuotientGroup.eq.trans ?_
  rw [mul_one, Subgroup.inv_mem_iff]

@[to_additive (attr := simp)]
lemma mk'_comp_subtype : (mk' N).comp N.subtype = 1 := by ext; simp

/- Note: `range_mk'` is a lemma about the primed constructor `QuotientGroup.mk'`, not a
  modified version of some `range_mk`. -/
set_option linter.docPrime false in
@[to_additive (attr := simp)]
theorem range_mk' : (QuotientGroup.mk' N).range = вҠӨ :=
  MonoidHom.range_eq_top.mpr (mk'_surjective N)

@[to_additive]
theorem ker_le_range_iff [MulOneClass I] (f : G вҶ’* H) [f.range.Normal] (g : H вҶ’* I) :
    g.ker вүӨ f.range вҶ” (mk' f.range).comp g.ker.subtype = 1 :=
  вҹЁfun h => MonoidHom.ext fun вҹЁ_, hxвҹ© => (eq_one_iff _).mpr <| h hx,
    fun h x hx => (eq_one_iff _).mp <| by exact DFunLike.congr_fun h вҹЁx, hxвҹ©вҹ©

@[to_additive (attr := simp)]
theorem ker_mk' : MonoidHom.ker (QuotientGroup.mk' N : G вҶ’* G в§ё N) = N :=
  Subgroup.ext eq_one_iff

@[to_additive]
theorem eq_iff_div_mem {N : Subgroup G} [nN : N.Normal] {x y : G} :
    (x : G в§ё N) = y вҶ” x / y вҲҲ N := by
  refine eq_comm.trans (QuotientGroup.eq.trans ?_)
  rw [nN.mem_comm_iff, div_eq_mul_inv]

-- for commutative groups we don't need normality assumption

@[to_additive]
instance Quotient.commGroup {G : Type*} [CommGroup G] (N : Subgroup G) : CommGroup (G в§ё N) where
  mul_comm := fun a b => Quotient.inductionOnвӮӮ' a b fun a b => congr_arg mk (mul_comm a b)

local notation " Q" => G в§ё N

@[to_additive (attr := simp)]
theorem mk_one : ((1 : G) : Q) = 1 :=
  rfl

@[to_additive (attr := simp)]
theorem mk_mul (a b : G) : ((a * b : G) : Q) = a * b :=
  rfl

@[to_additive (attr := simp)]
theorem mk_inv (a : G) : ((aвҒ»В№ : G) : Q) = (a : Q)вҒ»В№ :=
  rfl

@[to_additive (attr := simp)]
theorem mk_div (a b : G) : ((a / b : G) : Q) = a / b :=
  rfl

@[to_additive (attr := simp)]
theorem mk_pow (a : G) (n : в„•) : ((a ^ n : G) : Q) = (a : Q) ^ n :=
  rfl

@[to_additive (attr := simp)]
theorem mk_zpow (a : G) (n : в„Ө) : ((a ^ n : G) : Q) = (a : Q) ^ n :=
  rfl

@[to_additive (attr := simp)] lemma map_mk'_self : N.map (mk' N) = вҠҘ := by aesop

/--
The subgroup defined by the class of `1` for a congruence relation on a group.
-/
@[to_additive
/-- The `AddSubgroup` defined by the class of `0` for an additive congruence relation
on an `AddGroup`. -/]
protected def _root_.Con.subgroup (c : Con G) : Subgroup G where
  carrier := { x | c x 1 }
  one_mem' := c.refl 1
  mul_mem' hx hy := by simpa using c.mul hx hy
  inv_mem' h := by simpa using c.inv h

@[to_additive (attr := simp)]
theorem _root_.Con.mem_subgroup_iff {c : Con G} {x : G} :
    x вҲҲ c.subgroup вҶ” c x 1 := Iff.rfl

@[to_additive]
instance (c : Con G) : c.subgroup.Normal :=
  вҹЁfun x hx g вҶҰ by simpa using (c.mul (c.mul (c.refl g) hx) (c.refl gвҒ»В№))вҹ©

@[to_additive (attr := simp)]
theorem _root_.Con.subgroup_quotientGroupCon (H : Subgroup G) [H.Normal] :
    (QuotientGroup.con H).subgroup = H := by
  ext
  simp [QuotientGroup.con, leftRel_apply]

@[to_additive (attr := simp)]
theorem con_subgroup (c : Con G) :
    QuotientGroup.con c.subgroup = c := by
  ext x y
  rw [QuotientGroup.con, Con.rel_mk, leftRel_apply, Con.mem_subgroup_iff]
  exact вҹЁfun h вҶҰ by simpa using c.mul (c.refl x) (c.symm h),
    fun h вҶҰ by simpa using c.mul (c.refl xвҒ»В№) (c.symm h)вҹ©

/--
The normal subgroups correspond to the congruence relations on a group.
-/
@[to_additive (attr := simps) AddSubgroup.orderIsoAddCon
/-- The normal subgroups correspond to the additive congruence relations on an `AddGroup`. -/]
def _root_.Subgroup.orderIsoCon :
    { N : Subgroup G // N.Normal } вүғo Con G where
  toFun N := letI : N.val.Normal := N.prop; QuotientGroup.con N
  invFun c := вҹЁc.subgroup, inferInstanceвҹ©
  left_inv := fun вҹЁN, _вҹ© вҶҰ Subtype.mk_eq_mk.mpr (Con.subgroup_quotientGroupCon N)
  right_inv c := QuotientGroup.con_subgroup c
  map_rel_iff' := by
    simp only [QuotientGroup.con, Equiv.coe_fn_mk, Con.le_def, Con.rel_mk, leftRel_apply]
    refine вҹЁfun h x _ вҶҰ ?_, fun hle _ _ h вҶҰ hle hвҹ©
    specialize @h 1 x
    simp_all

@[to_additive (attr := simp)]
lemma con_le_iff {N M : Subgroup G} [N.Normal] [M.Normal] :
    QuotientGroup.con N вүӨ QuotientGroup.con M вҶ” N вүӨ M :=
  (Subgroup.orderIsoCon.map_rel_iff (a := вҹЁN, inferInstanceвҹ©) (b := вҹЁM, inferInstanceвҹ©))

@[to_additive (attr := gcongr)]
lemma con_mono {N M : Subgroup G} [hN : N.Normal] [hM : M.Normal] (h : N вүӨ M) :
    QuotientGroup.con N вүӨ QuotientGroup.con M :=
  con_le_iff.mpr h

/-- A group homomorphism `ПҶ : G вҶ’* M` with `N вҠҶ ker(ПҶ)` descends (i.e. `lift`s) to a
group homomorphism `G/N вҶ’* M`. -/
@[to_additive /-- An `AddGroup` homomorphism `ПҶ : G вҶ’+ M` with `N вҠҶ ker(ПҶ)` descends (i.e. `lift`s)
to an `AddGroup` homomorphism `G/N вҶ’+ M`. -/]
def lift (ПҶ : G вҶ’* M) (HN : N вүӨ ПҶ.ker) : Q вҶ’* M :=
  (QuotientGroup.con N).lift ПҶ <| con_ker_eq_conKer ПҶ в–ё con_mono HN

@[to_additive (attr := simp)]
theorem lift_mk {ПҶ : G вҶ’* M} (HN : N вүӨ ПҶ.ker) (g : G) : lift N ПҶ HN (g : Q) = ПҶ g :=
  rfl

@[to_additive (attr := simp)]
theorem lift_mk' {ПҶ : G вҶ’* M} (HN : N вүӨ ПҶ.ker) (g : G) : lift N ПҶ HN (mk g : Q) = ПҶ g :=
  rfl
-- TODO: replace `mk` with `mk'`)

@[to_additive (attr := simp)]
theorem lift_comp_mk' (ПҶ : G вҶ’* M) (HN : N вүӨ ПҶ.ker) :
    (QuotientGroup.lift N ПҶ HN).comp (QuotientGroup.mk' N) = ПҶ :=
  rfl

@[to_additive (attr := simp)]
theorem lift_quot_mk {ПҶ : G вҶ’* M} (HN : N вүӨ ПҶ.ker) (g : G) :
    lift N ПҶ HN (Quot.mk _ g : Q) = ПҶ g :=
  rfl

@[to_additive]
theorem lift_surjective_of_surjective (ПҶ : G вҶ’* M) (hПҶ : Function.Surjective ПҶ) (HN : N вүӨ ПҶ.ker) :
    Function.Surjective (QuotientGroup.lift N ПҶ HN) :=
  Quotient.lift_surjective _ _ hПҶ

@[to_additive]
theorem ker_lift (ПҶ : G вҶ’* M) (HN : N вүӨ ПҶ.ker) :
    (QuotientGroup.lift N ПҶ HN).ker = Subgroup.map (QuotientGroup.mk' N) ПҶ.ker := by
  rw [вҶҗ congrArg MonoidHom.ker (lift_comp_mk' N ПҶ HN), вҶҗ MonoidHom.comap_ker,
    Subgroup.map_comap_eq_self_of_surjective (mk'_surjective N)]

/-- A surjective group homomorphism `ПҶ : G вҶ’* H` with `N = ker(ПҶ)` descends (i.e. `lift`s) to a
group isomorphism `G/N вүғ* H`. -/
@[to_additive /-- A surjective `AddGroup` homomorphism `ПҶ : G вҶ’+ H` with `N = ker(ПҶ)` descends
(i.e. `lift`s) to an `AddGroup` isomorphism `G/N вүғ+ H`. -/]
noncomputable def liftEquiv {ПҶ : G вҶ’* H} (hПҶ : Function.Surjective ПҶ)
    (HN : N = ПҶ.ker) : G в§ё N вүғ* H :=
  MulEquiv.ofBijective (QuotientGroup.lift N ПҶ HN.le)
    вҹЁby rw [вҶҗ MonoidHom.ker_eq_bot_iff, ker_lift, вҶҗ HN, QuotientGroup.map_mk'_self],
      lift_surjective_of_surjective N ПҶ hПҶ HN.leвҹ©

@[to_additive (attr := simp)]
theorem liftEquiv_coe {ПҶ : G вҶ’* H} (hПҶ : Function.Surjective ПҶ) (HN : N = ПҶ.ker) (g : G) :
    liftEquiv N hПҶ HN (g : Q) = ПҶ g := rfl

@[to_additive (attr := simp)]
theorem liftEquiv_mk {ПҶ : G вҶ’* H} (hПҶ : Function.Surjective ПҶ) (HN : N = ПҶ.ker) (g : G) :
    liftEquiv N hПҶ HN (mk g : Q) = ПҶ g := rfl

/-- A group homomorphism `f : G вҶ’* H` induces a map `G/N вҶ’* H/M` if `N вҠҶ fвҒ»В№(M)`. -/
@[to_additive
      /-- An `AddGroup` homomorphism `f : G вҶ’+ H` induces a map `G/N вҶ’+ H/M` if `N вҠҶ fвҒ»В№(M)`. -/]
def map (M : Subgroup H) [M.Normal] (f : G вҶ’* H) (h : N вүӨ M.comap f) : G в§ё N вҶ’* H в§ё M := by
  refine QuotientGroup.lift N ((mk' M).comp f) ?_
  intro x hx
  refine QuotientGroup.eq.2 ?_
  rw [mul_one, Subgroup.inv_mem_iff]
  exact h hx

@[to_additive (attr := simp)]
theorem map_mk (M : Subgroup H) [M.Normal] (f : G вҶ’* H) (h : N вүӨ M.comap f) (x : G) :
    map N M f h вҶ‘x = вҶ‘(f x) :=
  rfl

@[to_additive]
theorem map_mk' (M : Subgroup H) [M.Normal] (f : G вҶ’* H) (h : N вүӨ M.comap f) (x : G) :
    map N M f h (mk' _ x) = вҶ‘(f x) :=
  rfl

@[to_additive]
theorem map_surjective_of_surjective (M : Subgroup H) [M.Normal] (f : G вҶ’* H)
    (hf : Function.Surjective (mk вҲҳ f : G вҶ’ H в§ё M)) (h : N вүӨ M.comap f) :
    Function.Surjective (map N M f h) :=
  lift_surjective_of_surjective _ _ hf _

@[to_additive]
theorem ker_map (M : Subgroup H) [M.Normal] (f : G вҶ’* H) (h : N вүӨ Subgroup.comap f M) :
    (map N M f h).ker = Subgroup.map (mk' N) (M.comap f) := by
  simp_rw [вҶҗ ker_mk' M, MonoidHom.comap_ker]
  exact QuotientGroup.ker_lift _ _ _

@[to_additive]
theorem map_id_apply (h : N вүӨ Subgroup.comap (MonoidHom.id _) N := (Subgroup.comap_id N).le) (x) :
    map N N (MonoidHom.id _) h x = x :=
  induction_on x fun _x => rfl

@[to_additive (attr := simp)]
theorem map_id (h : N вүӨ Subgroup.comap (MonoidHom.id _) N := (Subgroup.comap_id N).le) :
    map N N (MonoidHom.id _) h = MonoidHom.id _ :=
  MonoidHom.ext (map_id_apply N h)

@[to_additive (attr := simp)]
theorem map_map {I : Type*} [Group I] (M : Subgroup H) (O : Subgroup I) [M.Normal] [O.Normal]
    (f : G вҶ’* H) (g : H вҶ’* I) (hf : N вүӨ Subgroup.comap f M) (hg : M вүӨ Subgroup.comap g O)
    (hgf : N вүӨ Subgroup.comap (g.comp f) O :=
      hf.trans ((Subgroup.comap_mono hg).trans_eq (Subgroup.comap_comap _ _ _)))
    (x : G в§ё N) : map M O g hg (map N M f hf x) = map N O (g.comp f) hgf x := by
  refine induction_on x fun x => ?_
  simp only [map_mk, MonoidHom.comp_apply]

@[to_additive (attr := simp)]
theorem map_comp_map {I : Type*} [Group I] (M : Subgroup H) (O : Subgroup I) [M.Normal] [O.Normal]
    (f : G вҶ’* H) (g : H вҶ’* I) (hf : N вүӨ Subgroup.comap f M) (hg : M вүӨ Subgroup.comap g O)
    (hgf : N вүӨ Subgroup.comap (g.comp f) O :=
      hf.trans ((Subgroup.comap_mono hg).trans_eq (Subgroup.comap_comap _ _ _))) :
    (map M O g hg).comp (map N M f hf) = map N O (g.comp f) hgf :=
  MonoidHom.ext (map_map N M O f g hf hg hgf)

section Pointwise
open Set

@[to_additive (attr := simp)] lemma image_coe : ((вҶ‘) : G вҶ’ Q) '' N = 1 :=
  congr_arg ((вҶ‘) : Subgroup Q вҶ’ Set Q) <| map_mk'_self N

@[to_additive]
lemma preimage_image_coe (s : Set G) : ((вҶ‘) : G вҶ’ Q) вҒ»В№' ((вҶ‘) '' s) = N * s := by
  ext a
  constructor
  В· rintro вҹЁb, hb, hвҹ©
    refine вҹЁa / b, (QuotientGroup.eq_one_iff _).1 ?_, b, hb, div_mul_cancel _ _вҹ©
    simp only [h, QuotientGroup.mk_div, div_self']
  В· rintro вҹЁa, ha, b, hb, rflвҹ©
    refine вҹЁb, hb, ?_вҹ©
    simpa only [QuotientGroup.mk_mul, right_eq_mul, QuotientGroup.eq_one_iff]

@[to_additive]
lemma image_coe_inj {s t : Set G} : ((вҶ‘) : G вҶ’ Q) '' s = ((вҶ‘) : G вҶ’ Q) '' t вҶ” вҶ‘N * s = N * t := by
  simp_rw [вҶҗ preimage_image_coe]
  exact QuotientGroup.mk_surjective.preimage_injective.eq_iff.symm

end Pointwise

section congr

variable (G' : Subgroup G) (H' : Subgroup H) [Subgroup.Normal G'] [Subgroup.Normal H']

/-- `QuotientGroup.congr` lifts the isomorphism `e : G вүғ H` to `G в§ё G' вүғ H в§ё H'`,
given that `e` maps `G` to `H`. -/
@[to_additive /-- `QuotientAddGroup.congr` lifts the isomorphism `e : G вүғ H` to `G в§ё G' вүғ H в§ё H'`,
given that `e` maps `G` to `H`. -/]
def congr (e : G вүғ* H) (he : G'.map e = H') : G в§ё G' вүғ* H в§ё H' :=
  { map G' H' e (he в–ё G'.le_comap_map (e : G вҶ’* H)) with
    toFun := map G' H' e (he в–ё G'.le_comap_map (e : G вҶ’* H))
    invFun := map H' G' e.symm (he в–ё (G'.map_equiv_eq_comap_symm e).le)
    left_inv := fun x => by
      rw [map_map G' H' G' e e.symm (he в–ё G'.le_comap_map (e : G вҶ’* H))
        (he в–ё (G'.map_equiv_eq_comap_symm e).le)]
      simp only [вҶҗ MulEquiv.coe_monoidHom_trans, MulEquiv.self_trans_symm,
        MulEquiv.coe_monoidHom_refl, map_id_apply]
    right_inv := fun x => by
      rw [map_map H' G' H' e.symm e (he в–ё (G'.map_equiv_eq_comap_symm e).le)
        (he в–ё G'.le_comap_map (e : G вҶ’* H))]
      simp only [вҶҗ MulEquiv.coe_monoidHom_trans, MulEquiv.symm_trans_self,
        MulEquiv.coe_monoidHom_refl, map_id_apply] }

@[simp]
theorem congr_mk (e : G вүғ* H) (he : G'.map вҶ‘e = H') (x) : congr G' H' e he (mk x) = e x :=
  rfl

theorem congr_mk' (e : G вүғ* H) (he : G'.map вҶ‘e = H') (x) :
    congr G' H' e he (mk' G' x) = mk' H' (e x) :=
  rfl

@[simp]
theorem congr_apply (e : G вүғ* H) (he : G'.map вҶ‘e = H') (x : G) :
    congr G' H' e he x = mk' H' (e x) :=
  rfl

@[simp]
theorem congr_refl (he : G'.map (MulEquiv.refl G : G вҶ’* G) = G' := Subgroup.map_id G') :
    congr G' G' (MulEquiv.refl G) he = MulEquiv.refl (G в§ё G') := by
  ext вҹЁxвҹ©
  rfl

@[simp]
theorem congr_symm (e : G вүғ* H) (he : G'.map вҶ‘e = H') :
    (congr G' H' e he).symm = congr H' G' e.symm ((Subgroup.map_symm_eq_iff_map_eq _).mpr he) :=
