/-!
# Quotients of groups by normal subgroups

This file defines the group structure on the quotient by a normal subgroup.

## Main definitions

* `QuotientGroup.Quotient.Group`: the group structure on `G/N` given a normal subgroup `N` of `G`.
* `mk'`: the canonical group homomorphism `G ‚Üí* G/N` given a normal subgroup `N` of `G`.
* `lift ŌÜ`: the group homomorphism `G/N ‚Üí* H` given a group homomorphism `ŌÜ : G ‚Üí* H` such that
  `N ‚äÜ ker ŌÜ`.
* `map f`: the group homomorphism `G/N ‚Üí* H/M` given a group homomorphism `f : G ‚Üí* H` such that
  `N ‚äÜ f‚ĀĽ¬Ļ(M)`.

## Tags

quotient groups
-/
set_option backward.defeqAttrib.useBackward true

@[expose] public section

open Function
open scoped Pointwise

namespace QuotientGroup

variable {G H I M : Type*} [Group G] [Group H] [Monoid M] {N : Subgroup G}

@[to_additive (attr := simp)] lemma leftRel_eq_top : leftRel N = ‚ä§ ‚ÜĒ N = ‚ä§ := by
  simpa [leftRel, MulAction.orbitRel, funext_iff, MulAction.mem_orbit_iff,
    MulAction.subgroup_smul_def, ‚Üź eq_inv_mul_iff_mul_eq]
    using ‚ü®fun h ‚Ü¶ by ext; simpa using h _ 1, fun h ‚Ü¶ by simp [h]‚ü©

@[to_additive (attr := simp)] lemma rightRel_eq_top : rightRel N = ‚ä§ ‚ÜĒ N = ‚ä§ := by
  simpa [rightRel, MulAction.orbitRel, funext_iff, MulAction.mem_orbit_iff,
    MulAction.subgroup_smul_def, ‚Üź eq_mul_inv_iff_mul_eq]
    using ‚ü®fun h ‚Ü¶ by ext; simpa using h _ 1, fun h ‚Ü¶ by simp [h]‚ü©

@[to_additive (attr := simp)] protected lemma subsingleton_iff : Subsingleton (G ‚ßł N) ‚ÜĒ N = ‚ä§ := by
  simp [HasQuotient.Quotient]

@[to_additive (attr := simp)] protected lemma nontrivial_iff : Nontrivial (G ‚ßł N) ‚ÜĒ N ‚Č† ‚ä§ := by
  simp [‚Üź not_subsingleton_iff_nontrivial]

variable (N) [nN : N.Normal]

/-- The congruence relation generated by a normal subgroup. -/
@[to_additive /-- The additive congruence relation generated by a normal additive subgroup. -/]
protected def con : Con G where
  toSetoid := leftRel N
  mul' := fun {a b c d} hab hcd => by
    rw [leftRel_eq] at hab hcd ‚äĘ
    dsimp only
    calc
      c‚ĀĽ¬Ļ * (a‚ĀĽ¬Ļ * b) * c‚ĀĽ¬Ļ‚ĀĽ¬Ļ * (c‚ĀĽ¬Ļ * d) ‚ąą N := N.mul_mem (nN.conj_mem _ hab _) hcd
      _ = (a * c)‚ĀĽ¬Ļ * (b * d) := by
        simp only [mul_inv_rev, mul_assoc, inv_mul_cancel_left]

@[to_additive]
instance Quotient.group : Group (G ‚ßł N) :=
  inferInstanceAs <| Group (delta% QuotientGroup.con N).Quotient

/--
The congruence relation defined by the kernel of a group homomorphism is equal to its kernel
as a congruence relation.
-/
@[to_additive QuotientAddGroup.con_ker_eq_addConKer
/-- The additive congruence relation defined by the kernel of an additive group homomorphism is
equal to its kernel as an additive congruence relation. -/]
theorem con_ker_eq_conKer (f : G ‚Üí* M) : QuotientGroup.con f.ker = Con.ker f := by
  ext
  rw [QuotientGroup.con, Con.rel_mk, Setoid.comm', leftRel_apply, Con.ker_rel, MonoidHom.eq_iff]

/-- The group homomorphism from `G` to `G/N`. -/
@[to_additive /-- The additive group homomorphism from `G` to `G/N`. -/]
def mk' : G ‚Üí* G ‚ßł N :=
  MonoidHom.mk' QuotientGroup.mk fun _ _ => rfl

@[to_additive (attr := simp)]
theorem coe_mk' : (mk' N : G ‚Üí G ‚ßł N) = mk :=
  rfl

@[to_additive (attr := simp)]
theorem mk'_apply (x : G) : mk' N x = x :=
  rfl

@[to_additive]
theorem mk'_surjective : Surjective <| mk' N :=
  @mk_surjective _ _ N

@[to_additive]
theorem mk'_eq_mk' {x y : G} : mk' N x = mk' N y ‚ÜĒ ‚ąÉ z ‚ąą N, x * z = y :=
  QuotientGroup.eq.trans <| by
    simp only [‚Üź _root_.eq_inv_mul_iff_mul_eq, exists_eq_right]

/-- Two `MonoidHom`s from a quotient group are equal if their compositions with
`QuotientGroup.mk'` are equal.

See note [partially-applied ext lemmas]. -/
@[to_additive (attr := ext 1100) /-- Two `AddMonoidHom`s from an additive quotient group are equal
if their compositions with `AddQuotientGroup.mk'` are equal.

See note [partially-applied ext lemmas]. -/]
theorem monoidHom_ext ‚¶Éf g : G ‚ßł N ‚Üí* M‚¶Ą (h : f.comp (mk' N) = g.comp (mk' N)) : f = g :=
  MonoidHom.ext fun x => QuotientGroup.induction_on x <| (DFunLike.congr_fun h :)

@[to_additive (attr := simp)]
theorem eq_one_iff {N : Subgroup G} [N.Normal] (x : G) : (x : G ‚ßł N) = 1 ‚ÜĒ x ‚ąą N := by
  refine QuotientGroup.eq.trans ?_
  rw [mul_one, Subgroup.inv_mem_iff]

@[to_additive (attr := simp)]
lemma mk'_comp_subtype : (mk' N).comp N.subtype = 1 := by ext; simp

/- Note: `range_mk'` is a lemma about the primed constructor `QuotientGroup.mk'`, not a
  modified version of some `range_mk`. -/
set_option linter.docPrime false in
@[to_additive (attr := simp)]
theorem range_mk' : (QuotientGroup.mk' N).range = ‚ä§ :=
  MonoidHom.range_eq_top.mpr (mk'_surjective N)

@[to_additive]
theorem ker_le_range_iff [MulOneClass I] (f : G ‚Üí* H) [f.range.Normal] (g : H ‚Üí* I) :
    g.ker ‚Č§ f.range ‚ÜĒ (mk' f.range).comp g.ker.subtype = 1 :=
  ‚ü®fun h => MonoidHom.ext fun ‚ü®_, hx‚ü© => (eq_one_iff _).mpr <| h hx,
    fun h x hx => (eq_one_iff _).mp <| by exact DFunLike.congr_fun h ‚ü®x, hx‚ü©‚ü©

@[to_additive (attr := simp)]
theorem ker_mk' : MonoidHom.ker (QuotientGroup.mk' N : G ‚Üí* G ‚ßł N) = N :=
  Subgroup.ext eq_one_iff

@[to_additive]
theorem eq_iff_div_mem {N : Subgroup G} [nN : N.Normal] {x y : G} :
    (x : G ‚ßł N) = y ‚ÜĒ x / y ‚ąą N := by
  refine eq_comm.trans (QuotientGroup.eq.trans ?_)
  rw [nN.mem_comm_iff, div_eq_mul_inv]

-- for commutative groups we don't need normality assumption

@[to_additive]
instance Quotient.commGroup {G : Type*} [CommGroup G] (N : Subgroup G) : CommGroup (G ‚ßł N) where
  mul_comm := fun a b => Quotient.inductionOn‚āā' a b fun a b => congr_arg mk (mul_comm a b)

local notation " Q" => G ‚ßł N

@[to_additive (attr := simp)]
theorem mk_one : ((1 : G) : Q) = 1 :=
  rfl

@[to_additive (attr := simp)]
theorem mk_mul (a b : G) : ((a * b : G) : Q) = a * b :=
  rfl

@[to_additive (attr := simp)]
theorem mk_inv (a : G) : ((a‚ĀĽ¬Ļ : G) : Q) = (a : Q)‚ĀĽ¬Ļ :=
  rfl

@[to_additive (attr := simp)]
theorem mk_div (a b : G) : ((a / b : G) : Q) = a / b :=
  rfl

@[to_additive (attr := simp)]
theorem mk_pow (a : G) (n : ‚Ąē) : ((a ^ n : G) : Q) = (a : Q) ^ n :=
  rfl

@[to_additive (attr := simp)]
theorem mk_zpow (a : G) (n : ‚Ą§) : ((a ^ n : G) : Q) = (a : Q) ^ n :=
  rfl

@[to_additive (attr := simp)] lemma map_mk'_self : N.map (mk' N) = ‚ä• := by aesop

/--
The subgroup defined by the class of `1` for a congruence relation on a group.
-/
@[to_additive
/-- The `AddSubgroup` defined by the class of `0` for an additive congruence relation
on an `AddGroup`. -/]
protected def _root_.Con.subgroup (c : Con G) : Subgroup G where
  carrier := { x | c x 1 }
  one_mem' := c.refl 1
  mul_mem' hx hy := by simpa using c.mul hx hy
  inv_mem' h := by simpa using c.inv h

@[to_additive (attr := simp)]
theorem _root_.Con.mem_subgroup_iff {c : Con G} {x : G} :
    x ‚ąą c.subgroup ‚ÜĒ c x 1 := Iff.rfl

@[to_additive]
instance (c : Con G) : c.subgroup.Normal :=
  ‚ü®fun x hx g ‚Ü¶ by simpa using (c.mul (c.mul (c.refl g) hx) (c.refl g‚ĀĽ¬Ļ))‚ü©

@[to_additive (attr := simp)]
theorem _root_.Con.subgroup_quotientGroupCon (H : Subgroup G) [H.Normal] :
    (QuotientGroup.con H).subgroup = H := by
  ext
  simp [QuotientGroup.con, leftRel_apply]

@[to_additive (attr := simp)]
theorem con_subgroup (c : Con G) :
    QuotientGroup.con c.subgroup = c := by
  ext x y
  rw [QuotientGroup.con, Con.rel_mk, leftRel_apply, Con.mem_subgroup_iff]
  exact ‚ü®fun h ‚Ü¶ by simpa using c.mul (c.refl x) (c.symm h),
    fun h ‚Ü¶ by simpa using c.mul (c.refl x‚ĀĽ¬Ļ) (c.symm h)‚ü©

/--
The normal subgroups correspond to the congruence relations on a group.
-/
@[to_additive (attr := simps) AddSubgroup.orderIsoAddCon
/-- The normal subgroups correspond to the additive congruence relations on an `AddGroup`. -/]
def _root_.Subgroup.orderIsoCon :
    { N : Subgroup G // N.Normal } ‚ČÉo Con G where
  toFun N := letI : N.val.Normal := N.prop; QuotientGroup.con N
  invFun c := ‚ü®c.subgroup, inferInstance‚ü©
  left_inv := fun ‚ü®N, _‚ü© ‚Ü¶ Subtype.mk_eq_mk.mpr (Con.subgroup_quotientGroupCon N)
  right_inv c := QuotientGroup.con_subgroup c
  map_rel_iff' := by
    simp only [QuotientGroup.con, Equiv.coe_fn_mk, Con.le_def, Con.rel_mk, leftRel_apply]
    refine ‚ü®fun h x _ ‚Ü¶ ?_, fun hle _ _ h ‚Ü¶ hle h‚ü©
    specialize @h 1 x
    simp_all

@[to_additive (attr := simp)]
lemma con_le_iff {N M : Subgroup G} [N.Normal] [M.Normal] :
    QuotientGroup.con N ‚Č§ QuotientGroup.con M ‚ÜĒ N ‚Č§ M :=
  (Subgroup.orderIsoCon.map_rel_iff (a := ‚ü®N, inferInstance‚ü©) (b := ‚ü®M, inferInstance‚ü©))

@[to_additive (attr := gcongr)]
lemma con_mono {N M : Subgroup G} [hN : N.Normal] [hM : M.Normal] (h : N ‚Č§ M) :
    QuotientGroup.con N ‚Č§ QuotientGroup.con M :=
  con_le_iff.mpr h

/-- A group homomorphism `ŌÜ : G ‚Üí* M` with `N ‚äÜ ker(ŌÜ)` descends (i.e. `lift`s) to a
group homomorphism `G/N ‚Üí* M`. -/
@[to_additive /-- An `AddGroup` homomorphism `ŌÜ : G ‚Üí+ M` with `N ‚äÜ ker(ŌÜ)` descends (i.e. `lift`s)
to an `AddGroup` homomorphism `G/N ‚Üí+ M`. -/]
def lift (ŌÜ : G ‚Üí* M) (HN : N ‚Č§ ŌÜ.ker) : Q ‚Üí* M :=
  (QuotientGroup.con N).lift ŌÜ <| con_ker_eq_conKer ŌÜ ‚Ėł con_mono HN

@[to_additive (attr := simp)]
theorem lift_mk {ŌÜ : G ‚Üí* M} (HN : N ‚Č§ ŌÜ.ker) (g : G) : lift N ŌÜ HN (g : Q) = ŌÜ g :=
  rfl

@[to_additive (attr := simp)]
theorem lift_mk' {ŌÜ : G ‚Üí* M} (HN : N ‚Č§ ŌÜ.ker) (g : G) : lift N ŌÜ HN (mk g : Q) = ŌÜ g :=
  rfl
-- TODO: replace `mk` with `mk'`)

@[to_additive (attr := simp)]
theorem lift_comp_mk' (ŌÜ : G ‚Üí* M) (HN : N ‚Č§ ŌÜ.ker) :
    (QuotientGroup.lift N ŌÜ HN).comp (QuotientGroup.mk' N) = ŌÜ :=
  rfl

@[to_additive (attr := simp)]
theorem lift_quot_mk {ŌÜ : G ‚Üí* M} (HN : N ‚Č§ ŌÜ.ker) (g : G) :
    lift N ŌÜ HN (Quot.mk _ g : Q) = ŌÜ g :=
  rfl

@[to_additive]
theorem lift_surjective_of_surjective (ŌÜ : G ‚Üí* M) (hŌÜ : Function.Surjective ŌÜ) (HN : N ‚Č§ ŌÜ.ker) :
    Function.Surjective (QuotientGroup.lift N ŌÜ HN) :=
  Quotient.lift_surjective _ _ hŌÜ

@[to_additive]
theorem ker_lift (ŌÜ : G ‚Üí* M) (HN : N ‚Č§ ŌÜ.ker) :
    (QuotientGroup.lift N ŌÜ HN).ker = Subgroup.map (QuotientGroup.mk' N) ŌÜ.ker := by
  rw [‚Üź congrArg MonoidHom.ker (lift_comp_mk' N ŌÜ HN), ‚Üź MonoidHom.comap_ker,
    Subgroup.map_comap_eq_self_of_surjective (mk'_surjective N)]

/-- A surjective group homomorphism `ŌÜ : G ‚Üí* H` with `N = ker(ŌÜ)` descends (i.e. `lift`s) to a
group isomorphism `G/N ‚ČÉ* H`. -/
@[to_additive /-- A surjective `AddGroup` homomorphism `ŌÜ : G ‚Üí+ H` with `N = ker(ŌÜ)` descends
(i.e. `lift`s) to an `AddGroup` isomorphism `G/N ‚ČÉ+ H`. -/]
noncomputable def liftEquiv {ŌÜ : G ‚Üí* H} (hŌÜ : Function.Surjective ŌÜ)
    (HN : N = ŌÜ.ker) : G ‚ßł N ‚ČÉ* H :=
  MulEquiv.ofBijective (QuotientGroup.lift N ŌÜ HN.le)
    ‚ü®by rw [‚Üź MonoidHom.ker_eq_bot_iff, ker_lift, ‚Üź HN, QuotientGroup.map_mk'_self],
      lift_surjective_of_surjective N ŌÜ hŌÜ HN.le‚ü©

@[to_additive (attr := simp)]
theorem liftEquiv_coe {ŌÜ : G ‚Üí* H} (hŌÜ : Function.Surjective ŌÜ) (HN : N = ŌÜ.ker) (g : G) :
    liftEquiv N hŌÜ HN (g : Q) = ŌÜ g := rfl

@[to_additive (attr := simp)]
theorem liftEquiv_mk {ŌÜ : G ‚Üí* H} (hŌÜ : Function.Surjective ŌÜ) (HN : N = ŌÜ.ker) (g : G) :
    liftEquiv N hŌÜ HN (mk g : Q) = ŌÜ g := rfl

/-- A group homomorphism `f : G ‚Üí* H` induces a map `G/N ‚Üí* H/M` if `N ‚äÜ f‚ĀĽ¬Ļ(M)`. -/
@[to_additive
      /-- An `AddGroup` homomorphism `f : G ‚Üí+ H` induces a map `G/N ‚Üí+ H/M` if `N ‚äÜ f‚ĀĽ¬Ļ(M)`. -/]
def map (M : Subgroup H) [M.Normal] (f : G ‚Üí* H) (h : N ‚Č§ M.comap f) : G ‚ßł N ‚Üí* H ‚ßł M := by
  refine QuotientGroup.lift N ((mk' M).comp f) ?_
  intro x hx
  refine QuotientGroup.eq.2 ?_
  rw [mul_one, Subgroup.inv_mem_iff]
  exact h hx

@[to_additive (attr := simp)]
theorem map_mk (M : Subgroup H) [M.Normal] (f : G ‚Üí* H) (h : N ‚Č§ M.comap f) (x : G) :
    map N M f h ‚ÜĎx = ‚ÜĎ(f x) :=
  rfl

@[to_additive]
theorem map_mk' (M : Subgroup H) [M.Normal] (f : G ‚Üí* H) (h : N ‚Č§ M.comap f) (x : G) :
    map N M f h (mk' _ x) = ‚ÜĎ(f x) :=
  rfl

@[to_additive]
theorem map_surjective_of_surjective (M : Subgroup H) [M.Normal] (f : G ‚Üí* H)
    (hf : Function.Surjective (mk ‚ąė f : G ‚Üí H ‚ßł M)) (h : N ‚Č§ M.comap f) :
    Function.Surjective (map N M f h) :=
  lift_surjective_of_surjective _ _ hf _

@[to_additive]
theorem ker_map (M : Subgroup H) [M.Normal] (f : G ‚Üí* H) (h : N ‚Č§ Subgroup.comap f M) :
    (map N M f h).ker = Subgroup.map (mk' N) (M.comap f) := by
  simp_rw [‚Üź ker_mk' M, MonoidHom.comap_ker]
  exact QuotientGroup.ker_lift _ _ _

@[to_additive]
theorem map_id_apply (h : N ‚Č§ Subgroup.comap (MonoidHom.id _) N := (Subgroup.comap_id N).le) (x) :
    map N N (MonoidHom.id _) h x = x :=
  induction_on x fun _x => rfl

@[to_additive (attr := simp)]
theorem map_id (h : N ‚Č§ Subgroup.comap (MonoidHom.id _) N := (Subgroup.comap_id N).le) :
    map N N (MonoidHom.id _) h = MonoidHom.id _ :=
  MonoidHom.ext (map_id_apply N h)

@[to_additive (attr := simp)]
theorem map_map {I : Type*} [Group I] (M : Subgroup H) (O : Subgroup I) [M.Normal] [O.Normal]
    (f : G ‚Üí* H) (g : H ‚Üí* I) (hf : N ‚Č§ Subgroup.comap f M) (hg : M ‚Č§ Subgroup.comap g O)
    (hgf : N ‚Č§ Subgroup.comap (g.comp f) O :=
      hf.trans ((Subgroup.comap_mono hg).trans_eq (Subgroup.comap_comap _ _ _)))
    (x : G ‚ßł N) : map M O g hg (map N M f hf x) = map N O (g.comp f) hgf x := by
  refine induction_on x fun x => ?_
  simp only [map_mk, MonoidHom.comp_apply]

@[to_additive (attr := simp)]
theorem map_comp_map {I : Type*} [Group I] (M : Subgroup H) (O : Subgroup I) [M.Normal] [O.Normal]
    (f : G ‚Üí* H) (g : H ‚Üí* I) (hf : N ‚Č§ Subgroup.comap f M) (hg : M ‚Č§ Subgroup.comap g O)
    (hgf : N ‚Č§ Subgroup.comap (g.comp f) O :=
      hf.trans ((Subgroup.comap_mono hg).trans_eq (Subgroup.comap_comap _ _ _))) :
    (map M O g hg).comp (map N M f hf) = map N O (g.comp f) hgf :=
  MonoidHom.ext (map_map N M O f g hf hg hgf)

section Pointwise
open Set

@[to_additive (attr := simp)] lemma image_coe : ((‚ÜĎ) : G ‚Üí Q) '' N = 1 :=
  congr_arg ((‚ÜĎ) : Subgroup Q ‚Üí Set Q) <| map_mk'_self N

@[to_additive]
lemma preimage_image_coe (s : Set G) : ((‚ÜĎ) : G ‚Üí Q) ‚ĀĽ¬Ļ' ((‚ÜĎ) '' s) = N * s := by
  ext a
  constructor
  ¬∑ rintro ‚ü®b, hb, h‚ü©
    refine ‚ü®a / b, (QuotientGroup.eq_one_iff _).1 ?_, b, hb, div_mul_cancel _ _‚ü©
    simp only [h, QuotientGroup.mk_div, div_self']
  ¬∑ rintro ‚ü®a, ha, b, hb, rfl‚ü©
    refine ‚ü®b, hb, ?_‚ü©
    simpa only [QuotientGroup.mk_mul, right_eq_mul, QuotientGroup.eq_one_iff]

@[to_additive]
lemma image_coe_inj {s t : Set G} : ((‚ÜĎ) : G ‚Üí Q) '' s = ((‚ÜĎ) : G ‚Üí Q) '' t ‚ÜĒ ‚ÜĎN * s = N * t := by
  simp_rw [‚Üź preimage_image_coe]
  exact QuotientGroup.mk_surjective.preimage_injective.eq_iff.symm

end Pointwise

section congr

variable (G' : Subgroup G) (H' : Subgroup H) [Subgroup.Normal G'] [Subgroup.Normal H']

/-- `QuotientGroup.congr` lifts the isomorphism `e : G ‚ČÉ H` to `G ‚ßł G' ‚ČÉ H ‚ßł H'`,
given that `e` maps `G` to `H`. -/
@[to_additive /-- `QuotientAddGroup.congr` lifts the isomorphism `e : G ‚ČÉ H` to `G ‚ßł G' ‚ČÉ H ‚ßł H'`,
given that `e` maps `G` to `H`. -/]
def congr (e : G ‚ČÉ* H) (he : G'.map e = H') : G ‚ßł G' ‚ČÉ* H ‚ßł H' :=
  { map G' H' e (he ‚Ėł G'.le_comap_map (e : G ‚Üí* H)) with
    toFun := map G' H' e (he ‚Ėł G'.le_comap_map (e : G ‚Üí* H))
    invFun := map H' G' e.symm (he ‚Ėł (G'.map_equiv_eq_comap_symm e).le)
    left_inv := fun x => by
      rw [map_map G' H' G' e e.symm (he ‚Ėł G'.le_comap_map (e : G ‚Üí* H))
        (he ‚Ėł (G'.map_equiv_eq_comap_symm e).le)]
      simp only [‚Üź MulEquiv.coe_monoidHom_trans, MulEquiv.self_trans_symm,
        MulEquiv.coe_monoidHom_refl, map_id_apply]
    right_inv := fun x => by
      rw [map_map H' G' H' e.symm e (he ‚Ėł (G'.map_equiv_eq_comap_symm e).le)
        (he ‚Ėł G'.le_comap_map (e : G ‚Üí* H))]
      simp only [‚Üź MulEquiv.coe_monoidHom_trans, MulEquiv.symm_trans_self,
        MulEquiv.coe_monoidHom_refl, map_id_apply] }

@[simp]
theorem congr_mk (e : G ‚ČÉ* H) (he : G'.map ‚ÜĎe = H') (x) : congr G' H' e he (mk x) = e x :=
  rfl

theorem congr_mk' (e : G ‚ČÉ* H) (he : G'.map ‚ÜĎe = H') (x) :
    congr G' H' e he (mk' G' x) = mk' H' (e x) :=
  rfl

@[simp]
theorem congr_apply (e : G ‚ČÉ* H) (he : G'.map ‚ÜĎe = H') (x : G) :
    congr G' H' e he x = mk' H' (e x) :=
  rfl

@[simp]
