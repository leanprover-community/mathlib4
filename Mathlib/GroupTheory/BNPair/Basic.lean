module

public import Mathlib.Algebra.Group.Subgroup.Pointwise

/-!
# `(B, N)`-pairs

This file defines `(B, N)`-pairs (also known as Tits systems): a group `G` together with two
subgroups `B` and `N` satisfying a list of axioms abstracting the interplay between a Borel
subgroup and the normaliser of a maximal torus in a group of Lie type.

Summarising the axioms (see `BNPair`),
* `B` and `N` generate `G`;
* `N / (B ÔŐô N)` is a Coxeter group, although the definition of a Coxeter group is not directly
  referenced in the axioms;
* the products of certain double cosets are contained in the union of other double cosets.

In particular, the "surprising" axiom `BNPair.cup` implies that the product of double cosets of the
form `BxB`, with `x Ôłł N`, is still a union of double cosets of the same form
(see `BNPair.doubleCoset_closure_le_of_mem_closure` for a "stabilised" version of this observation).

## Main definitions

* `BNPair G`: a `(B, N)`-pair structure on a group `G`.
* `BNPair.toSubgroup`: for a subset `J` of the involutions `Sbar`, the double coset
  `B (closure J) B` is a subgroup of `G`.
* `BNPair.trivial`: every group admits a trivial `(B, N)`-pair of rank `0`, with `B = ÔŐĄ`, `N = ÔŐą`
  and `Sbar = Ôłů`.

## Main results

* `BNPair.toSubgroup_Sbar_eq_top`: in a group with a `(B, N)`-pair, `G = BNB`.

## References

* [R. W. Carter, *Simple groups of Lie type*][carter1972], Section 8.2 and Proposition 8.2.2.
-/

@[expose] public section

variable {G : Type*} [Group G]

open Subgroup
open scoped Pointwise

attribute [-simp] Set.mul_singleton

/--
A `(B, N)`-pair structure on a group `G` is determined by two subgroups `B, N ÔëĄ G` satisfying
several axioms.

Summarising,
* `B` and `N` generate `G`,
* `N / (B ÔŐô N)` is a Coxeter group, although the definition of a Coxeter group
  is not directly referenced in the axioms,
* the products of certain double cosets are contained in the union of other double cosets.

In particular, the "surprising" axiom `cup` implies that the product of double cosets of the form
`BxB`, with `x Ôłł N` is still a union of double cosets of the same form.

See `doubleCoset_closure_le_of_mem_closure` as a "stabilised" version of this observation.

This is [R. W. Carter, *Simple groups of Lie type*][carter1972], Section 8.2.
-/
structure BNPair (G : Type*) [Group G] where
  /-- `B` is the subgroup that plays the role of a Borel subgroup. -/
  B : Subgroup G
  /-- `N` is the subgroup that plays the role of the normaliser of a diagonalisable torus. -/
  N : Subgroup G
  /-- `BN1`: `G` is generated by `B` and `N`. -/
  B_sup_N : B ÔŐö N = ÔŐĄ
  /-- `BN2`: `B Ôłę N` is a normal subgroup of `N`. -/
  B_normal : (B.subgroupOf N).Normal
  /-- `Sbar` is really contained in `N` and consists of elements that map to involutions in
  `N / (B ÔŐô N)`. -/
  Sbar : Set G
  /-- The subset `Sbar` is contained in `N`. -/
  Sbar_N : Sbar ÔŐć N
  /-- `BN3`: every element `s Ôłł Sbar` maps to an involution in `W = N ÔžŞ B Ôłę N`, that is,
  `s * s Ôłł B`. -/
  S_involutions : ÔłÇ s Ôłł Sbar, s * s Ôłł B
  /-- The subgroup `N` is generated by the "involutions" `Sbar`. -/
  S_gens : closure Sbar = N
  /-- `BN4`: If `nßÁó Ôłł N` maps to `wßÁó` under the natural homomorphism of `N` into `W`, and
  if `n` is any element of `N`, then `BnßÁóB . BnB ÔŐć BnßÁónB U BnB`. -/
  cup : ÔłÇ s Ôłł Sbar, ÔłÇ n Ôłł N,
    (B * ({s} : Set G) * B) * (B * {n} * B) ÔŐć (B * ({s * n} : Set G) * B) Ôł¬ B * {n} * B
  /-- `BN5`: If `nßÁó Ôłł N` maps to `wßÁó` under the natural homomorphism of `N` into `W`,
  then `nßÁóBnßÁó Ôëá B`. -/
  conj_ne : ÔłÇ s Ôłł Sbar, {s} * B * {s} Ôëá (B : Set G)

namespace BNPair

lemma N_ne_bot_iff_exists_SBar_ne_one (BN : BNPair G) : BN.N Ôëá ÔŐą Ôćö Ôłâ n Ôłł BN.Sbar, n Ôëá 1 := by
  simp [ÔćÉ BN.S_gens]

variable {BN : BNPair G}

lemma B_mul_inv_eq_mul_of_mem_Sbar {s : G} (hs : s Ôłł BN.Sbar) :
    BN.B * {sÔü╗┬╣} = (BN.B * {s} : Set G) := by
  trans (BN.B : Set G) * {s * s} * {sÔü╗┬╣}
  ┬Ě rw [subgroup_mul_singleton (BN.S_involutions s hs)]
  ┬Ě simp [mul_assoc]

lemma conj_ne_iff {s : G} (hs : s Ôłł BN.Sbar) :
    (({s} : Set G) * BN.B * {s} Ôëá BN.B) Ôćö (ConjAct.toConjAct s) ÔÇó BN.B Ôëá BN.B := by
  rw [mul_assoc, ÔćÉ BN.B_mul_inv_eq_mul_of_mem_Sbar hs, ÔćÉ mul_assoc]
  simp only [singleton_mul_subgroup_mul_singleton_inv, ne_eq, SetLike.coe_ne_coe]

/--
A reformulation of `BNPair.conj_ne` showing that indeed conjugating `BN.B` by the elements in
`BN.Sbar` does not stabilise `BN.B`.
-/
lemma conj_ne' {s : G} (hs : s Ôłł BN.Sbar) : (ConjAct.toConjAct s) ÔÇó BN.B Ôëá BN.B :=
  (conj_ne_iff hs).mp (BN.conj_ne s hs)

/--
In a `(B, N)`-pair, if the group `B` is normal, than `Sbar` is empty.

Equivalently, if `B` is normal, then `N` is trivial and
hence `G = B`, since `B` and `N` generate `G`.
-/
lemma B_normal_iff_SBar_eq_empty (Bnormal : BN.B.Normal) : BN.Sbar = Ôłů := by
  by_contra! hB
  cases hB with
  | intro g hg =>
    exact BN.conj_ne' hg <| Bnormal.conjAct (ConjAct.toConjAct g)

/-- If a group admits a `(B, N)`-pair with `N` non-trivial, then `B` is a proper subgroup. -/
lemma B_ne_top_of_N_ne_bot (hN : BN.N Ôëá ÔŐą) : BN.B Ôëá ÔŐĄ := by
  intro B_eq_top
  have := BN.B_normal_iff_SBar_eq_empty (B_eq_top ÔľŞ { conj_mem := fun n a g ÔćŽ a })
  obtain ÔčĘn, hn, hn1Ôčę := BN.N_ne_bot_iff_exists_SBar_ne_one.mp hN
  simp_all only [ne_eq, Set.mem_empty_iff_false]

/-- The `trivial` `(B, N)`-pair structure is one where `G = B` and `N = {1}`.

Note that the equality `Sbar = Ôłů` is forced by the `conj_ne` axiom. -/
def trivial : BNPair G where
  B := ÔŐĄ
  N := ÔŐą
  B_sup_N := by simp
  B_normal := normal_subgroupOf
  Sbar := Ôłů
  Sbar_N := by simp
  S_involutions := by simp
  S_gens := by simp
  cup := by simp
  conj_ne := by simp

lemma doubleCoset_mul_le_closure_of_le_sbar_of_le_closure {J : Set G} (hJ : J ÔŐć BN.Sbar) {n w : G}
    (hn : n Ôłł J) (hb : w Ôłł closure J) :
    (BN.B * {n} * BN.B * (BN.B * {w} * BN.B) : Set G) ÔŐć BN.B * closure J * BN.B := by
  trans BN.B * {n * w} * BN.B Ôł¬ BN.B * {w} * BN.B
  ┬Ě refine BN.cup _ (hJ hn) w ?_
    refine Set.mem_of_mem_of_subset hb ?_
    exact le_of_le_of_eq (closure_mono hJ) (by rw [BN.S_gens]) -- insert a `closure BN.Sbar`
  ┬Ě refine Set.union_subset ?_ ?_ <;>
      refine Set.mul_subset_mul_right (Set.mul_subset_mul_left ?_)
    ┬Ě simpa using mul_mem (mem_closure_of_mem hn) hb
    ┬Ě simpa only [Set.singleton_subset_iff, SetLike.mem_coe]

/--
This lemma is very close to what we want.
The main issue is that the element `n` is in `J` and not in `closure J`.

See `doubleCoset_closure_le_of_mem_closure` for the final result.
-/
lemma one_step {J : Set G} (hJ : J ÔŐć BN.Sbar) {n : G} (hn : n Ôłł J) :
    (BN.B * {n} * BN.B * (BN.B * closure J * BN.B) : Set G) ÔŐć BN.B * closure J * BN.B := by
  intro y hy
  obtain ÔčĘy1, h1, y2, h2, rflÔčę := hy
  obtain ÔčĘy2, ÔčĘz2, hzb2, w2, hz2, rflÔčę, y2, hyb2, rflÔčę := h2
  obtain ÔčĘy1, ÔčĘz1, hzb1, w1, hz1, rflÔčę, y1, hyb1, rflÔčę := h1
  dsimp only
  apply Set.mem_of_mem_of_subset ?_ <|
    doubleCoset_mul_le_closure_of_le_sbar_of_le_closure (n := w1) (w := w2) ..
  ┬Ě repeat first | apply Set.mul_mem_mul | assumption | simp
  ┬Ě exact hJ
  ┬Ě simp_all
  ┬Ě exact hz2

/-- This lemma is part of the inductive step to prove `doubleCoset_closure_le_of_mem_closure` . -/
lemma doubleMulCoset_le_closure_of_mul_le
    {J : Set G} (hJ : J ÔŐć BN.Sbar) {n g b : G} (hn : n Ôłł J)
    (hgb : (BN.B * {g} * BN.B * (BN.B * {b} * BN.B) : Set G) ÔŐć BN.B * closure J * BN.B) :
    (BN.B * {n * g} * BN.B * (BN.B * {b} * BN.B) : Set G) ÔŐć BN.B * closure J * BN.B := by
  trans BN.B * {n} * BN.B * ((BN.B * {g} * BN.B) * (BN.B * {b} * BN.B))
  ┬Ě trans BN.B * {n} * BN.B * (BN.B * {g} * BN.B) * (BN.B * {b} * BN.B)
    ┬Ě refine Set.mul_subset_mul_right ?_
      simp only [ÔćÉ mul_assoc, ÔćÉ Set.singleton_mul_singleton]
      refine Set.mul_subset_mul_right (Set.mul_subset_mul_right ?_)
      simp only [mul_assoc]
      exact Set.mul_subset_mul_left (by simp)
    simp [mul_assoc]
  trans BN.B * {n} * BN.B * (BN.B * closure J * BN.B)
  ┬Ě simp only [mul_assoc] at hgb ÔŐó
    refine Set.mul_subset_mul_left ?_
    refine Set.mul_subset_mul_left ?_
    exact Set.mul_subset_mul_left hgb
  exact BN.one_step hJ hn

lemma doubleCoset_closure_le_of_mem_closure {J : Set G} (hJ : J ÔŐć BN.Sbar)
    {a b : G} (ha : a Ôłł closure J) (hb : b Ôłł closure J) :
    ((BN.B * {a} * BN.B) * (BN.B * {b} * BN.B) : Set G) ÔŐć BN.B * closure J * BN.B := by
  refine closure_induction_left ?_ ?_ ?_ ha
  ┬Ě rw [subgroup_mul_singleton (one_mem _), coe_mul_coe]
    simp_rw [ÔćÉ mul_assoc]
    rw [coe_mul_coe]
    exact Set.mul_subset_mul_right (Set.mul_subset_mul_left (by simpa))
  ┬Ě intros x hx y hy yb
    exact BN.doubleMulCoset_le_closure_of_mul_le hJ hx yb
  ┬Ě intros x xs y ys yb
    have : (BN.B * {xÔü╗┬╣ * y} : Set G) = BN.B * {x * y} := by
      rw [ÔćÉ Set.singleton_mul_singleton, ÔćÉ mul_assoc, B_mul_inv_eq_mul_of_mem_Sbar (hJ xs)]
      simp [mul_assoc]
    rw [this]
    exact BN.doubleMulCoset_le_closure_of_mul_le hJ xs yb

/--
Let `G` be a group with a `(B, N)`-pair. Then
1. `G = BNB` (proved in `toSubgroup_Sbar_eq_top`).
2. For each subset `J` of `I`, let `W_J` be the subgroup of `W` generated by
   the elements `wßÁó` for `i Ôłł J`, and `N_J` be the subgroup of `N` mapping to `W_J` under
   the natural homomorphism.
   Then `P_J = B N_J B` is a subgroup of `G`.

From item 2. it follows that `BNB` is a subgroup: this is the special case when `J = I` --
that is `J = BN.Sbar`.

This is [R. W. Carter, *Simple groups of Lie type*][carter1972], Proposition 8.2.2 (ii); item 1.
is proved in `toSubgroup_Sbar_eq_top`.
-/
def toSubgroup (J : Set G) (hJ : J ÔŐć BN.Sbar) : Subgroup G where
  carrier := BN.B * closure J * BN.B
  one_mem' := by
    rw [show (1 : G) = 1 * 1 * 1 by simp]
    repeat first | apply Set.mul_mem_mul | simp
  inv_mem' {x} hx := by
    simp_rw [Set.mem_mul] at hx
    obtain ÔčĘy, ÔčĘz, hzb, w, hz, rflÔčę, y, hyb, rflÔčę := hx
    simp only [mul_inv_rev, ÔćÉ mul_assoc]
    repeat first | apply Set.mul_mem_mul | apply inv_mem | assumption
  mul_mem' {a b} ha hb := by
    obtain ÔčĘy, ÔčĘb1, hb1, n, hn, rflÔčę, b2, hb2, rflÔčę := ha
    obtain ÔčĘy, ÔčĘ╬▓1, h╬▓1, ¤â, h¤â, rflÔčę, ╬▓2, h╬▓2, rflÔčę := hb
    dsimp
    apply BN.doubleCoset_closure_le_of_mem_closure hJ hn h¤â
    apply Set.mul_mem_mul <;>
    ┬Ě repeat apply Set.mul_mem_mul
      any_goals assumption
      simp only [Set.mem_singleton_iff]

/-- If `G` is a group with a `(B, N)`-pair, then the equality `G = BNB` holds. -/
lemma toSubgroup_Sbar_eq_doubleCoset :
    BN.toSubgroup BN.Sbar le_rfl = (BN.B * BN.N * BN.B : Set G) := by
  simp [toSubgroup, BN.S_gens]

/--
If `G` is a group with a `(B, N)`-pair, then for any subset `J` of "involutions",
`B` is contained in the double coset `B N_J B`.
-/
lemma B_le_toSubgroup {J : Set G} (hJ : J ÔŐć BN.Sbar) :
    BN.B ÔëĄ BN.toSubgroup J hJ := by
  rw [ÔćÉ SetLike.coe_subset_coe, ÔćÉ mul_one (BN.B : Set G), ÔćÉ mul_one (BN.B : Set G)]
  refine Set.mul_subset_mul ?_ (by simp)
  exact Set.mul_subset_mul le_rfl (by simp)

/--
If `G` is a group with a `(B, N)`-pair, then for any subset `J` of "involutions",
`N_J` is contained in the double coset `B N_J B`.
-/
lemma N_le_toSubgroup_closure {J : Set G} (hJ : J ÔŐć BN.Sbar) :
    closure J ÔëĄ BN.toSubgroup J hJ := by
  intros g hg
  rw [ÔćÉ SetLike.mem_coe, toSubgroup]
  simp only [coe_set_mk, Submonoid.coe_set_mk, Subsemigroup.coe_set_mk, Set.mem_mul,
    SetLike.mem_coe, exists_exists_and_exists_and_eq_and]
  use 1, one_mem _, g, hg
  simp

/--
If `G` is a group with a `(B, N)`-pair, then `N` is contained in the double coset `B N B`.
-/
lemma N_le_toSubgroup : BN.N ÔëĄ BN.toSubgroup _ le_rfl :=
  BN.S_gens.ge.trans (N_le_toSubgroup_closure _)

/-- Let `G` be a group with a `(B, N)`-pair. Then `G = BNB`.

This is [R. W. Carter, *Simple groups of Lie type*][carter1972], Proposition 8.2.2 (i); item 2.
is proved in `toSubgroup`. -/
theorem toSubgroup_Sbar_eq_top : BN.toSubgroup BN.Sbar le_rfl = ÔŐĄ :=
  eq_top_iff.mpr <| BN.B_sup_N.ge.trans <|
    sup_le (BN.B_le_toSubgroup le_rfl) BN.N_le_toSubgroup

end BNPair
