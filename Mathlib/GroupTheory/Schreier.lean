/-!
# Schreier's Lemma

In this file we prove Schreier's lemma.

## Main results

- `closure_mul_image_eq` : **Schreier's Lemma**: If `R : Set G` is a right transversal
  of `H : Subgroup G` with `1 Ôłł R`, and if `G` is generated by `S : Set G`,
  then `H` is generated by the `Set` `(R * S).image (fun g ÔćŽ g * (hR.toRightFun g)Ôü╗┬╣)`.
- `fg_of_index_ne_zero` : **Schreier's Lemma**: A finite index subgroup of a finitely generated
  group is finitely generated.
- `card_commutator_le_of_finite_commutatorSet`: A theorem of Schur: The size of the commutator
  subgroup is bounded in terms of the number of commutators.
-/

@[expose] public section


open scoped Finset Pointwise

section CommGroup

open Subgroup

variable (G : Type*) [CommGroup G] [Group.FG G]

@[to_additive]
theorem card_dvd_exponent_pow_rank : Nat.card G Ôłú Monoid.exponent G ^ Group.rank G := by
  classical
  obtain ÔčĘS, hS1, hS2Ôčę := Group.rank_spec G
  rw [ÔćÉ hS1, ÔćÉ Fintype.card_coe, ÔćÉ Finset.card_univ, ÔćÉ Finset.prod_const]
  let f : (ÔłÇ g : S, zpowers (g : G)) Ôćĺ* G := noncommPiCoprod fun s t _ x y _ _ => mul_comm x _
  have hf : Function.Surjective f := by
    rw [ÔćÉ MonoidHom.range_eq_top, eq_top_iff, ÔćÉ hS2, closure_le]
    exact fun g hg => ÔčĘPi.mulSingle ÔčĘg, hgÔčę ÔčĘg, mem_zpowers gÔčę, noncommPiCoprod_mulSingle _ _Ôčę
  replace hf := card_dvd_of_surjective f hf
  rw [Nat.card_pi] at hf
  refine hf.trans (Finset.prod_dvd_prod_of_dvd _ _ fun g _ => ?_)
  rw [Nat.card_zpowers]
  exact Monoid.order_dvd_exponent (g : G)

@[to_additive]
theorem card_dvd_exponent_pow_rank' {n : ÔäĽ} (hG : ÔłÇ g : G, g ^ n = 1) :
    Nat.card G Ôłú n ^ Group.rank G :=
  (card_dvd_exponent_pow_rank G).trans
    (pow_dvd_pow_of_dvd (Monoid.exponent_dvd_of_forall_pow_eq_one hG) (Group.rank G))

end CommGroup

namespace Subgroup

variable {G : Type*} [Group G] {H : Subgroup G} {R S : Set G}

theorem closure_mul_image_mul_eq_top
    (hR : IsComplement H R) (hR1 : (1 : G) Ôłł R) (hS : closure S = ÔŐĄ) :
    (closure ((R * S).image fun g => g * (hR.toRightFun g : G)Ôü╗┬╣)) * R = ÔŐĄ := by
  let f : G Ôćĺ R := hR.toRightFun
  let U : Set G := (R * S).image fun g => g * (f g : G)Ôü╗┬╣
  change (closure U : Set G) * R = ÔŐĄ
  refine top_le_iff.mp fun g _ => ?_
  refine closure_induction_right ?_ ?_ ?_ (eq_top_iff.mp hS (mem_top g))
  ┬Ě exact ÔčĘ1, (closure U).one_mem, 1, hR1, one_mul 1Ôčę
  ┬Ě rintro - - s hs ÔčĘu, hu, r, hr, rflÔčę
    rw [show u * r * s = u * (r * s * (f (r * s) : G)Ôü╗┬╣) * f (r * s) by group]
    refine Set.mul_mem_mul ((closure U).mul_mem hu ?_) (f (r * s)).coe_prop
    exact subset_closure ÔčĘr * s, Set.mul_mem_mul hr hs, rflÔčę
  ┬Ě rintro - - s hs ÔčĘu, hu, r, hr, rflÔčę
    rw [show u * r * sÔü╗┬╣ = u * (f (r * sÔü╗┬╣) * s * rÔü╗┬╣)Ôü╗┬╣ * f (r * sÔü╗┬╣) by group]
    refine Set.mul_mem_mul ((closure U).mul_mem hu ((closure U).inv_mem ?_)) (f (r * sÔü╗┬╣)).2
    refine subset_closure ÔčĘf (r * sÔü╗┬╣) * s, Set.mul_mem_mul (f (r * sÔü╗┬╣)).2 hs, ?_Ôčę
    rw [mul_right_inj, inv_inj, ÔćÉ Subtype.coe_mk r hr, ÔćÉ Subtype.ext_iff, Subtype.coe_mk]
    apply (isComplement_iff_existsUnique_mul_inv_mem.mp hR (f (r * sÔü╗┬╣) * s)).unique
      (hR.mul_inv_toRightFun_mem (f (r * sÔü╗┬╣) * s))
    rw [mul_assoc, ÔćÉ inv_inv s, ÔćÉ mul_inv_rev, inv_inv]
    exact hR.toRightFun_mul_inv_mem (r * sÔü╗┬╣)

/-- **Schreier's Lemma**: If `R : Set G` is a `rightTransversal` of `H : Subgroup G`
  with `1 Ôłł R`, and if `G` is generated by `S : Set G`, then `H` is generated by the `Set`
  `(R * S).image (fun g ÔćŽ g * (hR.toRightFun g)Ôü╗┬╣)`. -/
theorem closure_mul_image_eq (hR : IsComplement H R) (hR1 : (1 : G) Ôłł R)
    (hS : closure S = ÔŐĄ) : closure ((R * S).image fun g => g * (hR.toRightFun g : G)Ôü╗┬╣) = H := by
  have hU : closure ((R * S).image fun g => g * (hR.toRightFun g : G)Ôü╗┬╣) ÔëĄ H := by
    rw [closure_le]
    rintro - ÔčĘg, -, rflÔčę
    exact hR.mul_inv_toRightFun_mem g
  refine le_antisymm hU fun h hh => ?_
  obtain ÔčĘg, hg, r, hr, rflÔčę :=
    show h Ôłł _ from eq_top_iff.mp (closure_mul_image_mul_eq_top hR hR1 hS) (mem_top h)
  suffices (ÔčĘr, hrÔčę : R) = (ÔčĘ1, hR1Ôčę : R) by
    simpa only [show r = 1 from Subtype.ext_iff.mp this, mul_one]
  apply (isComplement_iff_existsUnique_mul_inv_mem.mp hR r).unique
  ┬Ě rw [Subtype.coe_mk, mul_inv_cancel]
    exact H.one_mem
  ┬Ě rw [Subtype.coe_mk, inv_one, mul_one]
    exact (H.mul_mem_cancel_left (hU hg)).mp hh

/-- **Schreier's Lemma**: If `R : Set G` is a `rightTransversal` of `H : Subgroup G`
  with `1 Ôłł R`, and if `G` is generated by `S : Set G`, then `H` is generated by the `Set`
  `(R * S).image (fun g ÔćŽ g * (hR.toRightFun g)Ôü╗┬╣)`. -/
theorem closure_mul_image_eq_top (hR : IsComplement H R) (hR1 : (1 : G) Ôłł R)
    (hS : closure S = ÔŐĄ) : closure ((R * S).image fun g =>
      ÔčĘg * (hR.toRightFun g : G)Ôü╗┬╣, hR.mul_inv_toRightFun_mem gÔčę : Set H) = ÔŐĄ := by
  rw [eq_top_iff, ÔćÉ map_subtype_le_map_subtype, MonoidHom.map_closure, Set.image_image]
  exact (map_subtype_le ÔŐĄ).trans (ge_of_eq (closure_mul_image_eq hR hR1 hS))

/-- **Schreier's Lemma**: If `R : Finset G` is a `rightTransversal` of `H : Subgroup G`
  with `1 Ôłł R`, and if `G` is generated by `S : Finset G`, then `H` is generated by the `Finset`
  `(R * S).image (fun g ÔćŽ g * (hR.toRightFun g)Ôü╗┬╣)`. -/
theorem closure_mul_image_eq_top' [DecidableEq G] {R S : Finset G}
    (hR : IsComplement (H : Set G) R) (hR1 : (1 : G) Ôłł R)
    (hS : closure (S : Set G) = ÔŐĄ) :
    closure (((R * S).image fun g => ÔčĘ_, hR.mul_inv_toRightFun_mem gÔčę : Finset H) : Set H) = ÔŐĄ := by
  rw [Finset.coe_image, Finset.coe_mul]
  exact closure_mul_image_eq_top hR hR1 hS

variable (H)

theorem exists_finset_card_le_mul [FiniteIndex H] {S : Finset G} (hS : closure (S : Set G) = ÔŐĄ) :
    Ôłâ T : Finset H, #T ÔëĄ H.index * #S Ôłž closure (T : Set H) = ÔŐĄ := by
  letI := H.fintypeQuotientOfFiniteIndex
  haveI : DecidableEq G := Classical.decEq G
  obtain ÔčĘRÔéÇ, hR, hR1Ôčę := H.exists_isComplement_right 1
  haveI : Fintype RÔéÇ := Fintype.ofEquiv _ hR.rightQuotientEquiv
  let R : Finset G := Set.toFinset RÔéÇ
  replace hR : IsComplement (H : Set G) R := by rwa [Set.coe_toFinset]
  replace hR1 : (1 : G) Ôłł R := by rwa [Set.mem_toFinset]
  refine ÔčĘ_, ?_, closure_mul_image_eq_top' hR hR1 hSÔčę
  calc
    _ ÔëĄ #(R * S) := Finset.card_image_le
    _ ÔëĄ #R * #S := Finset.card_mul_le
    _ = H.index * S.card := congr_arg (┬Ě * S.card) ?_
  calc
    #R = Fintype.card R := (Fintype.card_coe R).symm
    _ = _ := (Fintype.card_congr hR.rightQuotientEquiv).symm
    _ = Fintype.card (G ÔžŞ H) := QuotientGroup.card_quotient_rightRel H
    _ = H.index := by rw [index_eq_card, Nat.card_eq_fintype_card]

/-- **Schreier's Lemma**: A finite index subgroup of a finitely generated
  group is finitely generated. -/
instance fg_of_finiteIndex [hG : Group.FG G] [FiniteIndex H] : H.FG := by
  obtain ÔčĘS, hSÔčę := hG.1
  obtain ÔčĘT, -, hTÔčę := exists_finset_card_le_mul H hS
  exact (Group.fg_iff_subgroup_fg H).mp ÔčĘÔčĘT, hTÔčęÔčę

@[deprecated (since := "2026-04-17")] alias fg_of_index_ne_zero := fg_of_finiteIndex

theorem rank_le_index_mul_rank [hG : Group.FG G] [FiniteIndex H] :
    Group.rank H ÔëĄ H.index * Group.rank G := by
  haveI := H.fg_of_finiteIndex
  obtain ÔčĘS, hSÔéÇ, hSÔčę := Group.rank_spec G
  obtain ÔčĘT, hTÔéÇ, hTÔčę := exists_finset_card_le_mul H hS
  calc
    Group.rank H ÔëĄ #T := Group.rank_le hT
    _ ÔëĄ H.index * #S := hTÔéÇ
    _ = H.index * Group.rank G := congr_arg (H.index * ┬Ě) hSÔéÇ

variable (G)

open scoped IsMulCommutative in
/-- If `G` has `n` commutators `[gÔéü, gÔéé]`, then `|G'| Ôłú [G : Z(G)] ^ ([G : Z(G)] * n + 1)`,
where `G'` denotes the commutator of `G`. -/
theorem card_commutator_dvd_index_center_pow [Finite (commutatorSet G)] :
    Nat.card (_root_.commutator G) Ôłú
      (center G).index ^ ((center G).index * Nat.card (commutatorSet G) + 1) := by
  -- First handle the case when `Z(G)` has infinite index and `[G : Z(G)]` is defined to be `0`
  by_cases hG : (center G).index = 0
  ┬Ě simp_rw [hG, zero_mul, zero_add, pow_one, dvd_zero]
  haveI : FiniteIndex (center G) := ÔčĘhGÔčę
  -- Rewrite as `|Z(G) Ôłę G'| * [G' : Z(G) Ôłę G'] Ôłú [G : Z(G)] ^ ([G : Z(G)] * n) * [G : Z(G)]`
  rw [ÔćÉ ((center G).subgroupOf (_root_.commutator G)).card_mul_index, pow_succ]
  -- We have `h1 : [G' : Z(G) Ôłę G'] Ôłú [G : Z(G)]`
  have h1 := relIndex_dvd_index_of_normal (center G) (_root_.commutator G)
  -- So we can reduce to proving `|Z(G) Ôłę G'| Ôłú [G : Z(G)] ^ ([G : Z(G)] * n)`
  refine mul_dvd_mul ?_ h1
  -- We know that `[G' : Z(G) Ôłę G'] < Ôł×` by `h1` and `hG`
  haveI : FiniteIndex ((center G).subgroupOf (_root_.commutator G)) :=
    ÔčĘne_zero_of_dvd_ne_zero hG h1Ôčę
  -- We have `h2 : rank (Z(G) Ôłę G') ÔëĄ [G' : Z(G) Ôłę G'] * rank G'` by Schreier's lemma
  have h2 := rank_le_index_mul_rank ((center G).subgroupOf (_root_.commutator G))
  -- We have `h3 : [G' : Z(G) Ôłę G'] * rank G' ÔëĄ [G : Z(G)] * n` by `h1` and `rank G' ÔëĄ n`
  have h3 := Nat.mul_le_mul (Nat.le_of_dvd (Nat.pos_of_ne_zero hG) h1) (rank_commutator_le_card G)
  -- So we can reduce to proving `|Z(G) Ôłę G'| Ôłú [G : Z(G)] ^ rank (Z(G) Ôłę G')`
  refine dvd_trans ?_ (pow_dvd_pow (center G).index (h2.trans h3))
  -- `Z(G) Ôłę G'` is abelian, so it enough to prove that `g ^ [G : Z(G)] = 1` for `g Ôłł Z(G) Ôłę G'`
  apply card_dvd_exponent_pow_rank'
  intro g
  -- `Z(G)` is abelian, so `g Ôłł Z(G) Ôłę G' ÔëĄ G' ÔëĄ ker (transfer : G Ôćĺ Z(G))`
  have := Abelianization.commutator_subset_ker (MonoidHom.transferCenterPow G) g.1.2
  -- `transfer g` is defeq to `g ^ [G : Z(G)]`, so we are done
  simpa only [MonoidHom.mem_ker, Subtype.ext_iff] using this

/-- A bound for the size of the commutator subgroup in terms of the number of commutators. -/
def cardCommutatorBound (n : ÔäĽ) :=
  (n ^ (2 * n)) ^ (n ^ (2 * n + 1) + 1)

/-- A theorem of Schur: The size of the commutator subgroup is bounded in terms of the number of
  commutators. -/
theorem card_commutator_le_of_finite_commutatorSet [Finite (commutatorSet G)] :
    Nat.card (_root_.commutator G) ÔëĄ cardCommutatorBound (Nat.card (commutatorSet G)) := by
  have h1 := index_center_le_pow (closureCommutatorRepresentatives G)
  have h2 := card_commutator_dvd_index_center_pow (closureCommutatorRepresentatives G)
  rw [card_commutatorSet_closureCommutatorRepresentatives] at h1 h2
  rw [card_commutator_closureCommutatorRepresentatives] at h2
  replace h1 :=
    h1.trans
      (Nat.pow_le_pow_right Finite.card_pos (rank_closureCommutatorRepresentatives_le G))
  replace h2 := h2.trans (pow_dvd_pow _ (add_le_add_left (mul_le_mul_left h1 _) 1))
  rw [ÔćÉ pow_succ] at h2
  refine (Nat.le_of_dvd ?_ h2).trans (Nat.pow_le_pow_left h1 _)
  exact pow_pos (Nat.pos_of_ne_zero FiniteIndex.index_ne_zero) _

/-- A theorem of Schur: A group with finitely many commutators has finite commutator subgroup. -/
instance [Finite (commutatorSet G)] : Finite (_root_.commutator G) := by
  have h2 := card_commutator_dvd_index_center_pow (closureCommutatorRepresentatives G)
  refine Nat.finite_of_card_ne_zero fun h => ?_
  rw [card_commutator_closureCommutatorRepresentatives, h, zero_dvd_iff] at h2
  exact FiniteIndex.index_ne_zero (eq_zero_of_pow_eq_zero h2)

end Subgroup
