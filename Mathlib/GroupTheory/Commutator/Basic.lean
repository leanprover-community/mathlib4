module

public import Mathlib.Algebra.Group.Commutator
public import Mathlib.GroupTheory.Subgroup.Centralizer
public import Mathlib.GroupTheory.QuotientGroup.Defs

/-!
# Commutators of Subgroups

If `G` is a group and `H‚āĀ H‚āā : Subgroup G` then the commutator `‚ĀÖH‚āĀ, H‚āā‚ĀÜ : Subgroup G`
is the subgroup of `G` generated by the commutators `h‚āĀ * h‚āā * h‚āĀ‚ĀĽ¬Ļ * h‚āā‚ĀĽ¬Ļ`.

## Main definitions

* `‚ĀÖg‚āĀ, g‚āā‚ĀÜ` : the commutator of the elements `g‚āĀ` and `g‚āā`
    (defined by `commutatorElement` elsewhere).
* `‚ĀÖH‚āĀ, H‚āā‚ĀÜ` : the commutator of the subgroups `H‚āĀ` and `H‚āā`.
* `commutator`: defines the commutator of a group `G` as a subgroup of `G`.
-/

@[expose] public section

assert_not_exists Cardinal Multiset Ring

open scoped commutatorElement

variable {G G' F : Type*} [Group G] [Group G'] [FunLike F G G'] [MonoidHomClass F G G']
variable (f : F) {g‚āĀ g‚āā g‚āÉ g : G}

@[to_additive]
theorem commutatorElement_eq_one_iff_mul_comm : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = 1 ‚ÜĒ g‚āĀ * g‚āā = g‚āā * g‚āĀ := by
  rw [commutatorElement_def, mul_inv_eq_one, mul_inv_eq_iff_eq_mul]

@[to_additive]
theorem commutatorElement_eq_one_iff_commute : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = 1 ‚ÜĒ Commute g‚āĀ g‚āā :=
  commutatorElement_eq_one_iff_mul_comm

@[to_additive]
theorem Commute.commutator_eq (h : Commute g‚āĀ g‚āā) : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = 1 :=
  commutatorElement_eq_one_iff_commute.mpr h

variable (g‚āĀ g‚āā g‚āÉ g)

@[to_additive (attr := simp)]
theorem commutatorElement_one_right : ‚ĀÖg, (1 : G)‚ĀÜ = 1 :=
  (Commute.one_right g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_one_left : ‚ĀÖ(1 : G), g‚ĀÜ = 1 :=
  (Commute.one_left g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_self : ‚ĀÖg, g‚ĀÜ = 1 :=
  (Commute.refl g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_inv : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ‚ĀĽ¬Ļ = ‚ĀÖg‚āā, g‚āĀ‚ĀÜ := by
  simp_rw [commutatorElement_def, mul_inv_rev, inv_inv, mul_assoc]

@[to_additive]
theorem map_commutatorElement : (f ‚ĀÖg‚āĀ, g‚āā‚ĀÜ : G') = ‚ĀÖf g‚āĀ, f g‚āā‚ĀÜ := by
  simp_rw [commutatorElement_def, map_mul f, map_inv f]

@[to_additive]
theorem conjugate_commutatorElement : g‚āÉ * ‚ĀÖg‚āĀ, g‚āā‚ĀÜ * g‚āÉ‚ĀĽ¬Ļ = ‚ĀÖg‚āÉ * g‚āĀ * g‚āÉ‚ĀĽ¬Ļ, g‚āÉ * g‚āā * g‚āÉ‚ĀĽ¬Ļ‚ĀÜ := by
  simp [mul_assoc, commutatorElement_def]

namespace Subgroup

/-- The commutator of two subgroups `H‚āĀ` and `H‚āā`. -/
@[to_additive /-- The commutator of two additive subgroups `H‚āĀ` and `H‚āā`. -/]
instance commutator : Bracket (Subgroup G) (Subgroup G) :=
  ‚ü®fun H‚āĀ H‚āā => closure { g | ‚ąÉ g‚āĀ ‚ąą H‚āĀ, ‚ąÉ g‚āā ‚ąą H‚āā, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g }‚ü©

@[to_additive]
theorem commutator_def (H‚āĀ H‚āā : Subgroup G) :
    ‚ĀÖH‚āĀ, H‚āā‚ĀÜ = closure { g | ‚ąÉ g‚āĀ ‚ąą H‚āĀ, ‚ąÉ g‚āā ‚ąą H‚āā, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g } :=
  rfl

variable {g‚āĀ g‚āā g‚āÉ} {H H‚āĀ H‚āā H‚āÉ K‚āĀ K‚āā : Subgroup G}

@[to_additive]
theorem commutator_mem_commutator (h‚āĀ : g‚āĀ ‚ąą H‚āĀ) (h‚āā : g‚āā ‚ąą H‚āā) : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą ‚ĀÖH‚āĀ, H‚āā‚ĀÜ :=
  subset_closure ‚ü®g‚āĀ, h‚āĀ, g‚āā, h‚āā, rfl‚ü©

@[to_additive]
theorem commutator_le : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ H‚āÉ ‚ÜĒ ‚ąÄ g‚āĀ ‚ąą H‚āĀ, ‚ąÄ g‚āā ‚ąą H‚āā, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą H‚āÉ :=
  H‚āÉ.closure_le.trans
    ‚ü®fun h a b c d => h ‚ü®a, b, c, d, rfl‚ü©, fun h _g ‚ü®a, b, c, d, h_eq‚ü© => h_eq ‚Ėł h a b c d‚ü©

@[to_additive]
theorem commutator_mono (h‚āĀ : H‚āĀ ‚Č§ K‚āĀ) (h‚āā : H‚āā ‚Č§ K‚āā) : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ ‚ĀÖK‚āĀ, K‚āā‚ĀÜ :=
  commutator_le.mpr fun _g‚āĀ hg‚āĀ _g‚āā hg‚āā => commutator_mem_commutator (h‚āĀ hg‚āĀ) (h‚āā hg‚āā)

@[to_additive]
theorem commutator_eq_bot_iff_le_centralizer : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ = ‚ä• ‚ÜĒ H‚āĀ ‚Č§ centralizer H‚āā := by
  rw [eq_bot_iff, commutator_le]
  refine forall_congr' fun p =>
    forall_congr' fun _hp => forall_congr' fun q => forall_congr' fun hq => ?_
  rw [mem_bot, commutatorElement_eq_one_iff_mul_comm, eq_comm]

/-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/
@[to_additive /-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/]
theorem commutator_commutator_eq_bot_of_rotate (h1 : ‚ĀÖ‚ĀÖH‚āā, H‚āÉ‚ĀÜ, H‚āĀ‚ĀÜ = ‚ä•) (h2 : ‚ĀÖ‚ĀÖH‚āÉ, H‚āĀ‚ĀÜ, H‚āā‚ĀÜ = ‚ä•) :
    ‚ĀÖ‚ĀÖH‚āĀ, H‚āā‚ĀÜ, H‚āÉ‚ĀÜ = ‚ä• := by
  simp_rw [commutator_eq_bot_iff_le_centralizer, commutator_le,
    mem_centralizer_iff_commutator_eq_one, ‚Üź commutatorElement_def] at h1 h2 ‚äĘ
  intro x hx y hy z hz
  trans x * z * ‚ĀÖy, ‚ĀÖz‚ĀĽ¬Ļ, x‚ĀĽ¬Ļ‚ĀÜ‚ĀÜ‚ĀĽ¬Ļ * z‚ĀĽ¬Ļ * y * ‚ĀÖx‚ĀĽ¬Ļ, ‚ĀÖy‚ĀĽ¬Ļ, z‚ĀÜ‚ĀÜ‚ĀĽ¬Ļ * y‚ĀĽ¬Ļ * x‚ĀĽ¬Ļ
  -- We avoid `group` here to minimize imports while low in the hierarchy;
  -- typically it would be better to invoke the tactic.
  ¬∑ simp [commutatorElement_def, mul_assoc]
  ¬∑ rw [h1 _ (H‚āā.inv_mem hy) _ hz _ (H‚āĀ.inv_mem hx), h2 _ (H‚āÉ.inv_mem hz) _ (H‚āĀ.inv_mem hx) _ hy]
    simp [mul_assoc]

variable (H‚āĀ H‚āā)

@[to_additive]
theorem commutator_comm_le : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ ‚ĀÖH‚āā, H‚āĀ‚ĀÜ :=
  commutator_le.mpr fun g‚āĀ h‚āĀ g‚āā h‚āā =>
    commutatorElement_inv g‚āā g‚āĀ ‚Ėł ‚ĀÖH‚āā, H‚āĀ‚ĀÜ.inv_mem_iff.mpr (commutator_mem_commutator h‚āā h‚āĀ)

@[to_additive]
theorem commutator_comm : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ = ‚ĀÖH‚āā, H‚āĀ‚ĀÜ :=
  le_antisymm (commutator_comm_le H‚āĀ H‚āā) (commutator_comm_le H‚āā H‚āĀ)

section Normal

@[to_additive]
instance commutator_normal [h‚āĀ : H‚āĀ.Normal] [h‚āā : H‚āā.Normal] : Normal ‚ĀÖH‚āĀ, H‚āā‚ĀÜ := by
  let base : Set G := { x | ‚ąÉ g‚āĀ ‚ąą H‚āĀ, ‚ąÉ g‚āā ‚ąą H‚āā, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = x }
  change (closure base).Normal
  suffices h_base : base = Group.conjugatesOfSet base by
    rw [h_base]
    exact Subgroup.normalClosure_normal
  refine Set.Subset.antisymm Group.subset_conjugatesOfSet fun a h => ?_
  simp_rw [Group.mem_conjugatesOfSet_iff, isConj_iff] at h
  rcases h with ‚ü®b, ‚ü®c, hc, e, he, rfl‚ü©, d, rfl‚ü©
  exact ‚ü®_, h‚āĀ.conj_mem c hc d, _, h‚āā.conj_mem e he d, (conjugate_commutatorElement c e d).symm‚ü©

@[to_additive]
theorem commutator_def' [H‚āĀ.Normal] [H‚āā.Normal] :
    ‚ĀÖH‚āĀ, H‚āā‚ĀÜ = normalClosure { g | ‚ąÉ g‚āĀ ‚ąą H‚āĀ, ‚ąÉ g‚āā ‚ąą H‚āā, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g } :=
  le_antisymm closure_le_normalClosure (normalClosure_le_normal subset_closure)

@[to_additive]
theorem commutator_le_right [h : H‚āā.Normal] : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ H‚āā :=
  commutator_le.mpr fun g‚āĀ _h‚āĀ g‚āā h‚āā => H‚āā.mul_mem (h.conj_mem g‚āā h‚āā g‚āĀ) (H‚āā.inv_mem h‚āā)

@[to_additive]
theorem commutator_le_left [H‚āĀ.Normal] : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ H‚āĀ :=
  commutator_comm H‚āā H‚āĀ ‚Ėł commutator_le_right H‚āā H‚āĀ

@[to_additive]
theorem commutator_top_left_le_iff : ‚ĀÖ(‚ä§ : Subgroup G), H‚ĀÜ ‚Č§ H ‚ÜĒ H.Normal := by
  refine ‚ü®fun hle ‚Ü¶ ‚ü®fun h hh g ‚Ü¶ ?_‚ü©, fun h ‚Ü¶ commutator_le_right ‚ä§ H‚ü©
  exact (H.mul_mem_cancel_right <| H.inv_mem hh).mp <| commutator_le.mp hle g trivial h hh

@[to_additive]
theorem commutator_top_right_le_iff : ‚ĀÖH, ‚ä§‚ĀÜ ‚Č§ H ‚ÜĒ H.Normal :=
  commutator_comm H ‚ä§ ‚Ėł commutator_top_left_le_iff

@[to_additive (attr := simp)]
theorem commutator_bot_left : ‚ĀÖ(‚ä• : Subgroup G), H‚āĀ‚ĀÜ = ‚ä• :=
  le_bot_iff.mp (commutator_le_left ‚ä• H‚āĀ)

@[to_additive (attr := simp)]
theorem commutator_bot_right : ‚ĀÖH‚āĀ, ‚ä•‚ĀÜ = (‚ä• : Subgroup G) :=
  le_bot_iff.mp (commutator_le_right H‚āĀ ‚ä•)

@[to_additive]
theorem commutator_le_inf [Normal H‚āĀ] [Normal H‚āā] : ‚ĀÖH‚āĀ, H‚āā‚ĀÜ ‚Č§ H‚āĀ ‚äď H‚āā :=
  le_inf (commutator_le_left H‚āĀ H‚āā) (commutator_le_right H‚āĀ H‚āā)

end Normal

@[to_additive]
theorem map_commutator (f : G ‚Üí* G') : map f ‚ĀÖH‚āĀ, H‚āā‚ĀÜ = ‚ĀÖmap f H‚āĀ, map f H‚āā‚ĀÜ := by
  simp_rw [le_antisymm_iff, map_le_iff_le_comap, commutator_le, mem_comap, map_commutatorElement]
  constructor
  ¬∑ intro p hp q hq
    exact commutator_mem_commutator (mem_map_of_mem _ hp) (mem_map_of_mem _ hq)
  ¬∑ rintro _ ‚ü®p, hp, rfl‚ü© _ ‚ü®q, hq, rfl‚ü©
    rw [‚Üź map_commutatorElement]
    exact mem_map_of_mem _ (commutator_mem_commutator hp hq)

variable {H‚āĀ H‚āā}

@[to_additive]
theorem commutator_le_map_commutator {f : G ‚Üí* G'} {K‚āĀ K‚āā : Subgroup G'} (h‚āĀ : K‚āĀ ‚Č§ H‚āĀ.map f)
    (h‚āā : K‚āā ‚Č§ H‚āā.map f) : ‚ĀÖK‚āĀ, K‚āā‚ĀÜ ‚Č§ ‚ĀÖH‚āĀ, H‚āā‚ĀÜ.map f :=
  (commutator_mono h‚āĀ h‚āā).trans (ge_of_eq (map_commutator H‚āĀ H‚āā f))

variable (H‚āĀ H‚āā)

@[to_additive]
instance commutator_characteristic [h‚āĀ : Characteristic H‚āĀ] [h‚āā : Characteristic H‚āā] :
    Characteristic ‚ĀÖH‚āĀ, H‚āā‚ĀÜ :=
  characteristic_iff_le_map.mpr fun Ōē =>
    commutator_le_map_commutator (characteristic_iff_le_map.mp h‚āĀ Ōē)
      (characteristic_iff_le_map.mp h‚āā Ōē)

@[to_additive]
theorem commutator_prod_prod (K‚āĀ K‚āā : Subgroup G') :
    ‚ĀÖH‚āĀ.prod K‚āĀ, H‚āā.prod K‚āā‚ĀÜ = ‚ĀÖH‚āĀ, H‚āā‚ĀÜ.prod ‚ĀÖK‚āĀ, K‚āā‚ĀÜ := by
  apply le_antisymm
  ¬∑ rw [commutator_le]
    rintro ‚ü®p‚āĀ, p‚āā‚ü© ‚ü®hp‚āĀ, hp‚āā‚ü© ‚ü®q‚āĀ, q‚āā‚ü© ‚ü®hq‚āĀ, hq‚āā‚ü©
    exact ‚ü®commutator_mem_commutator hp‚āĀ hq‚āĀ, commutator_mem_commutator hp‚āā hq‚āā‚ü©
  ¬∑ rw [prod_le_iff]
    constructor <;>
      ¬∑ rw [map_commutator]
        apply commutator_mono <;>
          simp [le_prod_iff, map_map, MonoidHom.fst_comp_inl, MonoidHom.snd_comp_inl,
            MonoidHom.fst_comp_inr, MonoidHom.snd_comp_inr]

/-- The commutator of direct product is contained in the direct product of the commutators.

See `commutator_pi_pi_of_finite` for equality given `Fintype ő∑`.
-/
@[to_additive /-- The commutator of direct product is contained in the direct product of the
commutators. See `commutator_pi_pi_of_finite` for equality given `Fintype ő∑`. -/]
theorem commutator_pi_pi_le {ő∑ : Type*} {Gs : ő∑ ‚Üí Type*} [‚ąÄ i, Group (Gs i)]
    (H K : ‚ąÄ i, Subgroup (Gs i)) :
    ‚ĀÖSubgroup.pi Set.univ H, Subgroup.pi Set.univ K‚ĀÜ ‚Č§ Subgroup.pi Set.univ fun i => ‚ĀÖH i, K i‚ĀÜ :=
  commutator_le.mpr fun _p hp _q hq i hi => commutator_mem_commutator (hp i hi) (hq i hi)

end Subgroup

open Subgroup hiding commutator

variable (G)

/-- The set of commutator elements `‚ĀÖg‚āĀ, g‚āā‚ĀÜ` in `G`. -/
@[to_additive /-- The set of additive commutator elements `‚ĀÖg‚āĀ, g‚āā‚ĀÜ` in `G`. -/]
def commutatorSet : Set G :=
  { g | ‚ąÉ g‚āĀ g‚āā : G, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g }

@[to_additive]
theorem commutatorSet_def : commutatorSet G = { g | ‚ąÉ g‚āĀ g‚āā : G, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g } :=
  rfl

@[to_additive]
theorem one_mem_commutatorSet : (1 : G) ‚ąą commutatorSet G :=
  ‚ü®1, 1, commutatorElement_self 1‚ü©

@[to_additive]
instance : Nonempty (commutatorSet G) :=
  ‚ü®‚ü®1, one_mem_commutatorSet G‚ü©‚ü©

variable {G g}

@[to_additive]
theorem mem_commutatorSet_iff : g ‚ąą commutatorSet G ‚ÜĒ ‚ąÉ g‚āĀ g‚āā : G, ‚ĀÖg‚āĀ, g‚āā‚ĀÜ = g :=
  Iff.rfl

@[to_additive]
theorem commutator_mem_commutatorSet : ‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą commutatorSet G :=
  ‚ü®g‚āĀ, g‚āā, rfl‚ü©

variable (G)

/-- The commutator subgroup of a group G is the normal subgroup
  generated by the commutators `[p,q] = p * q * p‚ĀĽ¬Ļ * q‚ĀĽ¬Ļ`. -/
@[to_additive /-- The commutator subgroup of an additive group G is the normal additive subgroup
  generated by the additive commutators `[p,q] = p + q + -p + -q`. -/]
def commutator : Subgroup G := ‚ĀÖ(‚ä§ : Subgroup G), ‚ä§‚ĀÜ
deriving Subgroup.Normal, Subgroup.Characteristic

attribute [to_additive] instNormalCommutator
attribute [to_additive] instCharacteristicCommutator

@[to_additive]
lemma commutator_def : commutator G = ‚ĀÖ(‚ä§ : Subgroup G), ‚ä§‚ĀÜ :=
  rfl

@[to_additive]
lemma commutator_eq_closure : commutator G = Subgroup.closure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def, commutatorSet]

@[to_additive]
lemma commutator_eq_normalClosure : commutator G = Subgroup.normalClosure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def', commutatorSet]

variable {G} in
@[to_additive]
lemma Subgroup.map_subtype_commutator (H : Subgroup G) :
    (_root_.commutator H).map H.subtype = ‚ĀÖH, H‚ĀÜ := by
  rw [_root_.commutator_def, map_commutator, ‚Üź MonoidHom.range_eq_map, H.range_subtype]

variable {G} in
@[to_additive]
lemma Subgroup.commutator_le_self (H : Subgroup G) : ‚ĀÖH, H‚ĀÜ ‚Č§ H :=
  H.map_subtype_commutator.symm.trans_le (map_subtype_le _)

@[to_additive]
theorem Subgroup.Normal.of_commutator_le {H : Subgroup G} (h : _root_.commutator G ‚Č§ H) :
    H.Normal :=
  commutator_top_left_le_iff.mp <| commutator_mono le_top le_top |>.trans h

@[to_additive]
theorem commutator_eq_bot_iff_center_eq_top : commutator G = ‚ä• ‚ÜĒ Subgroup.center G = ‚ä§ := by
  simp [commutator, Subgroup.commutator_eq_bot_iff_le_centralizer]

@[to_additive]
lemma commutator_centralizer_commutator_le_center :
    ‚ĀÖcentralizer (commutator G : Set G), centralizer (commutator G)‚ĀÜ ‚Č§ Subgroup.center G := by
  rw [‚Üź Subgroup.centralizer_univ, ‚Üź Subgroup.coe_top, ‚Üź
    Subgroup.commutator_eq_bot_iff_le_centralizer]
  suffices ‚ĀÖ‚ĀÖ‚ä§, centralizer (commutator G : Set G)‚ĀÜ, centralizer (commutator G : Set G)‚ĀÜ = ‚ä• by
    refine Subgroup.commutator_commutator_eq_bot_of_rotate ?_ this
    rwa [Subgroup.commutator_comm (centralizer (commutator G : Set G))]
  rw [Subgroup.commutator_comm, Subgroup.commutator_eq_bot_iff_le_centralizer]
  exact Set.centralizer_subset (Subgroup.commutator_mono le_top le_top)

/-- If `g` is conjugate to `g ^ 2`, then `g` is a commutator -/
@[to_additive /-- If g is conjugate to `2 ‚ÄĘ g`, then `g` is an additive commutator -/]
lemma mem_commutatorSet_of_isConj_sq {g : G} (hg : IsConj g (g ^ 2)) : g ‚ąą commutatorSet G := by
  obtain ‚ü®h, hg‚ü© := hg
  use h, g
  rw [commutatorElement_def, hg]
  simp only [IsUnit.mul_inv_cancel_right, Units.isUnit, mul_inv_eq_iff_eq_mul, pow_two]

@[to_additive]
lemma map_commutator_eq {H : Type*} [Group H] (f : G ‚Üí* H) :
    (commutator G).map f = ‚ĀÖf.range, f.range‚ĀÜ := by
  rw [_root_.commutator_def, Subgroup.map_commutator]
  apply congr_arg‚āā <;>
  ¬∑ rw [Subgroup.map_eq_range_iff]
    rw [codisjoint_iff, top_sup_eq]

section commutatorRepresentatives

open Subgroup

/-- Representatives `(g‚āĀ, g‚āā) : G √ó G` of commutators `‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą G`. -/
@[to_additive /-- Representatives `(g‚āĀ, g‚āā) : G √ó G` of additive commutators `‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą G`. -/]
def commutatorRepresentatives : Set (G √ó G) :=
  Set.range fun g : commutatorSet G => (g.2.choose, g.2.choose_spec.choose)

/-- Subgroup generated by representatives `g‚āĀ g‚āā : G` of commutators `‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą G`. -/
@[to_additive /-- Additive subgroup generated by representatives `g‚āĀ g‚āā : G` of additive
commutators `‚ĀÖg‚āĀ, g‚āā‚ĀÜ ‚ąą G`. -/]
def closureCommutatorRepresentatives : Subgroup G :=
  closure (Prod.fst '' commutatorRepresentatives G ‚ą™ Prod.snd '' commutatorRepresentatives G)

@[to_additive]
lemma image_commutatorSet_closureCommutatorRepresentatives :
    (closureCommutatorRepresentatives G).subtype ''
        commutatorSet (closureCommutatorRepresentatives G) =
      commutatorSet G := by
  apply Set.Subset.antisymm
  ¬∑ rintro - ‚ü®-, ‚ü®g‚āĀ, g‚āā, rfl‚ü©, rfl‚ü©
    exact ‚ü®g‚āĀ, g‚āā, rfl‚ü©
  ¬∑ exact fun g hg ‚Ü¶
      ‚ü®_, ‚ü®‚ü®_, subset_closure <| .inl ‚ü®_, ‚ü®‚ü®g, hg‚ü©, rfl‚ü©, rfl‚ü©‚ü©,
          ‚ü®_, subset_closure <| .inr ‚ü®_, ‚ü®‚ü®g, hg‚ü©, rfl‚ü©, rfl‚ü©‚ü©, rfl‚ü©,
        hg.choose_spec.choose_spec‚ü©

end commutatorRepresentatives

variable {G}

@[to_additive]
theorem Subgroup.Normal.quotient_commutative_iff_commutator_le {N : Subgroup G} [N.Normal] :
    IsMulCommutative (G ‚ßł N) ‚ÜĒ _root_.commutator G ‚Č§ N := by
  refine ‚ü®fun hcomm ‚Ü¶ ?_, fun hGN ‚Ü¶ ‚ü®‚ü®fun x' y' ‚Ü¶ ?_‚ü©‚ü©‚ü©
  ¬∑ rw [commutator_eq_normalClosure, ‚Üź Subgroup.normalClosure_subset_iff]
    rintro x ‚ü®p, q, rfl‚ü©
    rw [SetLike.mem_coe, ‚Üź QuotientGroup.eq_one_iff, commutatorElement_def]
    simp only [QuotientGroup.mk_mul, QuotientGroup.mk_inv]
    rw [‚Üź commutatorElement_def, commutatorElement_eq_one_iff_mul_comm, mul_comm']
  ¬∑ obtain ‚ü®x, rfl‚ü© := QuotientGroup.mk'_surjective N x'
    obtain ‚ü®y, rfl‚ü© := QuotientGroup.mk'_surjective N y'
    rw [‚Üź commutatorElement_eq_one_iff_mul_comm, ‚Üź map_commutatorElement, QuotientGroup.mk'_apply,
      QuotientGroup.eq_one_iff]
    apply hGN
    rw [commutator_eq_closure]
    exact Subgroup.subset_closure (commutator_mem_commutatorSet x y)

/-- If `N` is a normal subgroup of `G` and `H` a commutative subgroup such that `H ‚äĒ N = ‚ä§`,
  then `N` contains `commutator G`. -/
@[to_additive /-- If `N` is a normal additive subgroup of `G` and `H` a commutative additive
subgroup such that `H ‚äĒ N = ‚ä§`, then `N` contains `addCommutator G`. -/]
theorem Subgroup.Normal.commutator_le_of_self_sup_commutative_eq_top {N : Subgroup G} [N.Normal]
    {H : Subgroup G} (hHN : N ‚äĒ H = ‚ä§) (hH : IsMulCommutative H) : _root_.commutator G ‚Č§ N := by
  -- It is enough to prove that Q = G ‚ßł N is commutative
  apply quotient_commutative_iff_commutator_le.mp
  -- Q is a quotient of H
  let ŌÜ : H ‚Üí‚āô* G ‚ßł N := MonoidHom.comp (QuotientGroup.mk' N) (Subgroup.subtype H)
  -- It is enough to prove that ŌÜ is surjective
  apply Function.Surjective.mul_comm (f := ŌÜ) _ hH
  -- We have to prove that `MonoidHom.range ŌÜ = ‚ä§`
  have : Subgroup.map (QuotientGroup.mk' N) ‚ä§ = ‚ä§ := by
    rw [‚Üź MonoidHom.range_eq_map, MonoidHom.range_eq_top]
    exact QuotientGroup.mk'_surjective N
  rw [MulHom.coe_coe, ‚Üź MonoidHom.range_eq_top, MonoidHom.range_eq_map, ‚Üź Subgroup.map_map, ‚Üź this,
    Subgroup.map_eq_map_iff, QuotientGroup.ker_mk', sup_comm, ‚Üź hHN, ‚Üź MonoidHom.range_eq_map]
  simp
