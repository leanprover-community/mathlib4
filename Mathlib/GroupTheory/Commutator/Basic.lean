instance commutator_normal [hâ‚پ : Hâ‚پ.Normal] [hâ‚‚ : Hâ‚‚.Normal] : Normal âپ…Hâ‚پ, Hâ‚‚âپ† := by
  let base : Set G := { x | âˆƒ gâ‚پ âˆˆ Hâ‚پ, âˆƒ gâ‚‚ âˆˆ Hâ‚‚, âپ…gâ‚پ, gâ‚‚âپ† = x }
  change (closure base).Normal
  suffices h_base : base = Group.conjugatesOfSet base by
    rw [h_base]
    exact Subgroup.normalClosure_normal
  refine Set.Subset.antisymm Group.subset_conjugatesOfSet fun a h => ?_
  simp_rw [Group.mem_conjugatesOfSet_iff, isConj_iff] at h
  rcases h with âں¨b, âں¨c, hc, e, he, rflâں©, d, rflâں©
  exact âں¨_, hâ‚پ.conj_mem c hc d, _, hâ‚‚.conj_mem e he d, (conjugate_commutatorElement c e d).symmâں©

