/-!
# Commutators of Subgroups

If `G` is a group and `Hв‚Ѓ Hв‚‚ : Subgroup G` then the commutator `вЃ…Hв‚Ѓ, Hв‚‚вЃ† : Subgroup G`
is the subgroup of `G` generated by the commutators `hв‚Ѓ * hв‚‚ * hв‚ЃвЃ»В№ * hв‚‚вЃ»В№`.

## Main definitions

* `вЃ…gв‚Ѓ, gв‚‚вЃ†` : the commutator of the elements `gв‚Ѓ` and `gв‚‚`
    (defined by `commutatorElement` elsewhere).
* `вЃ…Hв‚Ѓ, Hв‚‚вЃ†` : the commutator of the subgroups `Hв‚Ѓ` and `Hв‚‚`.
* `commutator`: defines the commutator of a group `G` as a subgroup of `G`.
-/

@[expose] public section

assert_not_exists Cardinal Multiset Ring

open scoped commutatorElement

variable {G G' F : Type*} [Group G] [Group G'] [FunLike F G G'] [MonoidHomClass F G G']
variable (f : F) {gв‚Ѓ gв‚‚ gв‚ѓ g : G}

@[to_additive]
theorem commutatorElement_eq_one_iff_mul_comm : вЃ…gв‚Ѓ, gв‚‚вЃ† = 1 в†” gв‚Ѓ * gв‚‚ = gв‚‚ * gв‚Ѓ := by
  rw [commutatorElement_def, mul_inv_eq_one, mul_inv_eq_iff_eq_mul]

@[to_additive]
theorem commutatorElement_eq_one_iff_commute : вЃ…gв‚Ѓ, gв‚‚вЃ† = 1 в†” Commute gв‚Ѓ gв‚‚ :=
  commutatorElement_eq_one_iff_mul_comm

@[to_additive]
theorem Commute.commutator_eq (h : Commute gв‚Ѓ gв‚‚) : вЃ…gв‚Ѓ, gв‚‚вЃ† = 1 :=
  commutatorElement_eq_one_iff_commute.mpr h

variable (gв‚Ѓ gв‚‚ gв‚ѓ g)

@[to_additive (attr := simp)]
theorem commutatorElement_one_right : вЃ…g, (1 : G)вЃ† = 1 :=
  (Commute.one_right g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_one_left : вЃ…(1 : G), gвЃ† = 1 :=
  (Commute.one_left g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_self : вЃ…g, gвЃ† = 1 :=
  (Commute.refl g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_inv : вЃ…gв‚Ѓ, gв‚‚вЃ†вЃ»В№ = вЃ…gв‚‚, gв‚ЃвЃ† := by
  simp_rw [commutatorElement_def, mul_inv_rev, inv_inv, mul_assoc]

@[to_additive]
theorem map_commutatorElement : (f вЃ…gв‚Ѓ, gв‚‚вЃ† : G') = вЃ…f gв‚Ѓ, f gв‚‚вЃ† := by
  simp_rw [commutatorElement_def, map_mul f, map_inv f]

@[to_additive]
theorem conjugate_commutatorElement : gв‚ѓ * вЃ…gв‚Ѓ, gв‚‚вЃ† * gв‚ѓвЃ»В№ = вЃ…gв‚ѓ * gв‚Ѓ * gв‚ѓвЃ»В№, gв‚ѓ * gв‚‚ * gв‚ѓвЃ»В№вЃ† := by
  simp [mul_assoc, commutatorElement_def]

namespace Subgroup

/-- The commutator of two subgroups `Hв‚Ѓ` and `Hв‚‚`. -/
@[to_additive /-- The commutator of two additive subgroups `Hв‚Ѓ` and `Hв‚‚`. -/]
instance commutator : Bracket (Subgroup G) (Subgroup G) :=
  вџЁfun Hв‚Ѓ Hв‚‚ => closure { g | в€ѓ gв‚Ѓ в€€ Hв‚Ѓ, в€ѓ gв‚‚ в€€ Hв‚‚, вЃ…gв‚Ѓ, gв‚‚вЃ† = g }вџ©

@[to_additive]
theorem commutator_def (Hв‚Ѓ Hв‚‚ : Subgroup G) :
    вЃ…Hв‚Ѓ, Hв‚‚вЃ† = closure { g | в€ѓ gв‚Ѓ в€€ Hв‚Ѓ, в€ѓ gв‚‚ в€€ Hв‚‚, вЃ…gв‚Ѓ, gв‚‚вЃ† = g } :=
  rfl

variable {gв‚Ѓ gв‚‚ gв‚ѓ} {H Hв‚Ѓ Hв‚‚ Hв‚ѓ Kв‚Ѓ Kв‚‚ : Subgroup G}

@[to_additive]
theorem commutator_mem_commutator (hв‚Ѓ : gв‚Ѓ в€€ Hв‚Ѓ) (hв‚‚ : gв‚‚ в€€ Hв‚‚) : вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ вЃ…Hв‚Ѓ, Hв‚‚вЃ† :=
  subset_closure вџЁgв‚Ѓ, hв‚Ѓ, gв‚‚, hв‚‚, rflвџ©

@[to_additive]
theorem commutator_le : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ Hв‚ѓ в†” в€Ђ gв‚Ѓ в€€ Hв‚Ѓ, в€Ђ gв‚‚ в€€ Hв‚‚, вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ Hв‚ѓ :=
  Hв‚ѓ.closure_le.trans
    вџЁfun h a b c d => h вџЁa, b, c, d, rflвџ©, fun h _g вџЁa, b, c, d, h_eqвџ© => h_eq в–ё h a b c dвџ©

@[to_additive]
theorem commutator_mono (hв‚Ѓ : Hв‚Ѓ в‰¤ Kв‚Ѓ) (hв‚‚ : Hв‚‚ в‰¤ Kв‚‚) : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ вЃ…Kв‚Ѓ, Kв‚‚вЃ† :=
  commutator_le.mpr fun _gв‚Ѓ hgв‚Ѓ _gв‚‚ hgв‚‚ => commutator_mem_commutator (hв‚Ѓ hgв‚Ѓ) (hв‚‚ hgв‚‚)

@[to_additive]
theorem commutator_eq_bot_iff_le_centralizer : вЃ…Hв‚Ѓ, Hв‚‚вЃ† = вЉҐ в†” Hв‚Ѓ в‰¤ centralizer Hв‚‚ := by
  rw [eq_bot_iff, commutator_le]
  refine forall_congr' fun p =>
    forall_congr' fun _hp => forall_congr' fun q => forall_congr' fun hq => ?_
  rw [mem_bot, commutatorElement_eq_one_iff_mul_comm, eq_comm]

/-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/
@[to_additive /-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/]
theorem commutator_commutator_eq_bot_of_rotate (h1 : вЃ…вЃ…Hв‚‚, Hв‚ѓвЃ†, Hв‚ЃвЃ† = вЉҐ) (h2 : вЃ…вЃ…Hв‚ѓ, Hв‚ЃвЃ†, Hв‚‚вЃ† = вЉҐ) :
    вЃ…вЃ…Hв‚Ѓ, Hв‚‚вЃ†, Hв‚ѓвЃ† = вЉҐ := by
  simp_rw [commutator_eq_bot_iff_le_centralizer, commutator_le,
    mem_centralizer_iff_commutator_eq_one] at h1 h2 вЉў
  intro x hx y hy z hz
  trans x * z * вЃ…y, вЃ…zвЃ»В№, xвЃ»В№вЃ†вЃ†вЃ»В№ * zвЃ»В№ * y * вЃ…xвЃ»В№, вЃ…yвЃ»В№, zвЃ†вЃ†вЃ»В№ * yвЃ»В№ * xвЃ»В№
  -- We avoid `group` here to minimize imports while low in the hierarchy;
  -- typically it would be better to invoke the tactic.
  В· simp [commutatorElement_def, mul_assoc]
  В· rw [h1 _ (Hв‚‚.inv_mem hy) _ hz _ (Hв‚Ѓ.inv_mem hx), h2 _ (Hв‚ѓ.inv_mem hz) _ (Hв‚Ѓ.inv_mem hx) _ hy]
    simp [mul_assoc]

variable (Hв‚Ѓ Hв‚‚)

@[to_additive]
theorem commutator_comm_le : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ вЃ…Hв‚‚, Hв‚ЃвЃ† :=
  commutator_le.mpr fun gв‚Ѓ hв‚Ѓ gв‚‚ hв‚‚ =>
    commutatorElement_inv gв‚‚ gв‚Ѓ в–ё вЃ…Hв‚‚, Hв‚ЃвЃ†.inv_mem_iff.mpr (commutator_mem_commutator hв‚‚ hв‚Ѓ)

@[to_additive]
theorem commutator_comm : вЃ…Hв‚Ѓ, Hв‚‚вЃ† = вЃ…Hв‚‚, Hв‚ЃвЃ† :=
  le_antisymm (commutator_comm_le Hв‚Ѓ Hв‚‚) (commutator_comm_le Hв‚‚ Hв‚Ѓ)

section Normal

@[to_additive]
instance commutator_normal [hв‚Ѓ : Hв‚Ѓ.Normal] [hв‚‚ : Hв‚‚.Normal] : Normal вЃ…Hв‚Ѓ, Hв‚‚вЃ† := by
  let base : Set G := { x | в€ѓ gв‚Ѓ в€€ Hв‚Ѓ, в€ѓ gв‚‚ в€€ Hв‚‚, вЃ…gв‚Ѓ, gв‚‚вЃ† = x }
  change (closure base).Normal
  suffices h_base : base = Group.conjugatesOfSet base by
    rw [h_base]
    exact Subgroup.normalClosure_normal
  refine Set.Subset.antisymm Group.subset_conjugatesOfSet fun a h => ?_
  simp_rw [Group.mem_conjugatesOfSet_iff, isConj_iff] at h
  rcases h with вџЁb, вџЁc, hc, e, he, rflвџ©, d, rflвџ©
  exact вџЁ_, hв‚Ѓ.conj_mem c hc d, _, hв‚‚.conj_mem e he d, (conjugate_commutatorElement c e d).symmвџ©

@[to_additive]
theorem commutator_def' [Hв‚Ѓ.Normal] [Hв‚‚.Normal] :
    вЃ…Hв‚Ѓ, Hв‚‚вЃ† = normalClosure { g | в€ѓ gв‚Ѓ в€€ Hв‚Ѓ, в€ѓ gв‚‚ в€€ Hв‚‚, вЃ…gв‚Ѓ, gв‚‚вЃ† = g } :=
  le_antisymm closure_le_normalClosure (normalClosure_le_normal subset_closure)

@[to_additive]
theorem commutator_le_right [h : Hв‚‚.Normal] : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ Hв‚‚ :=
  commutator_le.mpr fun gв‚Ѓ _hв‚Ѓ gв‚‚ hв‚‚ => Hв‚‚.mul_mem (h.conj_mem gв‚‚ hв‚‚ gв‚Ѓ) (Hв‚‚.inv_mem hв‚‚)

@[to_additive]
theorem commutator_le_left [Hв‚Ѓ.Normal] : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ Hв‚Ѓ :=
  commutator_comm Hв‚‚ Hв‚Ѓ в–ё commutator_le_right Hв‚‚ Hв‚Ѓ

@[to_additive]
theorem commutator_top_left_le_iff : вЃ…(вЉ¤ : Subgroup G), HвЃ† в‰¤ H в†” H.Normal := by
  refine вџЁfun hle в†¦ вџЁfun h hh g в†¦ ?_вџ©, fun h в†¦ commutator_le_right вЉ¤ Hвџ©
  exact (H.mul_mem_cancel_right <| H.inv_mem hh).mp <| commutator_le.mp hle g trivial h hh

@[to_additive]
theorem commutator_top_right_le_iff : вЃ…H, вЉ¤вЃ† в‰¤ H в†” H.Normal :=
  commutator_comm H вЉ¤ в–ё commutator_top_left_le_iff

@[to_additive (attr := simp)]
theorem commutator_bot_left : вЃ…(вЉҐ : Subgroup G), Hв‚ЃвЃ† = вЉҐ :=
  le_bot_iff.mp (commutator_le_left вЉҐ Hв‚Ѓ)

@[to_additive (attr := simp)]
theorem commutator_bot_right : вЃ…Hв‚Ѓ, вЉҐвЃ† = (вЉҐ : Subgroup G) :=
  le_bot_iff.mp (commutator_le_right Hв‚Ѓ вЉҐ)

@[to_additive]
theorem commutator_le_inf [Normal Hв‚Ѓ] [Normal Hв‚‚] : вЃ…Hв‚Ѓ, Hв‚‚вЃ† в‰¤ Hв‚Ѓ вЉ“ Hв‚‚ :=
  le_inf (commutator_le_left Hв‚Ѓ Hв‚‚) (commutator_le_right Hв‚Ѓ Hв‚‚)

end Normal

@[to_additive]
theorem map_commutator (f : G в†’* G') : map f вЃ…Hв‚Ѓ, Hв‚‚вЃ† = вЃ…map f Hв‚Ѓ, map f Hв‚‚вЃ† := by
  simp_rw [le_antisymm_iff, map_le_iff_le_comap, commutator_le, mem_comap, map_commutatorElement]
  constructor
  В· intro p hp q hq
    exact commutator_mem_commutator (mem_map_of_mem _ hp) (mem_map_of_mem _ hq)
  В· rintro _ вџЁp, hp, rflвџ© _ вџЁq, hq, rflвџ©
    rw [в†ђ map_commutatorElement]
    exact mem_map_of_mem _ (commutator_mem_commutator hp hq)

variable {Hв‚Ѓ Hв‚‚}

@[to_additive]
theorem commutator_le_map_commutator {f : G в†’* G'} {Kв‚Ѓ Kв‚‚ : Subgroup G'} (hв‚Ѓ : Kв‚Ѓ в‰¤ Hв‚Ѓ.map f)
    (hв‚‚ : Kв‚‚ в‰¤ Hв‚‚.map f) : вЃ…Kв‚Ѓ, Kв‚‚вЃ† в‰¤ вЃ…Hв‚Ѓ, Hв‚‚вЃ†.map f :=
  (commutator_mono hв‚Ѓ hв‚‚).trans (ge_of_eq (map_commutator Hв‚Ѓ Hв‚‚ f))

variable (Hв‚Ѓ Hв‚‚)

@[to_additive]
instance commutator_characteristic [hв‚Ѓ : Characteristic Hв‚Ѓ] [hв‚‚ : Characteristic Hв‚‚] :
    Characteristic вЃ…Hв‚Ѓ, Hв‚‚вЃ† :=
  characteristic_iff_le_map.mpr fun П• =>
    commutator_le_map_commutator (characteristic_iff_le_map.mp hв‚Ѓ П•)
      (characteristic_iff_le_map.mp hв‚‚ П•)

@[to_additive]
theorem commutator_prod_prod (Kв‚Ѓ Kв‚‚ : Subgroup G') :
    вЃ…Hв‚Ѓ.prod Kв‚Ѓ, Hв‚‚.prod Kв‚‚вЃ† = вЃ…Hв‚Ѓ, Hв‚‚вЃ†.prod вЃ…Kв‚Ѓ, Kв‚‚вЃ† := by
  apply le_antisymm
  В· rw [commutator_le]
    rintro вџЁpв‚Ѓ, pв‚‚вџ© вџЁhpв‚Ѓ, hpв‚‚вџ© вџЁqв‚Ѓ, qв‚‚вџ© вџЁhqв‚Ѓ, hqв‚‚вџ©
    exact вџЁcommutator_mem_commutator hpв‚Ѓ hqв‚Ѓ, commutator_mem_commutator hpв‚‚ hqв‚‚вџ©
  В· rw [prod_le_iff]
    constructor <;>
      В· rw [map_commutator]
        apply commutator_mono <;>
          simp [le_prod_iff, map_map, MonoidHom.fst_comp_inl, MonoidHom.snd_comp_inl,
            MonoidHom.fst_comp_inr, MonoidHom.snd_comp_inr]

/-- The commutator of direct product is contained in the direct product of the commutators.

See `commutator_pi_pi_of_finite` for equality given `Fintype О·`.
-/
@[to_additive /-- The commutator of direct product is contained in the direct product of the
commutators. See `commutator_pi_pi_of_finite` for equality given `Fintype О·`. -/]
theorem commutator_pi_pi_le {О· : Type*} {Gs : О· в†’ Type*} [в€Ђ i, Group (Gs i)]
    (H K : в€Ђ i, Subgroup (Gs i)) :
    вЃ…Subgroup.pi Set.univ H, Subgroup.pi Set.univ KвЃ† в‰¤ Subgroup.pi Set.univ fun i => вЃ…H i, K iвЃ† :=
  commutator_le.mpr fun _p hp _q hq i hi => commutator_mem_commutator (hp i hi) (hq i hi)

end Subgroup

open Subgroup hiding commutator

variable (G)

/-- The set of commutator elements `вЃ…gв‚Ѓ, gв‚‚вЃ†` in `G`. -/
@[to_additive /-- The set of additive commutator elements `вЃ…gв‚Ѓ, gв‚‚вЃ†` in `G`. -/]
def commutatorSet : Set G :=
  { g | в€ѓ gв‚Ѓ gв‚‚ : G, вЃ…gв‚Ѓ, gв‚‚вЃ† = g }

@[to_additive]
theorem commutatorSet_def : commutatorSet G = { g | в€ѓ gв‚Ѓ gв‚‚ : G, вЃ…gв‚Ѓ, gв‚‚вЃ† = g } :=
  rfl

@[to_additive]
theorem one_mem_commutatorSet : (1 : G) в€€ commutatorSet G :=
  вџЁ1, 1, commutatorElement_self 1вџ©

@[to_additive]
instance : Nonempty (commutatorSet G) :=
  вџЁвџЁ1, one_mem_commutatorSet Gвџ©вџ©

variable {G g}

@[to_additive]
theorem mem_commutatorSet_iff : g в€€ commutatorSet G в†” в€ѓ gв‚Ѓ gв‚‚ : G, вЃ…gв‚Ѓ, gв‚‚вЃ† = g :=
  Iff.rfl

@[to_additive]
theorem commutator_mem_commutatorSet : вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ commutatorSet G :=
  вџЁgв‚Ѓ, gв‚‚, rflвџ©

variable (G)

/-- The commutator subgroup of a group G is the normal subgroup
  generated by the commutators `[p,q] = p * q * pвЃ»В№ * qвЃ»В№`. -/
@[to_additive /-- The commutator subgroup of an additive group G is the normal additive subgroup
  generated by the additive commutators `[p,q] = p + q + -p + -q`. -/]
def commutator : Subgroup G := вЃ…(вЉ¤ : Subgroup G), вЉ¤вЃ†
deriving Subgroup.Normal, Subgroup.Characteristic

attribute [to_additive] instNormalCommutator
attribute [to_additive] instCharacteristicCommutator

@[to_additive]
lemma commutator_def : commutator G = вЃ…(вЉ¤ : Subgroup G), вЉ¤вЃ† :=
  rfl

@[to_additive]
lemma commutator_eq_closure : commutator G = Subgroup.closure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def, commutatorSet]

@[to_additive]
lemma commutator_eq_normalClosure : commutator G = Subgroup.normalClosure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def', commutatorSet]

variable {G} in
@[to_additive]
lemma Subgroup.map_subtype_commutator (H : Subgroup G) :
    (_root_.commutator H).map H.subtype = вЃ…H, HвЃ† := by
  rw [_root_.commutator_def, map_commutator, в†ђ MonoidHom.range_eq_map, H.range_subtype]

variable {G} in
@[to_additive]
lemma Subgroup.commutator_le_self (H : Subgroup G) : вЃ…H, HвЃ† в‰¤ H :=
  H.map_subtype_commutator.symm.trans_le (map_subtype_le _)

@[to_additive]
theorem Subgroup.Normal.of_commutator_le {H : Subgroup G} (h : _root_.commutator G в‰¤ H) :
    H.Normal :=
  commutator_top_left_le_iff.mp <| commutator_mono le_top le_top |>.trans h

@[to_additive]
theorem commutator_eq_bot_iff_center_eq_top : commutator G = вЉҐ в†” Subgroup.center G = вЉ¤ := by
  simp [commutator, Subgroup.commutator_eq_bot_iff_le_centralizer]

@[to_additive]
theorem commutator_eq_bot_iff : commutator G = вЉҐ в†” IsMulCommutative G := by
  rw [commutator_eq_bot_iff_center_eq_top, center_eq_top_iff]

@[to_additive]
theorem commutator_eq_bot [hG : IsMulCommutative G] : commutator G = вЉҐ :=
  (commutator_eq_bot_iff G).mpr hG

@[to_additive]
lemma commutator_centralizer_commutator_le_center :
    вЃ…centralizer (commutator G : Set G), centralizer (commutator G)вЃ† в‰¤ Subgroup.center G := by
  rw [в†ђ Subgroup.centralizer_univ, в†ђ Subgroup.coe_top, в†ђ
    Subgroup.commutator_eq_bot_iff_le_centralizer]
  suffices вЃ…вЃ…вЉ¤, centralizer (commutator G : Set G)вЃ†, centralizer (commutator G : Set G)вЃ† = вЉҐ by
    refine Subgroup.commutator_commutator_eq_bot_of_rotate ?_ this
    rwa [Subgroup.commutator_comm (centralizer (commutator G : Set G))]
  rw [Subgroup.commutator_comm, Subgroup.commutator_eq_bot_iff_le_centralizer]
  exact Set.centralizer_subset (Subgroup.commutator_mono le_top le_top)

/-- If `g` is conjugate to `g ^ 2`, then `g` is a commutator -/
@[to_additive /-- If g is conjugate to `2 вЂў g`, then `g` is an additive commutator -/]
lemma mem_commutatorSet_of_isConj_sq {g : G} (hg : IsConj g (g ^ 2)) : g в€€ commutatorSet G := by
  obtain вџЁh, hgвџ© := hg
  use h, g
  rw [commutatorElement_def, hg]
  simp only [IsUnit.mul_inv_cancel_right, Units.isUnit, mul_inv_eq_iff_eq_mul, pow_two]

@[to_additive]
lemma map_commutator_eq {H : Type*} [Group H] (f : G в†’* H) :
    (commutator G).map f = вЃ…f.range, f.rangeвЃ† := by
  rw [_root_.commutator_def, Subgroup.map_commutator]
  apply congr_argв‚‚ <;>
  В· rw [Subgroup.map_eq_range_iff]
    rw [codisjoint_iff, top_sup_eq]

section commutatorRepresentatives

open Subgroup

/-- Representatives `(gв‚Ѓ, gв‚‚) : G Г— G` of commutators `вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ G`. -/
@[to_additive /-- Representatives `(gв‚Ѓ, gв‚‚) : G Г— G` of additive commutators `вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ G`. -/]
def commutatorRepresentatives : Set (G Г— G) :=
  Set.range fun g : commutatorSet G => (g.2.choose, g.2.choose_spec.choose)

/-- Subgroup generated by representatives `gв‚Ѓ gв‚‚ : G` of commutators `вЃ…gв‚Ѓ, gв‚‚вЃ† в€€ G`. -/
@[to_additive /-- Additive subgroup generated by representatives `gв‚Ѓ gв‚‚ : G` of additive
