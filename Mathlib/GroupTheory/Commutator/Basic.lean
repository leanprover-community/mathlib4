  -- Q is a quotient of H
  let П† : H в†’в‚™* G в§ё N := MonoidHom.comp (QuotientGroup.mk' N) (Subgroup.subtype H)
  -- It is enough to prove that П† is surjective
  apply Function.Surjective.mul_comm (f := П†) _ hH
  -- We have to prove that `MonoidHom.range П† = вЉ¤`
  have : Subgroup.map (QuotientGroup.mk' N) вЉ¤ = вЉ¤ := by
    rw [в†ђ MonoidHom.range_eq_map, MonoidHom.range_eq_top]
    exact QuotientGroup.mk'_surjective N
  rw [MulHom.coe_coe, в†ђ MonoidHom.range_eq_top, MonoidHom.range_eq_map, в†ђ Subgroup.map_map, в†ђ this,
    Subgroup.map_eq_map_iff, QuotientGroup.ker_mk', sup_comm, в†ђ hHN, в†ђ MonoidHom.range_eq_map]
