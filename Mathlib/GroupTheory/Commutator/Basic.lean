    rintro x вџЁp, q, rflвџ©
    rw [SetLike.mem_coe, в†ђ QuotientGroup.eq_one_iff, commutatorElement_def]
    simp only [QuotientGroup.mk_mul, QuotientGroup.mk_inv]
