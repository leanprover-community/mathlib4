/-!
# Commutators of Subgroups

If `G` is a group and `HтВБ HтВВ : Subgroup G` then the commutator `тБЕHтВБ, HтВВтБЖ : Subgroup G`
is the subgroup of `G` generated by the commutators `hтВБ * hтВВ * hтВБтБ╗┬╣ * hтВВтБ╗┬╣`.

## Main definitions

* `тБЕgтВБ, gтВВтБЖ` : the commutator of the elements `gтВБ` and `gтВВ`
    (defined by `commutatorElement` elsewhere).
* `тБЕHтВБ, HтВВтБЖ` : the commutator of the subgroups `HтВБ` and `HтВВ`.
* `commutator`: defines the commutator of a group `G` as a subgroup of `G`.
-/

@[expose] public section

assert_not_exists Cardinal Multiset Ring

open scoped commutatorElement

variable {G G' F : Type*} [Group G] [Group G'] [FunLike F G G'] [MonoidHomClass F G G']
variable (f : F) {gтВБ gтВВ gтВГ g : G}

@[to_additive]
theorem commutatorElement_eq_one_iff_mul_comm : тБЕgтВБ, gтВВтБЖ = 1 тЖФ gтВБ * gтВВ = gтВВ * gтВБ := by
  rw [commutatorElement_def, mul_inv_eq_one, mul_inv_eq_iff_eq_mul]

@[to_additive]
theorem commutatorElement_eq_one_iff_commute : тБЕgтВБ, gтВВтБЖ = 1 тЖФ Commute gтВБ gтВВ :=
  commutatorElement_eq_one_iff_mul_comm

@[to_additive]
theorem Commute.commutator_eq (h : Commute gтВБ gтВВ) : тБЕgтВБ, gтВВтБЖ = 1 :=
  commutatorElement_eq_one_iff_commute.mpr h

variable (gтВБ gтВВ gтВГ g)

@[to_additive (attr := simp)]
theorem commutatorElement_one_right : тБЕg, (1 : G)тБЖ = 1 :=
  (Commute.one_right g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_one_left : тБЕ(1 : G), gтБЖ = 1 :=
  (Commute.one_left g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_self : тБЕg, gтБЖ = 1 :=
  (Commute.refl g).commutator_eq

@[to_additive (attr := simp)]
theorem commutatorElement_inv : тБЕgтВБ, gтВВтБЖтБ╗┬╣ = тБЕgтВВ, gтВБтБЖ := by
  simp_rw [commutatorElement_def, mul_inv_rev, inv_inv, mul_assoc]

@[to_additive (attr := simp)]
theorem map_commutatorElement : (f тБЕgтВБ, gтВВтБЖ : G') = тБЕf gтВБ, f gтВВтБЖ := by
  simp_rw [commutatorElement_def, map_mul f, map_inv f]

@[to_additive]
theorem conjugate_commutatorElement : gтВГ * тБЕgтВБ, gтВВтБЖ * gтВГтБ╗┬╣ = тБЕgтВГ * gтВБ * gтВГтБ╗┬╣, gтВГ * gтВВ * gтВГтБ╗┬╣тБЖ := by
  simp [mul_assoc, commutatorElement_def]

namespace Subgroup

/-- The commutator of two subgroups `HтВБ` and `HтВВ`. -/
@[to_additive /-- The commutator of two additive subgroups `HтВБ` and `HтВВ`. -/]
instance commutator : Bracket (Subgroup G) (Subgroup G) :=
  тЯиfun HтВБ HтВВ => closure { g | тИГ gтВБ тИИ HтВБ, тИГ gтВВ тИИ HтВВ, тБЕgтВБ, gтВВтБЖ = g }тЯй

@[to_additive]
theorem commutator_def (HтВБ HтВВ : Subgroup G) :
    тБЕHтВБ, HтВВтБЖ = closure { g | тИГ gтВБ тИИ HтВБ, тИГ gтВВ тИИ HтВВ, тБЕgтВБ, gтВВтБЖ = g } :=
  rfl

variable {gтВБ gтВВ gтВГ} {H HтВБ HтВВ HтВГ KтВБ KтВВ : Subgroup G}

@[to_additive]
theorem commutator_mem_commutator (hтВБ : gтВБ тИИ HтВБ) (hтВВ : gтВВ тИИ HтВВ) : тБЕgтВБ, gтВВтБЖ тИИ тБЕHтВБ, HтВВтБЖ :=
  subset_closure тЯиgтВБ, hтВБ, gтВВ, hтВВ, rflтЯй

@[to_additive]
theorem commutator_le : тБЕHтВБ, HтВВтБЖ тЙд HтВГ тЖФ тИА gтВБ тИИ HтВБ, тИА gтВВ тИИ HтВВ, тБЕgтВБ, gтВВтБЖ тИИ HтВГ :=
  HтВГ.closure_le.trans
    тЯиfun h a b c d => h тЯиa, b, c, d, rflтЯй, fun h _g тЯиa, b, c, d, h_eqтЯй => h_eq тЦ╕ h a b c dтЯй

@[to_additive]
theorem commutator_mono (hтВБ : HтВБ тЙд KтВБ) (hтВВ : HтВВ тЙд KтВВ) : тБЕHтВБ, HтВВтБЖ тЙд тБЕKтВБ, KтВВтБЖ :=
  commutator_le.mpr fun _gтВБ hgтВБ _gтВВ hgтВВ => commutator_mem_commutator (hтВБ hgтВБ) (hтВВ hgтВВ)

@[to_additive]
theorem commutator_eq_bot_iff_le_centralizer : тБЕHтВБ, HтВВтБЖ = тКе тЖФ HтВБ тЙд centralizer HтВВ := by
  rw [eq_bot_iff, commutator_le]
  refine forall_congr' fun p =>
    forall_congr' fun _hp => forall_congr' fun q => forall_congr' fun hq => ?_
  rw [mem_bot, commutatorElement_eq_one_iff_mul_comm, eq_comm]

/-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/
@[to_additive /-- **The Three Subgroups Lemma** (via the Hall-Witt identity) -/]
theorem commutator_commutator_eq_bot_of_rotate (h1 : тБЕтБЕHтВВ, HтВГтБЖ, HтВБтБЖ = тКе) (h2 : тБЕтБЕHтВГ, HтВБтБЖ, HтВВтБЖ = тКе) :
    тБЕтБЕHтВБ, HтВВтБЖ, HтВГтБЖ = тКе := by
  simp_rw [commutator_eq_bot_iff_le_centralizer, commutator_le,
    mem_centralizer_iff_commutator_eq_one] at h1 h2 тКв
  intro x hx y hy z hz
  trans x * z * тБЕy, тБЕzтБ╗┬╣, xтБ╗┬╣тБЖтБЖтБ╗┬╣ * zтБ╗┬╣ * y * тБЕxтБ╗┬╣, тБЕyтБ╗┬╣, zтБЖтБЖтБ╗┬╣ * yтБ╗┬╣ * xтБ╗┬╣
  -- We avoid `group` here to minimize imports while low in the hierarchy;
  -- typically it would be better to invoke the tactic.
  ┬╖ simp [commutatorElement_def, mul_assoc]
  ┬╖ rw [h1 _ (HтВВ.inv_mem hy) _ hz _ (HтВБ.inv_mem hx), h2 _ (HтВГ.inv_mem hz) _ (HтВБ.inv_mem hx) _ hy]
    simp [mul_assoc]

variable (HтВБ HтВВ)

@[to_additive]
theorem commutator_comm_le : тБЕHтВБ, HтВВтБЖ тЙд тБЕHтВВ, HтВБтБЖ :=
  commutator_le.mpr fun gтВБ hтВБ gтВВ hтВВ =>
    commutatorElement_inv gтВВ gтВБ тЦ╕ тБЕHтВВ, HтВБтБЖ.inv_mem_iff.mpr (commutator_mem_commutator hтВВ hтВБ)

@[to_additive]
theorem commutator_comm : тБЕHтВБ, HтВВтБЖ = тБЕHтВВ, HтВБтБЖ :=
  le_antisymm (commutator_comm_le HтВБ HтВВ) (commutator_comm_le HтВВ HтВБ)

section Normal

@[to_additive]
instance commutator_normal [hтВБ : HтВБ.Normal] [hтВВ : HтВВ.Normal] : Normal тБЕHтВБ, HтВВтБЖ := by
  let base : Set G := { x | тИГ gтВБ тИИ HтВБ, тИГ gтВВ тИИ HтВВ, тБЕgтВБ, gтВВтБЖ = x }
  change (closure base).Normal
  suffices h_base : base = Group.conjugatesOfSet base by
    rw [h_base]
    exact Subgroup.normalClosure_normal
  refine Set.Subset.antisymm Group.subset_conjugatesOfSet fun a h => ?_
  simp_rw [Group.mem_conjugatesOfSet_iff, isConj_iff] at h
  rcases h with тЯиb, тЯиc, hc, e, he, rflтЯй, d, rflтЯй
  exact тЯи_, hтВБ.conj_mem c hc d, _, hтВВ.conj_mem e he d, (conjugate_commutatorElement c e d).symmтЯй

@[to_additive]
theorem commutator_def' [HтВБ.Normal] [HтВВ.Normal] :
    тБЕHтВБ, HтВВтБЖ = normalClosure { g | тИГ gтВБ тИИ HтВБ, тИГ gтВВ тИИ HтВВ, тБЕgтВБ, gтВВтБЖ = g } :=
  le_antisymm closure_le_normalClosure (normalClosure_le_normal subset_closure)

@[to_additive]
theorem commutator_le_right [h : HтВВ.Normal] : тБЕHтВБ, HтВВтБЖ тЙд HтВВ :=
  commutator_le.mpr fun gтВБ _hтВБ gтВВ hтВВ => HтВВ.mul_mem (h.conj_mem gтВВ hтВВ gтВБ) (HтВВ.inv_mem hтВВ)

@[to_additive]
theorem commutator_le_left [HтВБ.Normal] : тБЕHтВБ, HтВВтБЖ тЙд HтВБ :=
  commutator_comm HтВВ HтВБ тЦ╕ commutator_le_right HтВВ HтВБ

@[to_additive]
theorem commutator_top_left_le_iff : тБЕ(тКд : Subgroup G), HтБЖ тЙд H тЖФ H.Normal := by
  refine тЯиfun hle тЖж тЯиfun h hh g тЖж ?_тЯй, fun h тЖж commutator_le_right тКд HтЯй
  exact (H.mul_mem_cancel_right <| H.inv_mem hh).mp <| commutator_le.mp hle g trivial h hh

@[to_additive]
theorem commutator_top_right_le_iff : тБЕH, тКдтБЖ тЙд H тЖФ H.Normal :=
  commutator_comm H тКд тЦ╕ commutator_top_left_le_iff

@[to_additive (attr := simp)]
theorem commutator_bot_left : тБЕ(тКе : Subgroup G), HтВБтБЖ = тКе :=
  le_bot_iff.mp (commutator_le_left тКе HтВБ)

@[to_additive (attr := simp)]
theorem commutator_bot_right : тБЕHтВБ, тКетБЖ = (тКе : Subgroup G) :=
  le_bot_iff.mp (commutator_le_right HтВБ тКе)

@[to_additive]
theorem commutator_le_inf [Normal HтВБ] [Normal HтВВ] : тБЕHтВБ, HтВВтБЖ тЙд HтВБ тКУ HтВВ :=
  le_inf (commutator_le_left HтВБ HтВВ) (commutator_le_right HтВБ HтВВ)

end Normal

@[to_additive]
theorem map_commutator (f : G тЖТ* G') : map f тБЕHтВБ, HтВВтБЖ = тБЕmap f HтВБ, map f HтВВтБЖ := by
  simp_rw [le_antisymm_iff, map_le_iff_le_comap, commutator_le, mem_comap, map_commutatorElement]
  constructor
  ┬╖ intro p hp q hq
    exact commutator_mem_commutator (mem_map_of_mem _ hp) (mem_map_of_mem _ hq)
  ┬╖ rintro _ тЯиp, hp, rflтЯй _ тЯиq, hq, rflтЯй
    rw [тЖР map_commutatorElement]
    exact mem_map_of_mem _ (commutator_mem_commutator hp hq)

variable {HтВБ HтВВ}

@[to_additive]
theorem commutator_le_map_commutator {f : G тЖТ* G'} {KтВБ KтВВ : Subgroup G'} (hтВБ : KтВБ тЙд HтВБ.map f)
    (hтВВ : KтВВ тЙд HтВВ.map f) : тБЕKтВБ, KтВВтБЖ тЙд тБЕHтВБ, HтВВтБЖ.map f :=
  (commutator_mono hтВБ hтВВ).trans (ge_of_eq (map_commutator HтВБ HтВВ f))

variable (HтВБ HтВВ)

@[to_additive]
instance commutator_characteristic [hтВБ : Characteristic HтВБ] [hтВВ : Characteristic HтВВ] :
    Characteristic тБЕHтВБ, HтВВтБЖ :=
  characteristic_iff_le_map.mpr fun ╧Х =>
    commutator_le_map_commutator (characteristic_iff_le_map.mp hтВБ ╧Х)
      (characteristic_iff_le_map.mp hтВВ ╧Х)

@[to_additive]
theorem commutator_prod_prod (KтВБ KтВВ : Subgroup G') :
    тБЕHтВБ.prod KтВБ, HтВВ.prod KтВВтБЖ = тБЕHтВБ, HтВВтБЖ.prod тБЕKтВБ, KтВВтБЖ := by
  apply le_antisymm
  ┬╖ rw [commutator_le]
    rintro тЯиpтВБ, pтВВтЯй тЯиhpтВБ, hpтВВтЯй тЯиqтВБ, qтВВтЯй тЯиhqтВБ, hqтВВтЯй
    exact тЯиcommutator_mem_commutator hpтВБ hqтВБ, commutator_mem_commutator hpтВВ hqтВВтЯй
  ┬╖ rw [prod_le_iff]
    constructor <;>
      ┬╖ rw [map_commutator]
        apply commutator_mono <;>
          simp [le_prod_iff, map_map, MonoidHom.fst_comp_inl, MonoidHom.snd_comp_inl,
            MonoidHom.fst_comp_inr, MonoidHom.snd_comp_inr]

/-- The commutator of direct product is contained in the direct product of the commutators.

See `commutator_pi_pi_of_finite` for equality given `Fintype ╬╖`.
-/
@[to_additive /-- The commutator of direct product is contained in the direct product of the
commutators. See `commutator_pi_pi_of_finite` for equality given `Fintype ╬╖`. -/]
theorem commutator_pi_pi_le {╬╖ : Type*} {Gs : ╬╖ тЖТ Type*} [тИА i, Group (Gs i)]
    (H K : тИА i, Subgroup (Gs i)) :
    тБЕSubgroup.pi Set.univ H, Subgroup.pi Set.univ KтБЖ тЙд Subgroup.pi Set.univ fun i => тБЕH i, K iтБЖ :=
  commutator_le.mpr fun _p hp _q hq i hi => commutator_mem_commutator (hp i hi) (hq i hi)

end Subgroup

open Subgroup hiding commutator

variable (G)

/-- The set of commutator elements `тБЕgтВБ, gтВВтБЖ` in `G`. -/
@[to_additive /-- The set of additive commutator elements `тБЕgтВБ, gтВВтБЖ` in `G`. -/]
def commutatorSet : Set G :=
  { g | тИГ gтВБ gтВВ : G, тБЕgтВБ, gтВВтБЖ = g }

@[to_additive]
theorem commutatorSet_def : commutatorSet G = { g | тИГ gтВБ gтВВ : G, тБЕgтВБ, gтВВтБЖ = g } :=
  rfl

@[to_additive]
theorem one_mem_commutatorSet : (1 : G) тИИ commutatorSet G :=
  тЯи1, 1, commutatorElement_self 1тЯй

@[to_additive]
instance : Nonempty (commutatorSet G) :=
  тЯитЯи1, one_mem_commutatorSet GтЯйтЯй

variable {G g}

@[to_additive]
theorem mem_commutatorSet_iff : g тИИ commutatorSet G тЖФ тИГ gтВБ gтВВ : G, тБЕgтВБ, gтВВтБЖ = g :=
  Iff.rfl

@[to_additive]
theorem commutator_mem_commutatorSet : тБЕgтВБ, gтВВтБЖ тИИ commutatorSet G :=
  тЯиgтВБ, gтВВ, rflтЯй

variable (G)

/-- The commutator subgroup of a group G is the normal subgroup
  generated by the commutators `[p,q] = p * q * pтБ╗┬╣ * qтБ╗┬╣`. -/
@[to_additive /-- The commutator subgroup of an additive group G is the normal additive subgroup
  generated by the additive commutators `[p,q] = p + q + -p + -q`. -/]
def commutator : Subgroup G := тБЕ(тКд : Subgroup G), тКдтБЖ
deriving Subgroup.Normal, Subgroup.Characteristic

attribute [to_additive] instNormalCommutator
attribute [to_additive] instCharacteristicCommutator

@[to_additive]
lemma commutator_def : commutator G = тБЕ(тКд : Subgroup G), тКдтБЖ :=
  rfl

@[to_additive]
lemma commutator_eq_closure : commutator G = Subgroup.closure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def, commutatorSet]

@[to_additive]
lemma commutator_eq_normalClosure : commutator G = Subgroup.normalClosure (commutatorSet G) := by
  simp [commutator, Subgroup.commutator_def', commutatorSet]

variable {G} in
@[to_additive]
lemma Subgroup.map_subtype_commutator (H : Subgroup G) :
    (_root_.commutator H).map H.subtype = тБЕH, HтБЖ := by
  rw [_root_.commutator_def, map_commutator, тЖР MonoidHom.range_eq_map, H.range_subtype]

variable {G} in
@[to_additive]
lemma Subgroup.commutator_le_self (H : Subgroup G) : тБЕH, HтБЖ тЙд H :=
  H.map_subtype_commutator.symm.trans_le (map_subtype_le _)

@[to_additive]
theorem Subgroup.Normal.of_commutator_le {H : Subgroup G} (h : _root_.commutator G тЙд H) :
    H.Normal :=
  commutator_top_left_le_iff.mp <| commutator_mono le_top le_top |>.trans h

@[to_additive]
theorem commutator_eq_bot_iff_center_eq_top : commutator G = тКе тЖФ Subgroup.center G = тКд := by
  simp [commutator, Subgroup.commutator_eq_bot_iff_le_centralizer]

@[to_additive]
theorem commutator_eq_bot_iff : commutator G = тКе тЖФ IsMulCommutative G := by
  rw [commutator_eq_bot_iff_center_eq_top, center_eq_top_iff]

@[to_additive]
theorem commutator_eq_bot [hG : IsMulCommutative G] : commutator G = тКе :=
  (commutator_eq_bot_iff G).mpr hG

@[to_additive]
lemma commutator_centralizer_commutator_le_center :
    тБЕcentralizer (commutator G : Set G), centralizer (commutator G)тБЖ тЙд Subgroup.center G := by
  rw [тЖР Subgroup.centralizer_univ, тЖР Subgroup.coe_top, тЖР
    Subgroup.commutator_eq_bot_iff_le_centralizer]
  suffices тБЕтБЕтКд, centralizer (commutator G : Set G)тБЖ, centralizer (commutator G : Set G)тБЖ = тКе by
    refine Subgroup.commutator_commutator_eq_bot_of_rotate ?_ this
    rwa [Subgroup.commutator_comm (centralizer (commutator G : Set G))]
  rw [Subgroup.commutator_comm, Subgroup.commutator_eq_bot_iff_le_centralizer]
  exact Set.centralizer_subset (Subgroup.commutator_mono le_top le_top)

/-- If `g` is conjugate to `g ^ 2`, then `g` is a commutator -/
@[to_additive /-- If g is conjugate to `2 тАв g`, then `g` is an additive commutator -/]
lemma mem_commutatorSet_of_isConj_sq {g : G} (hg : IsConj g (g ^ 2)) : g тИИ commutatorSet G := by
  obtain тЯиh, hgтЯй := hg
  use h, g
  rw [commutatorElement_def, hg]
  simp only [IsUnit.mul_inv_cancel_right, Units.isUnit, mul_inv_eq_iff_eq_mul, pow_two]

@[to_additive]
lemma map_commutator_eq {H : Type*} [Group H] (f : G тЖТ* H) :
    (commutator G).map f = тБЕf.range, f.rangeтБЖ := by
  rw [_root_.commutator_def, Subgroup.map_commutator]
  apply congr_argтВВ <;>
  ┬╖ rw [Subgroup.map_eq_range_iff]
    rw [codisjoint_iff, top_sup_eq]

section commutatorRepresentatives

open Subgroup

/-- Representatives `(gтВБ, gтВВ) : G ├Ч G` of commutators `тБЕgтВБ, gтВВтБЖ тИИ G`. -/
@[to_additive /-- Representatives `(gтВБ, gтВВ) : G ├Ч G` of additive commutators `тБЕgтВБ, gтВВтБЖ тИИ G`. -/]
def commutatorRepresentatives : Set (G ├Ч G) :=
  Set.range fun g : commutatorSet G => (g.2.choose, g.2.choose_spec.choose)

/-- Subgroup generated by representatives `gтВБ gтВВ : G` of commutators `тБЕgтВБ, gтВВтБЖ тИИ G`. -/
@[to_additive /-- Additive subgroup generated by representatives `gтВБ gтВВ : G` of additive
commutators `тБЕgтВБ, gтВВтБЖ тИИ G`. -/]
def closureCommutatorRepresentatives : Subgroup G :=
  closure (Prod.fst '' commutatorRepresentatives G тИк Prod.snd '' commutatorRepresentatives G)

@[to_additive]
lemma image_commutatorSet_closureCommutatorRepresentatives :
    (closureCommutatorRepresentatives G).subtype ''
        commutatorSet (closureCommutatorRepresentatives G) =
      commutatorSet G := by
  apply Set.Subset.antisymm
  ┬╖ rintro - тЯи-, тЯиgтВБ, gтВВ, rflтЯй, rflтЯй
    exact тЯиgтВБ, gтВВ, rflтЯй
  ┬╖ exact fun g hg тЖж
      тЯи_, тЯитЯи_, subset_closure <| .inl тЯи_, тЯитЯиg, hgтЯй, rflтЯй, rflтЯйтЯй,
          тЯи_, subset_closure <| .inr тЯи_, тЯитЯиg, hgтЯй, rflтЯй, rflтЯйтЯй, rflтЯй,
        hg.choose_spec.choose_specтЯй

end commutatorRepresentatives

variable {G}

@[to_additive]
theorem Subgroup.Normal.quotient_commutative_iff_commutator_le {N : Subgroup G} [N.Normal] :
    IsMulCommutative (G тз╕ N) тЖФ _root_.commutator G тЙд N := by
  refine тЯиfun hcomm тЖж ?_, fun hGN тЖж тЯитЯиfun x' y' тЖж ?_тЯйтЯйтЯй
  ┬╖ rw [commutator_eq_normalClosure, тЖР Subgroup.normalClosure_subset_iff]
    rintro x тЯиp, q, rflтЯй
    rw [SetLike.mem_coe, тЖР QuotientGroup.eq_one_iff, commutatorElement_def]
    simp only [QuotientGroup.mk_mul, QuotientGroup.mk_inv]
    rw [тЖР commutatorElement_def, commutatorElement_eq_one_iff_mul_comm, mul_comm']
  ┬╖ obtain тЯиx, rflтЯй := QuotientGroup.mk'_surjective N x'
    obtain тЯиy, rflтЯй := QuotientGroup.mk'_surjective N y'
    rw [тЖР commutatorElement_eq_one_iff_mul_comm, тЖР map_commutatorElement, QuotientGroup.mk'_apply,
      QuotientGroup.eq_one_iff]
    apply hGN
    rw [commutator_eq_closure]
    exact Subgroup.subset_closure (commutator_mem_commutatorSet x y)

/-- If `N` is a normal subgroup of `G` and `H` a commutative subgroup such that `H тКФ N = тКд`,
  then `N` contains `commutator G`. -/
@[to_additive /-- If `N` is a normal additive subgroup of `G` and `H` a commutative additive
subgroup such that `H тКФ N = тКд`, then `N` contains `addCommutator G`. -/]
theorem Subgroup.Normal.commutator_le_of_self_sup_commutative_eq_top {N : Subgroup G} [N.Normal]
    {H : Subgroup G} (hHN : N тКФ H = тКд) (hH : IsMulCommutative H) : _root_.commutator G тЙд N := by
  -- It is enough to prove that Q = G тз╕ N is commutative
  apply quotient_commutative_iff_commutator_le.mp
  -- Q is a quotient of H
  let ╧Ж : H тЖТтВЩ* G тз╕ N := MonoidHom.comp (QuotientGroup.mk' N) (Subgroup.subtype H)
  -- It is enough to prove that ╧Ж is surjective
  apply Function.Surjective.mul_comm (f := ╧Ж) _ hH
  -- We have to prove that `MonoidHom.range ╧Ж = тКд`
  have : Subgroup.map (QuotientGroup.mk' N) тКд = тКд := by
    rw [тЖР MonoidHom.range_eq_map, MonoidHom.range_eq_top]
    exact QuotientGroup.mk'_surjective N
  rw [MulHom.coe_coe, тЖР MonoidHom.range_eq_top, MonoidHom.range_eq_map, тЖР Subgroup.map_map, тЖР this,
    Subgroup.map_eq_map_iff, QuotientGroup.ker_mk', sup_comm, тЖР hHN, тЖР MonoidHom.range_eq_map]
  simp
