/-- If `N` is a normal subgroup of `G` and `H` a commutative subgroup such that `H вЉ” N = вЉ¤`,
  then `N` contains `commutator G`. -/
@[to_additive /-- If `N` is a normal additive subgroup of `G` and `H` a commutative additive
subgroup such that `H вЉ” N = вЉ¤`, then `N` contains `addCommutator G`. -/]
theorem Subgroup.Normal.commutator_le_of_self_sup_commutative_eq_top {N : Subgroup G} [N.Normal]
    {H : Subgroup G} (hHN : N вЉ” H = вЉ¤) (hH : IsMulCommutative H) : _root_.commutator G в‰¤ N := by
  -- It is enough to prove that Q = G в§ё N is commutative
