/-
The language of the substitution grammar is exactly the substitution of the languages of the component grammars. This proves that context-free languages are closed under substitution.
-/
theorem ContextFreeGrammar.subst_language_eq {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT] :
    (g.subst f).language = g.language.subst (fun a => (f a).language) := by
      ext w;
      constructor;
      ┬Ě exact?;
      ┬Ě exact?

/-
A language is context-free if it is the language of some context-free grammar.
-/
def IsContextFree {╬▒ : Type u} (L : Language ╬▒) : Prop :=
  Ôłâ g : ContextFreeGrammar ╬▒, g.language = L

/-
Context-free languages are closed under substitution.
-/
theorem IsContextFree.subst {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (L : Language ╬▒) (f : ╬▒ Ôćĺ Language ╬▓)
    (hL : IsContextFree L) (hf : ÔłÇ a, IsContextFree (f a)) :
    IsContextFree (L.subst f) := by
      obtain ÔčĘ g, hg Ôčę := hL
      obtain ÔčĘ F, hF Ôčę : Ôłâ F : ╬▒ Ôćĺ ContextFreeGrammar ╬▓, ÔłÇ a, (F a).language = f a := by
        exact ÔčĘ fun a => Classical.choose ( hf a ), fun a => Classical.choose_spec ( hf a ) Ôčę
      haveI : DecidableEq g.NT := fun a b => Classical.dec (a = b)
      haveI : ÔłÇ a, DecidableEq (F a).NT := fun a x y => Classical.dec (x = y)
      set G := g.subst F
      have hG : G.language = (L.subst f) := by
        rw [ ÔćÉ hg, ÔćÉ funext hF, ContextFreeGrammar.subst_language_eq ]
      exact ÔčĘ G, hG Ôčę

/-
-/
/-! ### Substitution equals concatenation -/
/-
PROBLEM
Show that `Language.subst {[false, true]} f = f false * f true` where `Language.subst` is defined
as `{ u | Ôłâ w Ôłł L, u Ôłł (w.map f).prod }` and `*` on `Language` is `Set.image2 (┬Ě ++ ┬Ě)`.
PROVIDED SOLUTION
If `u Ôłł Language.subst {[false, true]} f`, then the only `w` is `[false, true]`, so
`u Ôłł ([f false, f true]).prod = f false * f true`. Conversely, any `u Ôłł f false * f true`
witnesses `w = [false, true]`.
Key: `List.prod_cons`, `List.prod_nil`, `Language.mul_def`, `Language.one_def`.
-/
theorem Language.subst_pair_eq_mul {╬▓ : Type} (f : Bool Ôćĺ Language ╬▓) :
    Language.subst ({[false, true]} : Language Bool) f = f false * f true := by
      -- To prove equality of sets, we show each set is a subset of the other.
      apply Set.ext
      intro u
      simp [Language.subst, Language.mul_def];
      simp +decide [ List.prod ];
      -- To prove equality of sets, we show each set is a subset of the other. We start with the forward direction.
      apply Iff.intro;
      ┬Ě simp [Language.mul_def, Language.one_def] at *;
        grind;
      ┬Ě -- If there exist $a \in f(\text{false})$ and $b \in f(\text{true})$ such that $a ++ b = u$, then $u$ is in the concatenation of $f(\text{false})$ and $f(\text{true})$, which is exactly what the foldr operation computes.
        intro h
        obtain ÔčĘa, ha, b, hb, habÔčę := h
        use [false, true]
        simp [ha, hb, hab];
        exact ÔčĘ rfl, ÔčĘ a, ha, b, hb, hab Ôčę Ôčę
/-! ### Substitution equals union -/
/-
PROBLEM
Show that `Language.subst {[false], [true]} f = f false + f true`.
Here `+` on `Language` is union (by `Language.add_def`).
PROVIDED SOLUTION
Unfold `Language.subst`. We need `{ u | Ôłâ w Ôłł {[false], [true]}, u Ôłł (w.map f).prod } = f false + f true`.
Case on `w Ôłł {[false], [true]}`: either `w = [false]` giving `u Ôłł [f false].prod = f false`
(since `List.prod [x] = x` in a monoid), or `w = [true]` giving `u Ôłł f true`.
Thus the set is `f false Ôł¬ f true = f false + f true`.
Key: `Language.add_def`, `List.prod_cons`, `List.prod_nil`.
-/
theorem Language.subst_singletons_eq_add {╬▓ : Type} [DecidableEq ╬▓]
(f : Bool Ôćĺ Language ╬▓) :
    Language.subst ({[false], [true]} : Language Bool) f = f false + f true := by
      ext u;
      constructor;
      ┬Ě rintro ÔčĘ w, hw, hu Ôčę;
        rcases hw with ( rfl | rfl ) <;> simp_all +decide [ List.prod ];
        ┬Ě exact Or.inl hu;
        ┬Ě exact Or.inr hu;
      ┬Ě intro hu
        cases' hu with hu_false hu_true;
        ┬Ě use [false]
          constructor
          ┬Ě tauto
          ┬Ě simp only [List.map_cons, List.map_nil, List.prod_cons, List.prod_nil, mul_one]
            exact hu_false
        ┬Ě -- For the case when `u Ôłł f true`, we can use the fact that `[true]` is in the input language and `u` is in `f true`.
          use [true]
          constructor
          ┬Ě tauto
          ┬Ě simp only [List.map_cons, List.map_nil, List.prod_cons, List.prod_nil, mul_one]
            exact hu_true
/-! ### Substitution equals Kleene star -/
/-
PROBLEM
Show that `Language.subst (Set.univ : Language Unit) f = KStar.kstar (f ())`.
Here `Language.subst L f = { u | Ôłâ w Ôłł L, u Ôłł (w.map f).prod }` and
`Language.kstar_def` says `KStar.kstar l = {x | Ôłâ L, x = L.flatten Ôłž ÔłÇ y Ôłł L, y Ôłł l}`.
PROVIDED SOLUTION
(Ôćĺ) Given `w Ôłł Set.univ` of length `n`, every element of `w` is `()`, so `w.map f = List.replicate n (f ())`.
Then `u Ôłł (List.replicate n (f ())).prod = (f ())^n`. Any element of `ÔőâÔéÖ (f ())^n` is in `(f ())*`.
Use `Language.kstar_def` and show that membership in `(f ())^n` means `u` is a concatenation of
strings from `f ()`.
(ÔćÉ) Given `u Ôłł (f ())*`, by `Language.kstar_def`, there exist `sÔéü, ..., sÔéÖ Ôłł f ()` with `u = sÔéü ++ ... ++ sÔéÖ`.
Take `w = List.replicate n ()`. Then `w.map f = List.replicate n (f ())` and
`u Ôłł (List.replicate n (f ())).prod`.
-/
theorem Language.subst_univ_unit_eq_kstar {╬▓ : Type} [DecidableEq ╬▓] (f : Unit Ôćĺ Language ╬▓) :
    Language.subst (Set.univ : Language Unit) f = KStar.kstar (f ()) := by
      ext u; exact ÔčĘby
      rintro ÔčĘ w, hw, hu Ôčę;
      -- By induction on the length of the list `w`, we can show that `u` is in the kstar of `f ()`.
      induction' w with w ih generalizing u;
      ┬Ě exact ÔčĘ [ ], by simpa using hu Ôčę;
      ┬Ě rcases hu with ÔčĘ uÔéü, huÔéü, uÔéé, huÔéé, rfl Ôčę;
        rename_i h;
        obtain ÔčĘ L, hLÔéü, hLÔéé Ôčę := h uÔéé ( Set.mem_univ _ ) huÔéé;
        exact ÔčĘ [ uÔéü ] ++ L, by aesop Ôčę, by
        rintro ÔčĘ L, rfl, hL Ôčę;
        use List.replicate L.length ();
        induction L <;> simp_all +decide [ List.prod ];
        ┬Ě trivial;
        ┬Ě exact ÔčĘ Set.mem_univ _, Set.mem_image2_of_mem hL.1 ( by aesop ) ÔčęÔčę;
/-! ### Helper: no rewrites on terminal-only strings -/
lemma no_rewrites_of_all_terminal {T N : Type} (r : ContextFreeRule T N) (w : List T) (v : List (Symbol T N)) :
    ┬Č r.Rewrites (w.map Symbol.terminal) v := by
  intro h
  rw [ContextFreeRule.rewrites_iff] at h
  obtain ÔčĘp, q, hp, _Ôčę := h
  have : Symbol.nonterminal r.input Ôłł w.map Symbol.terminal := by
    rw [hp]; simp
  simp at this
lemma no_produces_of_all_terminal {T : Type} (g : ContextFreeGrammar T) (w : List T) (v : List (Symbol T g.NT)) :
    ┬Č g.Produces (w.map Symbol.terminal) v := by
  rintro ÔčĘr, _, hrÔčę
  exact no_rewrites_of_all_terminal r w v hr
lemma derives_of_all_terminal {T : Type} (g : ContextFreeGrammar T) (w : List T) (v : List (Symbol T g.NT)) :
    g.Derives (w.map Symbol.terminal) v Ôćĺ v = w.map Symbol.terminal := by
  intro h
  induction h with
  | refl => rfl
  | tail _ h2 ih => subst ih; exact absurd h2 (no_produces_of_all_terminal g w _)
/-! ### Singleton language is context-free -/
/-
PROBLEM
Show that for any word `w`, the singleton language `{w}` is context-free.
PROVIDED SOLUTION
Construct a CFG `g` with nonterminal type `Unit`, initial = `()`, and a single rule
`() Ôćĺ w.map Symbol.terminal`.
Forward (g.language ÔŐć {w}): If `u Ôłł g.language`, then `g.Derives [S] (u.map Symbol.terminal)`.
The only rule has input `()` = S. So the first step gives `[S] Ôćĺ w.map Symbol.terminal`.
Since `w.map Symbol.terminal` is all terminals, `derives_of_all_terminal` shows no further
derivation steps are possible. So `u.map Symbol.terminal = w.map Symbol.terminal`, hence `u = w`.
Backward ({w} ÔŐć g.language): Apply the single rule to get
`[S] Ôćĺ w.map Symbol.terminal`. This is one derivation step, so `w Ôłł g.language`.
Use `no_produces_of_all_terminal` and `derives_of_all_terminal` as helper lemmas.
Use `ContextFreeGrammar.mk Unit () {ÔčĘ(), w.map Symbol.terminalÔčę}`.
-/
/-
PROBLEM
Prove `isContextFree_singleton`.
PROVIDED SOLUTION
Let `g := ContextFreeGrammar.mk Unit () {ÔčĘ(), w.map Symbol.terminalÔčę}`.
We show `g.language = {w}` by `Set.ext`.
Backward (`w Ôłł g.language`): We need `g.Derives [Symbol.nonterminal ()] (w.map Symbol.terminal)`.
Apply `Relation.ReflTransGen.single`. The single step uses `ÔčĘ(), w.map Symbol.terminalÔčę` from the
rules (by `Finset.mem_singleton_self`) with `ContextFreeRule.Rewrites.head []`, converting
`r.output ++ [] = r.output` by `simp`.
Forward (`u Ôłł g.language Ôćĺ u = w`): We have `g.Derives [Symbol.nonterminal ()] (u.map Symbol.terminal)`.
We need to show this forces `u = w`.
First step: any `g.Produces [Symbol.nonterminal ()] v` forces `v = w.map Symbol.terminal`.
Proof: `rintro ÔčĘr, hr, hrwÔčę; simp [singleton_grammar] at hr; subst hr; cases hrw` with
- `head s`: gives `v = w.map Symbol.terminal ++ s`, but `s = []` since `[S]` has length 1.
- `cons x h`: impossible since `[S]` has no preceding element.
Actually: the only rule has `input = ()`. So from `[S]` (length 1 list with S = ()), the only
Rewrite gives `w.map Symbol.terminal ++ []`.
Then: since `v = w.map Symbol.terminal` is all terminals, `derives_of_all_terminal` gives
`u.map Symbol.terminal = w.map Symbol.terminal`, so `u = w` by `List.map_injective_iff` with
`Symbol.terminal.injective` (i.e., `Symbol.terminal_injective`).
-/
theorem isContextFree_singleton {╬▒ : Type} (w : List ╬▒) :
    IsContextFree ({w} : Language ╬▒) := by
  use ContextFreeGrammar.mk Unit () ({ContextFreeRule.mk () (w.map Symbol.terminal)})
  ext u; constructor
  ┬Ě intro hd
    rcases Relation.ReflTransGen.cases_head hd with h | ÔčĘmid, hstep, hrestÔčę
    ┬Ě exfalso
      have : Symbol.nonterminal () Ôłł u.map (Symbol.terminal (N := Unit)) := by rw [ÔćÉ h]; simp
      simp [List.mem_map] at this
    ┬Ě have hmid : mid = w.map Symbol.terminal := by
        obtain ÔčĘr, hr, hrwÔčę := hstep
        have := Finset.mem_singleton.mp hr; subst this
        cases hrw with | head s => simp | cons x h => cases h
      rw [hmid] at hrest
      have heq := derives_of_all_terminal _ w _ hrest
      show u = w
      exact ((Function.Injective.list_map (f := Symbol.terminal (N := Unit))
        (by intro a b hab; simpa using hab)) heq.symm).symm
  ┬Ě intro (hu : u = w)
    subst hu
    exact Relation.ReflTransGen.single ÔčĘÔčĘ(), u.map Symbol.terminalÔčę, Finset.mem_singleton_self _,
      by convert ContextFreeRule.Rewrites.head (r := ContextFreeRule.mk () (u.map Symbol.terminal)) [] using 1; simpÔčę
/-! ### Finite language {[false], [true]} is context-free -/
/-
PROBLEM
Show that `{[false], [true]} : Language Bool` is context-free.
PROVIDED SOLUTION
Construct a CFG `g` with nonterminal type `Unit`, initial = `()`, and two rules:
`() Ôćĺ [Symbol.terminal false]` and `() Ôćĺ [Symbol.terminal true]`.
Forward: If `u Ôłł g.language`, then `g.Derives [S] (u.map Symbol.terminal)`.
Since both rules produce all-terminal strings, after one step we get either
`[Symbol.terminal false]` or `[Symbol.terminal true]`, and no further derivation
is possible (by `no_produces_of_all_terminal`). So `u` is either `[false]` or `[true]`.
Backward: Apply the appropriate rule.
Use `no_produces_of_all_terminal` and `derives_of_all_terminal`.
Use `ContextFreeGrammar.mk Unit () {ÔčĘ(), [Symbol.terminal false]Ôčę, ÔčĘ(), [Symbol.terminal true]Ôčę}`.
-/
/-
PROBLEM
Prove `isContextFree_pair_bool`.
PROVIDED SOLUTION
Let `g := ContextFreeGrammar.mk Unit () {ÔčĘ(), [Symbol.terminal false]Ôčę, ÔčĘ(), [Symbol.terminal true]Ôčę}`.
We show `g.language = {[false], [true]}` by `Set.ext`.
Backward: For `[false]`, apply rule `ÔčĘ(), [Symbol.terminal false]Ôčę` (one step).
  For `[true]`, apply rule `ÔčĘ(), [Symbol.terminal true]Ôčę` (one step).
  Both use `Relation.ReflTransGen.single`, `ContextFreeRule.Rewrites.head []`.
Forward: If `u Ôłł g.language`, then `g.Derives [Symbol.nonterminal ()] (u.map Symbol.terminal)`.
  Any `g.Produces [Symbol.nonterminal ()] v` uses one of the two rules, giving either
  `v = [Symbol.terminal false]` or `v = [Symbol.terminal true]`.
  Proof: `rintro ÔčĘr, hr, hrwÔčę`, then `hr : r Ôłł {rule1, rule2}`, case split.
  In each case, `hrw` has form `Rewrites.head []`, so `v` is determined.
  After one step, `v` is all terminals, so `derives_of_all_terminal` shows
  `u.map Symbol.terminal = v`, hence `u = [false]` or `u = [true]`.
-/
theorem isContextFree_pair_bool :
    IsContextFree ({[false], [true]} : Language Bool) := by
  use ContextFreeGrammar.mk Unit () ({ContextFreeRule.mk () [Symbol.terminal false], ContextFreeRule.mk () [Symbol.terminal true]})
  ext u; constructor
  ┬Ě intro hd
    rcases Relation.ReflTransGen.cases_head hd with h | ÔčĘmid, hstep, hrestÔčę
    ┬Ě exfalso
      have : Symbol.nonterminal () Ôłł u.map (Symbol.terminal (N := Unit)) := by rw [ÔćÉ h]; simp
      simp [List.mem_map] at this
    ┬Ě obtain ÔčĘr, hr, hrwÔčę := hstep
      rcases Finset.mem_insert.mp hr with h1 | h1
      ┬Ě subst h1
        have hmid : mid = [Symbol.terminal false] := by
          cases hrw with | head s => simp | cons x h => cases h
        rw [hmid] at hrest
        have := derives_of_all_terminal _ [false] _ hrest
        show u Ôłł ({[false], [true]} : Set (List Bool))
        left
        exact ((Function.Injective.list_map (f := Symbol.terminal (N := Unit))
          (by intro a b hab; simpa using hab)) this.symm).symm
      ┬Ě have h2 := Finset.mem_singleton.mp h1; subst h2
        have hmid : mid = [Symbol.terminal true] := by
          cases hrw with | head s => simp | cons x h => cases h
        rw [hmid] at hrest
        have := derives_of_all_terminal _ [true] _ hrest
        show u Ôłł ({[false], [true]} : Set (List Bool))
        right
        exact ((Function.Injective.list_map (f := Symbol.terminal (N := Unit))
          (by intro a b hab; simpa using hab)) this.symm).symm
  ┬Ě intro hu
    rcases hu with rfl | rfl
    ┬Ě exact Relation.ReflTransGen.single ÔčĘÔčĘ(), [Symbol.terminal false]Ôčę,
        Finset.mem_insert_self _ _, ContextFreeRule.Rewrites.head []Ôčę
    ┬Ě exact Relation.ReflTransGen.single ÔčĘÔčĘ(), [Symbol.terminal true]Ôčę,
        Finset.mem_insert_of_mem (Finset.mem_singleton_self _),
        ContextFreeRule.Rewrites.head []Ôčę
/-! ### The universal language over Unit is context-free -/
/-
PROBLEM
Show that `Set.univ : Language Unit` (all strings over a single-symbol alphabet) is context-free.
PROVIDED SOLUTION
Construct a grammar `g` with one nonterminal type `Unit`, initial = `()`, and rules:
  `S Ôćĺ ╬Á` (output = [])
  `S Ôćĺ () ┬Ě S` (output = [Symbol.terminal (), Symbol.nonterminal ()])
Forward: trivial since `Set.univ` contains everything.
Backward: given `w : List Unit`, show `g.Generates (w.map Symbol.terminal)` by induction on `w`.
- Base case `w = []`: apply rule `S Ôćĺ ╬Á` to get `[S] Ôćĺ []`. Done.
- Inductive case `w = () :: w'`:
  Apply rule `S Ôćĺ () ┬Ě S` to get `[S] Ôćĺ [terminal (), nonterminal ()]`.
  Then by the induction hypothesis, `nonterminal ()` derives `w'.map Symbol.terminal`.
  So overall `[S] Ôćĺ [terminal ()] ++ w'.map Symbol.terminal = w.map Symbol.terminal`.
For the derivation step, use `ContextFreeGrammar.Produces` and `Relation.ReflTransGen`.
Use `ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}`.
-/
theorem isContextFree_univ_unit : IsContextFree (Set.univ : Language Unit) := by
  -- Let's choose the context-free grammar with the initial symbol `S` and the rules `S Ôćĺ ╬Á` and `S Ôćĺ aS`.
  use ÔčĘUnit, (), {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}Ôčę;
  refine' Set.eq_univ_of_forall _;
  intro x
  induction' x with x ih;
  ┬Ě constructor ; tauto;
    constructor ; tauto;
  ┬Ě rename_i h;
    -- Apply the rule that adds a terminal symbol to the front of the list.
    have h_add_terminal : ÔłÇ (u : List (Symbol Unit Unit)), (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives [Symbol.nonterminal ()] u Ôćĺ (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives [Symbol.nonterminal ()] ([Symbol.terminal ()] ++ u) := by
      intro u hu
      have h_add_terminal : (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives [Symbol.nonterminal ()] ([Symbol.terminal ()] ++ u) := by
        have h_step : (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives [Symbol.nonterminal ()] ([Symbol.terminal (), Symbol.nonterminal ()]) := by
          apply_rules [ Relation.ReflTransGen.single ];
          exact ÔčĘ _, Finset.mem_insert_of_mem ( Finset.mem_singleton_self _ ), by tauto Ôčę
        have h_step : (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives ([Symbol.terminal (), Symbol.nonterminal ()]) ([Symbol.terminal ()] ++ u) := by
          have h_step : ÔłÇ (u v : List (Symbol Unit Unit)), (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives u v Ôćĺ (ContextFreeGrammar.mk Unit () {ÔčĘ(), []Ôčę, ÔčĘ(), [Symbol.terminal (), Symbol.nonterminal ()]Ôčę}).Derives ([Symbol.terminal ()] ++ u) ([Symbol.terminal ()] ++ v) := by
            intros u v huv
            induction' huv with u v huv ih;
            ┬Ě constructor;
            ┬Ě exact .trans ÔÇ╣_ÔÇ║ ( .single <| by
                obtain ÔčĘ r, hr, h Ôčę := ih;
                use r;
                simp_all +decide [ ContextFreeRule.Rewrites ];
                exact ContextFreeRule.Rewrites.cons (Symbol.terminal ()) h );
          exact h_step _ _ hu;
        exact Relation.ReflTransGen.trans ÔÇ╣_ÔÇ║ ÔÇ╣_ÔÇ║;
      exact h_add_terminal;
    convert h_add_terminal _ h using 1
/-! ### Main corollaries -/
/-
PROBLEM
Show: if `LÔéü` and `LÔéé` are context-free, then `LÔéü * LÔéé` is context-free.
PROVIDED SOLUTION
Define `f : Bool Ôćĺ Language ╬▒` by `f false = LÔéü`, `f true = LÔéé`.
The language `{[false, true]}` is context-free by `isContextFree_singleton`.
By `Language.subst_pair_eq_mul`, `Language.subst {[false, true]} f = f false * f true = LÔéü * LÔéé`.
By `IsContextFree.subst`, the result follows.
Use `isContextFree_singleton`, `Language.subst_pair_eq_mul`, `IsContextFree.subst`.
-/
theorem IsContextFree.mul {╬▒ : Type} [DecidableEq ╬▒] {LÔéü LÔéé : Language ╬▒}
    (hÔéü : IsContextFree LÔéü) (hÔéé : IsContextFree LÔéé) :
    IsContextFree (LÔéü * LÔéé) := by
      have h_subst : IsContextFree (Language.subst ({[false, true]} : Language Bool) (fun b => if b then LÔéé else LÔéü)) := by
        apply IsContextFree.subst;
        ┬Ě exact isContextFree_singleton [false, true];
        ┬Ě grind;
      convert h_subst using 1;
      exact Eq.symm ( by simpa using Language.subst_pair_eq_mul ( fun b => if b = true then LÔéé else LÔéü ) )
/-
PROBLEM
Show: if `LÔéü` and `LÔéé` are context-free, then `LÔéü + LÔéé` (= `LÔéü Ôł¬ LÔéé`) is context-free.
PROVIDED SOLUTION
Define `f : Bool Ôćĺ Language ╬▒` by `f false = LÔéü`, `f true = LÔéé`.
The language `{[false], [true]}` is context-free by `isContextFree_pair_bool`.
By `Language.subst_singletons_eq_add`, `Language.subst {[false], [true]} f = f false + f true = LÔéü + LÔéé`.
By `IsContextFree.subst`, the result follows.
Use `isContextFree_pair_bool`, `Language.subst_singletons_eq_add`, `IsContextFree.subst`.
-/
theorem IsContextFree.add {╬▒ : Type} [DecidableEq ╬▒] {LÔéü LÔéé : Language ╬▒}
    (hÔéü : IsContextFree LÔéü) (hÔéé : IsContextFree LÔéé) :
    IsContextFree (LÔéü + LÔéé) := by
      obtain ÔčĘ gÔéü, hgÔéü Ôčę := hÔéü
      obtain ÔčĘ gÔéé, hgÔéé Ôčę := hÔéé
      set f : Bool Ôćĺ Language ╬▒ := fun b => if b then gÔéé.language else gÔéü.language
      have h_subst : IsContextFree (Language.subst ({[false], [true]} : Language Bool) f) := by
        apply_rules [ IsContextFree.subst, isContextFree_pair_bool ];
        exact fun a => by cases a <;> [ exact ÔčĘ gÔéü, rfl Ôčę ; exact ÔčĘ gÔéé, rfl Ôčę ] ;
      exact (by
      convert h_subst using 1;
      rw [ ÔćÉ hgÔéü, ÔćÉ hgÔéé, Language.subst_singletons_eq_add ] ; aesop;)
/-
PROBLEM
Show: if `L` is context-free, then `KStar.kstar L` is context-free.
PROVIDED SOLUTION
Define `f : Unit Ôćĺ Language ╬▒` by `f () = L`.
The language `Set.univ : Language Unit` is context-free by `isContextFree_univ_unit`.
By `Language.subst_univ_unit_eq_kstar`, `Language.subst Set.univ f = KStar.kstar (f ()) = KStar.kstar L`.
By `IsContextFree.subst`, the result follows.
Use `isContextFree_univ_unit`, `Language.subst_univ_unit_eq_kstar`, `IsContextFree.subst`.
