theorem IsContextFree.kstar {╬▒ : Type} [DecidableEq ╬▒] {L : Language ╬▒}
    (h : IsContextFree L) :
    IsContextFree (KStar.kstar L) := by
      convert IsContextFree.subst _ _ _ _;
      convert Language.subst_univ_unit_eq_kstar ( fun _ => L ) |> Eq.symm;
      ┬Ě exact instDecidableEqOfLawfulBEq
      ┬Ě exact instDecidableEqOfLawfulBEq
      ┬Ě exact isContextFree_univ_unit
      ┬Ě exact fun a ÔćŽ ((fun a ÔćŽ h) Ôłś fun a ÔćŽ ╬▒) ╬▒

