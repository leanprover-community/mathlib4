/-
If a context-free grammar derives `w` from `u ++ v`, then `w` can be split into `u' ++ v'` such that `u` derives `u'` and `v` derives `v'`.
-/
lemma ContextFreeGrammar.Derives.split_append {T : Type u} {g : ContextFreeGrammar T}
    (u v w : List (Symbol T g.NT))
    (h : g.Derives (u ++ v) w) :
    Ôłâ u' v', g.Derives u u' Ôłž g.Derives v v' Ôłž w = u' ++ v' := by
      revert h w u v;
      -- By induction on the derivation, we can show that if $u ++ v$ derives $w$, then there exist $u'$ and $v'$ such that $u$ derives $u'$, $v$ derives $v'$, and $w = u' ++ v'$.
      intro u v w h_deriv
      induction h_deriv with
      | refl => exact ÔčĘ u, v, by constructor, by constructor, rfl Ôčę
      | tail _ h_step ih =>
        obtain ÔčĘ u', v', hu', hv', rfl Ôčę := ih;
        -- By the properties of the derivation relation, we can split the derivation into two parts: one for `u'` and one for `v'`.
        rcases ContextFreeGrammar.Produces.split_append u' v' _ h_step with ÔčĘ u'', hu'', rfl Ôčę | ÔčĘ v'', hv'', rfl Ôčę;
        ┬Ě exact ÔčĘ u'', v', hu'.trans ( Relation.ReflTransGen.single hu'' ), hv', rfl Ôčę;
        ┬Ě exact ÔčĘ u', v'', hu', hv'.trans ( Relation.ReflTransGen.single hv'' ), rfl Ôčę ;

/-
If `ProducesF` transforms `u ++ v` to `w`, then the transformation occurs entirely within `u` or entirely within `v`.
-/
lemma ContextFreeGrammar.ProducesF.split_append {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT]
    (u v w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.ProducesF f (u ++ v) w) :
    (Ôłâ u', g.ProducesF f u u' Ôłž w = u' ++ v) ÔłĘ (Ôłâ v', g.ProducesF f v v' Ôłž w = u ++ v') := by
      obtain ÔčĘ r, hr, h Ôčę := h;
      have h_split : Ôłâ u' v', r.Rewrites u u' Ôłž w = u' ++ v ÔłĘ r.Rewrites v v' Ôłž w = u ++ v' := by
        have := ContextFreeRule.Rewrites.split_append r u v w h; aesop;
      rcases h_split with ÔčĘ u', v', h | h Ôčę <;> [ exact Or.inl ÔčĘ u', ÔčĘ r, hr, h.1 Ôčę, h.2 Ôčę ; exact Or.inr ÔčĘ v', ÔčĘ r, hr, h.1 Ôčę, h.2 Ôčę ]

/-
If `DerivesF` transforms `u ++ v` to `w`, then `w` splits into `u'` and `v'` such that `u` derives `u'` and `v` derives `v'` using only F-rules.
-/
lemma ContextFreeGrammar.DerivesF.split_append {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT]
    (u v w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.DerivesF f (u ++ v) w) :
    Ôłâ u' v', g.DerivesF f u u' Ôłž g.DerivesF f v v' Ôłž w = u' ++ v' := by
      induction h with
      | refl => exact ÔčĘ u, v, by constructor, by constructor, rfl Ôčę
      | tail _ h_step ih =>
        obtain ÔčĘu', v', hu', hv', rflÔčę := ih;
        rcases ContextFreeGrammar.ProducesF.split_append g f u' v' _ h_step with ÔčĘ u'', hu'', rfl Ôčę | ÔčĘ v'', hv'', rfl Ôčę;
        ┬Ě exact ÔčĘ u'', v', hu'.trans ( Relation.ReflTransGen.single hu'' ), hv', rfl Ôčę;
        ┬Ě exact ÔčĘ u', v'', hu', hv'.trans ( Relation.ReflTransGen.single hv'' ), rfl Ôčę ;

/-
If `u` derives `w` using F-rules, then `w` can be split into parts corresponding to each symbol in `u`.
-/
lemma ContextFreeGrammar.DerivesF_distrib {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT]
    (u : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) (w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.DerivesF f u w) :
    Ôłâ W, w = W.flatten Ôłž List.ForallÔéé (fun s w' => g.DerivesF f [s] w') u W := by
      revert h;
      induction u generalizing w with
      | nil =>
        intro hw
        use []
        simp [hw];
        induction hw with
        | refl => rfl
        | tail _ h_step _ =>
          obtain ÔčĘ r, hr, h Ôčę := h_step;
          cases h; aesop;
          rename_i h; cases h
      | cons s us ih =>
        intro h
        obtain ÔčĘw1, w2, hw1, hw2, hwÔčę : Ôłâ w1 w2, g.DerivesF f [s] w1 Ôłž g.DerivesF f us w2 Ôłž w = w1 ++ w2 := by
          have := h;
          have := this;
          have := @ContextFreeGrammar.DerivesF.split_append ╬▒ ╬▓ _ _ g _ f _ [s] us w this; aesop;
        obtain ÔčĘ W, rfl, hW Ôčę := ih _ hw2; use w1 :: W; aesop;

/-
If the start symbol of `f a` (lifted) derives a terminal string `w` (lifted) using F-rules, then `w` is in the language of `f a`.
-/
lemma ContextFreeGrammar.DerivesF_terminal_of_lift {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT]
    (a : ╬▒) (w : List ╬▓)
    (h : g.DerivesF f [Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę)] (w.map Symbol.terminal)) :
    w Ôłł (f a).language := by
      convert h using 1;
      constructor;
      ┬Ě exact?;
      ┬Ě intro hw;
        obtain ÔčĘ v, hvÔéü, hvÔéé Ôčę := ContextFreeGrammar.derivesF_unlift g f a [Symbol.nonterminal (f a).initial] (List.map Symbol.terminal w) hw;
        have h_eq : ÔłÇ {l1 l2 : List (Symbol ╬▓ (f a).NT)}, List.map Symbol.terminal w = List.map (g.liftSymbolF f a) l1 Ôćĺ List.map Symbol.terminal w = List.map (g.liftSymbolF f a) l2 Ôćĺ l1 = l2 := by
          intros l1 l2 hl1 hl2;
          have h_eq : List.map (g.liftSymbolF f a) l1 = List.map (g.liftSymbolF f a) l2 := by
            rw [ ÔćÉ hl1, ÔćÉ hl2 ];
          exact List.map_injective_iff.mpr ( ContextFreeGrammar.liftSymbolF_injective g f a ) h_eq;
        contrapose! h_eq;
        use v, List.map Symbol.terminal w;
        simp [hvÔéü];
        exact ÔčĘ hvÔéü.symm, fun h => h_eq <| by simpa [ h ] using hvÔéé Ôčę

/-
If a list of lifted start symbols derives a terminal string using F-rules, then the terminal string is in the product of the languages of the corresponding grammars.
-/
lemma ContextFreeGrammar.mem_subst_of_derivesF {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT]
    (u : List ╬▒) (w : List ╬▓)
    (h : g.DerivesF f (u.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę))) (w.map Symbol.terminal)) :
    w Ôłł (u.map (fun a => (f a).language)).prod := by
      obtain ÔčĘW, hWÔčę : Ôłâ W : List (List ╬▓), w = W.flatten Ôłž List.ForallÔéé (fun w_part a => g.DerivesF f (List.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę)) [a]) (List.map Symbol.terminal w_part)) W u := by
        have := @ContextFreeGrammar.DerivesF_distrib ╬▒ ╬▓ _ _ g _ f _ ( List.map ( fun a => Symbol.nonterminal ( Sum.inr ÔčĘ a, ( f a ).initial Ôčę ) ) u ) ( List.map Symbol.terminal w ) h;
        obtain ÔčĘ W, hWÔéü, hWÔéé Ôčę := this;
        -- Since `W.flatten` consists of terminals, each element of `W` must consist of terminals.
        have hW_terminals : ÔłÇ w' Ôłł W, ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := by
          have hW_terminals : ÔłÇ w' Ôłł W, ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := by
            intro w' hw' s hs
            have h_terminal : s Ôłł List.map Symbol.terminal w := by
              exact hWÔéü.symm ÔľŞ List.mem_flatten.mpr ÔčĘ w', hw', hs Ôčę
            rw [ List.mem_map ] at h_terminal; obtain ÔčĘ b, hb, rfl Ôčę := h_terminal; exact ÔčĘ b, rfl Ôčę ;
          assumption;
        -- Since `W.flatten` consists of terminals, we can replace each element of `W` with its corresponding list of terminals.
        obtain ÔčĘW', hW'Ôčę : Ôłâ W' : List (List ╬▓), W = W'.map (List.map Symbol.terminal) := by
          have hW_terminals : ÔłÇ w' Ôłł W, Ôłâ w'' : List ╬▓, w' = w''.map Symbol.terminal := by
            intro w' hw'
            obtain ÔčĘw'', hw''Ôčę : Ôłâ w'' : List ╬▓, w' = w''.map Symbol.terminal := by
              have hW'' : ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := hW_terminals w' hw'
              have hW'' : ÔłÇ {l : List (Symbol ╬▓ (g.NT ÔŐĽ (a : ╬▒) ├Ś (f a).NT))}, (ÔłÇ s Ôłł l, Ôłâ b : ╬▓, s = Symbol.terminal b) Ôćĺ Ôłâ l' : List ╬▓, l = l'.map Symbol.terminal := by
                intros l hl;
                induction l with
                | nil => simp_all +decide
                | cons hd tl ih_l =>
                  rcases hl hd List.mem_cons_self with ÔčĘ b, rfl Ôčę ; obtain ÔčĘ l', rfl Ôčę := ih_l (by aesop); exact ÔčĘ b :: l', by simp +decide Ôčę ;
              exact hW'' ÔÇ╣_ÔÇ║;
            use w'';
          choose! W' hW' using hW_terminals;
          use List.map W' W;
          refine' List.ext_get _ _ <;> simp +decide [ ÔćÉ hW' ];
        refine' ÔčĘ W', _, _ Ôčę <;> simp_all +decide [ List.map_map ];
        ┬Ě exact List.map_injective_iff.mpr ( by aesop_cat ) ( hWÔéü.trans ( by simp +decide [ List.map_flatten ] ) );
        ┬Ě exact?;
      rw [ hW.1, Language.mem_list_prod_iff_forall2 ];
      refine' ÔčĘ W, rfl, _ Ôčę;
      have hW_lifted : ÔłÇ {w_part : List ╬▓} {a : ╬▒}, g.DerivesF f (List.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę)) [a]) (List.map Symbol.terminal w_part) Ôćĺ w_part Ôłł (f a).language := by
        exact?;
      rw [ List.forallÔéé_iff_get ] at *;
      grind

/-
The language of the substitution grammar is a subset of the substitution of the languages.
-/
theorem ContextFreeGrammar.subst_language_subset_2 {╬▒ ╬▓ : Type} [DecidableEq ╬▒] [DecidableEq ╬▓]
    (g : ContextFreeGrammar ╬▒) [DecidableEq g.NT]
    (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) [ÔłÇ a, DecidableEq (f a).NT] :
    ÔłÇ w, w Ôłł (g.subst f).language Ôćĺ w Ôłł g.language.subst (fun a => (f a).language) := by
      intro w hw;
      obtain ÔčĘ v, hv Ôčę := ContextFreeGrammar.derives_split_G_F g f [Symbol.nonterminal (Sum.inl g.initial)] ( w.map Symbol.terminal ) hw;
      obtain ÔčĘ u, hu Ôčę := ContextFreeGrammar.derivesG_unlift g f [Symbol.nonterminal g.initial] v hv.1;
      -- Since `v` has no `Sum.inl` symbols, `u` must consist only of terminals.
      have hu_terminals : ÔłÇ s Ôłł u, Ôłâ a, s = Symbol.terminal a := by
        have hu_terminals : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
          have hv_no_inl : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
            intro s hs n
            have := hv.2
            have := ContextFreeGrammar.not_mem_inl_of_derivesF g f v ( List.map Symbol.terminal w ) this; aesop;
          exact hv_no_inl;
        apply ContextFreeGrammar.is_terminal_of_lift_no_inl g f u;
        aesop;
      -- Since `u` consists only of terminals, we can write `u` as `u_str.map Symbol.terminal` for some `u_str`.
      obtain ÔčĘ u_str, hu_str Ôčę : Ôłâ u_str : List ╬▒, u = u_str.map Symbol.terminal := by
        have hu_str : ÔłÇ {l : List (Symbol ╬▒ g.NT)}, (ÔłÇ s Ôłł l, Ôłâ a, s = Symbol.terminal a) Ôćĺ Ôłâ u_str : List ╬▒, l = u_str.map Symbol.terminal := by
          intros l hl;
          induction l with
          | nil => exact ÔčĘ [ ], rfl Ôčę
          | cons hd tl ih =>
            obtain ÔčĘ a, rfl Ôčę := hl hd ( by simp +decide ) ; obtain ÔčĘ u_str, hu_str Ôčę := ih fun s hs => hl s ( by simp +decide [ hs ] ) ; exact ÔčĘ a :: u_str, by simp +decide [ hu_str ] Ôčę ;
        exact hu_str hu_terminals;
      -- Since `v = u_str.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę))`, we can apply `mem_subst_of_derivesF` to conclude that `w Ôłł (u_str.map (fun a => (f a).language)).prod`.
      have hw_prod : w Ôłł (u_str.map (fun a => (f a).language)).prod := by
        apply ContextFreeGrammar.mem_subst_of_derivesF g f u_str w;
        aesop;
      exact ÔčĘ u_str, by aesop Ôčę

