  | Sum.inl _ => False
  | Sum.inr _ => True

/-
If a rule rewrites a string lifted from `f a`, its input non-terminal must be of the form `Sum.inr ÔčĘa, nÔčę`.
-/
lemma ContextFreeGrammar.input_eq_of_rewrites_lifted {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (a : ╬▒) (u : List (Symbol ╬▓ (f a).NT)) (r : ContextFreeRule ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))) (v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) (h : r.Rewrites (u.map (g.liftSymbolF f a)) v) : Ôłâ n, r.input = Sum.inr ÔčĘa, nÔčę := by
  apply ContextFreeGrammar.mem_liftSymbolF_nonterminal_iff;
  swap;
  exact u.filter ( fun s => Symbol.nonterminal ( r.input ) = g.liftSymbolF f a s );
  simp +zetaDelta at *;
  have h_nonterminal : ÔłÇ {u v : List (Symbol ╬▓ (g.NT ÔŐĽ (a : ╬▒) ├Ś (f a).NT))}, r.Rewrites u v Ôćĺ Ôłâ x, x Ôłł u Ôłž Symbol.nonterminal r.input = x := by
    intros u v h; induction' h with u v h ih; aesop;
    aesop;
  obtain ÔčĘ x, hxÔéü, hxÔéé Ôčę := h_nonterminal h; use Classical.choose ( List.mem_map.mp hxÔéü ) ; have := Classical.choose_spec ( List.mem_map.mp hxÔéü ) ; aesop;

/-
If a rule in the substitution grammar has an input non-terminal of the form `Sum.inr ÔčĘa, nÔčę`, then it must be a lifted rule from `f a`.
-/
lemma ContextFreeGrammar.rule_of_input_inr {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (r : ContextFreeRule ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))) (hr : r Ôłł (g.subst f).rules)
    (a : ╬▒) (n : (f a).NT) (h_input : r.input = Sum.inr ÔčĘa, nÔčę) :
    Ôłâ r' Ôłł (f a).rules, r.output = r'.output.map (g.liftSymbolF f a) := by
      contrapose! hr;
      unfold ContextFreeGrammar.subst;
      rw [ Finset.mem_union ] ; simp +decide [ h_input, hr, ContextFreeGrammar.subst_rules_g, ContextFreeGrammar.subst_rules_f ] ; aesop;

/-
If a rule `r'` rewrites a mapped string `u.map f` to `v'`, and `r'` is the image of `r` under `f` (where `f` is injective), then `v'` is the image of some `v` such that `r` rewrites `u` to `v`.
-/
lemma ContextFreeRule.Rewrites.map_inv {T N T' N'} (f : Symbol T N Ôćĺ Symbol T' N')
    (hf : Function.Injective f)
    (r : ContextFreeRule T N) (r' : ContextFreeRule T' N')
    (u : List (Symbol T N)) (v' : List (Symbol T' N'))
    (h : r'.Rewrites (u.map f) v')
    (h_input : f (Symbol.nonterminal r.input) = Symbol.nonterminal r'.input)
    (h_output : r'.output = r.output.map f) :
    Ôłâ v, v' = v.map f Ôłž r.Rewrites u v := by
      -- Since `u.map f = x' ++ [Symbol.nonterminal r'.input] ++ y'`, we can split `u` into `x ++ [Symbol.nonterminal r.input] ++ y` where `x' = x.map f` and `y' = y.map f`.
      obtain ÔčĘx, y, hx, hy, hv'Ôčę : Ôłâ x y : List (Symbol T N), u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž v' = List.map f x ++ List.map f r.output ++ List.map f y := by
        obtain ÔčĘx', y', hx', hy', hv'Ôčę : Ôłâ x' y' : List (Symbol T' N'), List.map f u = x' ++ [Symbol.nonterminal r'.input] ++ y' Ôłž v' = x' ++ r'.output ++ y' := by
          exact?;
        obtain ÔčĘx, y, hx, hy, hv'Ôčę : Ôłâ x y : List (Symbol T N), u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž List.map f x = x' Ôłž List.map f y = y' := by
          -- Since `f` is injective, we can split `u` into `x`, `[Symbol.nonterminal r.input]`, and `y` such that `List.map f x = x'` and `List.map f y = y'` by using the fact that `List.map f` is injective.
          have h_split : Ôłâ x y : List (Symbol T N), u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž List.map f x = x' Ôłž List.map f y = y' := by
            have h_split : List.map f u = List.map f (u.take (List.length x')) ++ [Symbol.nonterminal r'.input] ++ List.map f (u.drop (List.length x' + 1)) := by
              convert hx' using 1;
              rw [ ÔćÉ List.take_append_drop ( List.length x' + 1 ) u, List.map_append ] at * ; aesop
            refine' ÔčĘ List.take x'.length u, List.drop ( x'.length + 1 ) u, _, _, _ Ôčę;
            ┬Ě refine' List.map_injective_iff.mpr hf _;
              grind;
            ┬Ě have h_split : List.take (List.length x') (List.map f u) = List.map f (List.take x'.length u) := by
                rw [ List.map_take ];
              rw [ ÔćÉ h_split, hx', List.take_append_of_le_length ] <;> simp +decide;
            ┬Ě replace h_split := congr_arg ( fun z => z.drop ( x'.length + 1 ) ) h_split ; simp_all +decide [ List.drop_append ] ;
          exact h_split;
        aesop;
      use x ++ r.output ++ y;
      exact ÔčĘ by simp +decide, by rw [ hx ] ; exact? Ôčę

/-
The function `liftSymbolF` is injective.
-/
lemma ContextFreeGrammar.liftSymbolF_injective {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (a : ╬▒) :
    Function.Injective (g.liftSymbolF f a) := by
      -- To prove injectivity, we consider the cases where the input is a non-terminal or a terminal.
      intro x y hxy
      cases x <;> cases y <;> simp +decide [ ContextFreeGrammar.liftSymbolF ] at hxy ÔŐó;
      ┬Ě exact hxy;
      ┬Ě exact hxy

/-
If the substitution grammar produces `v'` from a string of symbols lifted from `f a`, then `v'` must be the lifting of some `v` produced by `f a` from the original string.
-/
lemma ContextFreeGrammar.produces_lift_f_inv {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (a : ╬▒)
    (u : List (Symbol ╬▓ (f a).NT)) (v' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : (g.subst f).Produces (u.map (g.liftSymbolF f a)) v') :
    Ôłâ v, v' = v.map (g.liftSymbolF f a) Ôłž (f a).Produces u v := by
      revert h;
      -- By definition of `Produces`, if `(g.subst f).Produces (u.map (g.liftSymbolF f a)) v'`, then there exists a sequence of rewrites leading from `u.map (g.liftSymbolF f a)` to `v'`.
      intro hv'
      obtain ÔčĘr, hrÔčę : Ôłâ r : ContextFreeRule ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)), r Ôłł (g.subst f).rules Ôłž r.Rewrites (u.map (g.liftSymbolF f a)) v' := by
        cases hv' ; aesop;
      obtain ÔčĘn, hnÔčę : Ôłâ n : (f a).NT, r.input = Sum.inr ÔčĘa, nÔčę := by
        apply ContextFreeGrammar.input_eq_of_rewrites_lifted g f a u r v' hr.2;
      obtain ÔčĘr', hr', hr''Ôčę : Ôłâ r' Ôłł (f a).rules, r.output = r'.output.map (g.liftSymbolF f a) Ôłž r'.input = n := by
        have h_rule_in_f : r Ôłł g.subst_rules_f f := by
          have h_rule_in_f : r Ôłł g.subst_rules_f f Ôł¬ g.subst_rules_g f := by
            convert hr.1 using 1;
            exact Finset.union_comm _ _;
          unfold ContextFreeGrammar.subst_rules_g at h_rule_in_f; aesop;
        unfold ContextFreeGrammar.subst_rules_f at h_rule_in_f; simp_all +decide ;
        obtain ÔčĘ a', ha', r', hr', rfl Ôčę := h_rule_in_f;
        cases hn ; tauto;
      obtain ÔčĘv, hvÔčę : Ôłâ v : List (Symbol ╬▓ (f a).NT), v' = v.map (g.liftSymbolF f a) Ôłž r'.Rewrites u v := by
        apply ContextFreeRule.Rewrites.map_inv (g.liftSymbolF f a) (ContextFreeGrammar.liftSymbolF_injective g f a) r' r u v' hr.2 (by
        aesop) (by
        exact hr''.1);
      exact ÔčĘ v, hv.1, by exact ÔčĘ r', hr', hv.2 Ôčę Ôčę

/-
If the substitution grammar derives a string of lifted symbols from another string of lifted symbols (where the lifting is for a specific component grammar `f a`), then the component grammar `f a` derives the corresponding unlifted string.
-/
lemma ContextFreeGrammar.derives_of_subst_derives_f {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (a : ╬▒) (u v : List (Symbol ╬▓ (f a).NT)) :
    (g.subst f).Derives (u.map (g.liftSymbolF f a)) (v.map (g.liftSymbolF f a)) Ôćĺ (f a).Derives u v := by
      intro h;
      have h_ind : ÔłÇ w' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))), (g.subst f).Derives (u.map (g.liftSymbolF f a)) w' Ôćĺ Ôłâ w : List (Symbol ╬▓ (f a).NT), w' = w.map (g.liftSymbolF f a) Ôłž (f a).Derives u w := by
        intro w' hw';
        induction' hw' with w' hw' ih;
        ┬Ě exact ÔčĘ u, rfl, by constructor Ôčę;
        ┬Ě obtain ÔčĘ w, rfl, hw Ôčę := ÔÇ╣Ôłâ w, w' = List.map ( g.liftSymbolF f a ) w Ôłž ( f a ).Derives u wÔÇ║;
          obtain ÔčĘ w', rfl, hw' Ôčę := ContextFreeGrammar.produces_lift_f_inv g f a w _ ÔÇ╣_ÔÇ║;
          exact ÔčĘ w', rfl, hw.trans ( Relation.ReflTransGen.single hw' ) Ôčę;
      obtain ÔčĘ w, hwÔéü, hwÔéé Ôčę := h_ind _ h;
      convert hwÔéé using 1;
      exact List.map_injective_iff.mpr ( ContextFreeGrammar.liftSymbolF_injective g f a ) hwÔéü

/-
Definitions of single-step productions using only G-rules or only F-rules.
-/
def ContextFreeGrammar.ProducesG {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) : Prop :=
  Ôłâ r Ôłł g.subst_rules_g f, r.Rewrites u v

def ContextFreeGrammar.ProducesF {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) : Prop :=
  Ôłâ r Ôłł g.subst_rules_f f, r.Rewrites u v

/-
The output of an F-rule does not contain any non-terminals from G (i.e., `Sum.inl` symbols).
-/
lemma ContextFreeGrammar.is_F_rule_output_no_inl {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (r : ContextFreeRule ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))) (hr : r Ôłł (g.subst f).rules) :
    g.is_F_rule f r Ôćĺ ÔłÇ s Ôłł r.output, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
      intro hr' s hs n hn; simp_all +decide [ ContextFreeGrammar.is_F_rule ] ;
      unfold ContextFreeGrammar.subst at hr; simp_all +decide [ Finset.mem_union ] ;
      rcases hr with ( hr | hr ) <;> simp_all +decide [ ContextFreeGrammar.subst_rules_g, ContextFreeGrammar.subst_rules_f ];
      ┬Ě grind +ring;
      ┬Ě rcases hr with ÔčĘ a, ha, r', hr', rfl Ôčę ; simp_all +decide [ List.mem_map ] ;
        rcases hs with ÔčĘ s, hs, hs' Ôčę ; cases s <;> cases hs' ;

/-
Definitions of derivations using only G-rules or only F-rules.
-/
def ContextFreeGrammar.DerivesG {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) : Prop :=
  Relation.ReflTransGen (g.ProducesG f) u v

def ContextFreeGrammar.DerivesF {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) : Prop :=
  Relation.ReflTransGen (g.ProducesF f) u v

/-
If a list can be split as `x ++ mid ++ y` and also as `x' ++ [a] ++ y'`, and `a` is not in `mid`, then the two splits are disjoint (one is strictly before or after the other).
-/
lemma List.split_commute_of_not_mem {╬▒ : Type} (x y x' y' : List ╬▒) (mid : List ╬▒) (a : ╬▒)
    (h : x ++ mid ++ y = x' ++ [a] ++ y')
    (h_not_mem : a Ôłë mid) :
    (Ôłâ z, x' = x ++ mid ++ z Ôłž y = z ++ [a] ++ y') ÔłĘ (Ôłâ z, x = x' ++ [a] ++ z Ôłž y' = z ++ mid ++ y) := by
      revert x y x' y' mid a h h_not_mem;
      intros x y x' y' mid a h1 h2; induction' x with x x ih generalizing y x' y' mid a <;> simp_all +decide [ List.append_assoc ] ;
      ┬Ě cases' List.append_eq_append_iff.mp h1 with h h ; aesop ( simp_config := { singlePass := true } ) ;
        rcases h with ÔčĘ bs, rfl, h Ôčę ; rcases bs with ( _ | ÔčĘ b, bs Ôčę ) <;> simp_all +decide [ List.append_assoc ] ;
      ┬Ě rcases x' with ( _ | ÔčĘ b, x' Ôčę ) <;> simp_all +decide [ List.append_assoc ]

#print ContextFreeRule.Rewrites

/-
If `r1` rewrites `u` to `v` and `r2` rewrites `v` to `w`, and the input symbol of `r2` does not appear in the output of `r1`, then `r2` can be applied to `u` first, followed by `r1`, to reach the same `w`.
-/
lemma ContextFreeRule.Rewrites.commute_of_not_mem_output {T N : Type}
    (r1 r2 : ContextFreeRule T N)
    (u v w : List (Symbol T N))
    (h1 : r1.Rewrites u v)
    (h2 : r2.Rewrites v w)
    (h_disjoint : Symbol.nonterminal r2.input Ôłë r1.output) :
    Ôłâ v', r2.Rewrites u v' Ôłž r1.Rewrites v' w := by
      revert h1 h2 h_disjoint;
      intro h1 h2 h3;
      rw [ ContextFreeRule.rewrites_iff ] at *;
      -- Apply `List.split_commute_of_not_mem` to this equality with `mid = r1.output` and `a = Symbol.nonterminal r2.input`.
      obtain ÔčĘp1, q1, hp1, hv1Ôčę := h1
      obtain ÔčĘp2, q2, hp2, hw2Ôčę := h2
      have h_split : Ôłâ z, p2 = p1 ++ r1.output ++ z Ôłž q1 = z ++ [Symbol.nonterminal r2.input] ++ q2 ÔłĘ p1 = p2 ++ [Symbol.nonterminal r2.input] ++ z Ôłž q2 = z ++ r1.output ++ q1 := by
        have h_split : p1 ++ r1.output ++ q1 = p2 ++ [Symbol.nonterminal r2.input] ++ q2 := by
          rw [ ÔćÉ hv1, hp2 ];
        have := List.split_commute_of_not_mem p1 q1 p2 q2 r1.output ( Symbol.nonterminal r2.input ) h_split h3; aesop;
      rcases h_split with ÔčĘ z, h | h Ôčę <;> simp_all +decide [ ContextFreeRule.rewrites_iff ];
      ┬Ě grind;
      ┬Ě exact ÔčĘ p2, z ++ Symbol.nonterminal r1.input :: q1, rfl, p2 ++ r2.output ++ z, q1, by simp [List.append_assoc], by simp [List.append_assoc] Ôčę

/-
If a derivation step using an F-rule is followed by a step using a G-rule, they can be swapped to perform the G-rule first.
-/
lemma ContextFreeGrammar.produces_F_commutes_G {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h_F : g.ProducesF f u v)
    (h_G : g.ProducesG f v w) :
    Ôłâ v', g.ProducesG f u v' Ôłž g.ProducesF f v' w := by
      obtain ÔčĘ rF, hrF, hv Ôčę := h_F
      obtain ÔčĘ rG, hrG, hw Ôčę := h_G
      have h_comm : Symbol.nonterminal rG.input Ôłë rF.output := by
        obtain ÔčĘ a, ha, hrF Ôčę := Finset.mem_biUnion.mp hrF;
        obtain ÔčĘ rF', hrF', hrF Ôčę := Finset.mem_map.mp hrF;
        obtain ÔčĘ rG', hrG', hrG Ôčę := Finset.mem_map.mp hrG;
        rw [ ÔćÉ hrG, ÔćÉ hrF ];
        simp +decide [ List.mem_map ];
        intro x hx; cases x <;> simp +decide ;
      obtain ÔčĘ v', hv', hw' Ôčę := ContextFreeRule.Rewrites.commute_of_not_mem_output rF rG u v w hv hw h_comm;
      exact ÔčĘ v', ÔčĘ rG, hrG, hv' Ôčę, ÔčĘ rF, hrF, hw' Ôčę Ôčę

#print ContextFreeGrammar.Derives.distrib_prod

/-
If we have an F-production followed by a sequence of G-productions, we can move the F-production to the end of the sequence.
-/
lemma ContextFreeGrammar.producesF_derivesG_commute {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h_F : g.ProducesF f u v)
    (h_G : g.DerivesG f v w) :
    Ôłâ v', g.DerivesG f u v' Ôłž g.ProducesF f v' w := by
      induction' h_G with v w h_G ih;
      ┬Ě exact ÔčĘ u, by tauto, by tauto Ôčę;
      ┬Ě rcases ÔÇ╣_ÔÇ║ with ÔčĘ v', hvÔéü, hvÔéé Ôčę;
        have := ContextFreeGrammar.produces_F_commutes_G g f v' v w hvÔéé ih;
        obtain ÔčĘ v'', hvÔéâ, hvÔéä Ôčę := this; exact ÔčĘ v'', hvÔéü.tail hvÔéâ, hvÔéä Ôčę ;

/-
If we have a sequence of F-productions followed by a sequence of G-productions, we can move all F-productions to the end.
-/
lemma ContextFreeGrammar.derivesF_derivesG_commute {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h_F : g.DerivesF f u v)
    (h_G : g.DerivesG f v w) :
    Ôłâ v', g.DerivesG f u v' Ôłž g.DerivesF f v' w := by
      induction' h_F with u v h_F ih generalizing w;
      ┬Ě exact ÔčĘ w, h_G, by exact Relation.ReflTransGen.refl Ôčę;
      ┬Ě obtain ÔčĘ v', hv' Ôčę := ContextFreeGrammar.producesF_derivesG_commute g f u v w ih h_G;
        exact Exists.elim ( ÔÇ╣ÔłÇ w, g.DerivesG f u w Ôćĺ Ôłâ v', g.DerivesG f _ v' Ôłž g.DerivesF f v' wÔÇ║ v' hv'.1 ) fun x hx => ÔčĘ x, hx.1, hx.2.trans ( Relation.ReflTransGen.single hv'.2 ) Ôčę

/-
A production in the substitution grammar is either a G-production or an F-production.
-/
lemma ContextFreeGrammar.produces_subst_iff {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT)))) :
    (g.subst f).Produces u v Ôćö g.ProducesG f u v ÔłĘ g.ProducesF f u v := by
      constructor <;> intro h;
      ┬Ě unfold ContextFreeGrammar.ProducesG ContextFreeGrammar.ProducesF at *;
        obtain ÔčĘ r, hr, h Ôčę := h;
        unfold ContextFreeGrammar.subst at hr; aesop;
      ┬Ě cases' h with h h;
        ┬Ě obtain ÔčĘ r, hr, h Ôčę := h; exact ÔčĘ r, by simp [ContextFreeGrammar.subst]; exact Finset.mem_union_left _ hr, h Ôčę
        ┬Ě obtain ÔčĘ r, hr, h Ôčę := h; exact ÔčĘ r, by simp [ContextFreeGrammar.subst]; exact Finset.mem_union_right _ hr, h Ôčę

/-
Any derivation in the substitution grammar can be rearranged into a sequence of G-rules followed by a sequence of F-rules.
-/
lemma ContextFreeGrammar.derives_split_G_F {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u w : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : (g.subst f).Derives u w) :
    Ôłâ v, g.DerivesG f u v Ôłž g.DerivesF f v w := by
      revert h;
      -- Let's unfold the definitions of `Derives` and `DerivesG`.
      intro h
      induction' h using Relation.ReflTransGen.head_induction_on with u w h h ih;
      ┬Ě exact ÔčĘ w, by constructor, by constructor Ôčę;
      ┬Ě rename_i h';
        obtain ÔčĘ v, hvÔéü, hvÔéé Ôčę := ih;
        by_cases h_case : g.ProducesG f u w;
        ┬Ě exact ÔčĘ v, Relation.ReflTransGen.single h_case |> Relation.ReflTransGen.trans <| hvÔéü, hvÔéé Ôčę;
        ┬Ě obtain ÔčĘ v', hv'Ôéü, hv'Ôéé Ôčę := ContextFreeGrammar.derivesF_derivesG_commute g f u w v (by
          exact Relation.ReflTransGen.single ( by rw [ ContextFreeGrammar.produces_subst_iff ] at h'; aesop )) hvÔéü;
          exact ÔčĘ v', hv'Ôéü, hv'Ôéé.trans hvÔéé Ôčę

/-
If `g` derives `v` from `u`, then the substitution grammar derives the lifted version of `v` from the lifted version of `u` using only G-rules.
-/
lemma ContextFreeGrammar.derivesG_of_derives {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    {u v : List (Symbol ╬▒ g.NT)} (h : g.Derives u v) :
    g.DerivesG f (u.map (g.liftSymbolG f)) (v.map (g.liftSymbolG f)) := by
      induction h;
      ┬Ě constructor;
      ┬Ě rename_i hÔéü hÔéé hÔéâ;
        obtain ÔčĘ r, hr, h Ôčę := hÔéé;
        refine' hÔéâ.trans ( Relation.ReflTransGen.single _ );
        refine' ÔčĘ _, _, _ Ôčę;
        exact ÔčĘ Sum.inl r.input, r.output.map ( g.liftSymbolG f ) Ôčę;
        ┬Ě exact Finset.mem_map.mpr ÔčĘ r, hr, rfl Ôčę;
        ┬Ě convert ContextFreeRule.Rewrites.map _ _ _ _ _ h _ _ using 1;
          ┬Ě rfl;
          ┬Ě rfl

/-
If `f a` produces `v` from `u`, then the substitution grammar produces the lifted version of `v` from the lifted version of `u` using an F-rule.
-/
lemma ContextFreeGrammar.producesF_lift_f {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (a : ╬▒) (ha : a Ôłł g.usedTerminals)
    {u v : List (Symbol ╬▓ (f a).NT)} (h : (f a).Produces u v) :
    g.ProducesF f (u.map (g.liftSymbolF f a)) (v.map (g.liftSymbolF f a)) := by
      obtain ÔčĘ r, hr, h Ôčę := h;
      refine' ÔčĘ _, _, _ Ôčę;
      exact ÔčĘ Sum.inr ÔčĘ a, r.input Ôčę, r.output.map ( g.liftSymbolF f a ) Ôčę;
      ┬Ě unfold ContextFreeGrammar.subst_rules_f; aesop;
      ┬Ě apply_rules [ ContextFreeRule.Rewrites.map ]

/-
If `f a` derives `v` from `u`, then the substitution grammar derives the lifted version of `v` from the lifted version of `u` using only F-rules.
-/
lemma ContextFreeGrammar.derivesF_lift_f {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (a : ╬▒) (ha : a Ôłł g.usedTerminals)
    {u v : List (Symbol ╬▓ (f a).NT)} (h : (f a).Derives u v) :
    g.DerivesF f (u.map (g.liftSymbolF f a)) (v.map (g.liftSymbolF f a)) := by
      induction' h with u v h ih;
      ┬Ě constructor;
      ┬Ě exact Relation.ReflTransGen.tail ÔÇ╣_ÔÇ║ ( by exact? )

/-
If the substitution grammar produces `v'` from the lifted version of `u` using a G-rule, then `v'` is the lifted version of some `v` produced by `g` from `u`.
-/
lemma ContextFreeGrammar.producesG_unlift {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u : List (Symbol ╬▒ g.NT)) (v' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.ProducesG f (u.map (g.liftSymbolG f)) v') :
    Ôłâ v, v' = v.map (g.liftSymbolG f) Ôłž g.Produces u v := by
      obtain ÔčĘ r, hr, h Ôčę := h;
      unfold ContextFreeGrammar.subst_rules_g at hr; simp_all +decide [ Finset.mem_map ] ;
      rcases hr with ÔčĘ r, hr, rfl Ôčę;
      -- By definition of `Rewrites`, there exists a list `v` such that `v' = v.map (g.liftSymbolG f)` and `u` is rewritten to `v` by `r`.
      obtain ÔčĘv, hvÔčę : Ôłâ v, v' = v.map (g.liftSymbolG f) Ôłž r.Rewrites u v := by
        apply_rules [ ContextFreeRule.Rewrites.map_inv ];
        intro x y; cases x <;> cases y <;> simp +decide [ ContextFreeGrammar.liftSymbolG ] ;
        tauto;
      exact ÔčĘ v, hv.1, ÔčĘ r, hr, hv.2 Ôčę Ôčę

/-
If the substitution grammar derives `v'` from the lifted version of `u` using only G-rules, then `v'` is the lifted version of some `v` derived by `g` from `u`.
-/
lemma ContextFreeGrammar.derivesG_unlift {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u : List (Symbol ╬▒ g.NT)) (v' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.DerivesG f (u.map (g.liftSymbolG f)) v') :
    Ôłâ v, v' = v.map (g.liftSymbolG f) Ôłž g.Derives u v := by
      induction' h with u v w huv hw ih;
      ┬Ě exact ÔčĘ u, rfl, by rfl Ôčę;
      ┬Ě obtain ÔčĘ v, rfl, hv Ôčę := hw;
        obtain ÔčĘ v', rfl, hv' Ôčę := ContextFreeGrammar.producesG_unlift g f v _ huv;
        exact ÔčĘ v', rfl, hv.trans ( Relation.ReflTransGen.single hv' ) Ôčę

/-
If the lifted string has no `Sum.inl` non-terminals, then the original string consists only of terminals.
-/
lemma ContextFreeGrammar.is_terminal_of_lift_no_inl {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u : List (Symbol ╬▒ g.NT))
    (h : ÔłÇ s Ôłł u.map (g.liftSymbolG f), ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n)) :
    ÔłÇ s Ôłł u, Ôłâ a, s = Symbol.terminal a := by
      contrapose! h;
      rcases h with ÔčĘ s, hs, hs' Ôčę ; cases s <;> aesop;

/-
If the substitution grammar produces `v'` from the lifted version of `u` using an F-rule, and `u` belongs to component `a`, then `v'` is the lifted version of some `v` produced by `f a` from `u`.
-/
lemma ContextFreeGrammar.producesF_unlift {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (a : ╬▒) (u : List (Symbol ╬▓ (f a).NT)) (v' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.ProducesF f (u.map (g.liftSymbolF f a)) v') :
    Ôłâ v, v' = v.map (g.liftSymbolF f a) Ôłž (f a).Produces u v := by
      have := @ContextFreeGrammar.produces_lift_f_inv;
      contrapose! this;
      use ╬▒, ╬▓, g, f, a, u, v';
      refine' ÔčĘ _, this Ôčę;
      -- Since h is a producesF step, it is also a produces step in the substitution grammar.
      apply (ContextFreeGrammar.produces_subst_iff g f (List.map (g.liftSymbolF f a) u) v').mpr;
      exact Or.inr h

/-
If the substitution grammar derives `v'` from the lifted version of `u` using only F-rules, and `u` belongs to component `a`, then `v'` is the lifted version of some `v` derived by `f a` from `u`.
-/
lemma ContextFreeGrammar.derivesF_unlift {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (a : ╬▒) (u : List (Symbol ╬▓ (f a).NT)) (v' : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.DerivesF f (u.map (g.liftSymbolF f a)) v') :
    Ôłâ v, v' = v.map (g.liftSymbolF f a) Ôłž (f a).Derives u v := by
      revert h v';
      intro v' hv';
      -- Apply induction on the derivation `hv'`.
      induction' hv' with u v' hv' ih;
      ┬Ě exact ÔčĘ u, rfl, by rfl Ôčę;
      ┬Ě obtain ÔčĘ v, rfl, hv Ôčę := ÔÇ╣_ÔÇ║;
        obtain ÔčĘ w, rfl, hw Ôčę := ContextFreeGrammar.producesF_unlift g f a v v' ih;
        exact ÔčĘ w, rfl, hv.trans ( Relation.ReflTransGen.single hw ) Ôčę

#check ContextFreeGrammar.subst_language_subset_1

/-
If an F-production results in a string with no `Sum.inl` non-terminals, then the input string also had no `Sum.inl` non-terminals.
-/
lemma ContextFreeGrammar.not_mem_inl_of_producesF {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.ProducesF f u v)
    (h_no_inl : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n)) :
    ÔłÇ s Ôłł u, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
      obtain ÔčĘr, hrÔčę := h;
      obtain ÔčĘx, y, hx, hyÔčę : Ôłâ x y, u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž v = x ++ r.output ++ y := by
        obtain ÔčĘx, y, hx, hyÔčę : Ôłâ x y, u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž v = x ++ r.output ++ y := by
          have h_rewrite : r.Rewrites u v := hr.right
          obtain ÔčĘx, y, hx, hyÔčę : Ôłâ x y, u = x ++ [Symbol.nonterminal r.input] ++ y Ôłž v = x ++ r.output ++ y := by
            have h_rewrite : r.Rewrites u v := h_rewrite
            exact?;
          use x, y;
        use x, y;
      cases h : r.input <;> simp_all +decide;
      ┬Ě unfold ContextFreeGrammar.subst_rules_f at hr; aesop;
      ┬Ě grind +ring

/-
The substitution of the languages is a subset of the language of the substitution grammar.
-/
theorem ContextFreeGrammar.subst_language_subset_1' {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) :
    ÔłÇ w, w Ôłł g.language.subst (fun a => (f a).language) Ôćĺ w Ôłł (g.subst f).language := by
      apply_rules [ ContextFreeGrammar.subst_language_subset_1 ]

/-
If an F-derivation results in a string with no `Sum.inl` non-terminals, then the input string also had no `Sum.inl` non-terminals.
-/
lemma ContextFreeGrammar.not_mem_inl_of_derivesF {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u v : List (Symbol ╬▓ (g.NT ÔŐĽ (╬ú a, (f a).NT))))
    (h : g.DerivesF f u v)
    (h_no_inl : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n)) :
    ÔłÇ s Ôłł u, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
      induction' h with u v h ih;
      ┬Ě assumption;
      ┬Ě apply_rules [ ContextFreeGrammar.not_mem_inl_of_producesF ]

/-
If a rule rewrites a concatenation `u ++ v`, the rewrite must occur entirely within `u` or entirely within `v`.
-/
lemma ContextFreeRule.Rewrites.split_append {T N : Type} (r : ContextFreeRule T N)
    (u v w : List (Symbol T N))
    (h : r.Rewrites (u ++ v) w) :
    (Ôłâ u', r.Rewrites u u' Ôłž w = u' ++ v) ÔłĘ (Ôłâ v', r.Rewrites v v' Ôłž w = u ++ v') := by
      -- By definition of Rewrites, if r.Rewrites (u ++ v) w, then there exists some s such that u ++ v = s ++ [n] ++ t, and w = s ++ r.output ++ t.
      obtain ÔčĘs, t, hs, htÔčę : Ôłâ s t : List (Symbol T N), u ++ v = s ++ [Symbol.nonterminal r.input] ++ t Ôłž w = s ++ r.output ++ t := by
        exact?;
      by_cases h_cases : s.length < u.length;
      ┬Ě -- Since $s$ is a prefix of $u$, we can split $u$ into $s$ and some $u'$.
        obtain ÔčĘu', hu'Ôčę : Ôłâ u' : List (Symbol T N), u = s ++ [Symbol.nonterminal r.input] ++ u' := by
          rw [ List.append_eq_append_iff ] at hs;
          rcases hs with ( ÔčĘ as, hs, ht Ôčę | ÔčĘ bs, rfl, ht Ôčę ) <;> simp_all +decide [ List.append_assoc ];
          replace hs := congr_arg List.length hs ; simp_all +arith +decide;
          cases as <;> simp_all +arith +decide;
        exact Or.inl ÔčĘ s ++ r.output ++ u', by
          rw [ ContextFreeRule.rewrites_iff ];
          exact ÔčĘ s, u', hu', rfl Ôčę, by
          aesop Ôčę;
      ┬Ě -- Since $s.length \geq u.length$, we have $s = u ++ s'$ for some $s'$.
        obtain ÔčĘs', hs'Ôčę : Ôłâ s', s = u ++ s' := by
          simp +zetaDelta at *;
          rw [ List.append_eq_append_iff ] at hs ; aesop;
        simp_all +decide [ List.append_assoc ];
        exact Or.inr <| by rw [ ContextFreeRule.rewrites_iff ] ; aesop;

/-
If a context-free grammar produces `w` from `u ++ v`, then the production must occur entirely within `u` or entirely within `v`.
-/
lemma ContextFreeGrammar.Produces.split_append {T : Type u} {g : ContextFreeGrammar T}
    (u v w : List (Symbol T g.NT))
    (h : g.Produces (u ++ v) w) :
    (Ôłâ u', g.Produces u u' Ôłž w = u' ++ v) ÔłĘ (Ôłâ v', g.Produces v v' Ôłž w = u ++ v') := by
      obtain ÔčĘ r, hr, h Ôčę := h;
      -- Apply `ContextFreeRule.Rewrites.split_append` to `h`.
      have h_split : (Ôłâ u', r.Rewrites u u' Ôłž w = u' ++ v) ÔłĘ (Ôłâ v', r.Rewrites v v' Ôłž w = u ++ v') := by
        have h_split : ÔłÇ r : ContextFreeRule T g.NT, ÔłÇ u v w : List (Symbol T g.NT), r.Rewrites (u ++ v) w Ôćĺ (Ôłâ u', r.Rewrites u u' Ôłž w = u' ++ v) ÔłĘ (Ôłâ v', r.Rewrites v v' Ôłž w = u ++ v') := by
          intros r u v w h;
          induction' u with u hu generalizing v w;
          ┬Ě aesop;
          ┬Ě cases h;
            ┬Ě exact Or.inl ÔčĘ r.output ++ hu, by tauto, by simp +decide [ List.append_assoc ] Ôčę;
            ┬Ě rename_i sÔéé hrs;
              rename_i ih;
              specialize ih v sÔéé hrs;
              cases' ih with ih ih <;> simp_all +decide [ ContextFreeRule.Rewrites ];
              obtain ÔčĘ u', hu', rfl Ôčę := ih; exact Or.inl ÔčĘ u :: u', by exact? , by simp +decide [ hu' ] Ôčę ;
        exact h_split r u v w h;
      exact Or.imp ( fun ÔčĘ u', hu', hw Ôčę => ÔčĘ u', ÔčĘ r, hr, hu' Ôčę, hw Ôčę ) ( fun ÔčĘ v', hv', hw Ôčę => ÔčĘ v', ÔčĘ r, hr, hv' Ôčę, hw Ôčę ) h_split

