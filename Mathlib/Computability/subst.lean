/-
If a list of lifted start symbols derives a terminal string using F-rules, then the terminal string is in the product of the languages of the corresponding grammars.
-/
lemma ContextFreeGrammar.mem_subst_of_derivesF {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓)
    (u : List ╬▒) (w : List ╬▓)
    (h : g.DerivesF f (u.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę))) (w.map Symbol.terminal)) :
    w Ôłł (u.map (fun a => (f a).language)).prod := by
      obtain ÔčĘW, hWÔčę : Ôłâ W : List (List ╬▓), w = W.flatten Ôłž List.ForallÔéé (fun w_part a => g.DerivesF f (List.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę)) [a]) (List.map Symbol.terminal w_part)) W u := by
        have := @ContextFreeGrammar.DerivesF_distrib ╬▒ ╬▓ g f ( List.map ( fun a => Symbol.nonterminal ( Sum.inr ÔčĘ a, ( f a ).initial Ôčę ) ) u ) ( List.map Symbol.terminal w ) h;
        obtain ÔčĘ W, hWÔéü, hWÔéé Ôčę := this;
        -- Since `W.flatten` consists of terminals, each element of `W` must consist of terminals.
        have hW_terminals : ÔłÇ w' Ôłł W, ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := by
          have hW_terminals : ÔłÇ w' Ôłł W, ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := by
            intro w' hw' s hs
            have h_terminal : s Ôłł List.map Symbol.terminal w := by
              exact hWÔéü.symm ÔľŞ List.mem_flatten.mpr ÔčĘ w', hw', hs Ôčę
            rw [ List.mem_map ] at h_terminal; obtain ÔčĘ b, hb, rfl Ôčę := h_terminal; exact ÔčĘ b, rfl Ôčę ;
          assumption;
        -- Since `W.flatten` consists of terminals, we can replace each element of `W` with its corresponding list of terminals.
        obtain ÔčĘW', hW'Ôčę : Ôłâ W' : List (List ╬▓), W = W'.map (List.map Symbol.terminal) := by
          have hW_terminals : ÔłÇ w' Ôłł W, Ôłâ w'' : List ╬▓, w' = w''.map Symbol.terminal := by
            intro w' hw'
            obtain ÔčĘw'', hw''Ôčę : Ôłâ w'' : List ╬▓, w' = w''.map Symbol.terminal := by
              have hW'' : ÔłÇ s Ôłł w', Ôłâ b : ╬▓, s = Symbol.terminal b := hW_terminals w' hw'
              have hW'' : ÔłÇ {l : List (Symbol ╬▓ (g.NT ÔŐĽ (a : ╬▒) ├Ś (f a).NT))}, (ÔłÇ s Ôłł l, Ôłâ b : ╬▓, s = Symbol.terminal b) Ôćĺ Ôłâ l' : List ╬▓, l = l'.map Symbol.terminal := by
                intros l hl; induction' l with s l ih <;> simp_all +decide ;
                rcases hl.1 with ÔčĘ b, rfl Ôčę ; obtain ÔčĘ l', rfl Ôčę := ih; exact ÔčĘ b :: l', by simp +decide Ôčę ;
              exact hW'' ÔÇ╣_ÔÇ║;
            use w'';
          choose! W' hW' using hW_terminals;
          use List.map W' W;
          refine' List.ext_get _ _ <;> simp +decide [ ÔćÉ hW' ];
        refine' ÔčĘ W', _, _ Ôčę <;> simp_all +decide [ List.map_map ];
        ┬Ě exact List.map_injective_iff.mpr ( by aesop_cat ) ( hWÔéü.trans ( by simp +decide [ List.map_flatten ] ) );
        ┬Ě exact?;
      rw [ hW.1, Language.mem_list_prod_iff_forall2 ];
      refine' ÔčĘ W, rfl, _ Ôčę;
      have hW_lifted : ÔłÇ {w_part : List ╬▓} {a : ╬▒}, g.DerivesF f (List.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę)) [a]) (List.map Symbol.terminal w_part) Ôćĺ w_part Ôłł (f a).language := by
        exact?;
      rw [ List.forallÔéé_iff_get ] at *;
      grind

/-
The language of the substitution grammar is a subset of the substitution of the languages.
-/
theorem ContextFreeGrammar.subst_language_subset_2 {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) :
    ÔłÇ w, w Ôłł (g.subst f).language Ôćĺ w Ôłł g.language.subst (fun a => (f a).language) := by
      intro w hw;
      obtain ÔčĘ v, hv Ôčę := ContextFreeGrammar.derives_split_G_F g f [Symbol.nonterminal (Sum.inl g.initial)] ( w.map Symbol.terminal ) hw;
      obtain ÔčĘ u, hu Ôčę := ContextFreeGrammar.derivesG_unlift g f [Symbol.nonterminal g.initial] v hv.1;
      -- Since `v` has no `Sum.inl` symbols, `u` must consist only of terminals.
      have hu_terminals : ÔłÇ s Ôłł u, Ôłâ a, s = Symbol.terminal a := by
        have hu_terminals : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
          have hv_no_inl : ÔłÇ s Ôłł v, ÔłÇ n, s Ôëá Symbol.nonterminal (Sum.inl n) := by
            intro s hs n
            have := hv.2
            have := ContextFreeGrammar.not_mem_inl_of_derivesF g f v ( List.map Symbol.terminal w ) this; aesop;
          exact hv_no_inl;
        apply ContextFreeGrammar.is_terminal_of_lift_no_inl g f u;
        aesop;
      -- Since `u` consists only of terminals, we can write `u` as `u_str.map Symbol.terminal` for some `u_str`.
      obtain ÔčĘ u_str, hu_str Ôčę : Ôłâ u_str : List ╬▒, u = u_str.map Symbol.terminal := by
        have hu_str : ÔłÇ {l : List (Symbol ╬▒ g.NT)}, (ÔłÇ s Ôłł l, Ôłâ a, s = Symbol.terminal a) Ôćĺ Ôłâ u_str : List ╬▒, l = u_str.map Symbol.terminal := by
          intros l hl; induction' l with s l ih;
          ┬Ě exact ÔčĘ [ ], rfl Ôčę;
          ┬Ě obtain ÔčĘ a, rfl Ôčę := hl s ( by simp +decide ) ; obtain ÔčĘ u_str, hu_str Ôčę := ih fun s hs => hl s ( by simp +decide [ hs ] ) ; exact ÔčĘ a :: u_str, by simp +decide [ hu_str ] Ôčę ;
        exact hu_str hu_terminals;
      -- Since `v = u_str.map (fun a => Symbol.nonterminal (Sum.inr ÔčĘa, (f a).initialÔčę))`, we can apply `mem_subst_of_derivesF` to conclude that `w Ôłł (u_str.map (fun a => (f a).language)).prod`.
      have hw_prod : w Ôłł (u_str.map (fun a => (f a).language)).prod := by
        apply ContextFreeGrammar.mem_subst_of_derivesF g f u_str w;
        aesop;
      exact ÔčĘ u_str, by aesop Ôčę

#check ContextFreeGrammar.subst_language_subset_1

/-
The language of the substitution grammar is exactly the substitution of the languages of the component grammars. This proves that context-free languages are closed under substitution.
-/
theorem ContextFreeGrammar.subst_language_eq {╬▒ ╬▓ : Type} (g : ContextFreeGrammar ╬▒) (f : ╬▒ Ôćĺ ContextFreeGrammar ╬▓) :
    (g.subst f).language = g.language.subst (fun a => (f a).language) := by
      ext w;
      constructor;
      ┬Ě exact?;
      ┬Ě exact?

/-
A language is context-free if it is the language of some context-free grammar.
-/
def IsContextFree {╬▒ : Type u} (L : Language ╬▒) : Prop :=
  Ôłâ g : ContextFreeGrammar ╬▒, g.language = L

/-
Context-free languages are closed under substitution.
-/
theorem IsContextFree.subst {╬▒ ╬▓ : Type} (L : Language ╬▒) (f : ╬▒ Ôćĺ Language ╬▓)
    (hL : IsContextFree L) (hf : ÔłÇ a, IsContextFree (f a)) :
    IsContextFree (L.subst f) := by
      obtain ÔčĘ g, hg Ôčę := hL
      obtain ÔčĘ F, hF Ôčę : Ôłâ F : ╬▒ Ôćĺ ContextFreeGrammar ╬▓, ÔłÇ a, (F a).language = f a := by
        exact ÔčĘ fun a => Classical.choose ( hf a ), fun a => Classical.choose_spec ( hf a ) Ôčę
      set G := g.subst F
      have hG : G.language = (L.subst f) := by
        rw [ ÔćÉ hg, ÔćÉ funext hF, ContextFreeGrammar.subst_language_eq ]
      exact ÔčĘ G, hG Ôčę
