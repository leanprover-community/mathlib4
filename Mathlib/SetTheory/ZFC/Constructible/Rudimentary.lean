module
public import Mathlib.SetTheory.ZFC.Constructible.Godel

/-!
# Formal terms for rudimentary closure

The closure in `Godel.lean` is defined by finite iteration.  This
file gives the equivalent finite term syntax.  The generic theorem applies to
any internally represented seed; its specialization to `U ∪ {U}` uses `none`
for the generator `U` and `some x` for a parameter `x ∈ U`.
-/

@[expose] public section

universe u v

namespace Constructible.Godel

/-- Finite terms generated by variables and the nine Gödel operations. -/
inductive RudimentaryTerm (α : Type u) : Type u where
  | var (a : α)
  | app (i : Fin 9) (left right : RudimentaryTerm α)

namespace RudimentaryTerm

variable {α β : Type u}

/-- Evaluation of a rudimentary term under an assignment of its variables. -/
noncomputable def eval (ρ : α → ZFSet.{v}) :
    RudimentaryTerm α → ZFSet.{v}
  | .var a => ρ a
  | .app i left right => op i (eval ρ left) (eval ρ right)

/-- Rename the variables occurring in a rudimentary term. -/
def rename (f : α → β) : RudimentaryTerm α → RudimentaryTerm β
  | .var a => .var (f a)
  | .app i left right => .app i (rename f left) (rename f right)

/-- Simultaneously substitute a term for every variable. -/
def subst (f : α → RudimentaryTerm β) :
    RudimentaryTerm α → RudimentaryTerm β
  | .var a => f a
  | .app i left right => .app i (subst f left) (subst f right)

@[simp]
theorem eval_rename (f : α → β) (ρ : β → ZFSet.{v})
    (t : RudimentaryTerm α) :
    eval ρ (rename f t) = eval (ρ ∘ f) t := by
  induction t with
  | var a => rfl
  | app i left right ihLeft ihRight => simp [rename, eval, ihLeft, ihRight]

@[simp]
theorem eval_subst (f : α → RudimentaryTerm β) (ρ : β → ZFSet.{v})
    (t : RudimentaryTerm α) :
    eval ρ (subst f t) = eval (fun a => eval ρ (f a)) t := by
  induction t with
  | var a => rfl
  | app i left right ihLeft ihRight => simp [subst, eval, ihLeft, ihRight]

/-- If every generator lies in the seed, every term value lies in its closure. -/
theorem eval_mem_closure_of_mem_seed {seed : ZFSet.{v}}
    {ρ : α → ZFSet.{v}} (hρ : ∀ a, ρ a ∈ seed)
    (t : RudimentaryTerm α) : eval ρ t ∈ closure seed := by
  induction t with
  | var a => exact seed_subset_closure seed (hρ a)
  | app i left right hleft hright =>
      exact op_mem_closure hleft hright

/--
Every member of a finite closure stage is the value of a term, provided the
assignment names every member of the seed.
-/
theorem exists_term_eval_eq_of_mem_rudimentaryIter
    {seed z : ZFSet.{v}} {ρ : α → ZFSet.{v}}
    (hρ : ∀ x, x ∈ seed → ∃ a, ρ a = x) :
    ∀ n, z ∈ rudimentaryIter seed n →
      ∃ t : RudimentaryTerm α, eval ρ t = z := by
  intro n
  induction n generalizing z with
  | zero =>
      intro hz
      rcases hρ z hz with ⟨a, ha⟩
      exact ⟨.var a, ha⟩
  | succ n ih =>
      intro hz
      rcases mem_rudimentaryStep_iff.mp hz with
        hz | ⟨i, x, hx, y, hy, rfl⟩
      · exact ih hz
      · rcases ih hx with ⟨left, hleft⟩
        rcases ih hy with ⟨right, hright⟩
        refine ⟨.app i left right, ?_⟩
        simp only [eval]
        rw [hleft, hright]

/--
The closure generated by an assignment is exactly the set of values of finite
rudimentary terms, when that assignment names the seed precisely.
-/
theorem mem_closure_iff_exists_term_eval {seed z : ZFSet.{v}}
    {ρ : α → ZFSet.{v}}
    (hmem : ∀ a, ρ a ∈ seed)
    (hnames : ∀ x, x ∈ seed → ∃ a, ρ a = x) :
    z ∈ closure seed ↔ ∃ t : RudimentaryTerm α, eval ρ t = z := by
  constructor
  · intro hz
    rcases mem_closure_iff.mp hz with ⟨n, hn⟩
    exact exists_term_eval_eq_of_mem_rudimentaryIter hnames n hn
  · rintro ⟨t, rfl⟩
    exact eval_mem_closure_of_mem_seed hmem t

end RudimentaryTerm

/-- Canonical term syntax for the closure of an internally represented seed. -/
abbrev ClosureTerm (seed : ZFSet.{u}) :=
  RudimentaryTerm (Constructible.ZFCarrier seed)

/-- Evaluation of a canonical closure term. -/
noncomputable abbrev ClosureTerm.eval {seed : ZFSet.{u}}
    (t : ClosureTerm seed) : ZFSet.{u} :=
  RudimentaryTerm.eval (fun x : Constructible.ZFCarrier seed => x.1) t

theorem mem_closure_iff_exists_closureTerm {seed z : ZFSet.{u}} :
    z ∈ closure seed ↔ ∃ t : ClosureTerm seed, t.eval = z := by
  apply RudimentaryTerm.mem_closure_iff_exists_term_eval
  · exact fun a => a.2
  · intro x hx
    exact ⟨⟨x, hx⟩, rfl⟩

/--
Variables for `rudimentaryClosure U`: `none` names `U`, while `some x` names
the parameter `x ∈ U`.
-/
abbrev RudimentaryClosureTerm (U : ZFSet.{u}) :=
  RudimentaryTerm (Option (Constructible.ZFCarrier U))

/-- The natural interpretation of the generators `U ∪ {U}`. -/
def rudimentaryGenerator (U : ZFSet.{u}) :
    Option (Constructible.ZFCarrier U) → ZFSet.{u}
  | none => U
  | some x => x.1

/-- Evaluation of a term over `U ∪ {U}`. -/
noncomputable abbrev RudimentaryClosureTerm.eval {U : ZFSet.{u}}
    (t : RudimentaryClosureTerm U) : ZFSet.{u} :=
  RudimentaryTerm.eval (rudimentaryGenerator U) t

@[simp]
theorem mem_rudimentaryClosure_iff_exists_term {U z : ZFSet.{u}} :
    z ∈ rudimentaryClosure U ↔
      ∃ t : RudimentaryClosureTerm U, t.eval = z := by
  apply RudimentaryTerm.mem_closure_iff_exists_term_eval
  · intro a
    cases a with
    | none => exact mem_rudimentarySeed_iff.mpr (Or.inl rfl)
    | some x => exact mem_rudimentarySeed_iff.mpr (Or.inr x.2)
  · intro x hx
    rcases mem_rudimentarySeed_iff.mp hx with rfl | hx
    · exact ⟨none, rfl⟩
    · exact ⟨some ⟨x, hx⟩, rfl⟩

/-- Term-syntax characterization of the Gödel presentation of `Def(U)`. -/
theorem mem_godelDef_iff_exists_rudimentaryTerm {U z : ZFSet.{u}} :
    z ∈ godelDef U ↔
      z ⊆ U ∧ ∃ t : RudimentaryClosureTerm U, t.eval = z := by
  rw [mem_godelDef_iff, mem_rudimentaryClosure_iff_exists_term]

end Constructible.Godel
