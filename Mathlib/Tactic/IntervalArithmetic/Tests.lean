module

import Mathlib.Algebra.Group.Nat.Defs
public import Mathlib.Tactic.IntervalArithmetic.Interval
public meta import Mathlib.Tactic.IntervalArithmetic.DyadicReal
public meta import Mathlib.Tactic.IntervalArithmetic.ExactRatReal

set_option linter.style.header false

@[expose] public section

open Set

/- **exact_interval** -/

example (x y : ℝ) (hx : x ∈ Ioo (-1) 1) (hy : y ∈ Icc 1 2) :
  x ^ 2 + y ^ 2 ∈ Ico 0 5 := by exact_interval

example (x y z : ℝ) (hx : x ∈ Set.Ioo 0 3) (hy : y < 2) (hz : -2 < z) (h : z < -1) :
  (|x*z| + y)^3 < 512 := by exact_interval


open Lean Elab Command

open IntervalArithmetic

set_option warn.sorry false

-- set_option trace.profiler true

theorem test_mem_share_hard (x : ℝ) (hx₁ : 2 ≤ x) (hx₂ : x ≤ 3) :
    x ^ 2 + Real.sqrt (x + Real.sqrt 2) ∈
      Set.Icc (x + Real.sqrt 2) (Real.exp x + x ^ 3) := by
  dyadic_interval [approx := 1]

example (x y z : ℝ) (hx : x = 3) (hy : y = 7) (hz : z = 10) : x + y = z := by dyadic_interval

theorem test (x : ℝ)
    (hx : x ∈ Set.Icc (Real.exp 1) (Real.exp 2)) :
    x ≤ x + 100 := by
  dyadic_interval [approx := 6]

example : √(√ 3 - √ 2) ≤ 0.6 := by
  dyadic_interval [approx := 1000 for Sqrt, approx := 5 for OfScientific]

example (x : ℝ) (hx : x ∈ Set.Ici 0) : -x ≤ 0 := by dyadic_interval

example (x : ℝ) (hx : x ≥ 0) : 0 ≥ -x := by dyadic_interval

example : 3.1415926535 ≤ Real.pi := by
  dyadic_interval [approx := 50]

example :
  Real.exp (Real.pi * Real.sqrt 163) > (640320) ^ 3 + 744 - (0.000000000001) := by
  dyadic_interval [approx := 113]

example (x : ℝ) (hx : 1 < x) : 0 ≤ x ^ 3 + x - 1  := by dyadic_interval


example (x : ℝ) (hx : 2 ≤ x) : Real.exp (- x ^ 2) ≤ x := by dyadic_interval [approx := 600]

example : Real.exp 1 ≤ 3 := by dyadic_interval [approx := 100]

example (x y : ℝ) (hx_lb : 0 ≤ x) (hx_ub : x ≤ √(√3 - √2)) (hy : 0.15 ≤ y) : x ^ 2 ≤ √y := by
  dyadic_interval [approx := 10]

example :
    2.
      ≤ Real.exp 1 := by
  dyadic_interval [approx := 3400]

example :
    Real.exp 1 ≤
      2. := by
  dyadic_interval [approx := 3400]

example :
