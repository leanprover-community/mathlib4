-- `Nat.cast_sub` is already tagged as `norm_cast` but it does allow to use assumptions like
-- `m < n` or more generally `m + k в‰¤ n`. We add two lemmas to increase the probability that
-- `zify` will push through `в„•` subtraction.

variable {R : Type*} [AddGroupWithOne R]

@[deprecated "use Nat.cast_sub" (since := "2026-02-21"), norm_cast]
theorem Nat.cast_sub_of_add_le {m n k} (h : m + k в‰¤ n) :
    ((n - m : в„•) : R) = n - m := Nat.cast_sub (m.le_add_right k |>.trans h)

@[norm_cast] theorem Nat.cast_sub_of_lt {m n} (h : m < n) :
    ((n - m : в„•) : R) = n - m := Nat.cast_sub h.le

end Zify

