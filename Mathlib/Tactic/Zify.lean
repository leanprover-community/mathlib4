/-!
# `zify` tactic

The `zify` tactic is used to shift propositions from `Nat` to `Int`.
This is often useful since `Int` has well-behaved subtraction.
```
example (a b c x y z : Nat) (h : В¬ x*y*z < 0) : c < a + 3*b := by
  zify
  zify at h
  /-
  h : В¬в†‘x * в†‘y * в†‘z < 0
  вЉў в†‘c < в†‘a + 3 * в†‘b
  -/
```
-/

public meta section

namespace Mathlib.Tactic.Zify

open Lean
open Lean.Meta
open Lean.Parser.Tactic
open Lean.Elab.Tactic

/--
`zify` rewrites the main goal by shifting propositions from `в„•` to `в„¤`.
This is often useful since `в„¤` has well-behaved subtraction.

`zify` makes use of the `@[zify_simps]` attribute to insert casts into propositions, and the
`push_cast` tactic to simplify the `в„¤`-valued expressions.

`zify` is in some sense dual to the `lift` tactic. `lift (z : Int) to Nat` will change the type of
an integer `z` (in the supertype) to `Nat` (the subtype), given a proof that `z в‰Ґ 0`; propositions
concerning `z` will still be over `Int`. `zify` changes propositions about `Nat` (the subtype) to
propositions about `Int` (the supertype), without changing the type of any variable.

* `zify at l1 l2 ...` rewrites at the given locations.
* `zify [hв‚Ѓ, ..., hв‚™]` uses the expressions `hв‚Ѓ`, ..., `hв‚™` as extra lemmas for simplification.
  This is especially useful in the presence of nat subtraction or of division: passing arguments of
  type `В· в‰¤ В·` will allow `push_cast` to do more work.

Examples:
```
example (a b c x y z : Nat) (h : В¬ x*y*z < 0) : c < a + 3*b := by
  zify
  zify at h
  /-
  h : В¬в†‘x * в†‘y * в†‘z < 0
  вЉў в†‘c < в†‘a + 3 * в†‘b
  -/
  sorry

example (a b c : Nat) (h : a - b < c) (hab : b в‰¤ a) : False := by
  -- Nonnegativity hypothesis allows pushing `В· - В·`.
  zify [hab] at h
  /- h : в†‘a - в†‘b < в†‘c -/
  sorry
```
-/
syntax (name := zify) "zify" (simpArgs)? (location)? : tactic

macro_rules
| `(tactic| zify $[[$simpArgs,*]]? $[at $location]?) =>
  let args := simpArgs.map (В·.getElems) |>.getD #[]
  `(tactic|
    simp -decide only [zify_simps, push_cast, $args,*] $[at $location]?)

/-- The `Simp.Context` generated by `zify`. -/
def mkZifyContext (simpArgs : Option (Syntax.TSepArray `Lean.Parser.Tactic.simpStar ",")) :
    TacticM MkSimpContextResult := do
  let args := simpArgs.map (В·.getElems) |>.getD #[]
  mkSimpContext
    (в†ђ `(tactic| simp -decide only [zify_simps, push_cast, $args,*])) false

/-- A variant of `applySimpResultToProp` that cannot close the goal, but does not need a meta
variable and returns a tuple of a proof and the corresponding simplified proposition. -/
def applySimpResultToProp' (proof : Expr) (prop : Expr) (r : Simp.Result) : MetaM (Expr Г— Expr) :=
  do
  match r.proof? with
  | some eqProof => return (в†ђ mkExpectedTypeHint (в†ђ mkEqMP eqProof proof) r.expr, r.expr)
  | none =>
    if r.expr != prop then
      return (в†ђ mkExpectedTypeHint proof r.expr, r.expr)
    else
      return (proof, r.expr)

/-- Translate a proof and the proposition into a zified form. -/
def zifyProof (simpArgs : Option (Syntax.TSepArray `Lean.Parser.Tactic.simpStar ","))
    (proof : Expr) (prop : Expr) : TacticM (Expr Г— Expr) := do
  let ctx_result в†ђ mkZifyContext simpArgs
  let (r, _) в†ђ simp prop ctx_result.ctx
  applySimpResultToProp' proof prop r

attribute [zify_simps в†ђ] Int.ofNat_inj Int.ofNat_le Int.ofNat_lt Int.ofNat_dvd

@[zify_simps] lemma natCast_ne (a b : Nat) : a в‰  b в†” (a : Int) в‰  (b : Int) :=
  not_congr Int.ofNat_inj.symm
