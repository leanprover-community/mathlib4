/-!
# `zify` tactic

The `zify` tactic is used to shift propositions from `Nat` to `Int`.
This is often useful since `Int` has well-behaved subtraction.
```
example (a b c x y z : Nat) (h : ¬¨ x*y*z < 0) : c < a + 3*b := by
  zify
  zify at h
  /-
  h : ¬¨‚ÜĎx * ‚ÜĎy * ‚ÜĎz < 0
  ‚äĘ ‚ÜĎc < ‚ÜĎa + 3 * ‚ÜĎb
  -/

set_option backward.defeqAttrib.useBackward true
```
-/

public meta section

namespace Mathlib.Tactic.Zify

open Lean
open Lean.Meta
open Lean.Parser.Tactic
open Lean.Elab.Tactic

/--
`zify` rewrites the main goal by shifting propositions from `‚Ąē` to `‚Ą§`.
This is often useful since `‚Ą§` has well-behaved subtraction.

`zify` makes use of the `@[zify_simps]` attribute to insert casts into propositions, and the
`push_cast` tactic to simplify the `‚Ą§`-valued expressions.

`zify` is in some sense dual to the `lift` tactic. `lift (z : Int) to Nat` will change the type of
an integer `z` (in the supertype) to `Nat` (the subtype), given a proof that `z ‚Č• 0`; propositions
concerning `z` will still be over `Int`. `zify` changes propositions about `Nat` (the subtype) to
propositions about `Int` (the supertype), without changing the type of any variable.

* `zify at l1 l2 ...` rewrites at the given locations.
* `zify [h‚āĀ, ..., h‚āô]` uses the expressions `h‚āĀ`, ..., `h‚āô` as extra lemmas for simplification.
  This is especially useful in the presence of nat subtraction or of division: passing arguments of
  type `¬∑ ‚Č§ ¬∑` will allow `push_cast` to do more work.

Examples:
```
example (a b c x y z : Nat) (h : ¬¨ x*y*z < 0) : c < a + 3*b := by
  zify
  zify at h
  /-
  h : ¬¨‚ÜĎx * ‚ÜĎy * ‚ÜĎz < 0
  ‚äĘ ‚ÜĎc < ‚ÜĎa + 3 * ‚ÜĎb
  -/
  sorry

example (a b c : Nat) (h : a - b < c) (hab : b ‚Č§ a) : False := by
  -- Nonnegativity hypothesis allows pushing `¬∑ - ¬∑`.
  zify [hab] at h
  /- h : ‚ÜĎa - ‚ÜĎb < ‚ÜĎc -/
  sorry
```
-/
syntax (name := zify) "zify" (simpArgs)? (location)? : tactic

macro_rules
| `(tactic| zify $[[$simpArgs,*]]? $[at $location]?) =>
  let args := simpArgs.map (¬∑.getElems) |>.getD #[]
  `(tactic|
    simp -decide only [zify_simps, push_cast, $args,*] $[at $location]?)

/-- The `Simp.Context` generated by `zify`. -/
def mkZifyContext (simpArgs : Option (Syntax.TSepArray `Lean.Parser.Tactic.simpStar ",")) :
    TacticM MkSimpContextResult := do
  let args := simpArgs.map (¬∑.getElems) |>.getD #[]
  mkSimpContext
    (‚Üź `(tactic| simp -decide only [zify_simps, push_cast, $args,*])) false

/-- A variant of `applySimpResultToProp` that cannot close the goal, but does not need a meta
variable and returns a tuple of a proof and the corresponding simplified proposition. -/
def applySimpResultToProp' (proof : Expr) (prop : Expr) (r : Simp.Result) : MetaM (Expr √ó Expr) :=
  do
  match r.proof? with
  | some eqProof => return (‚Üź mkExpectedTypeHint (‚Üź mkEqMP eqProof proof) r.expr, r.expr)
  | none =>
    if r.expr != prop then
      return (‚Üź mkExpectedTypeHint proof r.expr, r.expr)
    else
      return (proof, r.expr)

/-- Translate a proof and the proposition into a zified form. -/
def zifyProof (simpArgs : Option (Syntax.TSepArray `Lean.Parser.Tactic.simpStar ","))
    (proof : Expr) (prop : Expr) : TacticM (Expr √ó Expr) := do
  let ctx_result ‚Üź mkZifyContext simpArgs
  let (r, _) ‚Üź simp prop ctx_result.ctx
  applySimpResultToProp' proof prop r

@[zify_simps] lemma natCast_eq (a b : Nat) : a = b ‚ÜĒ (a : Int) = (b : Int) := Int.ofNat_inj.symm
@[zify_simps] lemma natCast_le (a b : Nat) : a ‚Č§ b ‚ÜĒ (a : Int) ‚Č§ (b : Int) := Int.ofNat_le.symm
@[zify_simps] lemma natCast_lt (a b : Nat) : a < b ‚ÜĒ (a : Int) < (b : Int) := Int.ofNat_lt.symm
@[zify_simps] lemma natCast_ne (a b : Nat) : a ‚Č† b ‚ÜĒ (a : Int) ‚Č† (b : Int) :=
  not_congr Int.ofNat_inj.symm
@[zify_simps] lemma natCast_dvd (a b : Nat) : a ‚ą£ b ‚ÜĒ (a : Int) ‚ą£ (b : Int) := Int.ofNat_dvd.symm
-- TODO: is it worth adding lemmas for Prime and Coprime as well?
-- Doing so in this file would require adding imports.


-- `Nat.cast_sub` is already tagged as `norm_cast` but it does allow to use assumptions like
-- `m < n` or more generally `m + k ‚Č§ n`. We add two lemmas to increase the probability that
-- `zify` will push through `‚Ąē` subtraction.

variable {R : Type*} [AddGroupWithOne R]

@[deprecated "use Nat.cast_sub" (since := "2026-02-21"), norm_cast]
theorem Nat.cast_sub_of_add_le {m n k} (h : m + k ‚Č§ n) :
    ((n - m : ‚Ąē) : R) = n - m := Nat.cast_sub (m.le_add_right k |>.trans h)

@[norm_cast] theorem Nat.cast_sub_of_lt {m n} (h : m < n) :
    ((n - m : ‚Ąē) : R) = n - m := Nat.cast_sub h.le

end Zify

end Mathlib.Tactic
