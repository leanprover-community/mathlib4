/--
`rify` rewrites the main goal by shifting propositions from `‚Ąē`, `‚Ą§`, `‚Ąö` or `‚ĄĚ‚Č•0` to `‚ĄĚ`.
Although less useful than its cousins `zify` and `qify`, it can be useful when your
goal or context already involves real numbers.

`rify` makes use of the `@[zify_simps]`, `@[qify_simps]` and `@[rify_simps]` attributes to insert
casts into propositions, and the `push_cast` tactic to simplify the `‚ĄĚ`-valued expressions.

`rify` is in some sense dual to the `lift` tactic. `lift (r : ‚ĄĚ) to ‚Ąö` will change the type of a
real number `r` (in the supertype) to `‚Ąö` (the subtype), given a proof that `r` is rational;
propositions concerning `r` will still be over `‚ĄĚ`. `rify` changes propositions about `‚Ąē`, `‚Ą§`, `‚Ąö`
or `‚ĄĚ‚Č•0` (the subtype) to propositions about `‚ĄĚ` (the supertype), without changing the type of any
variable.

* `rify at l1 l2 ...` rewrites at the given locations.
* `rify [h‚āĀ, ..., h‚āô]` uses the expressions `h‚āĀ`, ..., `h‚āô` as extra lemmas for simplification.
  This is especially useful in the presence of nat subtraction or of division: passing arguments of
  type `¬∑ ‚Č§ ¬∑` or `¬∑ ‚ą£ ¬∑` will allow `push_cast` to do more work.

Examples:
```
/--
import Mathlib

open Real
Here, the assumption `hn` is about natural numbers, `hk` is about integers
and involves casting a natural number to `‚Ą§`, and the conclusion is about real numbers.
-/
example {n : ‚Ąē} {k : ‚Ą§} (hn : 8 ‚Č§ n) (hk : 2 * k ‚Č§ n + 2) :
    (0 : ‚ĄĚ) < n - k - 1 := by
  rify at hn hk /- Now have hn : 8 ‚Č§ (n : ‚ĄĚ)   hk : 2 * (k : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) + 2 -/
  linarith

-- Extra hypotheses allow `push_cast` to do more work.
example (a b c : ‚Ąē) (h : a - b < c) (hab : b ‚Č§ a) : a < b + c := by
  rify [hab] at h ‚äĘ -- Here `zify` or `qify` would have also worked.
  linarith

example (a b : ‚Ąē) (ha : ŌÄ ‚Č§ a) : 3 ‚Č§ a + b := by
  rify
  linarith [pi_gt_three]
```
-/
syntax (name := rify) "rify" (simpArgs)? (location)? : tactic

macro_rules
| `(tactic| rify $[[$simpArgs,*]]? $[at $location]?) =>
  let args := simpArgs.map (¬∑.getElems) |>.getD #[]
  `(tactic|
    simp -decide only [zify_simps, qify_simps, rify_simps, push_cast, $args,*]
      $[at $location]?)

/-- The `Simp.Context` generated by `rify` (with no optional arguments or local context). -/
def mkRifyContext : MetaM Simp.Context := do
  let result ‚Üź #[`zify_simps, `qify_simps, `rify_simps, `push_cast].mapM fun ext ‚Ü¶ do
    let some ext ‚Üź getSimpExtension? ext | failure
    ext.getTheorems
  Simp.mkContext {failIfUnchanged := false} (simpTheorems := result)

/-- Translate a proof and the proposition into rified form. -/
def rifyProof (proof : Expr) (prop : Expr) : MetaM (Expr √ó Expr) := do
  let (r, _) ‚Üź simp prop (‚Üź mkRifyContext)
  Zify.applySimpResultToProp' proof prop r

@[rify_simps] lemma ratCast_eq (a b : ‚Ąö) : a = b ‚ÜĒ (a : ‚ĄĚ) = (b : ‚ĄĚ) := by simp
@[rify_simps] lemma ratCast_le (a b : ‚Ąö) : a ‚Č§ b ‚ÜĒ (a : ‚ĄĚ) ‚Č§ (b : ‚ĄĚ) := by simp
@[rify_simps] lemma ratCast_lt (a b : ‚Ąö) : a < b ‚ÜĒ (a : ‚ĄĚ) < (b : ‚ĄĚ) := by simp
@[rify_simps] lemma ratCast_ne (a b : ‚Ąö) : a ‚Č† b ‚ÜĒ (a : ‚ĄĚ) ‚Č† (b : ‚ĄĚ) := by simp

