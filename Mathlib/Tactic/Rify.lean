/--
`rify` rewrites the main goal by shifting propositions from `вДХ`, `вД§`, `вДЪ` or `вДЭвЙ•0` to `вДЭ`.
Although less useful than its cousins `zify` and `qify`, it can be useful when your
goal or context already involves real numbers.

`rify` makes use of the `@[zify_simps]`, `@[qify_simps]` and `@[rify_simps]` attributes to insert
casts into propositions, and the `push_cast` tactic to simplify the `вДЭ`-valued expressions.

`rify` is in some sense dual to the `lift` tactic. `lift (r : вДЭ) to вДЪ` will change the type of a
real number `r` (in the supertype) to `вДЪ` (the subtype), given a proof that `r` is rational;
propositions concerning `r` will still be over `вДЭ`. `rify` changes propositions about `вДХ`, `вД§`, `вДЪ`
or `вДЭвЙ•0` (the subtype) to propositions about `вДЭ` (the supertype), without changing the type of any
variable.

* `rify at l1 l2 ...` rewrites at the given locations.
* `rify [hвВБ, ..., hвВЩ]` uses the expressions `hвВБ`, ..., `hвВЩ` as extra lemmas for simplification.
  This is especially useful in the presence of nat subtraction or of division: passing arguments of
  type `¬Ј вЙ§ ¬Ј` or `¬Ј вИ£ ¬Ј` will allow `push_cast` to do more work.

Examples:
```
/--
Here, the assumption `hn` is about natural numbers, `hk` is about integers
and involves casting a natural number to `вД§`, and the conclusion is about real numbers.
-/
example {n : вДХ} {k : вД§} (hn : 8 вЙ§ n) (hk : 2 * k вЙ§ n + 2) :
    (0 : вДЭ) < n - k - 1 := by
  rify at hn hk /- Now have hn : 8 вЙ§ (n : вДЭ)   hk : 2 * (k : вДЭ) вЙ§ (n : вДЭ) + 2 -/
  linarith

-- Extra hypotheses allow `push_cast` to do more work.
example (a b c : вДХ) (h : a - b < c) (hab : b вЙ§ a) : a < b + c := by
  rify [hab] at h вКҐ -- Here `zify` or `qify` would have also worked.
  linarith
```
-/
syntax (name := rify) "rify" (simpArgs)? (location)? : tactic

macro_rules
| `(tactic| rify $[[$simpArgs,*]]? $[at $location]?) =>
  let args := simpArgs.map (¬Ј.getElems) |>.getD #[]
  `(tactic|
    simp -decide only [zify_simps, qify_simps, rify_simps, push_cast, $args,*]
      $[at $location]?)

/-- The `Simp.Context` generated by `rify` (with no optional arguments or local context). -/
def mkRifyContext : MetaM Simp.Context := do
  let result вЖР #[`zify_simps, `qify_simps, `rify_simps, `push_cast].mapM fun ext вЖ¶ do
    let some ext вЖР getSimpExtension? ext | failure
    ext.getTheorems
  Simp.mkContext {failIfUnchanged := false} (simpTheorems := result)

/-- Translate a proof and the proposition into rified form. -/
def rifyProof (proof : Expr) (prop : Expr) : MetaM (Expr √Ч Expr) := do
  let (r, _) вЖР simp prop (вЖР mkRifyContext)
  Zify.applySimpResultToProp' proof prop r

@[rify_simps] lemma ratCast_eq (a b : вДЪ) : a = b вЖФ (a : вДЭ) = (b : вДЭ) := by simp
@[rify_simps] lemma ratCast_le (a b : вДЪ) : a вЙ§ b вЖФ (a : вДЭ) вЙ§ (b : вДЭ) := by simp
@[rify_simps] lemma ratCast_lt (a b : вДЪ) : a < b вЖФ (a : вДЭ) < (b : вДЭ) := by simp
@[rify_simps] lemma ratCast_ne (a b : вДЪ) : a вЙ† b вЖФ (a : вДЭ) вЙ† (b : вДЭ) := by simp

