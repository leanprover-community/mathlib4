/--
`rify` rewrites the main goal by shifting propositions from `‚Ñï`, `‚Ñ§`, `‚Ñö` or `‚Ñù‚â•0` to `‚Ñù`.
Although less useful than its cousins `zify` and `qify`, it can be useful when your
goal or context already involves real numbers.

`rify` makes use of the `@[zify_simps]`, `@[qify_simps]` and `@[rify_simps]` attributes to insert
casts into propositions, and the `push_cast` tactic to simplify the `‚Ñù`-valued expressions.

`rify` is in some sense dual to the `lift` tactic. `lift (r : ‚Ñù) to ‚Ñö` will change the type of a
real number `r` (in the supertype) to `‚Ñö` (the subtype), given a proof that `r` is rational;
propositions concerning `r` will still be over `‚Ñù`. `rify` changes propositions about `‚Ñï`, `‚Ñ§`, `‚Ñö`
or `‚Ñù‚â•0` (the subtype) to propositions about `‚Ñù` (the supertype), without changing the type of any
variable.

* `rify at l1 l2 ...` rewrites at the given locations.
* `rify [h‚ÇÅ, ..., h‚Çô]` uses the expressions `h‚ÇÅ`, ..., `h‚Çô` as extra lemmas for simplification.
  This is especially useful in the presence of nat subtraction or of division: passing arguments of
  type `¬∑ ‚â§ ¬∑` or `¬∑ ‚à£ ¬∑` will allow `push_cast` to do more work.

Examples:
```
/--
import Mathlib

open Real
Here, the assumption `hn` is about natural numbers, `hk` is about integers
and involves casting a natural number to `‚Ñ§`, and the conclusion is about real numbers.
-/
example {n : ‚Ñï} {k : ‚Ñ§} (hn : 8 ‚â§ n) (hk : 2 * k ‚â§ n + 2) :
    (0 : ‚Ñù) < n - k - 1 := by
  rify at hn hk /- Now have hn : 8 ‚â§ (n : ‚Ñù)   hk : 2 * (k : ‚Ñù) ‚â§ (n : ‚Ñù) + 2 -/
  linarith

-- Extra hypotheses allow `push_cast` to do more work.
example (a b c : ‚Ñï) (h : a - b < c) (hab : b ‚â§ a) : a < b + c := by
  rify [hab] at h ‚ä¢ -- Here `zify` or `qify` would have also worked.
  linarith

example (a b : ‚Ñï) (ha : œÄ ‚â§ a) : 3 ‚â§ a + b := by
  rify
  linarith [pi_gt_three]
```
-/
syntax (name := rify) "rify" (simpArgs)? (location)? : tactic

macro_rules
| `(tactic| rify $[[$simpArgs,*]]? $[at $location]?) =>
  let args := simpArgs.map (¬∑.getElems) |>.getD #[]
  `(tactic|
    simp -decide only [zify_simps, qify_simps, rify_simps, push_cast, $args,*]
      $[at $location]?)

/-- The `Simp.Context` generated by `rify` (with no optional arguments or local context). -/
def mkRifyContext : MetaM Simp.Context := do
  let result ‚Üê #[`zify_simps, `qify_simps, `rify_simps, `push_cast].mapM fun ext ‚Ü¶ do
    let some ext ‚Üê getSimpExtension? ext | failure
    ext.getTheorems
  Simp.mkContext {failIfUnchanged := false} (simpTheorems := result)

/-- Translate a proof and the proposition into rified form. -/
def rifyProof (proof : Expr) (prop : Expr) : MetaM (Expr √ó Expr) := do
  let (r, _) ‚Üê simp prop (‚Üê mkRifyContext)
  Zify.applySimpResultToProp' proof prop r

@[rify_simps] lemma ratCast_eq (a b : ‚Ñö) : a = b ‚Üî (a : ‚Ñù) = (b : ‚Ñù) := by simp
@[rify_simps] lemma ratCast_le (a b : ‚Ñö) : a ‚â§ b ‚Üî (a : ‚Ñù) ‚â§ (b : ‚Ñù) := by simp
@[rify_simps] lemma ratCast_lt (a b : ‚Ñö) : a < b ‚Üî (a : ‚Ñù) < (b : ‚Ñù) := by simp
@[rify_simps] lemma ratCast_ne (a b : ‚Ñö) : a ‚âÝ b ‚Üî (a : ‚Ñù) ‚âÝ (b : ‚Ñù) := by simp

