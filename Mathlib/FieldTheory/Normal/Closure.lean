/-!
# Normal closures

## Main definitions

Given field extensions `K/F` and `L/F`, the predicate `IsNormalClosure F K L` says that the
minimal polynomial of every element of `K` over `F` splits in `L`, and that `L` is generated
by the roots of such minimal polynomials. These conditions uniquely characterize `L/F` up to
`F`-algebra isomorphisms (`IsNormalClosure.equiv`).

The explicit construction `IntermediateField.normalClosure F K L` of a field extension `K/F`
inside another field extension `L/F` is the smallest intermediate field of
`L/F` that contains the image of every `F`-algebra embedding `K ÔåÆÔéÉ[F] L`.
It satisfies the `IsNormalClosure` predicate if `L/F` satisfies the
abovementioned splitting condition, in particular if `L/K/F` form a tower and
`L/F` is normal.
-/

@[expose] public section

open IntermediateField IsScalarTower Polynomial

variable (F K L : Type*) [Field F] [Field K] [Field L] [Algebra F K] [Algebra F L]

/-- `L/F` is a normal closure of `K/F` if the minimal polynomial of every element of `K` over `F`
  splits in `L`, and `L` is generated by roots of such minimal polynomials over `F`.
  (Since the minimal polynomial of a transcendental element is 0,
  the normal closure of `K/F` is the same as the normal closure over `F`
  of the algebraic closure of `F` in `K`.) -/
@[stacks 0BMF "Predicate version"]
class IsNormalClosure : Prop where
  splits (x : K) : ((minpoly F x).map (algebraMap F L)).Splits
  adjoin_rootSet : Ô¿å x : K, adjoin F ((minpoly F x).rootSet L) = Ôèñ
/- TODO: show `IsNormalClosure F K L Ôåö IsNormalClosure F (integralClosure F K) L`; we can't state
  this yet because `integralClosure F K` needs to have a `Field` instance. -/

/-- The normal closure of `K/F` in `L/F`. -/
@[stacks 0BMF]
noncomputable def IntermediateField.normalClosure : IntermediateField F L :=
  Ô¿å f : K ÔåÆÔéÉ[F] L, f.fieldRange

lemma normalClosure_def : normalClosure F K L = Ô¿å f : K ÔåÆÔéÉ[F] L, f.fieldRange :=
  rfl

variable {F K L}

/-- A normal closure is always normal. -/
lemma IsNormalClosure.normal [h : IsNormalClosure F K L] : Normal F L :=
  Normal.of_algEquiv topEquiv (h := h.adjoin_rootSet Ôû© IntermediateField.normal_iSup (h :=
    fun _ Ôåª Normal.of_isSplittingField (hFEp := adjoin_rootSet_isSplittingField <| h.splits _)))

lemma normalClosure_le_iff {K' : IntermediateField F L} :
    normalClosure F K L Ôëñ K' Ôåö ÔêÇ f : K ÔåÆÔéÉ[F] L, f.fieldRange Ôëñ K' :=
  iSup_le_iff

lemma AlgHom.fieldRange_le_normalClosure (f : K ÔåÆÔéÉ[F] L) : f.fieldRange Ôëñ normalClosure F K L :=
  le_iSup AlgHom.fieldRange f

namespace Algebra.IsAlgebraic
variable [Algebra.IsAlgebraic F K]

lemma normalClosure_le_iSup_adjoin :
    normalClosure F K L Ôëñ Ô¿å x : K, IntermediateField.adjoin F ((minpoly F x).rootSet L) :=
  iSup_le fun f _ Ôƒ¿x, hxÔƒ® Ôåª le_iSup (╬▒ := IntermediateField F L) _ x <|
    IntermediateField.subset_adjoin F _ <| by
      rw [mem_rootSet_of_ne (minpoly.ne_zero (Algebra.IsIntegral.isIntegral x)), ÔåÉ hx,
        AlgHom.toRingHom_eq_coe, AlgHom.coe_toRingHom, aeval_algHom_apply, minpoly.aeval, map_zero]

variable (splits : ÔêÇ x : K, ((minpoly F x).map (algebraMap F L)).Splits)

include splits in
lemma normalClosure_eq_iSup_adjoin_of_splits :
    normalClosure F K L = Ô¿å x : K, IntermediateField.adjoin F ((minpoly F x).rootSet L) :=
  normalClosure_le_iSup_adjoin.antisymm <|
    iSup_le fun x Ôåª IntermediateField.adjoin_le_iff.mpr fun _ hy Ôåª
      let Ôƒ¿¤å, h¤åÔƒ® := IntermediateField.exists_algHom_of_splits_of_aeval
        (fun x Ôåª Ôƒ¿Algebra.IsIntegral.isIntegral x, splits xÔƒ®) (mem_rootSet.mp hy).2
      le_iSup AlgHom.fieldRange ¤å Ôƒ¿x, h¤åÔƒ®

/-- If `K/F` is algebraic, the "generated by roots" condition in IsNormalClosure can be replaced
  by "generated by images of embeddings". -/
lemma isNormalClosure_iff : IsNormalClosure F K L Ôåö
    (ÔêÇ x : K, ((minpoly F x).map (algebraMap F L)).Splits) Ôêº normalClosure F K L = Ôèñ := by
  refine Ôƒ¿fun Ôƒ¿splits, hÔƒ® Ôåª Ôƒ¿splits, ?_Ôƒ®, fun Ôƒ¿splits, hÔƒ® Ôåª Ôƒ¿splits, ?_Ôƒ®Ôƒ® <;>
    simpa only [normalClosure_eq_iSup_adjoin_of_splits splits] using h
-- TODO: IntermediateField.isNormalClosure_iff similar to IntermediateField.isSplittingField_iff

set_option backward.isDefEq.respectTransparency false in
include splits in
/-- `normalClosure F K L` is a valid normal closure if `K/F` is algebraic
  and all minimal polynomials of `K/F` splits in `L/F`. -/
lemma isNormalClosure_normalClosure : IsNormalClosure F K (normalClosure F K L) := by
  rw [isNormalClosure_iff]; constructor
  ┬À rw [normalClosure_eq_iSup_adjoin_of_splits splits]
    exact fun x Ôåª splits_of_splits (splits x) ((IntermediateField.subset_adjoin F _).trans <|
      SetLike.coe_subset_coe.mpr <| by apply le_iSup _ x)
  simp_rw [normalClosure, ÔåÉ top_le_iff]
  refine fun x _ Ôåª ((Ô¿å f : K ÔåÆÔéÉ[F] L, f.fieldRange).val).injective.mem_set_image |>.mp ?_
  rw [AlgHom.toRingHom_eq_coe, RingHom.coe_coe, coe_val, ÔåÉ IntermediateField.coe_val,
    ÔåÉ IntermediateField.coe_map, IntermediateField.map_iSup]
  refine (iSup_le fun f Ôåª ?_ : normalClosure F K L Ôëñ _) x.2
  refine le_iSup_of_le (f.codRestrict _ fun x Ôåª f.fieldRange_le_normalClosure Ôƒ¿x, rflÔƒ®) ?_
  rw [AlgHom.map_fieldRange, val, AlgHom.val_comp_codRestrict]

end Algebra.IsAlgebraic

/-- A normal closure of `K/F` embeds into any `L/F`
  where the minimal polynomials of `K/F` splits. -/
noncomputable def IsNormalClosure.lift [h : IsNormalClosure F K L] {L'} [Field L'] [Algebra F L']
    (splits : ÔêÇ x : K, ((minpoly F x).map (algebraMap F L')).Splits) : L ÔåÆÔéÉ[F] L' := by
  have := h.adjoin_rootSet; rw [ÔåÉ gc.l_iSup] at this
  refine Nonempty.some <| nonempty_algHom_of_adjoin_splits
    (fun x hx Ôåª Ôƒ¿isAlgebraic_iff_isIntegral.mp ((h.normal).isAlgebraic x), ?_Ôƒ®) this
  obtain Ôƒ¿y, hxÔƒ® := Set.mem_iUnion.mp hx
  by_cases iy : IsIntegral F y
  ┬À exact (splits y).of_dvd (map_ne_zero (minpoly.ne_zero iy))
      ((map_dvd_map' _).mpr (minpoly.dvd F x (mem_rootSet.mp hx).2))
  ┬À simp [minpoly.eq_zero iy] at hx

/-- Normal closures of `K/F` are unique up to F-algebra isomorphisms. -/
noncomputable def IsNormalClosure.equiv {L'} [Field L'] [Algebra F L']
    [h : IsNormalClosure F K L] [h' : IsNormalClosure F K L'] : L ÔëâÔéÉ[F] L' :=
  have := h.normal
  AlgEquiv.ofBijective _ <| And.left <|
    Normal.toIsAlgebraic.algHom_bijectiveÔéé
      (IsNormalClosure.lift fun _ : K Ôåª h'.splits _)
      (IsNormalClosure.lift fun _ : K Ôåª h.splits _)

variable (F K L)

instance isNormalClosure_normalClosure [ne : Nonempty (K ÔåÆÔéÉ[F] L)] [h : Normal F L] :
    IsNormalClosure F K (normalClosure F K L) := by
  have Ôƒ¿¤åÔƒ® := ne
  apply (h.toIsAlgebraic.of_injective ¤å ¤å.injective).isNormalClosure_normalClosure
  simp_rw [ÔåÉ minpoly.algHom_eq _ ¤å.injective]
  exact fun _ Ôåª h.splits _

theorem normalClosure_eq_iSup_adjoin' [ne : Nonempty (K ÔåÆÔéÉ[F] L)] [h : Normal F L] :
    normalClosure F K L = Ô¿å x : K, adjoin F ((minpoly F x).rootSet L) := by
  have Ôƒ¿¤åÔƒ® := ne
  refine h.toIsAlgebraic.of_injective ¤å ¤å.injective
    |>.normalClosure_eq_iSup_adjoin_of_splits fun x Ôåª ?_
  rw [ÔåÉ minpoly.algHom_eq _ ¤å.injective]
  apply h.splits

theorem normalClosure_eq_iSup_adjoin [Algebra K L] [IsScalarTower F K L] [Normal F L] :
    normalClosure F K L = Ô¿å x : K, adjoin F ((minpoly F x).rootSet L) :=
  normalClosure_eq_iSup_adjoin' (ne := Ôƒ¿IsScalarTower.toAlgHom F K LÔƒ®)

namespace normalClosure

/-- All `F`-`AlgHom`s from `K` to `L` factor through the normal closure of `K/F` in `L/F`. -/
noncomputable def algHomEquiv : (K ÔåÆÔéÉ[F] normalClosure F K L) Ôëâ (K ÔåÆÔéÉ[F] L) where
  toFun := (normalClosure F K L).val.comp
  invFun f := f.codRestrict _ fun x Ôåª f.fieldRange_le_normalClosure Ôƒ¿x, rflÔƒ®

@[stacks 0BMG "(1) normality."]
instance normal [h : Normal F L] : Normal F (normalClosure F K L) := by
  obtain _ | ¤å := isEmpty_or_nonempty (K ÔåÆÔéÉ[F] L)
  ┬À rw [normalClosure, iSup_of_empty]; exact Normal.of_algEquiv (botEquiv F L).symm
  ┬À exact (isNormalClosure_normalClosure F K L).normal

@[stacks 0BMG "When `L` is normal over `K`, this agrees with 0BMG (1) finiteness."]
instance is_finiteDimensional [FiniteDimensional F K] :
    FiniteDimensional F (normalClosure F K L) := by
  haveI : ÔêÇ f : K ÔåÆÔéÉ[F] L, FiniteDimensional F f.fieldRange := fun f Ôåª
    f.toLinearMap.finiteDimensional_range
  apply IntermediateField.finiteDimensional_iSup_of_finite

variable [Algebra K L] [IsScalarTower F K L]

noncomputable instance algebra : Algebra K (normalClosure F K L) :=
  inferInstanceAs <| Algebra K
    { Ô¿å f : K ÔåÆÔéÉ[F] L, f.fieldRange with
      algebraMap_mem' := fun r Ôåª (toAlgHom F K L).fieldRange_le_normalClosure Ôƒ¿r, rflÔƒ® }

instance : IsScalarTower F K (normalClosure F K L) := by
  apply of_algebraMap_eq'
  ext x
  exact algebraMap_apply F K L x

instance : IsScalarTower K (normalClosure F K L) L :=
  of_algebraMap_eq' rfl

lemma restrictScalars_eq :
    (toAlgHom K (normalClosure F K L) L).fieldRange.restrictScalars F = normalClosure F K L :=
  SetLike.ext' Subtype.range_val

end normalClosure

variable {F K L}

open Cardinal in
/-- An extension `L/F` in which every minimal polynomial of `K/F` splits is maximal with respect
  to `F`-embeddings of `K`, in the sense that `K ÔåÆÔéÉ[F] L` achieves maximal cardinality.
  We construct an explicit injective function from an arbitrary `K ÔåÆÔéÉ[F] L'` into `K ÔåÆÔéÉ[F] L`,
  using an embedding of `normalClosure F K L'` into `L`. -/
noncomputable def Algebra.IsAlgebraic.algHomEmbeddingOfSplits [Algebra.IsAlgebraic F K]
    (h : ÔêÇ x : K, ((minpoly F x).map (algebraMap F L)).Splits) (L' : Type*) [Field L']
    [Algebra F L'] : (K ÔåÆÔéÉ[F] L') Ôå¬ (K ÔåÆÔéÉ[F] L) :=
  let ¤å : Ôåæ(Ô¿å x : K, IntermediateField.adjoin F ((minpoly F x).rootSet L')) ÔåÆÔéÉ[F] L :=
    Nonempty.some <| by
      rw [ÔåÉ gc.l_iSup]
      refine nonempty_algHom_adjoin_of_splits fun x hx Ôåª ?_
      obtain Ôƒ¿y, hxÔƒ® := Set.mem_iUnion.mp hx
      refine Ôƒ¿isAlgebraic_iff_isIntegral.mp (isAlgebraic_of_mem_rootSet hx), ?_Ôƒ®
      by_cases iy : IsIntegral F y
      ┬À exact (h y).of_dvd (map_ne_zero (minpoly.ne_zero iy))
          ((map_dvd_map' _).mpr (minpoly.dvd F x (mem_rootSet.mp hx).2))
      ┬À simp [minpoly.eq_zero iy] at hx
  let ¤å' := (¤å.comp <| inclusion normalClosure_le_iSup_adjoin)
  { toFun := ¤å'.comp Ôêÿ (normalClosure.algHomEquiv F K L').symm
    inj' := fun _ _ h Ôåª (normalClosure.algHomEquiv F K L').symm.injective <| by
      rw [DFunLike.ext'_iff] at h Ôèó
      exact ¤å'.injective.comp_left h }

namespace IntermediateField

variable (K K' : IntermediateField F L)

lemma le_normalClosure : K Ôëñ normalClosure F K L :=
  K.fieldRange_val.symm.trans_le K.val.fieldRange_le_normalClosure

lemma normalClosure_of_normal [Normal F K] : normalClosure F K L = K := by
  simp only [normalClosure_def, AlgHom.fieldRange_of_normal, iSup_const]

variable [Normal F L]

lemma normalClosure_def' : normalClosure F K L = Ô¿å f : L ÔåÆÔéÉ[F] L, K.map f := by
  refine (normalClosure_def F K L).trans (le_antisymm (iSup_le (fun f Ôåª ?_)) (iSup_le (fun f Ôåª ?_)))
  ┬À exact le_iSup_of_le (f.liftNormal L) (fun b Ôƒ¿a, hÔƒ® Ôåª Ôƒ¿a, a.2, h Ôû© f.liftNormal_commutes L aÔƒ®)
  ┬À exact le_iSup_of_le (f.comp K.val) (fun b Ôƒ¿a, hÔƒ® Ôåª Ôƒ¿Ôƒ¿a, h.1Ôƒ®, h.2Ôƒ®)

lemma normalClosure_def'' : normalClosure F K L = Ô¿å f : Gal(L/F), K.map f := by
  refine (normalClosure_def' K).trans (le_antisymm (iSup_le (fun f Ôåª ?_)) (iSup_le (fun f Ôåª ?_)))
  ┬À exact le_iSup_of_le (f.restrictNormal' L)
      (fun b Ôƒ¿a, hÔƒ® Ôåª Ôƒ¿a, h.1, h.2 Ôû© f.restrictNormal_commutes L aÔƒ®)
  ┬À exact le_iSup_of_le f le_rfl

lemma normalClosure_mono (h : K Ôëñ K') : normalClosure F K L Ôëñ normalClosure F K' L := by
  rw [normalClosure_def', normalClosure_def']
  exact iSup_mono (fun f Ôåª map_mono f h)

variable (F L)

/-- `normalClosure` as a `ClosureOperator`. -/
@[simps]
noncomputable def normalClosureOperator : ClosureOperator (IntermediateField F L) where
  toFun K := normalClosure F K L
  monotone' K K' := normalClosure_mono K K'
  le_closure' := le_normalClosure
  idempotent' K := normalClosure_of_normal (normalClosure F K L)

@[deprecated (since := "2025-11-21")] alias closureOperator := normalClosureOperator

variable {K : IntermediateField F L} {F L}

lemma normal_iff_normalClosure_eq : Normal F K Ôåö normalClosure F K L = K :=
  Ôƒ¿@normalClosure_of_normal (K := K), fun h Ôåª h Ôû© normalClosure.normal F K LÔƒ®

lemma normal_iff_normalClosure_le : Normal F K Ôåö normalClosure F K L Ôëñ K :=
  normal_iff_normalClosure_eq.trans (le_normalClosure K).ge_iff_eq'.symm

lemma normal_iff_forall_fieldRange_le : Normal F K Ôåö ÔêÇ ¤â : K ÔåÆÔéÉ[F] L, ¤â.fieldRange Ôëñ K := by
  rw [normal_iff_normalClosure_le, normalClosure_def, iSup_le_iff]

lemma normal_iff_forall_map_le : Normal F K Ôåö ÔêÇ ¤â : L ÔåÆÔéÉ[F] L, K.map ¤â Ôëñ K := by
  rw [normal_iff_normalClosure_le, normalClosure_def', iSup_le_iff]

lemma normal_iff_forall_map_le' : Normal F K Ôåö ÔêÇ ¤â : Gal(L/F), K.map Ôåæ¤â Ôëñ K := by
  rw [normal_iff_normalClosure_le, normalClosure_def'', iSup_le_iff]

/-- If `L/K/F` is a field tower where `L/F` is normal, then
`K` is normal over `F` if and only if `¤â(K) = K` for every `¤â Ôêê K ÔåÆÔéÉ[F] L`. -/
@[stacks 09HQ "stronger version replacing an algebraic closure by a normal extension"]
lemma normal_iff_forall_fieldRange_eq : Normal F K Ôåö ÔêÇ ¤â : K ÔåÆÔéÉ[F] L, ¤â.fieldRange = K :=
Ôƒ¿@AlgHom.fieldRange_of_normal (E := K), normal_iff_forall_fieldRange_le.2 Ôêÿ fun h ¤â Ôåª (h ¤â).leÔƒ®

lemma normal_iff_forall_map_eq : Normal F K Ôåö ÔêÇ ¤â : L ÔåÆÔéÉ[F] L, K.map ¤â = K :=
Ôƒ¿fun h ¤â Ôåª (K.fieldRange_val Ôû© AlgHom.map_fieldRange K.val ¤â).trans
  (normal_iff_forall_fieldRange_eq.1 h _), fun h Ôåª normal_iff_forall_map_le.2 (fun ¤â Ôåª (h ¤â).le)Ôƒ®

lemma normal_iff_forall_map_eq' : Normal F K Ôåö ÔêÇ ¤â : Gal(L/F), K.map ¤â.toAlgHom = K :=
  Ôƒ¿fun h ¤â Ôåª normal_iff_forall_map_eq.1 h ¤â, fun h Ôåª normal_iff_forall_map_le'.2 (fun ¤â Ôåª (h ¤â).le)Ôƒ®

@[simp]
lemma normalClosure_map_eq (K : IntermediateField F L) (¤â : L ÔåÆÔéÉ[F] L) :
    normalClosure F (K.map ¤â) L = normalClosure F K L := by
  have (¤â : Gal(L/F)) : normalClosure F (K.map (¤â : L ÔåÆÔéÉ[F] L)) L = normalClosure F K L := by
    simp_rw [normalClosure_def'', map_map]
    exact (Equiv.mulRight ¤â).iSup_congr fun _ Ôåª rfl
  exact this ((Algebra.IsAlgebraic.algEquivEquivAlgHom _ _).symm ¤â)

@[simp]
theorem normalClosure_le_iff_of_normal {KÔéü KÔéé : IntermediateField F L} [Normal F KÔéé] :
    normalClosure F KÔéü L Ôëñ KÔéé Ôåö KÔéü Ôëñ KÔéé := by
  refine Ôƒ¿fun h Ôåª ?_, fun h Ôåª ?_Ôƒ®
  ┬À rw [normalClosure_le_iff] at h
    simpa only [fieldRange_val] using h KÔéü.val
  ┬À rw [ÔåÉ normalClosure_of_normal KÔéé]
    exact normalClosure_mono KÔéü KÔéé h

end IntermediateField
