import Mathlib.FieldTheory.Extension
import Mathlib.FieldTheory.Normal.Defs
import Mathlib.GroupTheory.Solvable
import Mathlib.FieldTheory.SplittingField.Construction

/-!
# Normal field extensions

In this file we prove that for a finite extension, being normal
is the same as being a splitting field (`Normal.of_isSplittingField` and
`Normal.exists_isSplittingField`).

## Additional Results

* `Algebra.IsQuadraticExtension.normal`: the instance that a quadratic extension, given as a class
  `Algebra.IsQuadraticExtension`, is normal.

-/


noncomputable section

open Polynomial IsScalarTower

variable (F K : Type*) [Field F] [Field K] [Algebra F K]

theorem Normal.exists_isSplittingField [h : Normal F K] [FiniteDimensional F K] :
    ‚ąÉ p : F[X], IsSplittingField F K p := by
  classical
  let s := Module.Basis.ofVectorSpace F K
  refine
    ‚ü®‚ąŹ x, minpoly F (s x), splits_prod _ fun x _ => h.splits (s x),
      Subalgebra.toSubmodule.injective ?_‚ü©
  rw [Algebra.top_toSubmodule, eq_top_iff, ‚Üź s.span_eq, Submodule.span_le, Set.range_subset_iff]
  refine fun x =>
    Algebra.subset_adjoin
      (Multiset.mem_toFinset.mpr <|
        (mem_roots <|
              mt (Polynomial.map_eq_zero <| algebraMap F K).1 <|
                Finset.prod_ne_zero_iff.2 fun x _ => ?_).2 ?_)
  ¬∑ exact minpoly.ne_zero (h.isIntegral (s x))
  rw [IsRoot.def, eval_map, ‚Üź aeval_def, map_prod]
  exact Finset.prod_eq_zero (Finset.mem_univ _) (minpoly.aeval _ _)

section NormalTower

variable (E : Type*) [Field E] [Algebra F E] [Algebra K E] [IsScalarTower F K E]

variable {E F}

open IntermediateField

@[stacks 09HU "Normal part"]
theorem Normal.of_isSplittingField (p : F[X]) [hFEp : IsSplittingField F E p] : Normal F E := by
  rcases eq_or_ne p 0 with (rfl | hp)
  ¬∑ have := hFEp.adjoin_rootSet
    rw [rootSet_zero, Algebra.adjoin_empty] at this
    exact Normal.of_algEquiv
      (AlgEquiv.ofBijective (Algebra.ofId F E) (Algebra.bijective_algebraMap_iff.2 this.symm))
  refine normal_iff.mpr fun x ‚Ü¶ ?_
  haveI : FiniteDimensional F E := IsSplittingField.finiteDimensional E p
  have hx := IsIntegral.of_finite F x
  let L := (p * minpoly F x).SplittingField
  have hL := splits_of_splits_mul' _ ?_ (SplittingField.splits (p * minpoly F x))
  ¬∑ let j : E ‚Üí‚āź[F] L := IsSplittingField.lift E p hL.1
    refine ‚ü®hx, splits_of_comp _ (j : E ‚Üí+* L) (j.comp_algebraMap ‚Ėł hL.2) fun a ha ‚Ü¶ ?_‚ü©
    rw [j.comp_algebraMap] at ha
    letI : Algebra F‚üģx‚üĮ L := ((algHomAdjoinIntegralEquiv F hx).symm ‚ü®a, ha‚ü©).toRingHom.toAlgebra
    let j' : E ‚Üí‚āź[F‚üģx‚üĮ] L := IsSplittingField.lift E (p.map (algebraMap F F‚üģx‚üĮ)) ?_
    ¬∑ change a ‚ąą j.range
      rw [‚Üź IsSplittingField.adjoin_rootSet_eq_range E p j,
            IsSplittingField.adjoin_rootSet_eq_range E p (j'.restrictScalars F)]
      exact ‚ü®x, (j'.commutes _).trans (algHomAdjoinIntegralEquiv_symm_apply_gen F hx _)‚ü©
    ¬∑ rw [splits_map_iff, ‚Üź IsScalarTower.algebraMap_eq]; exact hL.1
  ¬∑ rw [Polynomial.map_ne_zero_iff (algebraMap F L).injective, mul_ne_zero_iff]
    exact ‚ü®hp, minpoly.ne_zero hx‚ü©

instance Polynomial.SplittingField.instNormal (p : F[X]) : Normal F p.SplittingField :=
  Normal.of_isSplittingField p

end NormalTower

namespace IntermediateField

/-- A compositum of normal extensions is normal. -/
instance normal_iSup {őĻ : Type*} (t : őĻ ‚Üí IntermediateField F K) [h : ‚ąÄ i, Normal F (t i)] :
    Normal F (‚®Ü i, t i : IntermediateField F K) := by
  refine { toIsAlgebraic := isAlgebraic_iSup fun i => (h i).1, splits' := fun x => ?_ }
  obtain ‚ü®s, hx‚ü© := exists_finset_of_mem_supr'' (fun i => (h i).1) x.2
  let E : IntermediateField F K := ‚®Ü i ‚ąą s, adjoin F ((minpoly F (i.2 :)).rootSet K)
  have hF : Normal F E := by
    haveI : IsSplittingField F E (‚ąŹ i ‚ąą s, minpoly F i.snd) := by
      refine isSplittingField_iSup ?_ fun i _ => adjoin_rootSet_isSplittingField ?_
      ¬∑ exact Finset.prod_ne_zero_iff.mpr fun i _ => minpoly.ne_zero ((h i.1).isIntegral i.2)
      ¬∑ exact Polynomial.splits_comp_of_splits _ (algebraMap (t i.1) K) ((h i.1).splits i.2)
    apply Normal.of_isSplittingField (‚ąŹ i ‚ąą s, minpoly F i.2)
  have hE : E ‚Č§ ‚®Ü i, t i := by
    refine iSup_le fun i => iSup_le fun _ => le_iSup_of_le i.1 ?_
    rw [adjoin_le_iff, ‚Üź image_rootSet ((h i.1).splits i.2) (t i.1).val]
    exact fun _ ‚ü®a, _, h‚ü© => h ‚Ėł a.2
  have := hF.splits ‚ü®x, hx‚ü©
  rw [minpoly_eq, Subtype.coe_mk, ‚Üź minpoly_eq] at this
  exact Polynomial.splits_comp_of_splits _ (inclusion hE).toRingHom this

/-- If a set of algebraic elements in a field extension `K/F` have minimal polynomials that
  split in another extension `L/F`, then all minimal polynomials in the intermediate field
  generated by the set also split in `L/F`. -/
@[stacks 0BR3 "first part"]
theorem splits_of_mem_adjoin {L} [Field L] [Algebra F L] {S : Set K}
    (splits : ‚ąÄ x ‚ąą S, IsIntegral F x ‚ąß (minpoly F x).Splits (algebraMap F L)) {x : K}
    (hx : x ‚ąą adjoin F S) : (minpoly F x).Splits (algebraMap F L) := by
  let E : IntermediateField F L := ‚®Ü x : S, adjoin F ((minpoly F x.val).rootSet L)
  have normal : Normal F E := normal_iSup (h := fun x ‚Ü¶
    Normal.of_isSplittingField (hFEp := adjoin_rootSet_isSplittingField (splits x x.2).2))
  have : ‚ąÄ x ‚ąą S, (minpoly F x).Splits (algebraMap F E) := fun x hx ‚Ü¶ splits_of_splits
    (splits x hx).2 fun y hy ‚Ü¶ (le_iSup _ ‚ü®x, hx‚ü© : _ ‚Č§ E) (subset_adjoin F _ <| by exact hy)
  obtain ‚ü®ŌÜ‚ü© := nonempty_algHom_adjoin_of_splits fun x hx ‚Ü¶ ‚ü®(splits x hx).1, this x hx‚ü©
  convert splits_comp_of_splits _ E.val.toRingHom (normal.splits <| ŌÜ ‚ü®x, hx‚ü©)
  rw [minpoly.algHom_eq _ ŌÜ.injective, ‚Üź minpoly.algHom_eq _ (adjoin F S).val.injective, val_mk]

instance normal_sup
    (E E' : IntermediateField F K) [Normal F E] [Normal F E'] :
    Normal F (E ‚äĒ E' : IntermediateField F K) :=
  iSup_bool_eq (f := Bool.rec E' E) ‚Ėł normal_iSup (h := by rintro (_ | _) <;> infer_instance)

/-- An intersection of normal extensions is normal. -/
@[stacks 09HP]
instance normal_iInf {őĻ : Type*} [hőĻ : Nonempty őĻ]
    (t : őĻ ‚Üí IntermediateField F K) [h : ‚ąÄ i, Normal F (t i)] :
    Normal F (‚®Ö i, t i : IntermediateField F K) := by
  refine { toIsAlgebraic := ?_, splits' := fun x => ?_ }
  ¬∑ let f := inclusion (iInf_le t hőĻ.some)
    exact Algebra.IsAlgebraic.of_injective f f.injective
  ¬∑ have hx : ‚ąÄ i, Splits (algebraMap F (t i)) (minpoly F x) := by
      intro i
      rw [‚Üź minpoly.algHom_eq (inclusion (iInf_le t i)) (inclusion (iInf_le t i)).injective]
      exact (h i).splits' (inclusion (iInf_le t i) x)
    simp only [splits_iff_mem (splits_of_isScalarTower K (hx hőĻ.some))] at hx ‚äĘ
    rintro y hy - ‚ü®-, ‚ü®i, rfl‚ü©, rfl‚ü©
    exact hx i y hy

@[stacks 09HP]
instance normal_inf
    (E E' : IntermediateField F K) [Normal F E] [Normal F E'] :
    Normal F (E ‚äď E' : IntermediateField F K) :=
  iInf_bool_eq (f := Bool.rec E' E) ‚Ėł normal_iInf (h := by rintro (_ | _) <;> infer_instance)

end IntermediateField

variable {F} {K}
variable {K‚āĀ K‚āā K‚āÉ : Type*} [Field K‚āĀ] [Field K‚āā] [Field K‚āÉ] [Algebra F K‚āĀ]
  [Algebra F K‚āā] [Algebra F K‚āÉ] (Ōē : K‚āĀ ‚Üí‚āź[F] K‚āā) (Ōá : K‚āĀ ‚ČÉ‚āź[F] K‚āā) (Ōą : K‚āā ‚Üí‚āź[F] K‚āÉ)
  (ŌČ : K‚āā ‚ČÉ‚āź[F] K‚āÉ)

section Restrict

variable (E : Type*) [Field E] [Algebra F E] [Algebra E K‚āĀ] [Algebra E K‚āā] [Algebra E K‚āÉ]
  [IsScalarTower F E K‚āĀ] [IsScalarTower F E K‚āā] [IsScalarTower F E K‚āÉ]

theorem AlgHom.fieldRange_of_normal {E : IntermediateField F K} [Normal F E]
    (f : E ‚Üí‚āź[F] K) : f.fieldRange = E := by
  let g := f.restrictNormal' E
  rw [‚Üź show E.val.comp ‚ÜĎg = f from DFunLike.ext_iff.mpr (f.restrictNormal_commutes E),
    ‚Üź AlgHom.map_fieldRange, AlgEquiv.fieldRange_eq_top g, ‚Üź AlgHom.fieldRange_eq_map,
    IntermediateField.fieldRange_val]

end Restrict

section lift

variable (E : Type*) [Field E] [Algebra F E] [Algebra K‚āĀ E] [Algebra K‚āā E] [IsScalarTower F K‚āĀ E]
  [IsScalarTower F K‚āā E]

/-- If `E/KŠĶĘ/F` are towers of fields with `E/F` normal then we can lift
  an algebra homomorphism `Ōē : K‚āĀ ‚Üí‚āź[F] K‚āā` to `Ōē.liftNormal E : E ‚Üí‚āź[F] E`. -/
@[stacks 0BME "Part 2"]
noncomputable def AlgHom.liftNormal [h : Normal F E] : E ‚Üí‚āź[F] E :=
  @AlgHom.restrictScalars F K‚āĀ E E _ _ _ _ _ _
      ((IsScalarTower.toAlgHom F K‚āā E).comp Ōē).toRingHom.toAlgebra _ _ _ _ <|
    Nonempty.some <|
      @IntermediateField.nonempty_algHom_of_adjoin_splits _ _ _ _ _ _ _
        ((IsScalarTower.toAlgHom F K‚āā E).comp Ōē).toRingHom.toAlgebra _
        (fun x _ ‚Ü¶ ‚ü®(h.out x).1.tower_top,
          splits_of_splits_of_dvd _ (map_ne_zero (minpoly.ne_zero (h.out x).1))
            (by rw [splits_map_iff, ‚Üź IsScalarTower.algebraMap_eq]
                exact (h.out x).2)
            (minpoly.dvd_map_of_isScalarTower F K‚āĀ x)‚ü©)
        (IntermediateField.adjoin_univ _ _)

@[simp]
theorem AlgHom.liftNormal_commutes [Normal F E] (x : K‚āĀ) :
    Ōē.liftNormal E (algebraMap K‚āĀ E x) = algebraMap K‚āā E (Ōē x) :=
  -- We have to specify one `Algebra` instance by unification, not synthesis.
  @AlgHom.commutes K‚āĀ E E _ _ _ _ (_) _ _

@[simp]
theorem AlgHom.restrict_liftNormal (Ōē : K‚āĀ ‚Üí‚āź[F] K‚āĀ) [Normal F K‚āĀ] [Normal F E] :
    (Ōē.liftNormal E).restrictNormal K‚āĀ = Ōē :=
  AlgHom.ext fun x =>
    (algebraMap K‚āĀ E).injective
      (Eq.trans (AlgHom.restrictNormal_commutes _ K‚āĀ x) (Ōē.liftNormal_commutes E x))

/-- If `E/KŠĶĘ/F` are towers of fields with `E/F` normal then we can lift
  an algebra isomorphism `Ōē : K‚āĀ ‚ČÉ‚āź[F] K‚āā` to `Ōē.liftNormal E : E ‚ČÉ‚āź[F] E`. -/
noncomputable def AlgEquiv.liftNormal [Normal F E] : E ‚ČÉ‚āź[F] E :=
  AlgEquiv.ofBijective (Ōá.toAlgHom.liftNormal E) (AlgHom.normal_bijective F E E _)

@[simp]
theorem AlgEquiv.liftNormal_commutes [Normal F E] (x : K‚āĀ) :
    Ōá.liftNormal E (algebraMap K‚āĀ E x) = algebraMap K‚āā E (Ōá x) :=
  Ōá.toAlgHom.liftNormal_commutes E x

@[simp]
theorem AlgEquiv.restrict_liftNormal (Ōá : K‚āĀ ‚ČÉ‚āź[F] K‚āĀ) [Normal F K‚āĀ] [Normal F E] :
    (Ōá.liftNormal E).restrictNormal K‚āĀ = Ōá :=
  AlgEquiv.ext fun x =>
    (algebraMap K‚āĀ E).injective
      (Eq.trans (AlgEquiv.restrictNormal_commutes _ K‚āĀ x) (Ōá.liftNormal_commutes E x))

/-- The group homomorphism given by restricting an algebra isomorphism to a normal subfield
is surjective. -/
theorem AlgEquiv.restrictNormalHom_surjective [Normal F K‚āĀ] [Normal F E] :
    Function.Surjective (AlgEquiv.restrictNormalHom K‚āĀ : (E ‚ČÉ‚āź[F] E) ‚Üí K‚āĀ ‚ČÉ‚āź[F] K‚āĀ) := fun Ōá =>
  ‚ü®Ōá.liftNormal E, Ōá.restrict_liftNormal E‚ü©

open IntermediateField in
theorem Normal.minpoly_eq_iff_mem_orbit [h : Normal F E] {x y : E} :
    minpoly F x = minpoly F y ‚ÜĒ x ‚ąą MulAction.orbit (E ‚ČÉ‚āź[F] E) y := by
  refine ‚ü®fun he ‚Ü¶ ?_, fun ‚ü®f, he‚ü© ‚Ü¶ he ‚Ėł minpoly.algEquiv_eq f y‚ü©
  obtain ‚ü®ŌÜ, hŌÜ‚ü© := exists_algHom_of_splits_of_aeval (normal_iff.mp h) (he ‚Ėł minpoly.aeval F x)
  exact ‚ü®AlgEquiv.ofBijective ŌÜ (ŌÜ.normal_bijective F E E), hŌÜ‚ü©

variable (F K‚āĀ)

theorem isSolvable_of_isScalarTower [Normal F K‚āĀ] [h1 : IsSolvable (K‚āĀ ‚ČÉ‚āź[F] K‚āĀ)]
    [h2 : IsSolvable (E ‚ČÉ‚āź[K‚āĀ] E)] : IsSolvable (E ‚ČÉ‚āź[F] E) := by
  let f : (E ‚ČÉ‚āź[K‚āĀ] E) ‚Üí* E ‚ČÉ‚āź[F] E :=
    { toFun := fun Ōē =>
        AlgEquiv.ofAlgHom (Ōē.toAlgHom.restrictScalars F) (Ōē.symm.toAlgHom.restrictScalars F)
          (AlgHom.ext fun x => Ōē.apply_symm_apply x) (AlgHom.ext fun x => Ōē.symm_apply_apply x)
      map_one' := AlgEquiv.ext fun _ => rfl
      map_mul' := fun _ _ => AlgEquiv.ext fun _ => rfl }
  refine
    solvable_of_ker_le_range f (AlgEquiv.restrictNormalHom K‚āĀ) fun Ōē hŌē =>
      ‚ü®{ Ōē with commutes' := fun x => ?_ }, AlgEquiv.ext fun _ => rfl‚ü©
  exact Eq.trans (Ōē.restrictNormal_commutes K‚āĀ x).symm (congr_arg _ (AlgEquiv.ext_iff.mp hŌē x))

end lift

namespace minpoly

variable {K L : Type _} [Field K] [Field L] [Algebra K L]

open AlgEquiv IntermediateField

/-- If `x : L` is a root of `minpoly K y`, then we can find `(ŌÉ : L ‚ČÉ‚āź[K] L)` with `ŌÉ x = y`.
  That is, `x` and `y` are Galois conjugates. -/
theorem exists_algEquiv_of_root [Normal K L] {x y : L} (hy : IsAlgebraic K y)
    (h_ev : (Polynomial.aeval x) (minpoly K y) = 0) : ‚ąÉ ŌÉ : L ‚ČÉ‚āź[K] L, ŌÉ x = y := by
  have hx : IsAlgebraic K x := ‚ü®minpoly K y, ne_zero hy.isIntegral, h_ev‚ü©
  set f : K‚üģx‚üĮ ‚ČÉ‚āź[K] K‚üģy‚üĮ := algEquiv hx (eq_of_root hy h_ev)
  have hxy : (liftNormal f L) ((algebraMap (‚Ü•K‚üģx‚üĮ) L) (AdjoinSimple.gen K x)) = y := by
    rw [liftNormal_commutes f L, algEquiv_apply, AdjoinSimple.algebraMap_gen K y]
  exact ‚ü®(liftNormal f L), hxy‚ü©

/-- If `x : L` is a root of `minpoly K y`, then we can find `(ŌÉ : L ‚ČÉ‚āź[K] L)` with `ŌÉ y = x`.
  That is, `x` and `y` are Galois conjugates. -/
theorem exists_algEquiv_of_root' [Normal K L] {x y : L} (hy : IsAlgebraic K y)
    (h_ev : (Polynomial.aeval x) (minpoly K y) = 0) : ‚ąÉ ŌÉ : L ‚ČÉ‚āź[K] L, ŌÉ y = x := by
  obtain ‚ü®ŌÉ, hŌÉ‚ü© := exists_algEquiv_of_root hy h_ev
  use ŌÉ.symm
  rw [‚Üź hŌÉ, symm_apply_apply]

end minpoly

/--
A quadratic extension is normal.
-/
instance Algebra.IsQuadraticExtension.normal (F K : Type*) [Field F] [Field K] [Algebra F K]
    [IsQuadraticExtension F K] :
    Normal F K where
  splits' := by
    intro x
    obtain h | h := le_iff_lt_or_eq.mp (finrank_eq_two F K ‚Ėł minpoly.natDegree_le x)
    ¬∑ exact splits_of_natDegree_le_one _ (by rwa [Nat.le_iff_lt_add_one])
    ¬∑ exact splits_of_natDegree_eq_two _ h (minpoly.aeval F x)

