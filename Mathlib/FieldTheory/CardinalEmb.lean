variable (F E) in
/-- The functor on `WithTop ╬╣` given by embeddings of `EÔč«<iÔč»` into `─ĺ` -/
def embFunctor ÔŽâi j : WithTop ╬╣ÔŽä (h : i ÔëĄ j) (f : EÔč«<jÔč» ÔćĺÔéÉ[F] ─ĺ) : EÔč«<iÔč» ÔćĺÔéÉ[F] ─ĺ :=
  f.comp (Subalgebra.inclusion <| filtration.monotone h)

instance : InverseSystem (embFunctor F E) where
  map_self _ _ := rfl
  map_map _ _ _ _ _ _ := rfl

set_option backward.privateInPublic true in
private local instance (i : ╬╣) : Decidable (succ i = i) := .isFalse (lt_succ i).ne'

/-- Extend `succEquiv` from `╬╣` to `WithTop ╬╣`. -/
def equivSucc (i : WithTop ╬╣) : (EÔč«<iÔü║Ôč» ÔćĺÔéÉ[F] ─ĺ) Ôëâ (EÔč«<iÔč» ÔćĺÔéÉ[F] ─ĺ) ├Ś factor i :=
  i.recTopCoe (((equivOfEq <| by rw [succ_top]).arrowCongr .refl).trans <| .symm <| .prodPUnit _)
    (succEquiv ┬Ě)

theorem equivSucc_coherence (i f) : (equivSucc i f).1 = embFunctor F E (le_succ i) f := by
  cases i; exacts [rfl, succEquiv_coherence _ f]

