open WithTop

lemma eq_bot_of_not_nonempty (hi : ┬Č Nonempty (Iio i)) : filtration i = ÔŐą := by
  cases i
  ┬Ě have := mk_ne_zero_iff.mp (rank_pos.trans_eq (mk_ord_toType <| Module.rank F E).symm).ne'
    rw [ÔćÉ range_coe] at hi; exact (hi inferInstance).elim
  ┬Ě exact bot_unique <| adjoin_le_iff.mpr fun _ ÔčĘj, hj, _Ôčę ÔćŽ (hi ÔčĘj, coe_lt_coe.mpr hjÔčę).elim

open scoped Classical in
/-- If `i` is a limit, the type of embeddings of `EÔč«<iÔč»` into `─ĺ` is
the limit of the types of embeddings of `EÔč«<jÔč»` for `j < i`. -/
def equivLim : (EÔč«<iÔč» ÔćĺÔéÉ[F] ─ĺ) Ôëâ limit (embFunctor F E) i where
  toFun f := ÔčĘfun j ÔćŽ embFunctor _ _ (id j.2 : j < i).le f, fun _ _ _ ÔćŽ rflÔčę
  invFun f := if h : Nonempty (Iio i) then
    Subalgebra.iSupLift _ directed_filtration f.1
      (fun _ _ h ÔćŽ (f.2 <| filtration.map_rel_iff.mp h).symm) _ <| by
        rw [ÔćÉ iSup_filtration hi, toSubalgebra_iSup_of_directed directed_filtration]
    else (Algebra.ofId F ─ĺ).comp ((equivOfEq (eq_bot_of_not_nonempty hi h)).trans <| botEquiv F E)
  left_inv f := by
    split_ifs with h
    ┬Ě ext ÔčĘx, hxÔčę
      rw [ÔćÉ iSup_filtration hi, mem_toSubalgebra, ÔćÉ SetLike.mem_coe,
          coe_iSup_of_directed directed_filtration, mem_iUnion] at hx
      rw [Subalgebra.iSupLift_of_mem _ _ (by exact hx.choose_spec)]; rfl
    ┬Ě apply AlgHom.ext
      rw [((equivOfEq (eq_bot_of_not_nonempty hi h)).trans <| botEquiv F E).forall_congr_left]
      simp
  right_inv f := Subtype.ext <| funext fun j ÔćŽ by
    have := Nonempty.intro j
    simp_rw [dif_pos this]
    apply Subalgebra.iSupLift_comp_inclusion

theorem equivLim_coherence (x l) : (equivLim hi x).1 l = embFunctor F E (mem_Iio.mp l.2).le x :=
  rfl

end Lim

/-- A bijection between `E ÔćĺÔéÉ[F] ─ĺ` and the product of `EÔč«<iÔü║Ôč» ÔćĺÔéÉ[EÔč«<iÔč»] ─ĺ` over all `i : ╬╣`. -/
def embEquivPi : Field.Emb F E Ôëâ ÔłÇ i : ╬╣, factor (F := F) (E := E) i :=
  let e := globalEquiv
    (fun i _ ÔćŽ ÔčĘ_, equivSucc_coherence iÔčę) (fun _ hi ÔćŽ ÔčĘequivLim hi, fun _ _ ÔćŽ rflÔčę) ÔŐĄ
  (topEquiv.arrowCongr .refl).symm.trans <| e.trans <| .trans (.piCongrSet WithTop.range_coe.symm)
    <| .symm <| .piCongr (.ofInjective _ WithTop.coe_injective) fun _ ÔćŽ .refl _

