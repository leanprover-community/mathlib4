open Field in
theorem two_le_deg (i : ╬╣) : 2 ÔëĄ #(X i) := by
  rw [ÔćÉ Nat.cast_ofNat, ÔćÉ toNat_le_iff_le_of_lt_aleph0 natCast_lt_aleph0 (deg_lt_aleph0 i),
    toNat_natCast, ÔćÉ Nat.card, ÔćÉ finSepDegree, finSepDegree_eq_finrank_of_isSeparable,
    Nat.succ_le_iff]
  by_contra!
  obtain ÔčĘx, hxÔčę := finrank_adjoin_simple_eq_one_iff.mp (this.antisymm Module.finrank_pos)
  refine (isLeast_leastExt i).1 (hx ÔľŞ ?_)
  exact x.2

end

