variable (F E) in
/-- `leastExt i` is defined to be the smallest `k : ╬╣` that generates a nontrivial extension over
(i.e. does not lie in) the subalgebra (= intermediate field) generated by all previous
`leastExt j`, `j < i`. For cardinality reasons, such `k` always exist if `╬╣` is infinite. -/
def leastExt : ╬╣ Ôćĺ ╬╣ :=
  wellFounded_lt.fix fun i ih ÔćŽ
    let s := range fun j : Iio i ÔćŽ b (ih j j.2)
    wellFounded_lt.min {k | b k Ôłë adjoin F s} <| by
      rw [ÔćÉ compl_setOf, nonempty_compl]; by_contra!
      simp_rw [eq_univ_iff_forall, mem_setOf] at this
      have := adjoin_le_iff.mpr (range_subset_iff.mpr this)
      rw [adjoin_basis_eq_top, ÔćÉ eq_top_iff] at this
      apply_fun Module.rank F at this
      refine ne_of_lt ?_ this
      let _ : AddCommMonoid (ÔŐĄ : IntermediateField F E) := inferInstance
      conv_rhs => rw [topEquiv.toLinearEquiv.rank_eq]
      have := mk_Iio_lt i (by simp)
      rw [mk_toType, card_ord] at this
      obtain eq | lt := rank_inf.out.eq_or_lt
      ┬Ě simp_rw [ÔćÉ eq, mk_lt_aleph0_iff] at this
        have : FiniteDimensional F (adjoin F s) :=
          finiteDimensional_adjoin fun x _ ÔćŽ (IsAlgebraic.isAlgebraic x).isIntegral
        exact (Module.rank_lt_aleph0 _ _).trans_eq eq
      ┬Ě exact (Subalgebra.equivOfEq _ _ <| adjoin_toSubalgebra_of_isAlgebraic
          fun x _ ÔćŽ IsAlgebraic.isAlgebraic x) |>.toLinearEquiv.rank_eq.trans_lt <|
          (Algebra.rank_adjoin_le _).trans_lt (max_lt (mk_range_le.trans_lt this) lt)

local notation "¤ć" => leastExt F E

section
local notation "EÔč«<" i "Ôč»" => adjoin F (b Ôłś ¤ć '' Iio i)

theorem isLeast_leastExt (i : ╬╣) : IsLeast {k | b k Ôłë EÔč«<iÔč»} (¤ć i) := by
  rw [image_eq_range, leastExt, wellFounded_lt.fix_eq]
  exact ÔčĘwellFounded_lt.min_mem _ _, fun _ ÔćŽ (wellFounded_lt.min_le ┬Ě)Ôčę

theorem strictMono_leastExt : StrictMono ¤ć := fun i j h ÔćŽ by
  have least := isLeast_leastExt (F := F) (E := E)
  by_contra!
  obtain eq | lt := this.eq_or_lt
  ┬Ě exact (least j).1 (subset_adjoin _ _ ÔčĘi, h, congr_arg b eq.symmÔčę)
  ┬Ě refine ((least i).2 <| mt (adjoin.mono _ _ _ (image_mono ?_) ┬Ě) (least j).1).not_gt lt
    exact fun k (hk : k < i) ÔćŽ hk.trans h

theorem adjoin_image_leastExt (i : ╬╣) : EÔč«<iÔč» = adjoin F (b '' Iio (¤ć i)) := by
  refine le_antisymm (adjoin.mono _ _ _ ?_) (adjoin_le_iff.mpr ?_)
  ┬Ě rw [image_comp]; apply image_mono; rintro _ ÔčĘj, hj, rflÔčę; exact strictMono_leastExt hj
  ┬Ě rintro _ ÔčĘj, hj, rflÔčę; contrapose hj; exact ((isLeast_leastExt i).2 hj).not_gt

theorem iSup_adjoin_eq_top : ÔĘć i : ╬╣, EÔč«<iÔč» = ÔŐĄ := by
  simp_rw [adjoin_image_leastExt, eq_top_iff, ÔćÉ adjoin_basis_eq_top, adjoin_le_iff]
  rintro _ ÔčĘi, rflÔčę
  refine le_iSup (╬▒ := IntermediateField F E) _ (iÔü║) (subset_adjoin _ _ ÔčĘi, ?_, rflÔčę)
  exact (lt_succ i).trans_le strictMono_leastExt.le_apply

theorem strictMono_filtration : StrictMono (EÔč«<┬ĚÔč») :=
  fun i _ h ÔćŽ ÔčĘadjoin.mono _ _ _ (image_mono <| Iio_subset_Iio h.le),
    fun incl ÔćŽ (isLeast_leastExt i).1 (incl <| subset_adjoin _ _ ÔčĘi, h, rflÔčę)Ôčę

theorem filtration_succ (i : ╬╣) : EÔč«<iÔü║Ôč» = EÔč«<iÔč»Ôč«b (¤ć i)Ôč».restrictScalars F := by
  rw [Iio_succ, ÔćÉ Iio_insert, image_insert_eq, ÔćÉ union_singleton, adjoin_adjoin_left]; rfl

local notation "X" i => Field.Emb (EÔč«<iÔč») <| EÔč«<iÔč»Ôč«b (¤ć i)Ôč»

/-- Each embedding of `EÔč«<iÔč»` into `─ĺ` extend to `#(X i)` embeddings of `EÔč«<iÔü║Ôč»`. -/
def succEquiv (i : ╬╣) : (EÔč«<iÔü║Ôč» ÔćĺÔéÉ[F] ─ĺ) Ôëâ (EÔč«<iÔč» ÔćĺÔéÉ[F] ─ĺ) ├Ś X i :=
  (((show _ ÔëâÔéÉ[F] EÔč«<iÔč»Ôč«b (¤ć i)Ôč» from equivOfEq (filtration_succ i))).arrowCongr .refl).trans <|
    algHomEquivSigma (B := EÔč«<iÔč»).trans <| .sigmaEquivProdOfEquiv fun _ ÔćŽ
      (@Field.embEquivOfIsAlgClosed _ _ _ _ _ _ _ (_) <|
        (Algebra.IsAlgebraic.tower_top (K := F) _).of_injective (val _) Subtype.val_injective).symm

theorem succEquiv_coherence (i : ╬╣) (f) : (succEquiv i f).1 =
    f.comp (Subalgebra.inclusion <| strictMono_filtration.monotone <| le_succ i) := by
  ext
  rfl

instance (i : ╬╣) : FiniteDimensional (EÔč«<iÔč») (EÔč«<iÔč»Ôč«b (¤ć i)Ôč») :=
  adjoin.finiteDimensional ((Algebra.IsAlgebraic.tower_top (K := F) _).isAlgebraic _).isIntegral

theorem deg_lt_aleph0 (i : ╬╣) : #(X i) < ÔäÁÔéÇ :=
  lt_aleph0_of_finite _

open WithTop in
/-- Extend the family `EÔč«<iÔč», i : ╬╣` by adjoining a top element. -/
@[simps!] def filtration : WithTop ╬╣ Ôć¬o IntermediateField F E :=
  .ofStrictMono (fun i ÔćŽ i.recTopCoe ÔŐĄ (EÔč«<┬ĚÔč»)) fun i j h ÔćŽ by
    cases j
    ┬Ě obtain ÔčĘi, rflÔčę := ne_top_iff_exists.mp h.ne
      exact ÔčĘle_top, fun incl ÔćŽ (isLeast_leastExt i).1 (incl trivial)Ôčę
    ┬Ě obtain ÔčĘi, rflÔčę := ne_top_iff_exists.mp (h.trans <| coe_lt_top _).ne
      exact strictMono_filtration (coe_lt_coe.mp h)

/-- Extend the family `X i := EÔč«<iÔč» ÔćĺÔéÉ[F] ─ĺ` from `╬╣` to `WithTop ╬╣`. -/
def factor (i : WithTop ╬╣) : Type _ := i.recTopCoe PUnit (X ┬Ě)

