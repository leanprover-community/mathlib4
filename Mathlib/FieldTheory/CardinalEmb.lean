open WithTop in
theorem iSup_filtration : ÔĘć j : Iio i, filtration j = filtration i := by
  cases i
  ┬Ě rw [ÔćÉ range_coe, iSup_range']; exact iSup_adjoin_eq_top
  refine (iSup_le fun j ÔćŽ filtration.monotone (mem_Iio.1 j.2).le).antisymm (adjoin_le_iff.2 ?_)
