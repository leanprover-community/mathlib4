variable {F E}

theorem cardinal_eq_two_pow_rank [Algebra.IsSeparable F E]
    (rank_inf : ÔäÁÔéÇ ÔëĄ Module.rank F E) : #(Field.Emb F E) = 2 ^ Module.rank F E := by
  haveI := Fact.mk rank_inf
  rw [Emb.Cardinal.embEquivPi.cardinal_eq, mk_pi]
  apply le_antisymm
  ┬Ě rw [ÔćÉ power_eq_two_power rank_inf natCast_le_aleph0 rank_inf]
    conv_rhs => rw [ÔćÉ mk_ord_toType (Module.rank F E), ÔćÉ prod_const']
    exact prod_le_prod _ _ fun i ÔćŽ (Emb.Cardinal.deg_lt_aleph0 _).le
  ┬Ě conv_lhs => rw [ÔćÉ mk_ord_toType (Module.rank F E), ÔćÉ prod_const']
    exact prod_le_prod _ _ Emb.Cardinal.two_le_deg

theorem cardinal_eq_of_isSeparable [Algebra.IsSeparable F E] :
    #(Field.Emb F E) = (fun c ÔćŽ if ÔäÁÔéÇ ÔëĄ c then 2 ^ c else c) (Module.rank F E) := by
  dsimp only; split_ifs with h
  ┬Ě exact cardinal_eq_two_pow_rank h
  rw [not_le, ÔćÉ IsNoetherian.iff_rank_lt_aleph0] at h
  rw [ÔćÉ Module.finrank_eq_rank, ÔćÉ toNat_eq_iff Module.finrank_pos.ne',
    ÔćÉ Nat.card, ÔćÉ finSepDegree, finSepDegree_eq_finrank_of_isSeparable]

theorem cardinal_eq_two_pow_sepDegree [Algebra.IsAlgebraic F E]
    (rank_inf : ÔäÁÔéÇ ÔëĄ sepDegree F E) : #(Field.Emb F E) = 2 ^ sepDegree F E := by
  rw [ÔćÉ cardinal_separableClosure, cardinal_eq_two_pow_rank rank_inf]
  rfl

theorem cardinal_eq [Algebra.IsAlgebraic F E] :
    #(Field.Emb F E) = (fun c ÔćŽ if ÔäÁÔéÇ ÔëĄ c then 2 ^ c else c) (sepDegree F E) := by
  rw [ÔćÉ cardinal_separableClosure, cardinal_eq_of_isSeparable]; rfl

end Field.Emb
