import Mathlib.Algebra.Group.Action.End
import Mathlib.Algebra.Group.Subgroup.MulOppositeLemmas
import Mathlib.Algebra.Group.Submonoid.Pointwise
import Mathlib.GroupTheory.GroupAction.ConjAct

/-! # Pointwise instances on `Subgroup` and `AddSubgroup`s

This file provides the actions

* `Subgroup.pointwiseMulAction`
* `AddSubgroup.pointwiseMulAction`

which matches the action of `Set.mulActionSet`.

These actions are available in the `Pointwise` locale.

## Implementation notes

The pointwise section of this file is almost identical to
the file `Mathlib.Algebra.Group.Submonoid.Pointwise`.
Where possible, try to keep them in sync.
-/


open Set

open Pointwise

variable {őĪ G A S : Type*}

@[to_additive (attr := simp, norm_cast)]
theorem inv_coe_set [InvolutiveInv G] [SetLike S G] [InvMemClass S G] {H : S} : (H : Set G)‚ĀĽ¬Ļ = H :=
  Set.ext fun _ => inv_mem_iff

@[to_additive (attr := simp)]
lemma smul_coe_set [Group G] [SetLike S G] [SubgroupClass S G] {s : S} {a : G} (ha : a ‚ąą s) :
    a ‚ÄĘ (s : Set G) = s := by
  ext; simp [Set.mem_smul_set_iff_inv_smul_mem, mul_mem_cancel_left, ha]

@[norm_cast, to_additive]
lemma coe_set_eq_one [Group G] {s : Subgroup G} : (s : Set G) = 1 ‚ÜĒ s = ‚ä• :=
  (SetLike.ext'_iff.trans (by rfl)).symm

@[to_additive (attr := simp)]
lemma op_smul_coe_set [Group G] [SetLike S G] [SubgroupClass S G] {s : S} {a : G} (ha : a ‚ąą s) :
    MulOpposite.op a ‚ÄĘ (s : Set G) = s := by
  ext; simp [Set.mem_smul_set_iff_inv_smul_mem, mul_mem_cancel_right, ha]

@[to_additive (attr := simp, norm_cast)]
lemma coe_div_coe [SetLike S G] [DivisionMonoid G] [SubgroupClass S G] (H : S) :
    H / H = (H : Set G) := by simp [div_eq_mul_inv]

variable [Group G] [AddGroup A] {s : Set G}

namespace Set

open Subgroup

@[to_additive (attr := simp)]
lemma mul_subgroupClosure (hs : s.Nonempty) : s * closure s = closure s := by
  rw [‚Üź smul_eq_mul, ‚Üź Set.iUnion_smul_set]
  have h a (ha : a ‚ąą s) : a ‚ÄĘ (closure s : Set G) = closure s :=
    smul_coe_set <| subset_closure ha
  simp +contextual [h, hs]

open scoped RightActions in
@[to_additive (attr := simp)]
lemma subgroupClosure_mul (hs : s.Nonempty) : closure s * s = closure s := by
  rw [‚Üź Set.iUnion_op_smul_set]
  have h a (ha : a ‚ąą s) :  (closure s : Set G) <‚ÄĘ a = closure s :=
    op_smul_coe_set <| subset_closure ha
  simp +contextual [h, hs]

@[to_additive (attr := simp)]
lemma pow_mul_subgroupClosure (hs : s.Nonempty) : ‚ąÄ n, s ^ n * closure s = closure s
  | 0 => by simp
  | n + 1 => by rw [pow_succ, mul_assoc, mul_subgroupClosure hs, pow_mul_subgroupClosure hs]

@[to_additive (attr := simp)]
lemma subgroupClosure_mul_pow (hs : s.Nonempty) : ‚ąÄ n, closure s * s ^ n = closure s
  | 0 => by simp
  | n + 1 => by rw [pow_succ', ‚Üź mul_assoc, subgroupClosure_mul hs, subgroupClosure_mul_pow hs]

end Set

namespace Subgroup

@[to_additive (attr := simp)]
theorem inv_subset_closure (S : Set G) : S‚ĀĽ¬Ļ ‚äÜ closure S := fun s hs => by
  rw [SetLike.mem_coe, ‚Üź Subgroup.inv_mem_iff]
  exact subset_closure (mem_inv.mp hs)

@[to_additive]
theorem closure_toSubmonoid (S : Set G) :
    (closure S).toSubmonoid = Submonoid.closure (S ‚ą™ S‚ĀĽ¬Ļ) := by
  refine le_antisymm (fun x hx => ?_) (Submonoid.closure_le.2 ?_)
  ¬∑ refine
      closure_induction
        (fun x hx => Submonoid.closure_mono subset_union_left (Submonoid.subset_closure hx))
        (Submonoid.one_mem _) (fun x y _ _ hx hy => Submonoid.mul_mem _ hx hy) (fun x _ hx => ?_) hx
    rwa [‚Üź Submonoid.mem_closure_inv, Set.union_inv, inv_inv, Set.union_comm]
  ¬∑ simp only [true_and, coe_toSubmonoid, union_subset_iff, subset_closure, inv_subset_closure]

/-- For subgroups generated by a single element, see the simpler `zpow_induction_left`. -/
@[to_additive (attr := elab_as_elim)
  "For additive subgroups generated by a single element, see the simpler
  `zsmul_induction_left`."]
theorem closure_induction_left {p : (x : G) ‚Üí x ‚ąą closure s ‚Üí Prop} (one : p 1 (one_mem _))
    (mul_left : ‚ąÄ x (hx : x ‚ąą s), ‚ąÄ (y) hy, p y hy ‚Üí p (x * y) (mul_mem (subset_closure hx) hy))
    (inv_mul_cancel : ‚ąÄ x (hx : x ‚ąą s), ‚ąÄ (y) hy, p y hy ‚Üí
      p (x‚ĀĽ¬Ļ * y) (mul_mem (inv_mem (subset_closure hx)) hy))
    {x : G} (h : x ‚ąą closure s) : p x h := by
  revert h
  simp_rw [‚Üź mem_toSubmonoid, closure_toSubmonoid] at *
  intro h
  induction h using Submonoid.closure_induction_left with
  | one => exact one
  | mul_left x hx y hy ih =>
    cases hx with
    | inl hx => exact mul_left _ hx _ hy ih
    | inr hx => simpa only [inv_inv] using inv_mul_cancel _ hx _ hy ih

/-- For subgroups generated by a single element, see the simpler `zpow_induction_right`. -/
@[to_additive (attr := elab_as_elim)
  "For additive subgroups generated by a single element, see the simpler
  `zsmul_induction_right`."]
theorem closure_induction_right {p : (x : G) ‚Üí x ‚ąą closure s ‚Üí Prop} (one : p 1 (one_mem _))
    (mul_right : ‚ąÄ (x) hx, ‚ąÄ y (hy : y ‚ąą s), p x hx ‚Üí p (x * y) (mul_mem hx (subset_closure hy)))
    (mul_inv_cancel : ‚ąÄ (x) hx, ‚ąÄ y (hy : y ‚ąą s), p x hx ‚Üí
      p (x * y‚ĀĽ¬Ļ) (mul_mem hx (inv_mem (subset_closure hy))))
    {x : G} (h : x ‚ąą closure s) : p x h :=
  closure_induction_left (s := MulOpposite.unop ‚ĀĽ¬Ļ' s)
    (p := fun m hm => p m.unop <| by rwa [‚Üź op_closure] at hm)
    one
    (fun _x hx _y _ => mul_right _ _ _ hx)
    (fun _x hx _y _ => mul_inv_cancel _ _ _ hx)
    (by rwa [‚Üź op_closure])

@[to_additive (attr := simp)]
theorem closure_inv (s : Set G) : closure s‚ĀĽ¬Ļ = closure s := by
  simp only [‚Üź toSubmonoid_inj, closure_toSubmonoid, inv_inv, union_comm]

@[to_additive (attr := simp)]
lemma closure_singleton_inv (x : G) : closure {x‚ĀĽ¬Ļ} = closure {x} := by
  rw [‚Üź Set.inv_singleton, closure_inv]

/-- An induction principle for closure membership. If `p` holds for `1` and all elements of
`k` and their inverse, and is preserved under multiplication, then `p` holds for all elements of
the closure of `k`. -/
@[to_additive (attr := elab_as_elim)
  "An induction principle for additive closure membership. If `p` holds for `0` and all
  elements of `k` and their negation, and is preserved under addition, then `p` holds for all
  elements of the additive closure of `k`."]
theorem closure_induction'' {p : (g : G) ‚Üí g ‚ąą closure s ‚Üí Prop}
    (mem : ‚ąÄ x (hx : x ‚ąą s), p x (subset_closure hx))
    (inv_mem : ‚ąÄ x (hx : x ‚ąą s), p x‚ĀĽ¬Ļ (inv_mem (subset_closure hx)))
    (one : p 1 (one_mem _))
    (mul : ‚ąÄ x y hx hy, p x hx ‚Üí p y hy ‚Üí p (x * y) (mul_mem hx hy))
    {x} (h : x ‚ąą closure s) : p x h :=
  closure_induction_left one (fun x hx y _ hy => mul x y _ _ (mem x hx) hy)
    (fun x hx y _ => mul x‚ĀĽ¬Ļ y _ _ <| inv_mem x hx) h

/-- An induction principle for elements of `‚®Ü i, S i`.
If `C` holds for `1` and all elements of `S i` for all `i`, and is preserved under multiplication,
then it holds for all elements of the supremum of `S`. -/
@[to_additive (attr := elab_as_elim) " An induction principle for elements of `‚®Ü i, S i`.
If `C` holds for `0` and all elements of `S i` for all `i`, and is preserved under addition,
then it holds for all elements of the supremum of `S`. "]
theorem iSup_induction {őĻ : Sort*} (S : őĻ ‚Üí Subgroup G) {C : G ‚Üí Prop} {x : G} (hx : x ‚ąą ‚®Ü i, S i)
    (mem : ‚ąÄ (i), ‚ąÄ x ‚ąą S i, C x) (one : C 1) (mul : ‚ąÄ x y, C x ‚Üí C y ‚Üí C (x * y)) : C x := by
  rw [iSup_eq_closure] at hx
  induction hx using closure_induction'' with
  | one => exact one
  | mem x hx =>
    obtain ‚ü®i, hi‚ü© := Set.mem_iUnion.mp hx
    exact mem _ _ hi
  | inv_mem x hx =>
    obtain ‚ü®i, hi‚ü© := Set.mem_iUnion.mp hx
    exact mem _ _ (inv_mem hi)
  | mul x y _ _ ihx ihy => exact mul x y ihx ihy

/-- A dependent version of `Subgroup.iSup_induction`. -/
@[to_additive (attr := elab_as_elim) "A dependent version of `AddSubgroup.iSup_induction`. "]
theorem iSup_induction' {őĻ : Sort*} (S : őĻ ‚Üí Subgroup G) {C : ‚ąÄ x, (x ‚ąą ‚®Ü i, S i) ‚Üí Prop}
    (hp : ‚ąÄ (i), ‚ąÄ x (hx : x ‚ąą S i), C x (mem_iSup_of_mem i hx)) (h1 : C 1 (one_mem _))
    (hmul : ‚ąÄ x y hx hy, C x hx ‚Üí C y hy ‚Üí C (x * y) (mul_mem ‚ÄĻ_‚Äļ ‚ÄĻ_‚Äļ)) {x : G}
    (hx : x ‚ąą ‚®Ü i, S i) : C x hx := by
  suffices ‚ąÉ h, C x h from this.snd
  refine iSup_induction S (C := fun x => ‚ąÉ h, C x h) hx (fun i x hx => ?_) ?_ fun x y => ?_
  ¬∑ exact ‚ü®_, hp i _ hx‚ü©
  ¬∑ exact ‚ü®_, h1‚ü©
  ¬∑ rintro ‚ü®_, Cx‚ü© ‚ü®_, Cy‚ü©
    exact ‚ü®_, hmul _ _ _ _ Cx Cy‚ü©

@[to_additive]
theorem closure_mul_le (S T : Set G) : closure (S * T) ‚Č§ closure S ‚äĒ closure T :=
  sInf_le fun _x ‚ü®_s, hs, _t, ht, hx‚ü© => hx ‚Ėł
    (closure S ‚äĒ closure T).mul_mem (SetLike.le_def.mp le_sup_left <| subset_closure hs)
      (SetLike.le_def.mp le_sup_right <| subset_closure ht)

@[to_additive]
lemma closure_pow_le : ‚ąÄ {n}, n ‚Č† 0 ‚Üí closure (s ^ n) ‚Č§ closure s
  | 1, _ => by simp
  | n + 2, _ =>
    calc
      closure (s ^ (n + 2))
      _ = closure (s ^ (n + 1) * s) := by rw [pow_succ]
      _ ‚Č§ closure (s ^ (n + 1)) ‚äĒ closure s := closure_mul_le ..
      _ ‚Č§ closure s ‚äĒ closure s := by gcongr ?_ ‚äĒ _; exact closure_pow_le n.succ_ne_zero
      _ = closure s := sup_idem _

@[to_additive]
lemma closure_pow {n : ‚Ąē} (hs : 1 ‚ąą s) (hn : n ‚Č† 0) : closure (s ^ n) = closure s :=
  (closure_pow_le hn).antisymm <| by gcongr; exact subset_pow hs hn

@[to_additive]
theorem sup_eq_closure_mul (H K : Subgroup G) : H ‚äĒ K = closure ((H : Set G) * (K : Set G)) :=
  le_antisymm
    (sup_le (fun h hh => subset_closure ‚ü®h, hh, 1, K.one_mem, mul_one h‚ü©) fun k hk =>
      subset_closure ‚ü®1, H.one_mem, k, hk, one_mul k‚ü©)
    ((closure_mul_le _ _).trans <| by rw [closure_eq, closure_eq])

@[to_additive]
theorem set_mul_normal_comm (s : Set G) (N : Subgroup G) [hN : N.Normal] :
    s * (N : Set G) = (N : Set G) * s := by
  rw [‚Üź iUnion_mul_left_image, ‚Üź iUnion_mul_right_image]
  simp only [image_mul_left, image_mul_right, Set.preimage, SetLike.mem_coe, hN.mem_comm_iff]

/-- The carrier of `H ‚äĒ N` is just `‚ÜĎH * ‚ÜĎN` (pointwise set product) when `N` is normal. -/
@[to_additive "The carrier of `H ‚äĒ N` is just `‚ÜĎH + ‚ÜĎN` (pointwise set addition)
when `N` is normal."]
theorem mul_normal (H N : Subgroup G) [hN : N.Normal] : (‚ÜĎ(H ‚äĒ N) : Set G) = H * N := by
  rw [sup_eq_closure_mul]
  refine Set.Subset.antisymm (fun x hx => ?_) subset_closure
  induction hx using closure_induction'' with
  | one => exact ‚ü®1, one_mem _, 1, one_mem _, mul_one 1‚ü©
  | mem _ hx => exact hx
  | inv_mem x hx =>
    obtain ‚ü®x, hx, y, hy, rfl‚ü© := hx
    simpa only [mul_inv_rev, mul_assoc, inv_inv, inv_mul_cancel_left]
      using mul_mem_mul (inv_mem hx) (hN.conj_mem _ (inv_mem hy) x)
  | mul x' x' _ _ hx hx' =>
    obtain ‚ü®x, hx, y, hy, rfl‚ü© := hx
    obtain ‚ü®x', hx', y', hy', rfl‚ü© := hx'
    refine ‚ü®x * x', mul_mem hx hx', x'‚ĀĽ¬Ļ * y * x' * y', mul_mem ?_ hy', ?_‚ü©
    ¬∑ simpa using hN.conj_mem _ hy x'‚ĀĽ¬Ļ
    ¬∑ simp only [mul_assoc, mul_inv_cancel_left]

/-- The carrier of `N ‚äĒ H` is just `‚ÜĎN * ‚ÜĎH` (pointwise set product) when `N` is normal. -/
@[to_additive "The carrier of `N ‚äĒ H` is just `‚ÜĎN + ‚ÜĎH` (pointwise set addition)
when `N` is normal."]
theorem normal_mul (N H : Subgroup G) [N.Normal] : (‚ÜĎ(N ‚äĒ H) : Set G) = N * H := by
  rw [‚Üź set_mul_normal_comm, sup_comm, mul_normal]

@[to_additive]
theorem mul_inf_assoc (A B C : Subgroup G) (h : A ‚Č§ C) :
    (A : Set G) * ‚ÜĎ(B ‚äď C) = (A : Set G) * (B : Set G) ‚ą© C := by
  ext
  simp only [coe_inf, Set.mem_mul, Set.mem_inter_iff]
  constructor
  ¬∑ rintro ‚ü®y, hy, z, ‚ü®hzB, hzC‚ü©, rfl‚ü©
    refine ‚ü®?_, mul_mem (h hy) hzC‚ü©
    exact ‚ü®y, hy, z, hzB, rfl‚ü©
  rintro ‚ü®‚ü®y, hy, z, hz, rfl‚ü©, hyz‚ü©
  refine ‚ü®y, hy, z, ‚ü®hz, ?_‚ü©, rfl‚ü©
  suffices y‚ĀĽ¬Ļ * (y * z) ‚ąą C by simpa
  exact mul_mem (inv_mem (h hy)) hyz

@[to_additive]
theorem inf_mul_assoc (A B C : Subgroup G) (h : C ‚Č§ A) :
    ((A ‚äď B : Subgroup G) : Set G) * C = (A : Set G) ‚ą© (‚ÜĎB * ‚ÜĎC) := by
  ext
  simp only [coe_inf, Set.mem_mul, Set.mem_inter_iff]
  constructor
  ¬∑ rintro ‚ü®y, ‚ü®hyA, hyB‚ü©, z, hz, rfl‚ü©
    refine ‚ü®A.mul_mem hyA (h hz), ?_‚ü©
    exact ‚ü®y, hyB, z, hz, rfl‚ü©
  rintro ‚ü®hyz, y, hy, z, hz, rfl‚ü©
  refine ‚ü®y, ‚ü®?_, hy‚ü©, z, hz, rfl‚ü©
  suffices y * z * z‚ĀĽ¬Ļ ‚ąą A by simpa
  exact mul_mem hyz (inv_mem (h hz))

@[to_additive]
instance sup_normal (H K : Subgroup G) [hH : H.Normal] [hK : K.Normal] : (H ‚äĒ K).Normal where
  conj_mem n hmem g := by
    rw [‚Üź SetLike.mem_coe, normal_mul] at hmem ‚äĘ
    rcases hmem with ‚ü®h, hh, k, hk, rfl‚ü©
    refine ‚ü®g * h * g‚ĀĽ¬Ļ, hH.conj_mem h hh g, g * k * g‚ĀĽ¬Ļ, hK.conj_mem k hk g, ?_‚ü©
    simp only [mul_assoc, inv_mul_cancel_left]

@[to_additive]
theorem smul_mem_of_mem_closure_of_mem {X : Type*} [MulAction G X] {s : Set G} {t : Set X}
    (hs : ‚ąÄ g ‚ąą s, g‚ĀĽ¬Ļ ‚ąą s) (hst : ‚ąÄŠĶČ (g ‚ąą s) (x ‚ąą t), g ‚ÄĘ x ‚ąą t) {g : G}
    (hg : g ‚ąą Subgroup.closure s) {x : X} (hx : x ‚ąą t) : g ‚ÄĘ x ‚ąą t := by
  induction hg using Subgroup.closure_induction'' generalizing x with
  | one => simpa
  | mem g' hg' => exact hst g' hg' x hx
  | inv_mem g' hg' => exact hst g'‚ĀĽ¬Ļ (hs g' hg') x hx
  | mul _ _ _ _ h‚āĀ h‚āā => rw [mul_smul]; exact h‚āĀ (h‚āā hx)

@[to_additive]
theorem smul_opposite_image_mul_preimage' (g : G) (h : GŠĶźŠĶíŠĶĖ) (s : Set G) :
    (fun y => h ‚ÄĘ y) '' ((g * ¬∑) ‚ĀĽ¬Ļ' s) = (g * ¬∑) ‚ĀĽ¬Ļ' ((fun y => h ‚ÄĘ y) '' s) := by
  simp [preimage_preimage, mul_assoc]

-- TODO: deprecate?
@[to_additive]
theorem smul_opposite_image_mul_preimage {H : Subgroup G} (g : G) (h : H.op) (s : Set G) :
    (fun y => h ‚ÄĘ y) '' ((g * ¬∑) ‚ĀĽ¬Ļ' s) = (g * ¬∑) ‚ĀĽ¬Ļ' ((fun y => h ‚ÄĘ y) '' s) :=
  smul_opposite_image_mul_preimage' g h s

/-! ### Pointwise action -/


section Monoid

variable [Monoid őĪ] [MulDistribMulAction őĪ G]

/-- The action on a subgroup corresponding to applying the action to every element.

This is available as an instance in the `Pointwise` locale. -/
protected def pointwiseMulAction : MulAction őĪ (Subgroup G) where
  smul a S := S.map (MulDistribMulAction.toMonoidEnd _ _ a)
  one_smul S := by
    change S.map _ = S
    simpa only [map_one] using S.map_id
  mul_smul _ _ S :=
    (congr_arg (fun f : Monoid.End G => S.map f) (MonoidHom.map_mul _ _ _)).trans
      (S.map_map _ _).symm

scoped[Pointwise] attribute [instance] Subgroup.pointwiseMulAction

theorem pointwise_smul_def {a : őĪ} (S : Subgroup G) :
    a ‚ÄĘ S = S.map (MulDistribMulAction.toMonoidEnd _ _ a) :=
  rfl

@[simp]
theorem coe_pointwise_smul (a : őĪ) (S : Subgroup G) : ‚ÜĎ(a ‚ÄĘ S) = a ‚ÄĘ (S : Set G) :=
  rfl

@[simp]
theorem pointwise_smul_toSubmonoid (a : őĪ) (S : Subgroup G) :
    (a ‚ÄĘ S).toSubmonoid = a ‚ÄĘ S.toSubmonoid :=
  rfl

theorem smul_mem_pointwise_smul (m : G) (a : őĪ) (S : Subgroup G) : m ‚ąą S ‚Üí a ‚ÄĘ m ‚ąą a ‚ÄĘ S :=
  (Set.smul_mem_smul_set : _ ‚Üí _ ‚ąą a ‚ÄĘ (S : Set G))

instance : CovariantClass őĪ (Subgroup G) HSMul.hSMul LE.le :=
  ‚ü®fun _ _ => image_subset _‚ü©

theorem mem_smul_pointwise_iff_exists (m : G) (a : őĪ) (S : Subgroup G) :
    m ‚ąą a ‚ÄĘ S ‚ÜĒ ‚ąÉ s : G, s ‚ąą S ‚ąß a ‚ÄĘ s = m :=
  (Set.mem_smul_set : m ‚ąą a ‚ÄĘ (S : Set G) ‚ÜĒ _)

@[simp]
theorem smul_bot (a : őĪ) : a ‚ÄĘ (‚ä• : Subgroup G) = ‚ä• :=
  map_bot _

theorem smul_sup (a : őĪ) (S T : Subgroup G) : a ‚ÄĘ (S ‚äĒ T) = a ‚ÄĘ S ‚äĒ a ‚ÄĘ T :=
  map_sup _ _ _

theorem smul_closure (a : őĪ) (s : Set G) : a ‚ÄĘ closure s = closure (a ‚ÄĘ s) :=
  MonoidHom.map_closure _ _

instance pointwise_isCentralScalar [MulDistribMulAction őĪŠĶźŠĶíŠĶĖ G] [IsCentralScalar őĪ G] :
    IsCentralScalar őĪ (Subgroup G) :=
  ‚ü®fun _ S => (congr_arg fun f => S.map f) <| MonoidHom.ext <| op_smul_eq_smul _‚ü©

theorem conj_smul_le_of_le {P H : Subgroup G} (hP : P ‚Č§ H) (h : H) :
    MulAut.conj (h : G) ‚ÄĘ P ‚Č§ H := by
  rintro - ‚ü®g, hg, rfl‚ü©
  exact H.mul_mem (H.mul_mem h.2 (hP hg)) (H.inv_mem h.2)

theorem conj_smul_subgroupOf {P H : Subgroup G} (hP : P ‚Č§ H) (h : H) :
    MulAut.conj h ‚ÄĘ P.subgroupOf H = (MulAut.conj (h : G) ‚ÄĘ P).subgroupOf H := by
  refine le_antisymm ?_ ?_
  ¬∑ rintro - ‚ü®g, hg, rfl‚ü©
    exact ‚ü®g, hg, rfl‚ü©
  ¬∑ rintro p ‚ü®g, hg, hp‚ü©
    exact ‚ü®‚ü®g, hP hg‚ü©, hg, Subtype.ext hp‚ü©

end Monoid

section Group

variable [Group őĪ] [MulDistribMulAction őĪ G]

@[simp]
