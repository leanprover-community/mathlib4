  simp [preimage, mul_mem_cancel_left (inv_mem hh)]

theorem Normal.conjAct {H : Subgroup G} (hH : H.Normal) (g : ConjAct G) : g ‚ÄĘ H = H :=
  have : ‚ąÄ g : ConjAct G, g ‚ÄĘ H ‚Č§ H :=
    fun _ => map_le_iff_le_comap.2 fun _ h => hH.conj_mem _ h _
  (this g).antisymm <| (smul_inv_smul g H).symm.trans_le (map_mono <| this _)

@[simp]
theorem Normal.conj_smul_eq_self (g : G) (H : Subgroup G) [h : Normal H] : MulAut.conj g ‚ÄĘ H = H :=
  h.conjAct g

theorem Normal.of_conjugate_fixed {H : Subgroup G} (h : ‚ąÄ g : G, (MulAut.conj g) ‚ÄĘ H = H) :
    H.Normal := by
  constructor
  intro n hn g
  rw [‚Üź h g, Subgroup.mem_pointwise_smul_iff_inv_smul_mem, ‚Üź map_inv, MulAut.smul_def,
    MulAut.conj_apply, inv_inv, mul_assoc, mul_assoc, inv_mul_cancel, mul_one,
    ‚Üź mul_assoc, inv_mul_cancel, one_mul]
  exact hn

theorem normalCore_eq_iInf_conjAct (H : Subgroup G) :
    H.normalCore = ‚®Ö (g : ConjAct G), g ‚ÄĘ H := by
  ext g
  simp only [Subgroup.normalCore, Subgroup.mem_iInf, Subgroup.mem_pointwise_smul_iff_inv_smul_mem]
  refine ‚ü®fun h x ‚Ü¶ h x‚ĀĽ¬Ļ, fun h x ‚Ü¶ ?_‚ü©
  simpa only [ConjAct.toConjAct_inv, inv_inv] using h x‚ĀĽ¬Ļ

