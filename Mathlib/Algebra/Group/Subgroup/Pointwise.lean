variable [Monoid őĪ] [DistribMulAction őĪ A]

/-- The action on an additive subgroup corresponding to applying the action to every element.

This is available as an instance in the `Pointwise` locale. -/
protected def pointwiseMulAction : MulAction őĪ (AddSubgroup A) where
  smul a S := S.map (DistribMulAction.toAddMonoidEnd _ _ a)
  one_smul S := by
    change S.map _ = S
    simpa only [map_one] using S.map_id
  mul_smul _ _ S :=
    (congr_arg (fun f : AddMonoid.End A => S.map f) (MonoidHom.map_mul _ _ _)).trans
      (S.map_map _ _).symm

scoped[Pointwise] attribute [instance] AddSubgroup.pointwiseMulAction

theorem pointwise_smul_def {a : őĪ} (S : AddSubgroup A) :
    a ‚ÄĘ S = S.map (DistribMulAction.toAddMonoidEnd _ _ a) :=
  rfl

@[simp]
theorem coe_pointwise_smul (a : őĪ) (S : AddSubgroup A) : ‚ÜĎ(a ‚ÄĘ S) = a ‚ÄĘ (S : Set A) :=
  rfl

@[simp]
theorem pointwise_smul_toAddSubmonoid (a : őĪ) (S : AddSubgroup A) :
    (a ‚ÄĘ S).toAddSubmonoid = a ‚ÄĘ S.toAddSubmonoid :=
  rfl

theorem smul_mem_pointwise_smul (m : A) (a : őĪ) (S : AddSubgroup A) : m ‚ąą S ‚Üí a ‚ÄĘ m ‚ąą a ‚ÄĘ S :=
  (Set.smul_mem_smul_set : _ ‚Üí _ ‚ąą a ‚ÄĘ (S : Set A))

theorem mem_smul_pointwise_iff_exists (m : A) (a : őĪ) (S : AddSubgroup A) :
    m ‚ąą a ‚ÄĘ S ‚ÜĒ ‚ąÉ s : A, s ‚ąą S ‚ąß a ‚ÄĘ s = m :=
  (Set.mem_smul_set : m ‚ąą a ‚ÄĘ (S : Set A) ‚ÜĒ _)

instance pointwise_isCentralScalar [DistribMulAction őĪŠĶźŠĶíŠĶĖ A] [IsCentralScalar őĪ A] :
    IsCentralScalar őĪ (AddSubgroup A) :=
  ‚ü®fun _ S => (congr_arg fun f => S.map f) <| AddMonoidHom.ext <| op_smul_eq_smul _‚ü©

