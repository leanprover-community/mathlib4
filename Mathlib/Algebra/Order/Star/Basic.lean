@[aesop safe apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.sq_nonneg {a : R} (ha : IsSelfAdjoint a) : 0 ÔëĄ a ^ 2 := by
  simp [sq, ha.mul_self_nonneg]

lemma IsUnit.star_right_conjugate_nonneg_iff {u x : R} (hu : IsUnit u) :
    0 ÔëĄ u * x * star u Ôćö 0 ÔëĄ x := by
  refine ÔčĘfun h ÔćŽ ?_, fun h ÔćŽ star_right_conjugate_nonneg h _Ôčę
  obtain ÔčĘv, hvÔčę := hu.exists_left_inv
  have := by simpa [ÔćÉ mul_assoc] using star_right_conjugate_nonneg h v
  rwa [hv, one_mul, mul_assoc, ÔćÉ star_mul, hv, star_one, mul_one] at this

lemma IsUnit.star_left_conjugate_nonneg_iff {u x : R} (hu : IsUnit u) :
    0 ÔëĄ star u * x * u Ôćö 0 ÔëĄ x := by
  simpa using hu.star.star_right_conjugate_nonneg_iff

end Semiring

