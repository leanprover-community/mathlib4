/-! # Star ordered rings

We define the class `StarOrderedRing R`, which says that the order on `R` respects the
star operation, i.e. an element `r` is nonnegative iff it is in the `AddSubmonoid` generated by
elements of the form `star s * s`. In many cases, including all CÔőć-algebras, this can be reduced to
`0 ÔëĄ r Ôćö Ôłâ s, r = star s * s`. However, this generality is slightly more convenient (e.g., it
allows us to register a `StarOrderedRing` instance for `ÔäÜ`), and more closely resembles the
literature (see the seminal paper [*The positive cone in Banach algebras*][kelleyVaught1953])

In order to accommodate `NonUnitalSemiring R`, we actually don't characterize nonnegativity, but
rather the entire `ÔëĄ` relation with `StarOrderedRing.le_iff`. However, notice that when `R` is a
`NonUnitalRing`, these are equivalent (see `StarOrderedRing.nonneg_iff` and
`StarOrderedRing.of_nonneg_iff`).

It is important to note that while a `StarOrderedRing` is an `OrderedAddCommMonoid` it is often
*not* an `OrderedSemiring`.

## TODO

* In a Banach star algebra without a well-defined square root, the natural ordering is given by the
  positive cone which is the _closure_ of the sums of elements `star r * r`. A weaker version of
  `StarOrderedRing` could be defined for this case (again, see
  [*The positive cone in Banach algebras*][kelleyVaught1953]). Note that the current definition has
  the advantage of not requiring a topology.
-/

public section

open Set
open scoped NNRat

variable {R A : Type*}

section prereq
variable [Semiring R] [StarRing R]
  [NonUnitalSemiring A] [StarRing A] [Module R A]
  [StarModule R A] [IsScalarTower R A A] [SMulCommClass R A A]

lemma smul_mem_closure_star_mul {r : R}
    (hr : r Ôłł AddSubmonoid.closure (range fun s ÔćŽ star s * s)) {a : A}
    (ha : a Ôłł AddSubmonoid.closure (range fun s ÔćŽ star s * s)) :
    r ÔÇó a Ôłł AddSubmonoid.closure (range fun s ÔćŽ star s * s) := by
  induction hr using AddSubmonoid.closure_induction with
  | zero => simp
  | add rÔéü rÔéé _ _ hrÔéü hrÔéé => simpa [add_smul] using add_mem hrÔéü hrÔéé
  | mem r hr =>
  induction ha using AddSubmonoid.closure_induction with
  | zero => simp
  | add aÔéü aÔéé _ _ haÔéü haÔéé => simpa [smul_add] using add_mem haÔéü haÔéé
  | mem a ha =>
  obtain ÔčĘr, rflÔčę := hr
  obtain ÔčĘa, rflÔčę := ha
  exact AddSubmonoid.subset_closure ÔčĘr ÔÇó a, by simp [star_smul, smul_mul_smul_comm]Ôčę

end prereq

/-- An ordered \*-ring is a \*-ring with a partial order such that the nonnegative elements
constitute precisely the `AddSubmonoid` generated by elements of the form `star s * s`.

If you are working with a `NonUnitalRing` and not a `NonUnitalSemiring`, it may be more
convenient to declare instances using `StarOrderedRing.of_nonneg_iff`. -/
class StarOrderedRing (R : Type*) [NonUnitalSemiring R] [PartialOrder R] [StarRing R] : Prop where
  /-- characterization of the order in terms of the `StarRing` structure. -/
  le_iff :
    ÔłÇ x y : R, x ÔëĄ y Ôćö Ôłâ p, p Ôłł AddSubmonoid.closure (Set.range fun s => star s * s) Ôłž y = x + p

namespace StarOrderedRing
section NonUnitalSemiring
variable [NonUnitalSemiring R] [PartialOrder R] [StarRing R]

/-- To construct a `StarOrderedRing` instance it suffices to show that `x ÔëĄ y` if and only if
`y = x + star s * s` for some `s : R`.

This is provided for convenience because it holds in some common scenarios (e.g.,`ÔäŁÔëą0`, `C(X, ÔäŁÔëą0)`)
and obviates the hassle of `AddSubmonoid.closure_induction` when creating those instances.

If you are working with a `NonUnitalRing` and not a `NonUnitalSemiring`, see
`StarOrderedRing.of_nonneg_iff` for a more convenient version.
-/
lemma of_le_iff (h_le_iff : ÔłÇ x y : R, x ÔëĄ y Ôćö Ôłâ s, y = x + star s * s) : StarOrderedRing R where
  le_iff x y := by
    refine ÔčĘfun h => ?_, ?_Ôčę
    ┬Ě obtain ÔčĘp, hpÔčę := (h_le_iff x y).mp h
      exact ÔčĘstar p * p, AddSubmonoid.subset_closure ÔčĘp, rflÔčę, hpÔčę
    ┬Ě rintro ÔčĘp, hp, hpxyÔčę
      revert x y hpxy
      refine AddSubmonoid.closure_induction ?_ (fun x y h => add_zero x ÔľŞ h.ge) ?_ hp
      ┬Ě rintro _ ÔčĘs, rflÔčę x y rfl
        exact (h_le_iff _ _).mpr ÔčĘs, rflÔčę
      ┬Ě rintro _ _ _ _ ha hb x y rfl
        rw [ÔćÉ add_assoc]
        exact (ha _ _ rfl).trans (hb _ _ rfl)

variable [StarOrderedRing R] {x y : R}

-- see note [lower instance priority]
instance (priority := 100) toIsOrderedAddMonoid : IsOrderedAddMonoid R where
  add_le_add_left := fun x y hle z ÔćŽ by
    rw [StarOrderedRing.le_iff] at hle ÔŐó
    refine hle.imp fun s hs ÔćŽ ?_
    rw [hs.2, add_right_comm]
    exact ÔčĘhs.1, rflÔčę

-- see note [lower instance priority]
instance (priority := 100) toExistsAddOfLE : ExistsAddOfLE R where
  exists_add_of_le h :=
    match (le_iff _ _).mp h with
    | ÔčĘp, _, hpÔčę => ÔčĘp, hpÔčę

lemma nonneg_iff : 0 ÔëĄ x Ôćö x Ôłł AddSubmonoid.closure (Set.range fun s : R => star s * s) := by
  simp only [le_iff, zero_add, exists_eq_right']

lemma pos_iff : 0 < x Ôćö x Ôëá 0 Ôłž x Ôłł AddSubmonoid.closure (Set.range fun s : R => star s * s) := by
  simp [lt_iff_le_and_ne, and_comm, eq_comm, le_iff]

variable [IsCancelAdd R]

lemma lt_iff :
    x < y Ôćö Ôłâ p Ôëá 0, p Ôłł AddSubmonoid.closure (Set.range fun s => star s * s) Ôłž y = x + p := by
  rw [lt_iff_le_and_ne, and_comm, StarOrderedRing.le_iff, ÔćÉ exists_and_left]
  congr! 2 with p
  simp +contextual [ÔćÉ and_assoc]

end NonUnitalSemiring

/-- When `R` is a non-unital ring, to construct a `StarOrderedRing` instance it suffices to
show that the nonnegative elements are precisely those elements in the `AddSubmonoid` generated
by `star s * s` for `s : R`. -/
lemma of_nonneg_iff [NonUnitalRing R] [PartialOrder R] [StarRing R]
    (h_add : ÔłÇ {x y : R}, x ÔëĄ y Ôćĺ ÔłÇ z, z + x ÔëĄ z + y)
    (h_nonneg_iff : ÔłÇ x : R, 0 ÔëĄ x Ôćö x Ôłł AddSubmonoid.closure (Set.range fun s : R => star s * s)) :
    StarOrderedRing R where
  le_iff x y := by
    have : AddLeftMono R := ÔčĘfun _ _ _ h => h_add h _Ôčę
    simpa only [ÔćÉ sub_eq_iff_eq_add', sub_nonneg, exists_eq_right'] using h_nonneg_iff (y - x)

/-- When `R` is a non-unital ring, to construct a `StarOrderedRing` instance it suffices to
show that the nonnegative elements are precisely those elements of the form `star s * s`
for `s : R`.

This is provided for convenience because it holds in many common scenarios (e.g.,`ÔäŁ`, `Ôäé`, or
any CÔőć-algebra), and obviates the hassle of `AddSubmonoid.closure_induction` when creating those
instances. -/
lemma of_nonneg_iff' [NonUnitalRing R] [PartialOrder R] [StarRing R]
    (h_add : ÔłÇ {x y : R}, x ÔëĄ y Ôćĺ ÔłÇ z, z + x ÔëĄ z + y)
    (h_nonneg_iff : ÔłÇ x : R, 0 ÔëĄ x Ôćö Ôłâ s, x = star s * s) : StarOrderedRing R :=
  of_le_iff <| by
    have : AddLeftMono R := ÔčĘfun _ _ _ h => h_add h _Ôčę
    simpa [sub_eq_iff_eq_add', sub_nonneg] using fun x y => h_nonneg_iff (y - x)

end StarOrderedRing

section NonUnitalSemiring

variable [NonUnitalSemiring R] [PartialOrder R] [StarRing R] [StarOrderedRing R]

lemma IsSelfAdjoint.mono {x y : R} (h : x ÔëĄ y) (hx : IsSelfAdjoint x) : IsSelfAdjoint y := by
  rw [StarOrderedRing.le_iff] at h
  obtain ÔčĘd, hd, rflÔčę := h
  rw [IsSelfAdjoint, star_add, hx.star_eq]
  congr
  refine AddMonoidHom.eqOn_closureM (f := starAddEquiv (R := R)) (g := .id R) ?_ hd
  rintro - ÔčĘs, rflÔčę
  simp

@[aesop 10% apply, grind ÔćÉ]
lemma IsSelfAdjoint.of_nonneg {x : R} (hx : 0 ÔëĄ x) : IsSelfAdjoint x :=
  .mono hx <| .zero R

/-- An alias of `IsSelfAdjoint.of_nonneg` for use with dot notation. -/
alias LE.le.isSelfAdjoint := IsSelfAdjoint.of_nonneg

/-- The combination `(IsSelfAdjoint.star_eq <| .of_nonneg ┬Ě)` for use with dot notation. -/
lemma LE.le.star_eq {x : R} (hx : 0 ÔëĄ x) : star x = x :=
  hx.isSelfAdjoint.star_eq

@[simp]
theorem star_mul_self_nonneg (r : R) : 0 ÔëĄ star r * r :=
  StarOrderedRing.nonneg_iff.mpr <| AddSubmonoid.subset_closure ÔčĘr, rflÔčę

@[simp]
theorem mul_star_self_nonneg (r : R) : 0 ÔëĄ r * star r := by
  simpa only [star_star] using star_mul_self_nonneg (star r)

@[aesop safe apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.mul_self_nonneg {a : R} (ha : IsSelfAdjoint a) : 0 ÔëĄ a * a := by
  simpa [ha.star_eq] using star_mul_self_nonneg a

/-- A star projection is non-negative in a star-ordered ring. -/
theorem IsStarProjection.nonneg {p : R} (hp : IsStarProjection p) : 0 ÔëĄ p :=
  hp.isIdempotentElem ÔľŞ hp.isSelfAdjoint.mul_self_nonneg

@[aesop safe apply]
theorem star_left_conjugate_nonneg {a : R} (ha : 0 ÔëĄ a) (c : R) : 0 ÔëĄ star c * a * c := by
  rw [StarOrderedRing.nonneg_iff] at ha
  refine AddSubmonoid.closure_induction (fun x hx => ?_)
    (by rw [mul_zero, zero_mul]) (fun x y _ _ hx hy => ?_) ha
  ┬Ě obtain ÔčĘx, rflÔčę := hx
    convert star_mul_self_nonneg (x * c) using 1
    rw [star_mul, ÔćÉ mul_assoc, mul_assoc _ _ c]
  ┬Ě calc
      0 ÔëĄ star c * x * c + 0 := by rw [add_zero]; exact hx
      _ ÔëĄ star c * x * c + star c * y * c := by gcongr
      _ ÔëĄ _ := by rw [mul_add, add_mul]

@[aesop safe apply]
theorem star_right_conjugate_nonneg {a : R} (ha : 0 ÔëĄ a) (c : R) : 0 ÔëĄ c * a * star c := by
  simpa only [star_star] using star_left_conjugate_nonneg ha (star c)

@[aesop 90% apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.conjugate_nonneg {a : R} (ha : 0 ÔëĄ a) {c : R}
    (hc : IsSelfAdjoint c) : 0 ÔëĄ c * a * c := by
  nth_rewrite 2 [ÔćÉ hc]; exact star_right_conjugate_nonneg ha c

theorem conjugate_nonneg_of_nonneg {a : R} (ha : 0 ÔëĄ a) {c : R} (hc : 0 ÔëĄ c) :
    0 ÔëĄ c * a * c :=
  IsSelfAdjoint.of_nonneg hc |>.conjugate_nonneg ha

theorem star_left_conjugate_le_conjugate {a b : R} (hab : a ÔëĄ b) (c : R) :
    star c * a * c ÔëĄ star c * b * c := by
  rw [StarOrderedRing.le_iff] at hab ÔŐó
  obtain ÔčĘp, hp, rflÔčę := hab
  simp_rw [ÔćÉ StarOrderedRing.nonneg_iff] at hp ÔŐó
  exact ÔčĘstar c * p * c, star_left_conjugate_nonneg hp c, by simp only [add_mul, mul_add]Ôčę

theorem star_right_conjugate_le_conjugate {a b : R} (hab : a ÔëĄ b) (c : R) :
    c * a * star c ÔëĄ c * b * star c := by
  simpa only [star_star] using star_left_conjugate_le_conjugate hab (star c)

protected theorem IsSelfAdjoint.conjugate_le_conjugate {a b : R} (hab : a ÔëĄ b) {c : R}
    (hc : IsSelfAdjoint c) : c * a * c ÔëĄ c * b * c := by
  simpa only [hc.star_eq] using star_left_conjugate_le_conjugate hab c

theorem conjugate_le_conjugate_of_nonneg {a b : R} (hab : a ÔëĄ b) {c : R} (hc : 0 ÔëĄ c) :
    c * a * c ÔëĄ c * b * c :=
  IsSelfAdjoint.of_nonneg hc |>.conjugate_le_conjugate hab

@[simp]
lemma star_le_star_iff {x y : R} : star x ÔëĄ star y Ôćö x ÔëĄ y := by
  suffices ÔłÇ x y, x ÔëĄ y Ôćĺ star x ÔëĄ star y from
    ÔčĘby simpa only [star_star] using this (star x) (star y), this x yÔčę
  intro x y h
  rw [StarOrderedRing.le_iff] at h ÔŐó
  obtain ÔčĘd, hd, rflÔčę := h
  refine ÔčĘstarAddEquiv d, ?_, star_add _ _Ôčę
  refine AddMonoidHom.mclosure_preimage_le _ _ <| AddSubmonoid.closure_mono ?_ hd
  rintro - ÔčĘs, rflÔčę
  exact ÔčĘs, by simpÔčę

@[simp]
lemma star_lt_star_iff {x y : R} : star x < star y Ôćö x < y := by
  by_cases h : x = y
  ┬Ě simp [h]
  ┬Ě simpa [le_iff_lt_or_eq, h] using star_le_star_iff (x := x) (y := y)

lemma star_le_iff {x y : R} : star x ÔëĄ y Ôćö x ÔëĄ star y := by rw [ÔćÉ star_le_star_iff, star_star]

lemma star_lt_iff {x y : R} : star x < y Ôćö x < star y := by rw [ÔćÉ star_lt_star_iff, star_star]

@[simp]
lemma star_nonneg_iff {x : R} : 0 ÔëĄ star x Ôćö 0 ÔëĄ x := by
  simpa using star_le_star_iff (x := 0) (y := x)

@[simp]
lemma star_nonpos_iff {x : R} : star x ÔëĄ 0 Ôćö x ÔëĄ 0 := by
  simpa using star_le_star_iff (x := x) (y := 0)

@[simp]
lemma star_pos_iff {x : R} : 0 < star x Ôćö 0 < x := by
  simpa using star_lt_star_iff (x := 0) (y := x)

@[simp]
lemma star_neg_iff {x : R} : star x < 0 Ôćö x < 0 := by
  simpa using star_lt_star_iff (x := x) (y := 0)

theorem star_left_conjugate_lt_conjugate {a b : R} (hab : a < b) {c : R} (hc : IsRegular c) :
    star c * a * c < star c * b * c := by
  rw [(star_left_conjugate_le_conjugate hab.le _).lt_iff_ne, hc.right.ne_iff, hc.star.left.ne_iff]
  exact hab.ne

theorem star_right_conjugate_lt_conjugate {a b : R} (hab : a < b) {c : R} (hc : IsRegular c) :
    c * a * star c < c * b * star c := by
  simpa only [star_star] using star_left_conjugate_lt_conjugate hab hc.star

theorem star_left_conjugate_pos {a : R} (ha : 0 < a) {c : R} (hc : IsRegular c) :
    0 < star c * a * c := by
  simpa only [mul_zero, zero_mul] using star_left_conjugate_lt_conjugate ha hc

theorem star_right_conjugate_pos {a : R} (ha : 0 < a) {c : R} (hc : IsRegular c) :
    0 < c * a * star c := by
  simpa only [star_star] using star_left_conjugate_pos ha hc.star

theorem star_mul_self_pos [Nontrivial R] {x : R} (hx : IsRegular x) : 0 < star x * x := by
  rw [(star_mul_self_nonneg _).lt_iff_ne, ÔćÉ mul_zero (star x), hx.star.left.ne_iff]
  exact hx.ne_zero.symm

theorem mul_star_self_pos [Nontrivial R] {x : R} (hx : IsRegular x) : 0 < x * star x := by
  simpa using star_mul_self_pos hx.star

end NonUnitalSemiring

section Semiring
variable [Semiring R] [PartialOrder R] [StarRing R] [StarOrderedRing R]

instance : ZeroLEOneClass R where
  zero_le_one := by simpa using star_mul_self_nonneg (1 : R)

@[simp]
lemma one_le_star_iff {x : R} : 1 ÔëĄ star x Ôćö 1 ÔëĄ x := by
  simpa using star_le_star_iff (x := 1) (y := x)

@[simp]
