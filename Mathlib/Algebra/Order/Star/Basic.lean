/-! # Star ordered rings

We define the class `StarOrderedRing R`, which says that the order on `R` respects the
star operation, i.e. an element `r` is nonnegative iff it is in the `AddSubmonoid` generated by
elements of the form `star s * s`. In many cases, including all C‚čÜ-algebras, this can be reduced to
`0 ‚Č§ r ‚ÜĒ ‚ąÉ s, r = star s * s`. However, this generality is slightly more convenient (e.g., it
allows us to register a `StarOrderedRing` instance for `‚Ąö`), and more closely resembles the
literature (see the seminal paper [*The positive cone in Banach algebras*][kelleyVaught1953])

In order to accommodate `NonUnitalSemiring R`, we actually don't characterize nonnegativity, but
rather the entire `‚Č§` relation with `StarOrderedRing.le_iff`. However, notice that when `R` is a
`NonUnitalRing`, these are equivalent (see `StarOrderedRing.nonneg_iff` and
`StarOrderedRing.of_nonneg_iff`).

It is important to note that while a `StarOrderedRing` is an `OrderedAddCommMonoid` it is often
*not* an `OrderedSemiring`.

## TODO

* In a Banach star algebra without a well-defined square root, the natural ordering is given by the
  positive cone which is the _closure_ of the sums of elements `star r * r`. A weaker version of
  `StarOrderedRing` could be defined for this case (again, see
  [*The positive cone in Banach algebras*][kelleyVaught1953]). Note that the current definition has
  the advantage of not requiring a topology.
-/

open Set
open scoped NNRat

variable {R A : Type*}

section prereq
variable [Semiring R] [StarRing R]
  [NonUnitalSemiring A] [StarRing A] [Module R A]
  [StarModule R A] [IsScalarTower R A A] [SMulCommClass R A A]

lemma smul_mem_closure_star_mul {r : R}
    (hr : r ‚ąą AddSubmonoid.closure (range fun s ‚Ü¶ star s * s)) {a : A}
    (ha : a ‚ąą AddSubmonoid.closure (range fun s ‚Ü¶ star s * s)) :
    r ‚ÄĘ a ‚ąą AddSubmonoid.closure (range fun s ‚Ü¶ star s * s) := by
  induction hr using AddSubmonoid.closure_induction with
  | zero => simp
  | add r‚āĀ r‚āā _ _ hr‚āĀ hr‚āā => simpa [add_smul] using add_mem hr‚āĀ hr‚āā
  | mem r hr =>
  induction ha using AddSubmonoid.closure_induction with
  | zero => simp
  | add a‚āĀ a‚āā _ _ ha‚āĀ ha‚āā => simpa [smul_add] using add_mem ha‚āĀ ha‚āā
  | mem a ha =>
  obtain ‚ü®r, rfl‚ü© := hr
  obtain ‚ü®a, rfl‚ü© := ha
  exact AddSubmonoid.subset_closure  ‚ü®r ‚ÄĘ a, by simp [star_smul, smul_mul_smul_comm]‚ü©

end prereq

/-- An ordered `*`-ring is a `*`-ring with a partial order such that the nonnegative elements
constitute precisely the `AddSubmonoid` generated by elements of the form `star s * s`.

If you are working with a `NonUnitalRing` and not a `NonUnitalSemiring`, it may be more
convenient to declare instances using `StarOrderedRing.of_nonneg_iff`. -/
class StarOrderedRing (R : Type*) [NonUnitalSemiring R] [PartialOrder R] [StarRing R] : Prop where
  /-- characterization of the order in terms of the `StarRing` structure. -/
  le_iff :
    ‚ąÄ x y : R, x ‚Č§ y ‚ÜĒ ‚ąÉ p, p ‚ąą AddSubmonoid.closure (Set.range fun s => star s * s) ‚ąß y = x + p

namespace StarOrderedRing
section NonUnitalSemiring
variable [NonUnitalSemiring R] [PartialOrder R] [StarRing R]

/-- To construct a `StarOrderedRing` instance it suffices to show that `x ‚Č§ y` if and only if
`y = x + star s * s` for some `s : R`.

This is provided for convenience because it holds in some common scenarios (e.g.,`‚ĄĚ‚Č•0`, `C(X, ‚ĄĚ‚Č•0)`)
and obviates the hassle of `AddSubmonoid.closure_induction` when creating those instances.

If you are working with a `NonUnitalRing` and not a `NonUnitalSemiring`, see
`StarOrderedRing.of_nonneg_iff` for a more convenient version.
-/
lemma of_le_iff (h_le_iff : ‚ąÄ x y : R, x ‚Č§ y ‚ÜĒ ‚ąÉ s, y = x + star s * s) : StarOrderedRing R where
  le_iff x y := by
    refine ‚ü®fun h => ?_, ?_‚ü©
    ¬∑ obtain ‚ü®p, hp‚ü© := (h_le_iff x y).mp h
      exact ‚ü®star p * p, AddSubmonoid.subset_closure ‚ü®p, rfl‚ü©, hp‚ü©
    ¬∑ rintro ‚ü®p, hp, hpxy‚ü©
      revert x y hpxy
      refine AddSubmonoid.closure_induction ?_ (fun x y h => add_zero x ‚Ėł h.ge) ?_ hp
      ¬∑ rintro _ ‚ü®s, rfl‚ü© x y rfl
        exact (h_le_iff _ _).mpr ‚ü®s, rfl‚ü©
      ¬∑ rintro _ _ _ _ ha hb x y rfl
        rw [‚Üź add_assoc]
        exact (ha _ _ rfl).trans (hb _ _ rfl)

variable [StarOrderedRing R] {x y : R}

-- see note [lower instance priority]
instance (priority := 100) toIsOrderedAddMonoid : IsOrderedAddMonoid R where
  add_le_add_left := fun x y hle z ‚Ü¶ by
    rw [StarOrderedRing.le_iff] at hle ‚äĘ
    refine hle.imp fun s hs ‚Ü¶ ?_
    rw [hs.2, add_assoc]
    exact ‚ü®hs.1, rfl‚ü©

-- see note [lower instance priority]
instance (priority := 100) toExistsAddOfLE : ExistsAddOfLE R where
  exists_add_of_le h :=
    match (le_iff _ _).mp h with
    | ‚ü®p, _, hp‚ü© => ‚ü®p, hp‚ü©

lemma nonneg_iff : 0 ‚Č§ x ‚ÜĒ x ‚ąą AddSubmonoid.closure (Set.range fun s : R => star s * s) := by
  simp only [le_iff, zero_add, exists_eq_right']

lemma pos_iff : 0 < x ‚ÜĒ x ‚Č† 0 ‚ąß x ‚ąą AddSubmonoid.closure (Set.range fun s : R => star s * s) := by
  simp [lt_iff_le_and_ne, and_comm, eq_comm, le_iff]

variable [IsCancelAdd R]

lemma lt_iff :
    x < y ‚ÜĒ ‚ąÉ p ‚Č† 0, p ‚ąą AddSubmonoid.closure (Set.range fun s => star s * s) ‚ąß y = x + p := by
  rw [lt_iff_le_and_ne, and_comm, StarOrderedRing.le_iff, ‚Üź exists_and_left]
  congr! 2 with p
  simp +contextual [‚Üź and_assoc]

end NonUnitalSemiring

/-- When `R` is a non-unital ring, to construct a `StarOrderedRing` instance it suffices to
show that the nonnegative elements are precisely those elements in the `AddSubmonoid` generated
by `star s * s` for `s : R`. -/
lemma of_nonneg_iff [NonUnitalRing R] [PartialOrder R] [StarRing R]
    (h_add : ‚ąÄ {x y : R}, x ‚Č§ y ‚Üí ‚ąÄ z, z + x ‚Č§ z + y)
    (h_nonneg_iff : ‚ąÄ x : R, 0 ‚Č§ x ‚ÜĒ x ‚ąą AddSubmonoid.closure (Set.range fun s : R => star s * s)) :
    StarOrderedRing R where
  le_iff x y := by
    have : AddLeftMono R := ‚ü®fun _ _ _ h => h_add h _‚ü©
    simpa only [‚Üź sub_eq_iff_eq_add', sub_nonneg, exists_eq_right'] using h_nonneg_iff (y - x)

/-- When `R` is a non-unital ring, to construct a `StarOrderedRing` instance it suffices to
show that the nonnegative elements are precisely those elements of the form `star s * s`
for `s : R`.

This is provided for convenience because it holds in many common scenarios (e.g.,`‚ĄĚ`, `‚Ąā`, or
any C‚čÜ-algebra), and obviates the hassle of `AddSubmonoid.closure_induction` when creating those
instances. -/
lemma of_nonneg_iff' [NonUnitalRing R] [PartialOrder R] [StarRing R]
    (h_add : ‚ąÄ {x y : R}, x ‚Č§ y ‚Üí ‚ąÄ z, z + x ‚Č§ z + y)
    (h_nonneg_iff : ‚ąÄ x : R, 0 ‚Č§ x ‚ÜĒ ‚ąÉ s, x = star s * s) : StarOrderedRing R :=
  of_le_iff <| by
    have : AddLeftMono R := ‚ü®fun _ _ _ h => h_add h _‚ü©
    simpa [sub_eq_iff_eq_add', sub_nonneg] using fun x y => h_nonneg_iff (y - x)

end StarOrderedRing

section NonUnitalSemiring

variable [NonUnitalSemiring R] [PartialOrder R] [StarRing R] [StarOrderedRing R]

lemma IsSelfAdjoint.mono {x y : R} (h : x ‚Č§ y) (hx : IsSelfAdjoint x) : IsSelfAdjoint y := by
  rw [StarOrderedRing.le_iff] at h
  obtain ‚ü®d, hd, rfl‚ü© := h
  rw [IsSelfAdjoint, star_add, hx.star_eq]
  congr
  refine AddMonoidHom.eqOn_closureM (f := starAddEquiv (R := R)) (g := .id R) ?_ hd
  rintro - ‚ü®s, rfl‚ü©
  simp

grind_pattern IsSelfAdjoint.mono => x ‚Č§ y, IsSelfAdjoint x

@[aesop 10% apply, grind ‚Üź]
lemma IsSelfAdjoint.of_nonneg {x : R} (hx : 0 ‚Č§ x) : IsSelfAdjoint x :=
  .mono hx <| .zero R

/-- An alias of `IsSelfAdjoint.of_nonneg` for use with dot notation. -/
alias LE.le.isSelfAdjoint := IsSelfAdjoint.of_nonneg

/-- The combination `(IsSelfAdjoint.star_eq <| .of_nonneg ¬∑)` for use with dot notation. -/
lemma LE.le.star_eq {x : R} (hx : 0 ‚Č§ x) : star x = x :=
  hx.isSelfAdjoint.star_eq

@[simp, grind]
theorem star_mul_self_nonneg (r : R) : 0 ‚Č§ star r * r :=
  StarOrderedRing.nonneg_iff.mpr <| AddSubmonoid.subset_closure ‚ü®r, rfl‚ü©

@[simp, grind]
theorem mul_star_self_nonneg (r : R) : 0 ‚Č§ r * star r := by
  simpa only [star_star] using star_mul_self_nonneg (star r)

@[aesop safe apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.mul_self_nonneg {a : R} (ha : IsSelfAdjoint a) : 0 ‚Č§ a * a := by
  simpa [ha.star_eq] using star_mul_self_nonneg a

/-- A star projection is non-negative in a star-ordered ring. -/
theorem IsStarProjection.nonneg {p : R} (hp : IsStarProjection p) : 0 ‚Č§ p :=
  hp.isIdempotentElem ‚Ėł hp.isSelfAdjoint.mul_self_nonneg

@[aesop safe apply, grind ‚Üź]
theorem conjugate_nonneg {a : R} (ha : 0 ‚Č§ a) (c : R) : 0 ‚Č§ star c * a * c := by
  rw [StarOrderedRing.nonneg_iff] at ha
  refine AddSubmonoid.closure_induction (fun x hx => ?_)
    (by rw [mul_zero, zero_mul]) (fun x y _ _ hx hy => ?_) ha
  ¬∑ obtain ‚ü®x, rfl‚ü© := hx
    convert star_mul_self_nonneg (x * c) using 1
    rw [star_mul, ‚Üź mul_assoc, mul_assoc _ _ c]
  ¬∑ calc
      0 ‚Č§ star c * x * c + 0 := by rw [add_zero]; exact hx
      _ ‚Č§ star c * x * c + star c * y * c := add_le_add_left hy _
      _ ‚Č§ _ := by rw [mul_add, add_mul]

@[aesop safe apply, grind ‚Üź]
theorem conjugate_nonneg' {a : R} (ha : 0 ‚Č§ a) (c : R) : 0 ‚Č§ c * a * star c := by
  simpa only [star_star] using conjugate_nonneg ha (star c)

@[aesop 90% apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.conjugate_nonneg {a : R} (ha : 0 ‚Č§ a) {c : R}
    (hc : IsSelfAdjoint c) : 0 ‚Č§ c * a * c := by
  nth_rewrite 2 [‚Üź hc]; exact conjugate_nonneg' ha c

theorem conjugate_nonneg_of_nonneg {a : R} (ha : 0 ‚Č§ a) {c : R} (hc : 0 ‚Č§ c) :
    0 ‚Č§ c * a * c :=
  IsSelfAdjoint.of_nonneg hc |>.conjugate_nonneg ha

theorem conjugate_le_conjugate {a b : R} (hab : a ‚Č§ b) (c : R) :
    star c * a * c ‚Č§ star c * b * c := by
  rw [StarOrderedRing.le_iff] at hab ‚äĘ
  obtain ‚ü®p, hp, rfl‚ü© := hab
  simp_rw [‚Üź StarOrderedRing.nonneg_iff] at hp ‚äĘ
  exact ‚ü®star c * p * c, conjugate_nonneg hp c, by simp only [add_mul, mul_add]‚ü©

theorem conjugate_le_conjugate' {a b : R} (hab : a ‚Č§ b) (c : R) :
    c * a * star c ‚Č§ c * b * star c := by
  simpa only [star_star] using conjugate_le_conjugate hab (star c)

protected theorem IsSelfAdjoint.conjugate_le_conjugate {a b : R} (hab : a ‚Č§ b) {c : R}
    (hc : IsSelfAdjoint c) : c * a * c ‚Č§ c * b * c := by
  simpa only [hc.star_eq] using conjugate_le_conjugate hab c

theorem conjugate_le_conjugate_of_nonneg {a b : R} (hab : a ‚Č§ b) {c : R} (hc : 0 ‚Č§ c) :
    c * a * c ‚Č§ c * b * c :=
  IsSelfAdjoint.of_nonneg hc |>.conjugate_le_conjugate hab

@[simp]
lemma star_le_star_iff {x y : R} : star x ‚Č§ star y ‚ÜĒ x ‚Č§ y := by
  suffices ‚ąÄ x y, x ‚Č§ y ‚Üí star x ‚Č§ star y from
    ‚ü®by simpa only [star_star] using this (star x) (star y), this x y‚ü©
  intro x y h
  rw [StarOrderedRing.le_iff] at h ‚äĘ
  obtain ‚ü®d, hd, rfl‚ü© := h
  refine ‚ü®starAddEquiv d, ?_, star_add _ _‚ü©
  refine AddMonoidHom.mclosure_preimage_le _ _ <| AddSubmonoid.closure_mono ?_ hd
  rintro - ‚ü®s, rfl‚ü©
  exact ‚ü®s, by simp‚ü©

@[simp]
lemma star_lt_star_iff {x y : R} : star x < star y ‚ÜĒ x < y := by
  by_cases h : x = y
  ¬∑ simp [h]
  ¬∑ simpa [le_iff_lt_or_eq, h] using star_le_star_iff (x := x) (y := y)

lemma star_le_iff {x y : R} : star x ‚Č§ y ‚ÜĒ x ‚Č§ star y := by rw [‚Üź star_le_star_iff, star_star]

lemma star_lt_iff {x y : R} : star x < y ‚ÜĒ x < star y := by rw [‚Üź star_lt_star_iff, star_star]

@[simp, grind =]
lemma star_nonneg_iff {x : R} : 0 ‚Č§ star x ‚ÜĒ 0 ‚Č§ x := by
  simpa using star_le_star_iff (x := 0) (y := x)

@[simp, grind =]
lemma star_nonpos_iff {x : R} : star x ‚Č§ 0 ‚ÜĒ x ‚Č§ 0 := by
  simpa using star_le_star_iff (x := x) (y := 0)

@[simp]
lemma star_pos_iff {x : R} : 0 < star x ‚ÜĒ 0 < x := by
  simpa using star_lt_star_iff (x := 0) (y := x)

@[simp]
lemma star_neg_iff {x : R} : star x < 0 ‚ÜĒ x < 0 := by
  simpa using star_lt_star_iff (x := x) (y := 0)

theorem conjugate_lt_conjugate {a b : R} (hab : a < b) {c : R} (hc : IsRegular c) :
    star c * a * c < star c * b * c := by
  rw [(conjugate_le_conjugate hab.le _).lt_iff_ne, hc.right.ne_iff, hc.star.left.ne_iff]
  exact hab.ne

theorem conjugate_lt_conjugate' {a b : R} (hab : a < b) {c : R} (hc : IsRegular c) :
    c * a * star c < c * b * star c := by
  simpa only [star_star] using conjugate_lt_conjugate hab hc.star

theorem conjugate_pos {a : R} (ha : 0 < a) {c : R} (hc : IsRegular c) : 0 < star c * a * c := by
  simpa only [mul_zero, zero_mul] using conjugate_lt_conjugate ha hc

theorem conjugate_pos' {a : R} (ha : 0 < a) {c : R} (hc : IsRegular c) : 0 < c * a * star c := by
  simpa only [star_star] using conjugate_pos ha hc.star

theorem star_mul_self_pos [Nontrivial R] {x : R} (hx : IsRegular x) : 0 < star x * x := by
  rw [(star_mul_self_nonneg _).lt_iff_ne, ‚Üź mul_zero (star x), hx.star.left.ne_iff]
  exact hx.ne_zero.symm

theorem mul_star_self_pos [Nontrivial R] {x : R} (hx : IsRegular x) : 0 < x * star x := by
  simpa using star_mul_self_pos hx.star

end NonUnitalSemiring

section Semiring
variable [Semiring R] [PartialOrder R] [StarRing R] [StarOrderedRing R]

instance : ZeroLEOneClass R where
  zero_le_one := by simpa using star_mul_self_nonneg (1 : R)

@[simp]
lemma one_le_star_iff {x : R} : 1 ‚Č§ star x ‚ÜĒ 1 ‚Č§ x := by
  simpa using star_le_star_iff (x := 1) (y := x)

@[simp]
lemma star_le_one_iff {x : R} : star x ‚Č§ 1 ‚ÜĒ x ‚Č§ 1 := by
  simpa using star_le_star_iff (x := x) (y := 1)

@[simp]
lemma one_lt_star_iff {x : R} : 1 < star x ‚ÜĒ 1 < x := by
  simpa using star_lt_star_iff (x := 1) (y := x)

@[simp]
lemma star_lt_one_iff {x : R} : star x < 1 ‚ÜĒ x < 1 := by
  simpa using star_lt_star_iff (x := x) (y := 1)

@[aesop safe apply (rule_sets := [CStarAlgebra])]
protected theorem IsSelfAdjoint.sq_nonneg {a : R} (ha : IsSelfAdjoint a) : 0 ‚Č§ a ^ 2 := by
  simp [sq, ha.mul_self_nonneg]

end Semiring

namespace MulOpposite

instance [NonUnitalSemiring R] [StarRing R] [PartialOrder R] [StarOrderedRing R] :
    StarOrderedRing RŠĶźŠĶíŠĶĖ where
  le_iff x y := by
    rw [‚Üź unop_le_unop, StarOrderedRing.le_iff, op_surjective.exists,
      ‚Üź (AddSubmonoid.closure _).comap_map_eq_of_injective opAddEquiv.injective]
    congr! with p
    ¬∑ simp [AddMonoidHom.map_mclosure, ‚Üź range_comp', Function.comp_def,
        ‚Üź (star_involutive.surjective.comp op_surjective).range_comp]
    ¬∑ simp [‚Üź op_inj (őĪ := R)]

end MulOpposite

section StarModule

variable [Semiring R] [PartialOrder R] [StarRing R] [StarOrderedRing R]
  [NonUnitalSemiring A] [StarRing A] [PartialOrder A] [StarOrderedRing A] [Module R A]
  [StarModule R A] [IsScalarTower R A A] [SMulCommClass R A A]

instance : PosSMulMono R A where
  elim r hr a b hab := by
    rw [StarOrderedRing.nonneg_iff] at hr
    rw [StarOrderedRing.le_iff] at hab ‚äĘ
    obtain ‚ü®a, ha, rfl‚ü© := hab
    exact ‚ü®r ‚ÄĘ a, smul_mem_closure_star_mul hr ha, smul_add ..‚ü©

instance : SMulPosMono R A where
  elim a ha r s hrs := by
    rw [StarOrderedRing.nonneg_iff] at ha
    rw [StarOrderedRing.le_iff] at hrs ‚äĘ
    obtain ‚ü®r, hr, rfl‚ü© := hrs
    exact ‚ü®r ‚ÄĘ a, smul_mem_closure_star_mul hr ha, add_smul ..‚ü©

variable [IsCancelAdd A] [NoZeroSMulDivisors R A]

instance : PosSMulStrictMono R A where
  elim r hr a b hab := by
    rw [StarOrderedRing.pos_iff] at hr
    rw [StarOrderedRing.lt_iff] at hab ‚äĘ
    obtain ‚ü®a, ha‚āÄ, ha, rfl‚ü© := hab
    obtain ‚ü®hr‚āÄ, hr‚ü© := hr
    exact ‚ü®r ‚ÄĘ a, smul_ne_zero hr‚āÄ ha‚āÄ, smul_mem_closure_star_mul hr ha, smul_add ..‚ü©

instance [IsCancelAdd R] : SMulPosStrictMono R A where
  elim a ha r s hrs := by
    rw [StarOrderedRing.pos_iff] at ha
    rw [StarOrderedRing.lt_iff] at hrs ‚äĘ
    obtain ‚ü®r, hr‚āÄ, hr, rfl‚ü© := hrs
    obtain ‚ü®ha‚āÄ, ha‚ü© := ha
    exact ‚ü®r ‚ÄĘ a, smul_ne_zero hr‚āÄ ha‚āÄ, smul_mem_closure_star_mul hr ha, add_smul ..‚ü©

@[deprecated smul_lt_smul_of_pos_left (since := "2025-08-24")]
lemma StarModule.smul_lt_smul_of_pos {a b : A} {c : R} (hab : a < b)
    (hc : 0 < c) : c ‚ÄĘ a < c ‚ÄĘ b := smul_lt_smul_of_pos_left hab hc

end StarModule

section OrderClass

variable {F R S : Type*} [NonUnitalSemiring R] [PartialOrder R] [StarRing R]
  [StarOrderedRing R]
variable [NonUnitalSemiring S] [PartialOrder S] [StarRing S] [StarOrderedRing S]

-- we prove this auxiliary lemma in order to avoid duplicating the proof twice below.
lemma NonUnitalStarRingHom.map_le_map_of_map_star (f : R ‚Üí‚čÜ‚āô+* S) {x y : R} (hxy : x ‚Č§ y) :
    f x ‚Č§ f y := by
  rw [StarOrderedRing.le_iff] at hxy ‚äĘ
  obtain ‚ü®p, hp, rfl‚ü© := hxy
  refine ‚ü®f p, ?_, map_add f _ _‚ü©
  have hf : ‚ąÄ r, f (star r) = star (f r) := map_star _
  induction hp using AddSubmonoid.closure_induction
  all_goals aesop

instance (priority := 100) StarRingHomClass.instOrderHomClass [FunLike F R S]
    [NonUnitalSemiring R] [StarRing R] [StarOrderedRing R] [NonUnitalSemiring S]
    [StarRing S] [StarOrderedRing S] [NonUnitalRingHomClass F R S]
    [NonUnitalStarRingHomClass F R S] : OrderHomClass F R S where
  map_rel f := (f : R ‚Üí‚čÜ‚āô+* S).map_le_map_of_map_star

instance (priority := 100) StarRingEquivClass.instOrderIsoClass [EquivLike F R S]
    [StarRingEquivClass F R S] : OrderIsoClass F R S where
  map_le_map_iff f x y := by
    refine ‚ü®fun h ‚Ü¶ ?_, map_rel f‚ü©
    let f_inv : S ‚Üí‚čÜ‚āô+* R := (f : R ‚ČÉ‚čÜ+* S).symm
    have f_inv_f (r : R) : f_inv (f r) = r := EquivLike.inv_apply_apply f r
    rw [‚Üź f_inv_f x, ‚Üź f_inv_f y]
    exact NonUnitalStarRingHom.map_le_map_of_map_star f_inv h

end OrderClass

instance Nat.instStarOrderedRing : StarOrderedRing ‚Ąē where
  le_iff a b := by
    have : AddSubmonoid.closure (range fun x : ‚Ąē ‚Ü¶ x * x) = ‚ä§ :=
      eq_top_mono
        (AddSubmonoid.closure_mono <| singleton_subset_iff.2 <| mem_range.2 ‚ü®1, one_mul _‚ü©)
        Nat.addSubmonoidClosure_one
    simp [this, le_iff_exists_add]

namespace IsStarProjection

section Ring
variable [Ring R] [PartialOrder R] [StarRing R] [StarOrderedRing R] {p : R}

theorem one_sub_nonneg (hp : IsStarProjection p) : 0 ‚Č§ 1 - p := hp.one_sub.nonneg

theorem le_one (hp : IsStarProjection p) : p ‚Č§ 1 := sub_nonneg.mp hp.one_sub_nonneg

/-- For a star projection `p`, we have `0 ‚Č§ p ‚Č§ 1`. -/
theorem mem_Icc (hp : IsStarProjection p) : p ‚ąą Set.Icc (0 : R) 1 := by
  simp only [Set.mem_Icc, hp.nonneg, hp.le_one, and_self]

end Ring

section NonUnitalRing
variable [NonUnitalRing R] [PartialOrder R] [StarRing R] [StarOrderedRing R] {p q : R}

/-- A star projection `p` is less than or equal to a star projection `q` when `p * q = p`. -/
theorem le_of_mul_eq_left (hp : IsStarProjection p) (hq : IsStarProjection q)
    (hpq : p * q = p) : p ‚Č§ q := sub_nonneg.mp (hp.sub_of_mul_eq_left hq hpq).nonneg

/-- A star projection `p` is less than or equal to a star projection `q` when `q * p = p`. -/
theorem le_of_mul_eq_right (hp : IsStarProjection p) (hq : IsStarProjection q)
    (hpq : q * p = p) : p ‚Č§ q := sub_nonneg.mp (hp.sub_of_mul_eq_right hq hpq).nonneg

end NonUnitalRing

end IsStarProjection
