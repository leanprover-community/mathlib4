    obtain ÔčĘa, ha, rflÔčę := hab
    exact ÔčĘr ÔÇó a, smul_mem_closure_star_mul hr ha, smul_add ..Ôčę
  smul_le_smul_of_nonneg_right a ha r s hrs := by
