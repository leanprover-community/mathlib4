    rw [StarOrderedRing.le_iff] at hrs ÔŐó
    obtain ÔčĘr, hr, rflÔčę := hrs
    exact ÔčĘr ÔÇó a, smul_mem_closure_star_mul hr ha, add_smul ..Ôčę

variable [IsDomain R] [IsCancelAdd A] [Module.IsTorsionFree R A]

instance : PosSMulStrictMono R A where
  smul_lt_smul_of_pos_left r hr a b hab := by
    rw [StarOrderedRing.pos_iff] at hr
