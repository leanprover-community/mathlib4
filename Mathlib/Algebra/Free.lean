/-!
# Free constructions

## Main definitions

* `FreeMagma Оұ`: free magma (structure with binary operation without any axioms) over alphabet `Оұ`,
  defined inductively, with traversable instance and decidable equality.
* `MagmaAssocQuotient Оұ`: quotient of a magma `Оұ` by the associativity equivalence relation.
* `FreeSemigroup Оұ`: free semigroup over alphabet `Оұ`, defined as a structure with two fields
  `head : Оұ` and `tail : List Оұ` (i.e. nonempty lists), with traversable instance and decidable
  equality.
* `FreeMagmaAssocQuotientEquiv Оұ`: isomorphism between `MagmaAssocQuotient (FreeMagma Оұ)` and
  `FreeSemigroup Оұ`.
* `FreeMagma.lift`: the universal property of the free magma, expressing its adjointness.
-/

@[expose] public section

universe u v l

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `Оұ` is a type, then `FreeAddMagma Оұ` is the free additive magma generated by `Оұ`.
This is an additive magma equipped with a function `FreeAddMagma.of : Оұ вҶ’ FreeAddMagma Оұ` which has
the following universal property: if `M` is any magma, and `f : Оұ вҶ’ M` is any function,
then this function is the composite of `FreeAddMagma.of` and a unique additive homomorphism
`FreeAddMagma.lift f : FreeAddMagma Оұ вҶ’вӮҷ+ M`.

A typical element of `FreeAddMagma Оұ` is a formal non-associative sum of
elements of `Оұ`. For example if `x` and `y` are terms of type `Оұ` then `x + ((y + y) + x)` is a
"typical" element of `FreeAddMagma Оұ`.
One can think of `FreeAddMagma Оұ` as the type of binary trees with leaves labelled by `Оұ`.
In general, no pair of distinct elements in `FreeAddMagma Оұ` will commute.
-/
inductive FreeAddMagma (Оұ : Type u) : Type u
  | of : Оұ вҶ’ FreeAddMagma Оұ
  | add : FreeAddMagma Оұ вҶ’ FreeAddMagma Оұ вҶ’ FreeAddMagma Оұ
  deriving DecidableEq
compile_inductive% FreeAddMagma

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `Оұ` is a type, then `FreeMagma Оұ` is the free magma generated by `Оұ`.
This is a magma equipped with a function `FreeMagma.of : Оұ вҶ’ FreeMagma Оұ` which has
the following universal property: if `M` is any magma, and `f : Оұ вҶ’ M` is any function,
then this function is the composite of `FreeMagma.of` and a unique multiplicative homomorphism
`FreeMagma.lift f : FreeMagma Оұ вҶ’вӮҷ* M`.

A typical element of `FreeMagma Оұ` is a formal non-associative product of
elements of `Оұ`. For example if `x` and `y` are terms of type `Оұ` then `x * ((y * y) * x)` is a
"typical" element of `FreeMagma Оұ`.
One can think of `FreeMagma Оұ` as the type of binary trees with leaves labelled by `Оұ`.
In general, no pair of distinct elements in `FreeMagma Оұ` will commute.
-/
@[to_additive]
inductive FreeMagma (Оұ : Type u) : Type u
  | of : Оұ вҶ’ FreeMagma Оұ
  | mul : FreeMagma Оұ вҶ’ FreeMagma Оұ вҶ’ FreeMagma Оұ
  deriving DecidableEq
compile_inductive% FreeMagma

namespace FreeMagma

variable {Оұ : Type u}

@[to_additive]
instance [Inhabited Оұ] : Inhabited (FreeMagma Оұ) := вҹЁof defaultвҹ©

@[to_additive]
instance : Mul (FreeMagma Оұ) := вҹЁFreeMagma.mulвҹ©

@[to_additive (attr := simp)]
theorem mul_eq (x y : FreeMagma Оұ) : mul x y = x * y := rfl

/-- Recursor for `FreeMagma` using `x * y` instead of `FreeMagma.mul x y`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for `FreeAddMagma` using `x + y` instead of `FreeAddMagma.add x y`. -/]
def recOnMul {C : FreeMagma Оұ вҶ’ Sort l} (x) (ih1 : вҲҖ x, C (of x))
    (ih2 : вҲҖ x y, C x вҶ’ C y вҶ’ C (x * y)) : C x :=
  FreeMagma.recOn x ih1 ih2

@[to_additive (attr := ext 1100)]
theorem hom_ext {ОІ : Type v} [Mul ОІ] {f g : FreeMagma Оұ вҶ’вӮҷ* ОІ} (h : f вҲҳ of = g вҲҳ of) : f = g :=
  (DFunLike.ext _ _) fun x вҶҰ recOnMul x (congr_fun h) <| by intros; simp only [map_mul, *]

end FreeMagma

/-- Lifts a function `Оұ вҶ’ ОІ` to a magma homomorphism `FreeMagma Оұ вҶ’ ОІ` given a magma `ОІ`. -/
def FreeMagma.liftAux {Оұ : Type u} {ОІ : Type v} [Mul ОІ] (f : Оұ вҶ’ ОІ) : FreeMagma Оұ вҶ’ ОІ
  | FreeMagma.of x => f x
  | x * y => liftAux f x * liftAux f y

/-- Lifts a function `Оұ вҶ’ ОІ` to an additive magma homomorphism `FreeAddMagma Оұ вҶ’ ОІ` given
an additive magma `ОІ`. -/
def FreeAddMagma.liftAux {Оұ : Type u} {ОІ : Type v} [Add ОІ] (f : Оұ вҶ’ ОІ) : FreeAddMagma Оұ вҶ’ ОІ
  | FreeAddMagma.of x => f x
  | x + y => liftAux f x + liftAux f y

attribute [to_additive existing] FreeMagma.liftAux

namespace FreeMagma

section lift

variable {Оұ : Type u} {ОІ : Type v} [Mul ОІ] (f : Оұ вҶ’ ОІ)

/-- The universal property of the free magma expressing its adjointness. -/
@[to_additive (attr := simps symm_apply)
/-- The universal property of the free additive magma expressing its adjointness. -/]
def lift : (Оұ вҶ’ ОІ) вүғ (FreeMagma Оұ вҶ’вӮҷ* ОІ) where
  toFun f :=
  { toFun := liftAux f
    map_mul' := fun _ _ вҶҰ rfl }
  invFun F := F вҲҳ of

@[to_additive (attr := simp)]
theorem lift_of (x) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f вҲҳ of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeMagma Оұ вҶ’вӮҷ* ОІ) : lift (f вҲҳ of) = f := lift.apply_symm_apply f

end lift

section Map

variable {Оұ : Type u} {ОІ : Type v} (f : Оұ вҶ’ ОІ)

/-- The unique magma homomorphism `FreeMagma Оұ вҶ’вӮҷ* FreeMagma ОІ` that sends
each `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive magma homomorphism `FreeAddMagma Оұ вҶ’ FreeAddMagma ОІ` that
sends each `of x` to `of (f x)`. -/]
def map (f : Оұ вҶ’ ОІ) : FreeMagma Оұ вҶ’вӮҷ* FreeMagma ОІ := lift (of вҲҳ f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end Map

section Category

variable {Оұ ОІ : Type u}

@[to_additive]
instance : Monad FreeMagma where
  pure := of
  bind x f := lift f x

/-- Recursor on `FreeMagma` using `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim)
/-- Recursor on `FreeAddMagma` using `pure` instead of `of`. -/]
protected def recOnPure {C : FreeMagma Оұ вҶ’ Sort l} (x) (ih1 : вҲҖ x, C (pure x))
    (ih2 : вҲҖ x y, C x вҶ’ C y вҶ’ C (x * y)) : C x :=
  FreeMagma.recOnMul x ih1 ih2

@[to_additive]
protected theorem map_pure (f : Оұ вҶ’ ОІ) (x) : (f <$> pure x : FreeMagma ОІ) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : Оұ вҶ’ ОІ) (x y : FreeMagma Оұ) : f <$> (x * y) = f <$> x * f <$> y := rfl

@[to_additive]
theorem pure_bind (f : Оұ вҶ’ FreeMagma ОІ) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : Оұ вҶ’ FreeMagma ОІ) (x y : FreeMagma Оұ) : x * y >>= f = (x >>= f) * (y >>= f) :=
  rfl

@[to_additive (attr := simp)]
theorem pure_seq {Оұ ОІ : Type u} {f : Оұ вҶ’ ОІ} {x : FreeMagma Оұ} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {Оұ ОІ : Type u} {f g : FreeMagma (Оұ вҶ’ ОІ)} {x : FreeMagma Оұ} :
    f * g <*> x = (f <*> x) * (g <*> x) := rfl

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeMagma.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ вҶҰ rfl)
  (bind_assoc := fun x f g вҶҰ FreeMagma.recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
    rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x вҶҰ FreeMagma.recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
    rw [map_mul', ih1, ih2])

end Category

end FreeMagma

/-- `FreeMagma` is traversable. -/
protected def FreeMagma.traverse {m : Type u вҶ’ Type u} [Applicative m] {Оұ ОІ : Type u}
    (F : Оұ вҶ’ m ОІ) : FreeMagma Оұ вҶ’ m (FreeMagma ОІ)
  | FreeMagma.of x => FreeMagma.of <$> F x
  | x * y => (В· * В·) <$> x.traverse F <*> y.traverse F

/-- `FreeAddMagma` is traversable. -/
protected def FreeAddMagma.traverse {m : Type u вҶ’ Type u} [Applicative m] {Оұ ОІ : Type u}
    (F : Оұ вҶ’ m ОІ) : FreeAddMagma Оұ вҶ’ m (FreeAddMagma ОІ)
  | FreeAddMagma.of x => FreeAddMagma.of <$> F x
  | x + y => (В· + В·) <$> x.traverse F <*> y.traverse F

attribute [to_additive existing] FreeMagma.traverse

namespace FreeMagma

variable {Оұ : Type u}

section Category

variable {ОІ : Type u}

@[to_additive]
instance : Traversable FreeMagma := вҹЁ@FreeMagma.traverseвҹ©

variable {m : Type u вҶ’ Type u} [Applicative m] (F : Оұ вҶ’ m ОІ)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeMagma Оұ) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F вҲҳ pure = fun x вҶҰ (pure <$> F x : m (FreeMagma ОІ)) := rfl

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeMagma Оұ) :
    traverse F (x * y) = (В· * В·) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) вҲҳ (HMul.hMul : FreeMagma Оұ вҶ’ FreeMagma Оұ вҶ’ FreeMagma Оұ) = fun x y вҶҰ
      (В· * В·) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeMagma.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeMagma.{u} :=
  { instLawfulMonad with
    id_traverse := fun x вҶҰ
      FreeMagma.recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x вҶҰ
      FreeMagma.recOnPure x
        (fun x вҶҰ by simp only [Function.comp_def, traverse_pure, functor_norm])
        (fun x y ih1 ih2 вҶҰ by
          rw [traverse_mul, ih1, ih2, traverse_mul]
          simp [Functor.Comp.map_mk, Functor.map_map, Function.comp_def, Comp.seq_mk, seq_map_assoc,
            map_seq, traverse_mul])
    naturality := fun О· Оұ ОІ f x вҶҰ
      FreeMagma.recOnPure x
        (fun x вҶҰ by simp only [traverse_pure, functor_norm, Function.comp_apply])
        (fun x y ih1 ih2 вҶҰ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x вҶҰ
      FreeMagma.recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

end FreeMagma

/-- Representation of an element of a free magma. -/
protected def FreeMagma.repr {Оұ : Type u} [Repr Оұ] : FreeMagma Оұ вҶ’ Lean.Format
  | FreeMagma.of x => repr x
  | x * y => "( " ++ x.repr ++ " * " ++ y.repr ++ " )"

/-- Representation of an element of a free additive magma. -/
protected def FreeAddMagma.repr {Оұ : Type u} [Repr Оұ] : FreeAddMagma Оұ вҶ’ Lean.Format
  | FreeAddMagma.of x => repr x
  | x + y => "( " ++ x.repr ++ " + " ++ y.repr ++ " )"

attribute [to_additive existing] FreeMagma.repr

@[to_additive]
instance {Оұ : Type u} [Repr Оұ] : Repr (FreeMagma Оұ) := вҹЁfun o _ => FreeMagma.repr oвҹ©

/-- Length of an element of a free magma. -/
def FreeMagma.length {Оұ : Type u} : FreeMagma Оұ вҶ’ в„•
  | FreeMagma.of _x => 1
  | x * y => x.length + y.length

/-- Length of an element of a free additive magma. -/
def FreeAddMagma.length {Оұ : Type u} : FreeAddMagma Оұ вҶ’ в„•
  | FreeAddMagma.of _x => 1
  | x + y => x.length + y.length

attribute [to_additive existing (attr := simp)] FreeMagma.length

/-- The length of an element of a free magma is positive. -/
@[to_additive /-- The length of an element of a free additive magma is positive. -/]
lemma FreeMagma.length_pos {Оұ : Type u} (x : FreeMagma Оұ) : 0 < x.length :=
  match x with
  | FreeMagma.of _ => Nat.succ_pos 0
  | mul y z => Nat.add_pos_left (length_pos y) z.length

/-- Associativity relations for an additive magma. -/
inductive AddMagma.AssocRel (Оұ : Type u) [Add Оұ] : Оұ вҶ’ Оұ вҶ’ Prop
  | intro : вҲҖ x y z, AddMagma.AssocRel Оұ (x + y + z) (x + (y + z))
  | left : вҲҖ w x y z, AddMagma.AssocRel Оұ (w + (x + y + z)) (w + (x + (y + z)))

/-- Associativity relations for a magma. -/
@[to_additive AddMagma.AssocRel /-- Associativity relations for an additive magma. -/]
inductive Magma.AssocRel (Оұ : Type u) [Mul Оұ] : Оұ вҶ’ Оұ вҶ’ Prop
  | intro : вҲҖ x y z, Magma.AssocRel Оұ (x * y * z) (x * (y * z))
  | left : вҲҖ w x y z, Magma.AssocRel Оұ (w * (x * y * z)) (w * (x * (y * z)))

namespace Magma

/-- Semigroup quotient of a magma. -/
@[to_additive AddMagma.FreeAddSemigroup /-- Additive semigroup quotient of an additive magma. -/]
def AssocQuotient (Оұ : Type u) [Mul Оұ] : Type u :=
  Quot <| AssocRel Оұ

namespace AssocQuotient

variable {Оұ : Type u} [Mul Оұ]

@[to_additive]
theorem quot_mk_assoc (x y z : Оұ) : Quot.mk (AssocRel Оұ) (x * y * z) = Quot.mk _ (x * (y * z)) :=
  Quot.sound (AssocRel.intro _ _ _)

@[to_additive]
theorem quot_mk_assoc_left (x y z w : Оұ) :
    Quot.mk (AssocRel Оұ) (x * (y * z * w)) = Quot.mk _ (x * (y * (z * w))) :=
  Quot.sound (AssocRel.left _ _ _ _)

@[to_additive]
instance : Semigroup (AssocQuotient Оұ) where
  mul x y := by
    refine Quot.liftOnвӮӮ x y (fun x y вҶҰ Quot.mk _ (x * y)) ?_ ?_
    В· rintro a bвӮҒ bвӮӮ (вҹЁc, d, eвҹ© | вҹЁc, d, e, fвҹ©) <;> simp only
      В· exact quot_mk_assoc_left _ _ _ _
      В· rw [вҶҗ quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc]
    В· rintro aвӮҒ aвӮӮ b (вҹЁc, d, eвҹ© | вҹЁc, d, e, fвҹ©) <;> simp only
      В· simp only [quot_mk_assoc, quot_mk_assoc_left]
      В· rw [quot_mk_assoc, quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc_left,
          quot_mk_assoc_left, вҶҗ quot_mk_assoc c d, вҶҗ quot_mk_assoc c d, quot_mk_assoc_left]
  mul_assoc x y z :=
    Quot.induction_onвӮғ x y z fun a b c вҶҰ quot_mk_assoc a b c

/-- Embedding from magma to its free semigroup. -/
@[to_additive /-- Embedding from additive magma to its free additive semigroup. -/]
def of : Оұ вҶ’вӮҷ* AssocQuotient Оұ where toFun := Quot.mk _; map_mul' _x _y := rfl

@[to_additive]
instance [Inhabited Оұ] : Inhabited (AssocQuotient Оұ) := вҹЁof defaultвҹ©

@[to_additive (attr := elab_as_elim, induction_eliminator)]
protected theorem induction_on {C : AssocQuotient Оұ вҶ’ Prop} (x : AssocQuotient Оұ)
    (ih : вҲҖ x, C (of x)) : C x := Quot.induction_on x ih

section lift

variable {ОІ : Type v} [Semigroup ОІ] (f : Оұ вҶ’вӮҷ* ОІ)

@[to_additive (attr := ext 1100)]
theorem hom_ext {f g : AssocQuotient Оұ вҶ’вӮҷ* ОІ} (h : f.comp of = g.comp of) : f = g :=
  (DFunLike.ext _ _) fun x => AssocQuotient.induction_on x <| DFunLike.congr_fun h

/-- Lifts a magma homomorphism `Оұ вҶ’ ОІ` to a semigroup homomorphism `Magma.AssocQuotient Оұ вҶ’ ОІ`
given a semigroup `ОІ`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts an additive magma homomorphism `Оұ вҶ’ ОІ` to an
additive semigroup homomorphism `AddMagma.AssocQuotient Оұ вҶ’ ОІ` given an additive semigroup `ОІ`. -/]
def lift : (Оұ вҶ’вӮҷ* ОІ) вүғ (AssocQuotient Оұ вҶ’вӮҷ* ОІ) where
  toFun f :=
  { toFun := fun x вҶҰ
      Quot.liftOn x f <| by rintro a b (вҹЁc, d, eвҹ© | вҹЁc, d, e, fвҹ©) <;> simp only [map_mul, mul_assoc]
    map_mul' := fun x y вҶҰ Quot.induction_onвӮӮ x y (map_mul f) }
  invFun f := f.comp of

@[to_additive (attr := simp)]
theorem lift_of (x : Оұ) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : (lift f).comp of = f := lift.symm_apply_apply f

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : AssocQuotient Оұ вҶ’вӮҷ* ОІ) : lift (f.comp of) = f := lift.apply_symm_apply f

end lift

variable {ОІ : Type v} [Mul ОІ] (f : Оұ вҶ’вӮҷ* ОІ)

/-- From a magma homomorphism `Оұ вҶ’вӮҷ* ОІ` to a semigroup homomorphism
`Magma.AssocQuotient Оұ вҶ’вӮҷ* Magma.AssocQuotient ОІ`. -/
@[to_additive /-- From an additive magma homomorphism `Оұ вҶ’ ОІ` to an additive semigroup homomorphism
`AddMagma.AssocQuotient Оұ вҶ’ AddMagma.AssocQuotient ОІ`. -/]
def map : AssocQuotient Оұ вҶ’вӮҷ* AssocQuotient ОІ := lift (of.comp f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end AssocQuotient

end Magma

/--
If `Оұ` is a type, then `FreeAddSemigroup Оұ` is the free additive semigroup generated by `Оұ`.
This is an additive semigroup equipped with a function
`FreeAddSemigroup.of : Оұ вҶ’ FreeAddSemigroup Оұ` which has the following universal property:
if `M` is any additive semigroup, and `f : Оұ вҶ’ M` is any function,
then this function is the composite of `FreeAddSemigroup.of` and a unique semigroup homomorphism
`FreeAddSemigroup.lift f : FreeAddSemigroup Оұ вҶ’вӮҷ+ M`.

A typical element of `FreeAddSemigroup Оұ` is a nonempty formal sum of elements of `Оұ`.
For example if `x` and `y` are terms of type `Оұ` then `x + y + y + x` is a
"typical" element of `FreeAddSemigroup Оұ`. In particular if `Оұ` is empty
then `FreeAddSemigroup Оұ` is also empty, and if `Оұ` has one term
then `FreeAddSemigroup Оұ` is isomorphic to `в„•+`.
If `Оұ` has two or more terms then `FreeAddSemigroup Оұ` is not commutative.
One can think of `FreeAddSemigroup Оұ` as the type of nonempty lists of `Оұ`, with addition
given by concatenation.
-/
structure FreeAddSemigroup (Оұ : Type u) where
  /-- The head of the element -/
  head : Оұ
  /-- The tail of the element -/
  tail : List Оұ
compile_inductive% FreeAddSemigroup

/--
If `Оұ` is a type, then `FreeSemigroup Оұ` is the free semigroup generated by `Оұ`.
This is a semigroup equipped with a function `FreeSemigroup.of : Оұ вҶ’ FreeSemigroup Оұ` which has
the following universal property: if `M` is any semigroup, and `f : Оұ вҶ’ M` is any function,
then this function is the composite of `FreeSemigroup.of` and a unique semigroup homomorphism
`FreeSemigroup.lift f : FreeSemigroup Оұ вҶ’вӮҷ* M`.

A typical element of `FreeSemigroup Оұ` is a nonempty formal product of elements of `Оұ`.
For example if `x` and `y` are terms of type `Оұ` then `x * y * y * x` is a
"typical" element of `FreeSemigroup Оұ`. In particular if `Оұ` is empty
then `FreeSemigroup Оұ` is also empty, and if `Оұ` has one term
then `FreeSemigroup Оұ` is isomorphic to `Multiplicative в„•+`.
If `Оұ` has two or more terms then `FreeSemigroup Оұ` is not commutative.
One can think of `FreeSemigroup Оұ` as the type of nonempty lists of `Оұ`, with multiplication
given by concatenation.
-/
@[to_additive (attr := ext)]
structure FreeSemigroup (Оұ : Type u) where
  /-- The head of the element -/
  head : Оұ
  /-- The tail of the element -/
  tail : List Оұ
compile_inductive% FreeSemigroup

namespace FreeSemigroup

variable {Оұ : Type u}

@[to_additive]
instance : Semigroup (FreeSemigroup Оұ) where
  mul L1 L2 := вҹЁL1.1, L1.2 ++ L2.1 :: L2.2вҹ©
  mul_assoc _L1 _L2 _L3 := FreeSemigroup.ext rfl <| List.append_assoc _ _ _

@[to_additive (attr := simp)]
theorem head_mul (x y : FreeSemigroup Оұ) : (x * y).1 = x.1 := rfl

@[to_additive (attr := simp)]
theorem tail_mul (x y : FreeSemigroup Оұ) : (x * y).2 = x.2 ++ y.1 :: y.2 := rfl

@[to_additive (attr := simp)]
theorem mk_mul_mk (x y : Оұ) (L1 L2 : List Оұ) : mk x L1 * mk y L2 = mk x (L1 ++ y :: L2) := rfl

/-- The embedding `Оұ вҶ’ FreeSemigroup Оұ`. -/
@[to_additive (attr := simps) /-- The embedding `Оұ вҶ’ FreeAddSemigroup Оұ`. -/]
def of (x : Оұ) : FreeSemigroup Оұ := вҹЁx, []вҹ©

/-- Length of an element of free semigroup. -/
@[to_additive /-- Length of an element of free additive semigroup -/]
def length (x : FreeSemigroup Оұ) : в„• := x.tail.length + 1

@[to_additive (attr := simp)]
theorem length_mul (x y : FreeSemigroup Оұ) : (x * y).length = x.length + y.length := by
  simp [length, Nat.add_right_comm]

@[to_additive (attr := simp)]
theorem length_of (x : Оұ) : (of x).length = 1 := rfl

@[to_additive]
instance [Inhabited Оұ] : Inhabited (FreeSemigroup Оұ) := вҹЁof defaultвҹ©

/-- Recursor for free semigroup using `of` and `*`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for free additive semigroup using `of` and `+`. -/]
protected def recOnMul {C : FreeSemigroup Оұ вҶ’ Sort l} (x) (ih1 : вҲҖ x, C (of x))
    (ih2 : вҲҖ x y, C (of x) вҶ’ C y вҶ’ C (of x * y)) : C x :=
      FreeSemigroup.recOn x fun f s вҶҰ
      List.recOn s ih1 (fun hd tl ih f вҶҰ ih2 f вҹЁhd, tlвҹ© (ih1 f) (ih hd)) f

@[to_additive (attr := ext 1100)]
theorem hom_ext {ОІ : Type v} [Mul ОІ] {f g : FreeSemigroup Оұ вҶ’вӮҷ* ОІ} (h : f вҲҳ of = g вҲҳ of) : f = g :=
  (DFunLike.ext _ _) fun x вҶҰ
    FreeSemigroup.recOnMul x (congr_fun h) fun x y hx hy вҶҰ by simp only [map_mul, *]

section lift

variable {ОІ : Type v} [Semigroup ОІ] (f : Оұ вҶ’ ОІ)

/-- Lifts a function `Оұ вҶ’ ОІ` to a semigroup homomorphism `FreeSemigroup Оұ вҶ’ ОІ` given
a semigroup `ОІ`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts a function `Оұ вҶ’ ОІ` to an additive semigroup
homomorphism `FreeAddSemigroup Оұ вҶ’ ОІ` given an additive semigroup `ОІ`. -/]
def lift : (Оұ вҶ’ ОІ) вүғ (FreeSemigroup Оұ вҶ’вӮҷ* ОІ) where
  toFun f :=
    { toFun x := x.2.foldl (fun a b вҶҰ a * f b) (f x.1)
      map_mul' := by simp [вҶҗ List.foldl_map, List.foldl_assoc] }
  invFun f := f вҲҳ of

@[to_additive]
lemma lift_mk_eq_foldl {f : Оұ вҶ’ ОІ} {x : Оұ} {xs : List Оұ} :
    lift f вҹЁx, xsвҹ© = xs.foldl (В· * f В·) (f x) := rfl

@[to_additive (attr := simp)]
theorem lift_of (x : Оұ) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f вҲҳ of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeSemigroup Оұ вҶ’вӮҷ* ОІ) : lift (f вҲҳ of) = f := hom_ext rfl

@[to_additive]
theorem lift_of_mul (x y) : lift f (of x * y) = f x * lift f y := by rw [map_mul, lift_of]

end lift

section Map

variable {ОІ : Type v} (f : Оұ вҶ’ ОІ)

/-- The unique semigroup homomorphism that sends `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive semigroup homomorphism that sends `of x` to `of (f x)`. -/]
def map : FreeSemigroup Оұ вҶ’вӮҷ* FreeSemigroup ОІ :=
  lift <| of вҲҳ f

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

@[to_additive (attr := simp)]
theorem length_map (x) : (map f x).length = x.length :=
  FreeSemigroup.recOnMul x (fun _ вҶҰ rfl) (fun x y hx hy вҶҰ by simp only [map_mul, length_mul, *])

end Map

section Category

variable {ОІ : Type u}

@[to_additive]
instance : Monad FreeSemigroup where
  pure := of
  bind x f := lift f x

/-- Recursor that uses `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim) /-- Recursor that uses `pure` instead of `of`. -/]
def recOnPure {C : FreeSemigroup Оұ вҶ’ Sort l} (x) (ih1 : вҲҖ x, C (pure x))
    (ih2 : вҲҖ x y, C (pure x) вҶ’ C y вҶ’ C (pure x * y)) : C x :=
  FreeSemigroup.recOnMul x ih1 ih2

@[to_additive]
protected theorem map_pure (f : Оұ вҶ’ ОІ) (x) : (f <$> pure x : FreeSemigroup ОІ) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : Оұ вҶ’ ОІ) (x y : FreeSemigroup Оұ) : f <$> (x * y) = f <$> x * f <$> y :=
  map_mul (map f) _ _

@[to_additive]
theorem pure_bind (f : Оұ вҶ’ FreeSemigroup ОІ) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : Оұ вҶ’ FreeSemigroup ОІ) (x y : FreeSemigroup Оұ) :
    x * y >>= f = (x >>= f) * (y >>= f) := map_mul (lift f) _ _

@[to_additive (attr := simp)]
theorem pure_seq {f : Оұ вҶ’ ОІ} {x : FreeSemigroup Оұ} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {f g : FreeSemigroup (Оұ вҶ’ ОІ)} {x : FreeSemigroup Оұ} :
    f * g <*> x = (f <*> x) * (g <*> x) := mul_bind _ _ _

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeSemigroup.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ вҶҰ rfl)
  (bind_assoc := fun x g f вҶҰ
    recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x вҶҰ recOnPure x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by rw [map_mul', ih1, ih2])

/-- `FreeSemigroup` is traversable. -/
@[to_additive /-- `FreeAddSemigroup` is traversable. -/]
protected def traverse {m : Type u вҶ’ Type u} [Applicative m] {Оұ ОІ : Type u}
    (F : Оұ вҶ’ m ОІ) (x : FreeSemigroup Оұ) : m (FreeSemigroup ОІ) :=
  recOnPure x (fun x вҶҰ pure <$> F x) fun _x _y ihx ihy вҶҰ (В· * В·) <$> ihx <*> ihy

@[to_additive]
instance : Traversable FreeSemigroup := вҹЁ@FreeSemigroup.traverseвҹ©

variable {m : Type u вҶ’ Type u} [Applicative m] (F : Оұ вҶ’ m ОІ)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeSemigroup Оұ) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F вҲҳ pure = fun x вҶҰ (pure <$> F x : m (FreeSemigroup ОІ)) := rfl

section

variable [LawfulApplicative m]

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeSemigroup Оұ) :
    traverse F (x * y) = (В· * В·) <$> traverse F x <*> traverse F y :=
  let вҹЁx, L1вҹ© := x
  let вҹЁy, L2вҹ© := y
  List.recOn L1 (fun _ вҶҰ rfl)
    (fun hd tl ih x вҶҰ show
        (В· * В·) <$> pure <$> F x <*> traverse F (mk hd tl * mk y L2) =
          (В· * В·) <$> ((В· * В·) <$> pure <$> F x <*> traverse F (mk hd tl)) <*> traverse F (mk y L2)
        by rw [ih]; simp only [Function.comp_def, (mul_assoc _ _ _).symm, functor_norm])
    x

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) вҲҳ (HMul.hMul : FreeSemigroup Оұ вҶ’ FreeSemigroup Оұ вҶ’ FreeSemigroup Оұ) =
      fun x y вҶҰ (В· * В·) <$> traverse F x <*> traverse F y :=
  funext fun x вҶҰ funext fun y вҶҰ traverse_mul F x y

end

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeSemigroup.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeSemigroup.{u} :=
  { instLawfulMonad with
    id_traverse := fun x вҶҰ
      FreeSemigroup.recOnMul x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x вҶҰ
      recOnPure x (fun x вҶҰ by simp only [traverse_pure, functor_norm, Function.comp_def])
        fun x y ih1 ih2 вҶҰ by
          rw [traverse_mul, ih1, ih2, traverse_mul, Functor.Comp.map_mk]
          simp only [Function.comp_def, functor_norm, traverse_mul]
    naturality := fun О· Оұ ОІ f x вҶҰ
      recOnPure x (fun x вҶҰ by simp only [traverse_pure, functor_norm, Function.comp])
          (fun x y ih1 ih2 вҶҰ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x вҶҰ
      FreeSemigroup.recOnMul x (fun _ вҶҰ rfl) fun x y ih1 ih2 вҶҰ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

@[to_additive]
instance [DecidableEq Оұ] : DecidableEq (FreeSemigroup Оұ) :=
  fun _ _ вҶҰ decidable_of_iff' _ FreeSemigroup.ext_iff

end FreeSemigroup

namespace FreeMagma

variable {Оұ : Type u} {ОІ : Type v}

/-- The canonical multiplicative morphism from `FreeMagma Оұ` to `FreeSemigroup Оұ`. -/
@[to_additive /-- The canonical additive morphism from `FreeAddMagma Оұ` to `FreeAddSemigroup Оұ`. -/]
def toFreeSemigroup : FreeMagma Оұ вҶ’вӮҷ* FreeSemigroup Оұ := FreeMagma.lift FreeSemigroup.of

@[to_additive (attr := simp)]
theorem toFreeSemigroup_of (x : Оұ) : toFreeSemigroup (of x) = FreeSemigroup.of x := rfl

@[to_additive (attr := simp)]
theorem toFreeSemigroup_comp_of : @toFreeSemigroup Оұ вҲҳ of = FreeSemigroup.of := rfl

@[to_additive]
theorem toFreeSemigroup_comp_map (f : Оұ вҶ’ ОІ) :
    toFreeSemigroup.comp (map f) = (FreeSemigroup.map f).comp toFreeSemigroup := by ext1; rfl

@[to_additive]
theorem toFreeSemigroup_map (f : Оұ вҶ’ ОІ) (x : FreeMagma Оұ) :
    toFreeSemigroup (map f x) = FreeSemigroup.map f (toFreeSemigroup x) :=
  DFunLike.congr_fun (toFreeSemigroup_comp_map f) x

@[to_additive (attr := simp)]
theorem length_toFreeSemigroup (x : FreeMagma Оұ) : (toFreeSemigroup x).length = x.length :=
  FreeMagma.recOnMul x (fun _ вҶҰ rfl) fun x y hx hy вҶҰ by
    rw [map_mul, FreeSemigroup.length_mul, hx, hy]; rfl

end FreeMagma

/-- Isomorphism between `Magma.AssocQuotient (FreeMagma Оұ)` and `FreeSemigroup Оұ`. -/
@[to_additive /-- Isomorphism between `AddMagma.AssocQuotient (FreeAddMagma Оұ)` and
`FreeAddSemigroup Оұ`. -/]
def FreeMagmaAssocQuotientEquiv (Оұ : Type u) :
    Magma.AssocQuotient (FreeMagma Оұ) вүғ* FreeSemigroup Оұ :=
      (Magma.AssocQuotient.lift FreeMagma.toFreeSemigroup).toMulEquiv
      (FreeSemigroup.lift (Magma.AssocQuotient.of вҲҳ FreeMagma.of))
      (by ext; rfl)
      (by ext1; rfl)
