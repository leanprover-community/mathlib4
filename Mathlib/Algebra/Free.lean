/-!
# Free constructions

## Main definitions

* `FreeMagma őĪ`: free magma (structure with binary operation without any axioms) over alphabet `őĪ`,
  defined inductively, with traversable instance and decidable equality.
* `MagmaAssocQuotient őĪ`: quotient of a magma `őĪ` by the associativity equivalence relation.
* `FreeSemigroup őĪ`: free semigroup over alphabet `őĪ`, defined as a structure with two fields
  `head : őĪ` and `tail : List őĪ` (i.e. nonempty lists), with traversable instance and decidable
  equality.
* `FreeMagmaAssocQuotientEquiv őĪ`: isomorphism between `MagmaAssocQuotient (FreeMagma őĪ)` and
  `FreeSemigroup őĪ`.
* `FreeMagma.lift`: the universal property of the free magma, expressing its adjointness.
-/

@[expose] public section

universe u v l

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `őĪ` is a type, then `FreeAddMagma őĪ` is the free additive magma generated by `őĪ`.
This is an additive magma equipped with a function `FreeAddMagma.of : őĪ ‚Üí FreeAddMagma őĪ` which has
the following universal property: if `M` is any magma, and `f : őĪ ‚Üí M` is any function,
then this function is the composite of `FreeAddMagma.of` and a unique additive homomorphism
`FreeAddMagma.lift f : FreeAddMagma őĪ ‚Üí‚āô+ M`.

A typical element of `FreeAddMagma őĪ` is a formal non-associative sum of
elements of `őĪ`. For example if `x` and `y` are terms of type `őĪ` then `x + ((y + y) + x)` is a
"typical" element of `FreeAddMagma őĪ`.
One can think of `FreeAddMagma őĪ` as the type of binary trees with leaves labelled by `őĪ`.
In general, no pair of distinct elements in `FreeAddMagma őĪ` will commute.
-/
inductive FreeAddMagma (őĪ : Type u) : Type u
  | of : őĪ ‚Üí FreeAddMagma őĪ
  | add : FreeAddMagma őĪ ‚Üí FreeAddMagma őĪ ‚Üí FreeAddMagma őĪ
  deriving DecidableEq
compile_inductive% FreeAddMagma

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `őĪ` is a type, then `FreeMagma őĪ` is the free magma generated by `őĪ`.
This is a magma equipped with a function `FreeMagma.of : őĪ ‚Üí FreeMagma őĪ` which has
the following universal property: if `M` is any magma, and `f : őĪ ‚Üí M` is any function,
then this function is the composite of `FreeMagma.of` and a unique multiplicative homomorphism
`FreeMagma.lift f : FreeMagma őĪ ‚Üí‚āô* M`.

A typical element of `FreeMagma őĪ` is a formal non-associative product of
elements of `őĪ`. For example if `x` and `y` are terms of type `őĪ` then `x * ((y * y) * x)` is a
"typical" element of `FreeMagma őĪ`.
One can think of `FreeMagma őĪ` as the type of binary trees with leaves labelled by `őĪ`.
In general, no pair of distinct elements in `FreeMagma őĪ` will commute.
-/
@[to_additive]
inductive FreeMagma (őĪ : Type u) : Type u
  | of : őĪ ‚Üí FreeMagma őĪ
  | mul : FreeMagma őĪ ‚Üí FreeMagma őĪ ‚Üí FreeMagma őĪ
  deriving DecidableEq
compile_inductive% FreeMagma

namespace FreeMagma

variable {őĪ : Type u}

@[to_additive]
instance [Inhabited őĪ] : Inhabited (FreeMagma őĪ) := ‚ü®of default‚ü©

@[to_additive]
instance : Mul (FreeMagma őĪ) := ‚ü®FreeMagma.mul‚ü©

@[to_additive (attr := simp)]
theorem mul_eq (x y : FreeMagma őĪ) : mul x y = x * y := rfl

/-- Recursor for `FreeMagma` using `x * y` instead of `FreeMagma.mul x y`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for `FreeAddMagma` using `x + y` instead of `FreeAddMagma.add x y`. -/]
def recOnMul {C : FreeMagma őĪ ‚Üí Sort l} (x) (ih1 : ‚ąÄ x, C (of x))
    (ih2 : ‚ąÄ x y, C x ‚Üí C y ‚Üí C (x * y)) : C x :=
  FreeMagma.recOn x ih1 ih2

@[to_additive (attr := ext 1100)]
theorem hom_ext {ő≤ : Type v} [Mul ő≤] {f g : FreeMagma őĪ ‚Üí‚āô* ő≤} (h : f ‚ąė of = g ‚ąė of) : f = g :=
  (DFunLike.ext _ _) fun x ‚Ü¶ recOnMul x (congr_fun h) <| by intros; simp only [map_mul, *]

end FreeMagma

/-- Lifts a function `őĪ ‚Üí ő≤` to a magma homomorphism `FreeMagma őĪ ‚Üí ő≤` given a magma `ő≤`. -/
def FreeMagma.liftAux {őĪ : Type u} {ő≤ : Type v} [Mul ő≤] (f : őĪ ‚Üí ő≤) : FreeMagma őĪ ‚Üí ő≤
  | FreeMagma.of x => f x
  | x * y => liftAux f x * liftAux f y

/-- Lifts a function `őĪ ‚Üí ő≤` to an additive magma homomorphism `FreeAddMagma őĪ ‚Üí ő≤` given
an additive magma `ő≤`. -/
def FreeAddMagma.liftAux {őĪ : Type u} {ő≤ : Type v} [Add ő≤] (f : őĪ ‚Üí ő≤) : FreeAddMagma őĪ ‚Üí ő≤
  | FreeAddMagma.of x => f x
  | x + y => liftAux f x + liftAux f y

attribute [to_additive existing] FreeMagma.liftAux

namespace FreeMagma

section lift

variable {őĪ : Type u} {ő≤ : Type v} [Mul ő≤] (f : őĪ ‚Üí ő≤)

/-- The universal property of the free magma expressing its adjointness. -/
@[to_additive (attr := simps symm_apply)
/-- The universal property of the free additive magma expressing its adjointness. -/]
def lift : (őĪ ‚Üí ő≤) ‚ČÉ (FreeMagma őĪ ‚Üí‚āô* ő≤) where
  toFun f :=
  { toFun := liftAux f
    map_mul' := fun _ _ ‚Ü¶ rfl }
  invFun F := F ‚ąė of

@[to_additive (attr := simp)]
theorem lift_of (x) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f ‚ąė of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeMagma őĪ ‚Üí‚āô* ő≤) : lift (f ‚ąė of) = f := lift.apply_symm_apply f

end lift

section Map

variable {őĪ : Type u} {ő≤ : Type v} (f : őĪ ‚Üí ő≤)

/-- The unique magma homomorphism `FreeMagma őĪ ‚Üí‚āô* FreeMagma ő≤` that sends
each `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive magma homomorphism `FreeAddMagma őĪ ‚Üí FreeAddMagma ő≤` that
sends each `of x` to `of (f x)`. -/]
def map (f : őĪ ‚Üí ő≤) : FreeMagma őĪ ‚Üí‚āô* FreeMagma ő≤ := lift (of ‚ąė f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end Map

section Category

variable {őĪ ő≤ : Type u}

@[to_additive]
instance : Monad FreeMagma where
  pure := of
  bind x f := lift f x

/-- Recursor on `FreeMagma` using `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim)
/-- Recursor on `FreeAddMagma` using `pure` instead of `of`. -/]
protected def recOnPure {C : FreeMagma őĪ ‚Üí Sort l} (x) (ih1 : ‚ąÄ x, C (pure x))
    (ih2 : ‚ąÄ x y, C x ‚Üí C y ‚Üí C (x * y)) : C x :=
  FreeMagma.recOnMul x ih1 ih2

@[to_additive (attr := simp)]
protected theorem map_pure (f : őĪ ‚Üí ő≤) (x) : (f <$> pure x : FreeMagma ő≤) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : őĪ ‚Üí ő≤) (x y : FreeMagma őĪ) : f <$> (x * y) = f <$> x * f <$> y := rfl

@[to_additive (attr := simp)]
theorem pure_bind (f : őĪ ‚Üí FreeMagma ő≤) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : őĪ ‚Üí FreeMagma ő≤) (x y : FreeMagma őĪ) : x * y >>= f = (x >>= f) * (y >>= f) :=
  rfl

@[to_additive (attr := simp)]
theorem pure_seq {őĪ ő≤ : Type u} {f : őĪ ‚Üí ő≤} {x : FreeMagma őĪ} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {őĪ ő≤ : Type u} {f g : FreeMagma (őĪ ‚Üí ő≤)} {x : FreeMagma őĪ} :
    f * g <*> x = (f <*> x) * (g <*> x) := rfl

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeMagma.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ ‚Ü¶ rfl)
  (bind_assoc := fun x f g ‚Ü¶ FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
    rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x ‚Ü¶ FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
    rw [map_mul', ih1, ih2])

end Category

end FreeMagma

/-- `FreeMagma` is traversable. -/
protected def FreeMagma.traverse {m : Type u ‚Üí Type u} [Applicative m] {őĪ ő≤ : Type u}
    (F : őĪ ‚Üí m ő≤) : FreeMagma őĪ ‚Üí m (FreeMagma ő≤)
  | FreeMagma.of x => FreeMagma.of <$> F x
  | x * y => (¬∑ * ¬∑) <$> x.traverse F <*> y.traverse F

/-- `FreeAddMagma` is traversable. -/
protected def FreeAddMagma.traverse {m : Type u ‚Üí Type u} [Applicative m] {őĪ ő≤ : Type u}
    (F : őĪ ‚Üí m ő≤) : FreeAddMagma őĪ ‚Üí m (FreeAddMagma ő≤)
  | FreeAddMagma.of x => FreeAddMagma.of <$> F x
  | x + y => (¬∑ + ¬∑) <$> x.traverse F <*> y.traverse F

attribute [to_additive existing] FreeMagma.traverse

namespace FreeMagma

variable {őĪ : Type u}

section Category

variable {ő≤ : Type u}

@[to_additive]
instance : Traversable FreeMagma := ‚ü®@FreeMagma.traverse‚ü©

variable {m : Type u ‚Üí Type u} [Applicative m] (F : őĪ ‚Üí m ő≤)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeMagma őĪ) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F ‚ąė pure = fun x ‚Ü¶ (pure <$> F x : m (FreeMagma ő≤)) := rfl

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeMagma őĪ) :
    traverse F (x * y) = (¬∑ * ¬∑) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) ‚ąė (HMul.hMul : FreeMagma őĪ ‚Üí FreeMagma őĪ ‚Üí FreeMagma őĪ) = fun x y ‚Ü¶
      (¬∑ * ¬∑) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeMagma.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeMagma.{u} :=
  { instLawfulMonad with
    id_traverse := fun x ‚Ü¶
      FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x ‚Ü¶
      FreeMagma.recOnPure x
        (fun x ‚Ü¶ by simp only [Function.comp_def, traverse_pure, functor_norm])
        (fun x y ih1 ih2 ‚Ü¶ by
          rw [traverse_mul, ih1, ih2, traverse_mul]
          simp [Functor.Comp.map_mk, Functor.map_map, Function.comp_def, Comp.seq_mk, seq_map_assoc,
            map_seq, traverse_mul])
    naturality := fun ő∑ őĪ ő≤ f x ‚Ü¶
      FreeMagma.recOnPure x
        (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp_apply])
        (fun x y ih1 ih2 ‚Ü¶ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x ‚Ü¶
      FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

end FreeMagma

/-- Representation of an element of a free magma. -/
protected def FreeMagma.repr {őĪ : Type u} [Repr őĪ] : FreeMagma őĪ ‚Üí Lean.Format
  | FreeMagma.of x => repr x
  | x * y => "( " ++ x.repr ++ " * " ++ y.repr ++ " )"

/-- Representation of an element of a free additive magma. -/
protected def FreeAddMagma.repr {őĪ : Type u} [Repr őĪ] : FreeAddMagma őĪ ‚Üí Lean.Format
  | FreeAddMagma.of x => repr x
  | x + y => "( " ++ x.repr ++ " + " ++ y.repr ++ " )"

attribute [to_additive existing] FreeMagma.repr

@[to_additive]
instance {őĪ : Type u} [Repr őĪ] : Repr (FreeMagma őĪ) := ‚ü®fun o _ => FreeMagma.repr o‚ü©

/-- Length of an element of a free magma. -/
def FreeMagma.length {őĪ : Type u} : FreeMagma őĪ ‚Üí ‚Ąē
  | FreeMagma.of _x => 1
  | x * y => x.length + y.length

/-- Length of an element of a free additive magma. -/
def FreeAddMagma.length {őĪ : Type u} : FreeAddMagma őĪ ‚Üí ‚Ąē
  | FreeAddMagma.of _x => 1
  | x + y => x.length + y.length

attribute [to_additive existing (attr := simp)] FreeMagma.length

/-- The length of an element of a free magma is positive. -/
@[to_additive /-- The length of an element of a free additive magma is positive. -/]
lemma FreeMagma.length_pos {őĪ : Type u} (x : FreeMagma őĪ) : 0 < x.length :=
  match x with
  | FreeMagma.of _ => Nat.succ_pos 0
  | mul y z => Nat.add_pos_left (length_pos y) z.length

/-- Associativity relations for an additive magma. -/
inductive AddMagma.AssocRel (őĪ : Type u) [Add őĪ] : őĪ ‚Üí őĪ ‚Üí Prop
  | intro : ‚ąÄ x y z, AddMagma.AssocRel őĪ (x + y + z) (x + (y + z))
  | left : ‚ąÄ w x y z, AddMagma.AssocRel őĪ (w + (x + y + z)) (w + (x + (y + z)))

/-- Associativity relations for a magma. -/
@[to_additive AddMagma.AssocRel /-- Associativity relations for an additive magma. -/]
inductive Magma.AssocRel (őĪ : Type u) [Mul őĪ] : őĪ ‚Üí őĪ ‚Üí Prop
  | intro : ‚ąÄ x y z, Magma.AssocRel őĪ (x * y * z) (x * (y * z))
  | left : ‚ąÄ w x y z, Magma.AssocRel őĪ (w * (x * y * z)) (w * (x * (y * z)))

namespace Magma

/-- Semigroup quotient of a magma. -/
@[to_additive AddMagma.FreeAddSemigroup /-- Additive semigroup quotient of an additive magma. -/]
def AssocQuotient (őĪ : Type u) [Mul őĪ] : Type u :=
  Quot <| AssocRel őĪ

namespace AssocQuotient

variable {őĪ : Type u} [Mul őĪ]

@[to_additive]
theorem quot_mk_assoc (x y z : őĪ) : Quot.mk (AssocRel őĪ) (x * y * z) = Quot.mk _ (x * (y * z)) :=
  Quot.sound (AssocRel.intro _ _ _)

@[to_additive]
theorem quot_mk_assoc_left (x y z w : őĪ) :
    Quot.mk (AssocRel őĪ) (x * (y * z * w)) = Quot.mk _ (x * (y * (z * w))) :=
  Quot.sound (AssocRel.left _ _ _ _)

@[to_additive]
instance : Semigroup (AssocQuotient őĪ) where
  mul x y := by
    refine Quot.liftOn‚āā x y (fun x y ‚Ü¶ Quot.mk _ (x * y)) ?_ ?_
    ¬∑ rintro a b‚āĀ b‚āā (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only
      ¬∑ exact quot_mk_assoc_left _ _ _ _
      ¬∑ rw [‚Üź quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc]
    ¬∑ rintro a‚āĀ a‚āā b (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only
      ¬∑ simp only [quot_mk_assoc, quot_mk_assoc_left]
      ¬∑ rw [quot_mk_assoc, quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc_left,
          quot_mk_assoc_left, ‚Üź quot_mk_assoc c d, ‚Üź quot_mk_assoc c d, quot_mk_assoc_left]
  mul_assoc x y z :=
    Quot.induction_on‚āÉ x y z fun a b c ‚Ü¶ quot_mk_assoc a b c

/-- Embedding from magma to its free semigroup. -/
@[to_additive /-- Embedding from additive magma to its free additive semigroup. -/]
def of : őĪ ‚Üí‚āô* AssocQuotient őĪ where toFun := Quot.mk _; map_mul' _x _y := rfl

@[to_additive]
instance [Inhabited őĪ] : Inhabited (AssocQuotient őĪ) := ‚ü®of default‚ü©

@[to_additive (attr := elab_as_elim, induction_eliminator)]
protected theorem induction_on {C : AssocQuotient őĪ ‚Üí Prop} (x : AssocQuotient őĪ)
    (ih : ‚ąÄ x, C (of x)) : C x := Quot.induction_on x ih

section lift

variable {ő≤ : Type v} [Semigroup ő≤] (f : őĪ ‚Üí‚āô* ő≤)

@[to_additive (attr := ext 1100)]
theorem hom_ext {f g : AssocQuotient őĪ ‚Üí‚āô* ő≤} (h : f.comp of = g.comp of) : f = g :=
  (DFunLike.ext _ _) fun x => AssocQuotient.induction_on x <| DFunLike.congr_fun h

/-- Lifts a magma homomorphism `őĪ ‚Üí ő≤` to a semigroup homomorphism `Magma.AssocQuotient őĪ ‚Üí ő≤`
given a semigroup `ő≤`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts an additive magma homomorphism `őĪ ‚Üí ő≤` to an
additive semigroup homomorphism `AddMagma.AssocQuotient őĪ ‚Üí ő≤` given an additive semigroup `ő≤`. -/]
def lift : (őĪ ‚Üí‚āô* ő≤) ‚ČÉ (AssocQuotient őĪ ‚Üí‚āô* ő≤) where
  toFun f :=
  { toFun := fun x ‚Ü¶
      Quot.liftOn x f <| by rintro a b (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only [map_mul, mul_assoc]
    map_mul' := fun x y ‚Ü¶ Quot.induction_on‚āā x y (map_mul f) }
  invFun f := f.comp of

@[to_additive (attr := simp)]
theorem lift_of (x : őĪ) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : (lift f).comp of = f := lift.symm_apply_apply f

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : AssocQuotient őĪ ‚Üí‚āô* ő≤) : lift (f.comp of) = f := lift.apply_symm_apply f

end lift

variable {ő≤ : Type v} [Mul ő≤] (f : őĪ ‚Üí‚āô* ő≤)

/-- From a magma homomorphism `őĪ ‚Üí‚āô* ő≤` to a semigroup homomorphism
`Magma.AssocQuotient őĪ ‚Üí‚āô* Magma.AssocQuotient ő≤`. -/
@[to_additive /-- From an additive magma homomorphism `őĪ ‚Üí ő≤` to an additive semigroup homomorphism
`AddMagma.AssocQuotient őĪ ‚Üí AddMagma.AssocQuotient ő≤`. -/]
def map : AssocQuotient őĪ ‚Üí‚āô* AssocQuotient ő≤ := lift (of.comp f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end AssocQuotient

end Magma

/--
If `őĪ` is a type, then `FreeAddSemigroup őĪ` is the free additive semigroup generated by `őĪ`.
This is an additive semigroup equipped with a function
`FreeAddSemigroup.of : őĪ ‚Üí FreeAddSemigroup őĪ` which has the following universal property:
if `M` is any additive semigroup, and `f : őĪ ‚Üí M` is any function,
then this function is the composite of `FreeAddSemigroup.of` and a unique semigroup homomorphism
`FreeAddSemigroup.lift f : FreeAddSemigroup őĪ ‚Üí‚āô+ M`.

A typical element of `FreeAddSemigroup őĪ` is a nonempty formal sum of elements of `őĪ`.
For example if `x` and `y` are terms of type `őĪ` then `x + y + y + x` is a
"typical" element of `FreeAddSemigroup őĪ`. In particular if `őĪ` is empty
then `FreeAddSemigroup őĪ` is also empty, and if `őĪ` has one term
then `FreeAddSemigroup őĪ` is isomorphic to `‚Ąē+`.
If `őĪ` has two or more terms then `FreeAddSemigroup őĪ` is not commutative.
One can think of `FreeAddSemigroup őĪ` as the type of nonempty lists of `őĪ`, with addition
given by concatenation.
-/
structure FreeAddSemigroup (őĪ : Type u) where
  /-- The head of the element -/
  head : őĪ
  /-- The tail of the element -/
  tail : List őĪ
compile_inductive% FreeAddSemigroup

/--
If `őĪ` is a type, then `FreeSemigroup őĪ` is the free semigroup generated by `őĪ`.
This is a semigroup equipped with a function `FreeSemigroup.of : őĪ ‚Üí FreeSemigroup őĪ` which has
the following universal property: if `M` is any semigroup, and `f : őĪ ‚Üí M` is any function,
then this function is the composite of `FreeSemigroup.of` and a unique semigroup homomorphism
`FreeSemigroup.lift f : FreeSemigroup őĪ ‚Üí‚āô* M`.

A typical element of `FreeSemigroup őĪ` is a nonempty formal product of elements of `őĪ`.
For example if `x` and `y` are terms of type `őĪ` then `x * y * y * x` is a
"typical" element of `FreeSemigroup őĪ`. In particular if `őĪ` is empty
then `FreeSemigroup őĪ` is also empty, and if `őĪ` has one term
then `FreeSemigroup őĪ` is isomorphic to `Multiplicative ‚Ąē+`.
If `őĪ` has two or more terms then `FreeSemigroup őĪ` is not commutative.
One can think of `FreeSemigroup őĪ` as the type of nonempty lists of `őĪ`, with multiplication
given by concatenation.
-/
@[to_additive (attr := ext)]
structure FreeSemigroup (őĪ : Type u) where
  /-- The head of the element -/
  head : őĪ
  /-- The tail of the element -/
  tail : List őĪ
compile_inductive% FreeSemigroup

namespace FreeSemigroup

variable {őĪ : Type u}

@[to_additive]
instance : Semigroup (FreeSemigroup őĪ) where
  mul L1 L2 := ‚ü®L1.1, L1.2 ++ L2.1 :: L2.2‚ü©
  mul_assoc _L1 _L2 _L3 := FreeSemigroup.ext rfl <| List.append_assoc _ _ _

@[to_additive (attr := simp)]
theorem head_mul (x y : FreeSemigroup őĪ) : (x * y).1 = x.1 := rfl

@[to_additive (attr := simp)]
theorem tail_mul (x y : FreeSemigroup őĪ) : (x * y).2 = x.2 ++ y.1 :: y.2 := rfl

@[to_additive (attr := simp)]
theorem mk_mul_mk (x y : őĪ) (L1 L2 : List őĪ) : mk x L1 * mk y L2 = mk x (L1 ++ y :: L2) := rfl

/-- The embedding `őĪ ‚Üí FreeSemigroup őĪ`. -/
@[to_additive (attr := simps) /-- The embedding `őĪ ‚Üí FreeAddSemigroup őĪ`. -/]
def of (x : őĪ) : FreeSemigroup őĪ := ‚ü®x, []‚ü©

/-- Length of an element of free semigroup. -/
@[to_additive /-- Length of an element of free additive semigroup -/]
def length (x : FreeSemigroup őĪ) : ‚Ąē := x.tail.length + 1

@[to_additive (attr := simp)]
theorem length_mul (x y : FreeSemigroup őĪ) : (x * y).length = x.length + y.length := by
  simp [length, Nat.add_right_comm, List.length, List.length_append]

@[to_additive (attr := simp)]
theorem length_of (x : őĪ) : (of x).length = 1 := rfl

@[to_additive]
instance [Inhabited őĪ] : Inhabited (FreeSemigroup őĪ) := ‚ü®of default‚ü©

/-- Recursor for free semigroup using `of` and `*`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for free additive semigroup using `of` and `+`. -/]
protected def recOnMul {C : FreeSemigroup őĪ ‚Üí Sort l} (x) (ih1 : ‚ąÄ x, C (of x))
    (ih2 : ‚ąÄ x y, C (of x) ‚Üí C y ‚Üí C (of x * y)) : C x :=
      FreeSemigroup.recOn x fun f s ‚Ü¶
      List.recOn s ih1 (fun hd tl ih f ‚Ü¶ ih2 f ‚ü®hd, tl‚ü© (ih1 f) (ih hd)) f

@[to_additive (attr := ext 1100)]
theorem hom_ext {ő≤ : Type v} [Mul ő≤] {f g : FreeSemigroup őĪ ‚Üí‚āô* ő≤} (h : f ‚ąė of = g ‚ąė of) : f = g :=
  (DFunLike.ext _ _) fun x ‚Ü¶
    FreeSemigroup.recOnMul x (congr_fun h) fun x y hx hy ‚Ü¶ by simp only [map_mul, *]

section lift

variable {ő≤ : Type v} [Semigroup ő≤] (f : őĪ ‚Üí ő≤)

/-- Lifts a function `őĪ ‚Üí ő≤` to a semigroup homomorphism `FreeSemigroup őĪ ‚Üí ő≤` given
a semigroup `ő≤`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts a function `őĪ ‚Üí ő≤` to an additive semigroup
homomorphism `FreeAddSemigroup őĪ ‚Üí ő≤` given an additive semigroup `ő≤`. -/]
def lift : (őĪ ‚Üí ő≤) ‚ČÉ (FreeSemigroup őĪ ‚Üí‚āô* ő≤) where
  toFun f :=
    { toFun := fun x ‚Ü¶ x.2.foldl (fun a b ‚Ü¶ a * f b) (f x.1)
      map_mul' := fun x y ‚Ü¶ by
        simp [head_mul, tail_mul, ‚Üź List.foldl_map, List.foldl_append, List.foldl_cons,
          List.foldl_assoc] }
  invFun f := f ‚ąė of

@[to_additive (attr := simp)]
theorem lift_of (x : őĪ) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f ‚ąė of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeSemigroup őĪ ‚Üí‚āô* ő≤) : lift (f ‚ąė of) = f := hom_ext rfl

@[to_additive]
theorem lift_of_mul (x y) : lift f (of x * y) = f x * lift f y := by rw [map_mul, lift_of]

end lift

section Map

variable {ő≤ : Type v} (f : őĪ ‚Üí ő≤)

/-- The unique semigroup homomorphism that sends `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive semigroup homomorphism that sends `of x` to `of (f x)`. -/]
def map : FreeSemigroup őĪ ‚Üí‚āô* FreeSemigroup ő≤ :=
  lift <| of ‚ąė f

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

@[to_additive (attr := simp)]
theorem length_map (x) : (map f x).length = x.length :=
  FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) (fun x y hx hy ‚Ü¶ by simp only [map_mul, length_mul, *])

end Map

section Category

variable {ő≤ : Type u}

@[to_additive]
instance : Monad FreeSemigroup where
  pure := of
  bind x f := lift f x

/-- Recursor that uses `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim) /-- Recursor that uses `pure` instead of `of`. -/]
def recOnPure {C : FreeSemigroup őĪ ‚Üí Sort l} (x) (ih1 : ‚ąÄ x, C (pure x))
    (ih2 : ‚ąÄ x y, C (pure x) ‚Üí C y ‚Üí C (pure x * y)) : C x :=
  FreeSemigroup.recOnMul x ih1 ih2

@[to_additive (attr := simp)]
protected theorem map_pure (f : őĪ ‚Üí ő≤) (x) : (f <$> pure x : FreeSemigroup ő≤) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : őĪ ‚Üí ő≤) (x y : FreeSemigroup őĪ) : f <$> (x * y) = f <$> x * f <$> y :=
  map_mul (map f) _ _

@[to_additive (attr := simp)]
theorem pure_bind (f : őĪ ‚Üí FreeSemigroup ő≤) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : őĪ ‚Üí FreeSemigroup ő≤) (x y : FreeSemigroup őĪ) :
    x * y >>= f = (x >>= f) * (y >>= f) := map_mul (lift f) _ _

@[to_additive (attr := simp)]
theorem pure_seq {f : őĪ ‚Üí ő≤} {x : FreeSemigroup őĪ} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {f g : FreeSemigroup (őĪ ‚Üí ő≤)} {x : FreeSemigroup őĪ} :
    f * g <*> x = (f <*> x) * (g <*> x) := mul_bind _ _ _

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeSemigroup.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ ‚Ü¶ rfl)
  (bind_assoc := fun x g f ‚Ü¶
    recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x ‚Ü¶ recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by rw [map_mul', ih1, ih2])

/-- `FreeSemigroup` is traversable. -/
@[to_additive /-- `FreeAddSemigroup` is traversable. -/]
protected def traverse {m : Type u ‚Üí Type u} [Applicative m] {őĪ ő≤ : Type u}
    (F : őĪ ‚Üí m ő≤) (x : FreeSemigroup őĪ) : m (FreeSemigroup ő≤) :=
  recOnPure x (fun x ‚Ü¶ pure <$> F x) fun _x _y ihx ihy ‚Ü¶ (¬∑ * ¬∑) <$> ihx <*> ihy

@[to_additive]
instance : Traversable FreeSemigroup := ‚ü®@FreeSemigroup.traverse‚ü©

variable {m : Type u ‚Üí Type u} [Applicative m] (F : őĪ ‚Üí m ő≤)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeSemigroup őĪ) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F ‚ąė pure = fun x ‚Ü¶ (pure <$> F x : m (FreeSemigroup ő≤)) := rfl

section

variable [LawfulApplicative m]

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeSemigroup őĪ) :
    traverse F (x * y) = (¬∑ * ¬∑) <$> traverse F x <*> traverse F y :=
  let ‚ü®x, L1‚ü© := x
  let ‚ü®y, L2‚ü© := y
  List.recOn L1 (fun _ ‚Ü¶ rfl)
    (fun hd tl ih x ‚Ü¶ show
        (¬∑ * ¬∑) <$> pure <$> F x <*> traverse F (mk hd tl * mk y L2) =
          (¬∑ * ¬∑) <$> ((¬∑ * ¬∑) <$> pure <$> F x <*> traverse F (mk hd tl)) <*> traverse F (mk y L2)
        by rw [ih]; simp only [Function.comp_def, (mul_assoc _ _ _).symm, functor_norm])
    x

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) ‚ąė (HMul.hMul : FreeSemigroup őĪ ‚Üí FreeSemigroup őĪ ‚Üí FreeSemigroup őĪ) =
      fun x y ‚Ü¶ (¬∑ * ¬∑) <$> traverse F x <*> traverse F y :=
  funext fun x ‚Ü¶ funext fun y ‚Ü¶ traverse_mul F x y

end

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeSemigroup.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeSemigroup.{u} :=
  { instLawfulMonad with
    id_traverse := fun x ‚Ü¶
      FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x ‚Ü¶
      recOnPure x (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp_def])
        fun x y ih1 ih2 ‚Ü¶ by
          rw [traverse_mul, ih1, ih2, traverse_mul, Functor.Comp.map_mk]
          simp only [Function.comp_def, functor_norm, traverse_mul]
    naturality := fun ő∑ őĪ ő≤ f x ‚Ü¶
      recOnPure x (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp])
          (fun x y ih1 ih2 ‚Ü¶ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x ‚Ü¶
      FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

@[to_additive]
instance [DecidableEq őĪ] : DecidableEq (FreeSemigroup őĪ) :=
  fun _ _ ‚Ü¶ decidable_of_iff' _ FreeSemigroup.ext_iff

end FreeSemigroup

namespace FreeMagma

variable {őĪ : Type u} {ő≤ : Type v}

/-- The canonical multiplicative morphism from `FreeMagma őĪ` to `FreeSemigroup őĪ`. -/
@[to_additive /-- The canonical additive morphism from `FreeAddMagma őĪ` to `FreeAddSemigroup őĪ`. -/]
