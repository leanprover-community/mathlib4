/-!
# Free constructions

## Main definitions

* `FreeMagma Œ±`: free magma (structure with binary operation without any axioms) over alphabet `Œ±`,
  defined inductively, with traversable instance and decidable equality.
* `MagmaAssocQuotient Œ±`: quotient of a magma `Œ±` by the associativity equivalence relation.
* `FreeSemigroup Œ±`: free semigroup over alphabet `Œ±`, defined as a structure with two fields
  `head : Œ±` and `tail : List Œ±` (i.e. nonempty lists), with traversable instance and decidable
  equality.
* `FreeMagmaAssocQuotientEquiv Œ±`: isomorphism between `MagmaAssocQuotient (FreeMagma Œ±)` and
  `FreeSemigroup Œ±`.
* `FreeMagma.lift`: the universal property of the free magma, expressing its adjointness.
-/
set_option backward.defeqAttrib.useBackward true

@[expose] public section

universe u v l

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `Œ±` is a type, then `FreeAddMagma Œ±` is the free additive magma generated by `Œ±`.
This is an additive magma equipped with a function `FreeAddMagma.of : Œ± ‚Üí FreeAddMagma Œ±` which has
the following universal property: if `M` is any magma, and `f : Œ± ‚Üí M` is any function,
then this function is the composite of `FreeAddMagma.of` and a unique additive homomorphism
`FreeAddMagma.lift f : FreeAddMagma Œ± ‚Üí‚Çô+ M`.

A typical element of `FreeAddMagma Œ±` is a formal non-associative sum of
elements of `Œ±`. For example if `x` and `y` are terms of type `Œ±` then `x + ((y + y) + x)` is a
"typical" element of `FreeAddMagma Œ±`.
One can think of `FreeAddMagma Œ±` as the type of binary trees with leaves labelled by `Œ±`.
In general, no pair of distinct elements in `FreeAddMagma Œ±` will commute.
-/
inductive FreeAddMagma (Œ± : Type u) : Type u
  | of : Œ± ‚Üí FreeAddMagma Œ±
  | add : FreeAddMagma Œ± ‚Üí FreeAddMagma Œ± ‚Üí FreeAddMagma Œ±
  deriving DecidableEq
compile_inductive% FreeAddMagma

-- Disable generation of `sizeOf_spec` and `injEq`,
-- which are not needed and the `simpNF` linter will complain about.
set_option genSizeOfSpec false in
set_option genInjectivity false in
/--
If `Œ±` is a type, then `FreeMagma Œ±` is the free magma generated by `Œ±`.
This is a magma equipped with a function `FreeMagma.of : Œ± ‚Üí FreeMagma Œ±` which has
the following universal property: if `M` is any magma, and `f : Œ± ‚Üí M` is any function,
then this function is the composite of `FreeMagma.of` and a unique multiplicative homomorphism
`FreeMagma.lift f : FreeMagma Œ± ‚Üí‚Çô* M`.

A typical element of `FreeMagma Œ±` is a formal non-associative product of
elements of `Œ±`. For example if `x` and `y` are terms of type `Œ±` then `x * ((y * y) * x)` is a
"typical" element of `FreeMagma Œ±`.
One can think of `FreeMagma Œ±` as the type of binary trees with leaves labelled by `Œ±`.
In general, no pair of distinct elements in `FreeMagma Œ±` will commute.
-/
@[to_additive]
inductive FreeMagma (Œ± : Type u) : Type u
  | of : Œ± ‚Üí FreeMagma Œ±
  | mul : FreeMagma Œ± ‚Üí FreeMagma Œ± ‚Üí FreeMagma Œ±
  deriving DecidableEq
compile_inductive% FreeMagma

namespace FreeMagma

variable {Œ± : Type u}

@[to_additive]
instance [Inhabited Œ±] : Inhabited (FreeMagma Œ±) := ‚ü®of default‚ü©

@[to_additive]
instance : Mul (FreeMagma Œ±) := ‚ü®FreeMagma.mul‚ü©

@[to_additive (attr := simp)]
theorem mul_eq (x y : FreeMagma Œ±) : mul x y = x * y := rfl

/-- Recursor for `FreeMagma` using `x * y` instead of `FreeMagma.mul x y`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for `FreeAddMagma` using `x + y` instead of `FreeAddMagma.add x y`. -/]
def recOnMul {C : FreeMagma Œ± ‚Üí Sort l} (x) (ih1 : ‚àÄ x, C (of x))
    (ih2 : ‚àÄ x y, C x ‚Üí C y ‚Üí C (x * y)) : C x :=
  FreeMagma.recOn x ih1 ih2

@[to_additive (attr := ext 1100)]
theorem hom_ext {Œ≤ : Type v} [Mul Œ≤] {f g : FreeMagma Œ± ‚Üí‚Çô* Œ≤} (h : f ‚àò of = g ‚àò of) : f = g :=
  (DFunLike.ext _ _) fun x ‚Ü¶ recOnMul x (congr_fun h) <| by intros; simp only [map_mul, *]

end FreeMagma

/-- Lifts a function `Œ± ‚Üí Œ≤` to a magma homomorphism `FreeMagma Œ± ‚Üí Œ≤` given a magma `Œ≤`. -/
def FreeMagma.liftAux {Œ± : Type u} {Œ≤ : Type v} [Mul Œ≤] (f : Œ± ‚Üí Œ≤) : FreeMagma Œ± ‚Üí Œ≤
  | FreeMagma.of x => f x
  | x * y => liftAux f x * liftAux f y

/-- Lifts a function `Œ± ‚Üí Œ≤` to an additive magma homomorphism `FreeAddMagma Œ± ‚Üí Œ≤` given
an additive magma `Œ≤`. -/
def FreeAddMagma.liftAux {Œ± : Type u} {Œ≤ : Type v} [Add Œ≤] (f : Œ± ‚Üí Œ≤) : FreeAddMagma Œ± ‚Üí Œ≤
  | FreeAddMagma.of x => f x
  | x + y => liftAux f x + liftAux f y

attribute [to_additive existing] FreeMagma.liftAux

namespace FreeMagma

section lift

variable {Œ± : Type u} {Œ≤ : Type v} [Mul Œ≤] (f : Œ± ‚Üí Œ≤)

/-- The universal property of the free magma expressing its adjointness. -/
@[to_additive (attr := simps symm_apply)
/-- The universal property of the free additive magma expressing its adjointness. -/]
def lift : (Œ± ‚Üí Œ≤) ‚âÉ (FreeMagma Œ± ‚Üí‚Çô* Œ≤) where
  toFun f :=
  { toFun := liftAux f
    map_mul' := fun _ _ ‚Ü¶ rfl }
  invFun F := F ‚àò of

@[to_additive (attr := simp)]
theorem lift_of (x) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f ‚àò of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeMagma Œ± ‚Üí‚Çô* Œ≤) : lift (f ‚àò of) = f := lift.apply_symm_apply f

end lift

section Map

variable {Œ± : Type u} {Œ≤ : Type v} (f : Œ± ‚Üí Œ≤)

/-- The unique magma homomorphism `FreeMagma Œ± ‚Üí‚Çô* FreeMagma Œ≤` that sends
each `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive magma homomorphism `FreeAddMagma Œ± ‚Üí FreeAddMagma Œ≤` that
sends each `of x` to `of (f x)`. -/]
def map (f : Œ± ‚Üí Œ≤) : FreeMagma Œ± ‚Üí‚Çô* FreeMagma Œ≤ := lift (of ‚àò f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end Map

section Category

variable {Œ± Œ≤ : Type u}

@[to_additive]
instance : Monad FreeMagma where
  pure := of
  bind x f := lift f x

/-- Recursor on `FreeMagma` using `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim)
/-- Recursor on `FreeAddMagma` using `pure` instead of `of`. -/]
protected def recOnPure {C : FreeMagma Œ± ‚Üí Sort l} (x) (ih1 : ‚àÄ x, C (pure x))
    (ih2 : ‚àÄ x y, C x ‚Üí C y ‚Üí C (x * y)) : C x :=
  FreeMagma.recOnMul x ih1 ih2

@[to_additive (attr := simp)]
protected theorem map_pure (f : Œ± ‚Üí Œ≤) (x) : (f <$> pure x : FreeMagma Œ≤) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : Œ± ‚Üí Œ≤) (x y : FreeMagma Œ±) : f <$> (x * y) = f <$> x * f <$> y := rfl

@[to_additive (attr := simp)]
theorem pure_bind (f : Œ± ‚Üí FreeMagma Œ≤) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : Œ± ‚Üí FreeMagma Œ≤) (x y : FreeMagma Œ±) : x * y >>= f = (x >>= f) * (y >>= f) :=
  rfl

@[to_additive (attr := simp)]
theorem pure_seq {Œ± Œ≤ : Type u} {f : Œ± ‚Üí Œ≤} {x : FreeMagma Œ±} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {Œ± Œ≤ : Type u} {f g : FreeMagma (Œ± ‚Üí Œ≤)} {x : FreeMagma Œ±} :
    f * g <*> x = (f <*> x) * (g <*> x) := rfl

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeMagma.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ ‚Ü¶ rfl)
  (bind_assoc := fun x f g ‚Ü¶ FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
    rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x ‚Ü¶ FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
    rw [map_mul', ih1, ih2])

end Category

end FreeMagma

/-- `FreeMagma` is traversable. -/
protected def FreeMagma.traverse {m : Type u ‚Üí Type u} [Applicative m] {Œ± Œ≤ : Type u}
    (F : Œ± ‚Üí m Œ≤) : FreeMagma Œ± ‚Üí m (FreeMagma Œ≤)
  | FreeMagma.of x => FreeMagma.of <$> F x
  | x * y => (¬∑ * ¬∑) <$> x.traverse F <*> y.traverse F

/-- `FreeAddMagma` is traversable. -/
protected def FreeAddMagma.traverse {m : Type u ‚Üí Type u} [Applicative m] {Œ± Œ≤ : Type u}
    (F : Œ± ‚Üí m Œ≤) : FreeAddMagma Œ± ‚Üí m (FreeAddMagma Œ≤)
  | FreeAddMagma.of x => FreeAddMagma.of <$> F x
  | x + y => (¬∑ + ¬∑) <$> x.traverse F <*> y.traverse F

attribute [to_additive existing] FreeMagma.traverse

namespace FreeMagma

variable {Œ± : Type u}

section Category

variable {Œ≤ : Type u}

@[to_additive]
instance : Traversable FreeMagma := ‚ü®@FreeMagma.traverse‚ü©

variable {m : Type u ‚Üí Type u} [Applicative m] (F : Œ± ‚Üí m Œ≤)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeMagma Œ±) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F ‚àò pure = fun x ‚Ü¶ (pure <$> F x : m (FreeMagma Œ≤)) := rfl

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeMagma Œ±) :
    traverse F (x * y) = (¬∑ * ¬∑) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) ‚àò (HMul.hMul : FreeMagma Œ± ‚Üí FreeMagma Œ± ‚Üí FreeMagma Œ±) = fun x y ‚Ü¶
      (¬∑ * ¬∑) <$> traverse F x <*> traverse F y := rfl

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeMagma.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeMagma.{u} :=
  { instLawfulMonad with
    id_traverse := fun x ‚Ü¶
      FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x ‚Ü¶
      FreeMagma.recOnPure x
        (fun x ‚Ü¶ by simp only [Function.comp_def, traverse_pure, functor_norm])
        (fun x y ih1 ih2 ‚Ü¶ by
          rw [traverse_mul, ih1, ih2, traverse_mul]
          simp [Functor.Comp.map_mk, Functor.map_map, Function.comp_def, Comp.seq_mk, seq_map_assoc,
            map_seq, traverse_mul])
    naturality := fun Œ∑ Œ± Œ≤ f x ‚Ü¶
      FreeMagma.recOnPure x
        (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp_apply])
        (fun x y ih1 ih2 ‚Ü¶ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x ‚Ü¶
      FreeMagma.recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

end FreeMagma

/-- Representation of an element of a free magma. -/
protected def FreeMagma.repr {Œ± : Type u} [Repr Œ±] : FreeMagma Œ± ‚Üí Lean.Format
  | FreeMagma.of x => repr x
  | x * y => "( " ++ x.repr ++ " * " ++ y.repr ++ " )"

/-- Representation of an element of a free additive magma. -/
protected def FreeAddMagma.repr {Œ± : Type u} [Repr Œ±] : FreeAddMagma Œ± ‚Üí Lean.Format
  | FreeAddMagma.of x => repr x
  | x + y => "( " ++ x.repr ++ " + " ++ y.repr ++ " )"

attribute [to_additive existing] FreeMagma.repr

@[to_additive]
instance {Œ± : Type u} [Repr Œ±] : Repr (FreeMagma Œ±) := ‚ü®fun o _ => FreeMagma.repr o‚ü©

/-- Length of an element of a free magma. -/
def FreeMagma.length {Œ± : Type u} : FreeMagma Œ± ‚Üí ‚Ñï
  | FreeMagma.of _x => 1
  | x * y => x.length + y.length

/-- Length of an element of a free additive magma. -/
def FreeAddMagma.length {Œ± : Type u} : FreeAddMagma Œ± ‚Üí ‚Ñï
  | FreeAddMagma.of _x => 1
  | x + y => x.length + y.length

attribute [to_additive existing (attr := simp)] FreeMagma.length

/-- The length of an element of a free magma is positive. -/
@[to_additive /-- The length of an element of a free additive magma is positive. -/]
lemma FreeMagma.length_pos {Œ± : Type u} (x : FreeMagma Œ±) : 0 < x.length :=
  match x with
  | FreeMagma.of _ => Nat.succ_pos 0
  | mul y z => Nat.add_pos_left (length_pos y) z.length

/-- Associativity relations for an additive magma. -/
inductive AddMagma.AssocRel (Œ± : Type u) [Add Œ±] : Œ± ‚Üí Œ± ‚Üí Prop
  | intro : ‚àÄ x y z, AddMagma.AssocRel Œ± (x + y + z) (x + (y + z))
  | left : ‚àÄ w x y z, AddMagma.AssocRel Œ± (w + (x + y + z)) (w + (x + (y + z)))

/-- Associativity relations for a magma. -/
@[to_additive AddMagma.AssocRel /-- Associativity relations for an additive magma. -/]
inductive Magma.AssocRel (Œ± : Type u) [Mul Œ±] : Œ± ‚Üí Œ± ‚Üí Prop
  | intro : ‚àÄ x y z, Magma.AssocRel Œ± (x * y * z) (x * (y * z))
  | left : ‚àÄ w x y z, Magma.AssocRel Œ± (w * (x * y * z)) (w * (x * (y * z)))

namespace Magma

/-- Semigroup quotient of a magma. -/
@[to_additive AddMagma.FreeAddSemigroup /-- Additive semigroup quotient of an additive magma. -/]
def AssocQuotient (Œ± : Type u) [Mul Œ±] : Type u :=
  Quot <| AssocRel Œ±

namespace AssocQuotient

variable {Œ± : Type u} [Mul Œ±]

@[to_additive]
theorem quot_mk_assoc (x y z : Œ±) : Quot.mk (AssocRel Œ±) (x * y * z) = Quot.mk _ (x * (y * z)) :=
  Quot.sound (AssocRel.intro _ _ _)

@[to_additive]
theorem quot_mk_assoc_left (x y z w : Œ±) :
    Quot.mk (AssocRel Œ±) (x * (y * z * w)) = Quot.mk _ (x * (y * (z * w))) :=
  Quot.sound (AssocRel.left _ _ _ _)

@[to_additive]
instance : Semigroup (AssocQuotient Œ±) where
  mul x y := by
    refine Quot.liftOn‚ÇÇ x y (fun x y ‚Ü¶ Quot.mk _ (x * y)) ?_ ?_
    ¬∑ rintro a b‚ÇÅ b‚ÇÇ (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only
      ¬∑ exact quot_mk_assoc_left _ _ _ _
      ¬∑ rw [‚Üê quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc]
    ¬∑ rintro a‚ÇÅ a‚ÇÇ b (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only
      ¬∑ simp only [quot_mk_assoc, quot_mk_assoc_left]
      ¬∑ rw [quot_mk_assoc, quot_mk_assoc, quot_mk_assoc_left, quot_mk_assoc_left,
          quot_mk_assoc_left, ‚Üê quot_mk_assoc c d, ‚Üê quot_mk_assoc c d, quot_mk_assoc_left]
  mul_assoc x y z :=
    Quot.induction_on‚ÇÉ x y z fun a b c ‚Ü¶ quot_mk_assoc a b c

/-- Embedding from magma to its free semigroup. -/
@[to_additive /-- Embedding from additive magma to its free additive semigroup. -/]
def of : Œ± ‚Üí‚Çô* AssocQuotient Œ± where toFun := Quot.mk _; map_mul' _x _y := rfl

@[to_additive]
instance [Inhabited Œ±] : Inhabited (AssocQuotient Œ±) := ‚ü®of default‚ü©

@[to_additive (attr := elab_as_elim, induction_eliminator)]
protected theorem induction_on {C : AssocQuotient Œ± ‚Üí Prop} (x : AssocQuotient Œ±)
    (ih : ‚àÄ x, C (of x)) : C x := Quot.induction_on x ih

section lift

variable {Œ≤ : Type v} [Semigroup Œ≤] (f : Œ± ‚Üí‚Çô* Œ≤)

@[to_additive (attr := ext 1100)]
theorem hom_ext {f g : AssocQuotient Œ± ‚Üí‚Çô* Œ≤} (h : f.comp of = g.comp of) : f = g :=
  (DFunLike.ext _ _) fun x => AssocQuotient.induction_on x <| DFunLike.congr_fun h

/-- Lifts a magma homomorphism `Œ± ‚Üí Œ≤` to a semigroup homomorphism `Magma.AssocQuotient Œ± ‚Üí Œ≤`
given a semigroup `Œ≤`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts an additive magma homomorphism `Œ± ‚Üí Œ≤` to an
additive semigroup homomorphism `AddMagma.AssocQuotient Œ± ‚Üí Œ≤` given an additive semigroup `Œ≤`. -/]
def lift : (Œ± ‚Üí‚Çô* Œ≤) ‚âÉ (AssocQuotient Œ± ‚Üí‚Çô* Œ≤) where
  toFun f :=
  { toFun := fun x ‚Ü¶
      Quot.liftOn x f <| by rintro a b (‚ü®c, d, e‚ü© | ‚ü®c, d, e, f‚ü©) <;> simp only [map_mul, mul_assoc]
    map_mul' := fun x y ‚Ü¶ Quot.induction_on‚ÇÇ x y (map_mul f) }
  invFun f := f.comp of

@[to_additive (attr := simp)]
theorem lift_of (x : Œ±) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : (lift f).comp of = f := lift.symm_apply_apply f

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : AssocQuotient Œ± ‚Üí‚Çô* Œ≤) : lift (f.comp of) = f := lift.apply_symm_apply f

end lift

variable {Œ≤ : Type v} [Mul Œ≤] (f : Œ± ‚Üí‚Çô* Œ≤)

/-- From a magma homomorphism `Œ± ‚Üí‚Çô* Œ≤` to a semigroup homomorphism
`Magma.AssocQuotient Œ± ‚Üí‚Çô* Magma.AssocQuotient Œ≤`. -/
@[to_additive /-- From an additive magma homomorphism `Œ± ‚Üí Œ≤` to an additive semigroup homomorphism
`AddMagma.AssocQuotient Œ± ‚Üí AddMagma.AssocQuotient Œ≤`. -/]
def map : AssocQuotient Œ± ‚Üí‚Çô* AssocQuotient Œ≤ := lift (of.comp f)

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

end AssocQuotient

end Magma

/--
If `Œ±` is a type, then `FreeAddSemigroup Œ±` is the free additive semigroup generated by `Œ±`.
This is an additive semigroup equipped with a function
`FreeAddSemigroup.of : Œ± ‚Üí FreeAddSemigroup Œ±` which has the following universal property:
if `M` is any additive semigroup, and `f : Œ± ‚Üí M` is any function,
then this function is the composite of `FreeAddSemigroup.of` and a unique semigroup homomorphism
`FreeAddSemigroup.lift f : FreeAddSemigroup Œ± ‚Üí‚Çô+ M`.

A typical element of `FreeAddSemigroup Œ±` is a nonempty formal sum of elements of `Œ±`.
For example if `x` and `y` are terms of type `Œ±` then `x + y + y + x` is a
"typical" element of `FreeAddSemigroup Œ±`. In particular if `Œ±` is empty
then `FreeAddSemigroup Œ±` is also empty, and if `Œ±` has one term
then `FreeAddSemigroup Œ±` is isomorphic to `‚Ñï+`.
If `Œ±` has two or more terms then `FreeAddSemigroup Œ±` is not commutative.
One can think of `FreeAddSemigroup Œ±` as the type of nonempty lists of `Œ±`, with addition
given by concatenation.
-/
structure FreeAddSemigroup (Œ± : Type u) where
  /-- The head of the element -/
  head : Œ±
  /-- The tail of the element -/
  tail : List Œ±
compile_inductive% FreeAddSemigroup

/--
If `Œ±` is a type, then `FreeSemigroup Œ±` is the free semigroup generated by `Œ±`.
This is a semigroup equipped with a function `FreeSemigroup.of : Œ± ‚Üí FreeSemigroup Œ±` which has
the following universal property: if `M` is any semigroup, and `f : Œ± ‚Üí M` is any function,
then this function is the composite of `FreeSemigroup.of` and a unique semigroup homomorphism
`FreeSemigroup.lift f : FreeSemigroup Œ± ‚Üí‚Çô* M`.

A typical element of `FreeSemigroup Œ±` is a nonempty formal product of elements of `Œ±`.
For example if `x` and `y` are terms of type `Œ±` then `x * y * y * x` is a
"typical" element of `FreeSemigroup Œ±`. In particular if `Œ±` is empty
then `FreeSemigroup Œ±` is also empty, and if `Œ±` has one term
then `FreeSemigroup Œ±` is isomorphic to `Multiplicative ‚Ñï+`.
If `Œ±` has two or more terms then `FreeSemigroup Œ±` is not commutative.
One can think of `FreeSemigroup Œ±` as the type of nonempty lists of `Œ±`, with multiplication
given by concatenation.
-/
@[to_additive (attr := ext)]
structure FreeSemigroup (Œ± : Type u) where
  /-- The head of the element -/
  head : Œ±
  /-- The tail of the element -/
  tail : List Œ±
compile_inductive% FreeSemigroup

namespace FreeSemigroup

variable {Œ± : Type u}

@[to_additive]
instance : Semigroup (FreeSemigroup Œ±) where
  mul L1 L2 := ‚ü®L1.1, L1.2 ++ L2.1 :: L2.2‚ü©
  mul_assoc _L1 _L2 _L3 := FreeSemigroup.ext rfl <| List.append_assoc _ _ _

@[to_additive (attr := simp)]
theorem head_mul (x y : FreeSemigroup Œ±) : (x * y).1 = x.1 := rfl

@[to_additive (attr := simp)]
theorem tail_mul (x y : FreeSemigroup Œ±) : (x * y).2 = x.2 ++ y.1 :: y.2 := rfl

@[to_additive (attr := simp)]
theorem mk_mul_mk (x y : Œ±) (L1 L2 : List Œ±) : mk x L1 * mk y L2 = mk x (L1 ++ y :: L2) := rfl

/-- The embedding `Œ± ‚Üí FreeSemigroup Œ±`. -/
@[to_additive (attr := simps) /-- The embedding `Œ± ‚Üí FreeAddSemigroup Œ±`. -/]
def of (x : Œ±) : FreeSemigroup Œ± := ‚ü®x, []‚ü©

/-- Length of an element of free semigroup. -/
@[to_additive /-- Length of an element of free additive semigroup -/]
def length (x : FreeSemigroup Œ±) : ‚Ñï := x.tail.length + 1

@[to_additive (attr := simp)]
theorem length_mul (x y : FreeSemigroup Œ±) : (x * y).length = x.length + y.length := by
  simp [length, Nat.add_right_comm, List.length, List.length_append]

@[to_additive (attr := simp)]
theorem length_of (x : Œ±) : (of x).length = 1 := rfl

@[to_additive]
instance [Inhabited Œ±] : Inhabited (FreeSemigroup Œ±) := ‚ü®of default‚ü©

/-- Recursor for free semigroup using `of` and `*`. -/
@[to_additive (attr := elab_as_elim, induction_eliminator)
  /-- Recursor for free additive semigroup using `of` and `+`. -/]
protected def recOnMul {C : FreeSemigroup Œ± ‚Üí Sort l} (x) (ih1 : ‚àÄ x, C (of x))
    (ih2 : ‚àÄ x y, C (of x) ‚Üí C y ‚Üí C (of x * y)) : C x :=
      FreeSemigroup.recOn x fun f s ‚Ü¶
      List.recOn s ih1 (fun hd tl ih f ‚Ü¶ ih2 f ‚ü®hd, tl‚ü© (ih1 f) (ih hd)) f

@[to_additive (attr := ext 1100)]
theorem hom_ext {Œ≤ : Type v} [Mul Œ≤] {f g : FreeSemigroup Œ± ‚Üí‚Çô* Œ≤} (h : f ‚àò of = g ‚àò of) : f = g :=
  (DFunLike.ext _ _) fun x ‚Ü¶
    FreeSemigroup.recOnMul x (congr_fun h) fun x y hx hy ‚Ü¶ by simp only [map_mul, *]

section lift

variable {Œ≤ : Type v} [Semigroup Œ≤] (f : Œ± ‚Üí Œ≤)

/-- Lifts a function `Œ± ‚Üí Œ≤` to a semigroup homomorphism `FreeSemigroup Œ± ‚Üí Œ≤` given
a semigroup `Œ≤`. -/
@[to_additive (attr := simps symm_apply) /-- Lifts a function `Œ± ‚Üí Œ≤` to an additive semigroup
homomorphism `FreeAddSemigroup Œ± ‚Üí Œ≤` given an additive semigroup `Œ≤`. -/]
def lift : (Œ± ‚Üí Œ≤) ‚âÉ (FreeSemigroup Œ± ‚Üí‚Çô* Œ≤) where
  toFun f :=
    { toFun := fun x ‚Ü¶ x.2.foldl (fun a b ‚Ü¶ a * f b) (f x.1)
      map_mul' := fun x y ‚Ü¶ by
        simp [head_mul, tail_mul, ‚Üê List.foldl_map, List.foldl_append, List.foldl_cons,
          List.foldl_assoc] }
  invFun f := f ‚àò of

@[to_additive (attr := simp)]
theorem lift_of (x : Œ±) : lift f (of x) = f x := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of : lift f ‚àò of = f := rfl

@[to_additive (attr := simp)]
theorem lift_comp_of' (f : FreeSemigroup Œ± ‚Üí‚Çô* Œ≤) : lift (f ‚àò of) = f := hom_ext rfl

@[to_additive]
theorem lift_of_mul (x y) : lift f (of x * y) = f x * lift f y := by rw [map_mul, lift_of]

end lift

section Map

variable {Œ≤ : Type v} (f : Œ± ‚Üí Œ≤)

/-- The unique semigroup homomorphism that sends `of x` to `of (f x)`. -/
@[to_additive /-- The unique additive semigroup homomorphism that sends `of x` to `of (f x)`. -/]
def map : FreeSemigroup Œ± ‚Üí‚Çô* FreeSemigroup Œ≤ :=
  lift <| of ‚àò f

@[to_additive (attr := simp)]
theorem map_of (x) : map f (of x) = of (f x) := rfl

@[to_additive (attr := simp)]
theorem length_map (x) : (map f x).length = x.length :=
  FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) (fun x y hx hy ‚Ü¶ by simp only [map_mul, length_mul, *])

end Map

section Category

variable {Œ≤ : Type u}

@[to_additive]
instance : Monad FreeSemigroup where
  pure := of
  bind x f := lift f x

/-- Recursor that uses `pure` instead of `of`. -/
@[to_additive (attr := elab_as_elim) /-- Recursor that uses `pure` instead of `of`. -/]
def recOnPure {C : FreeSemigroup Œ± ‚Üí Sort l} (x) (ih1 : ‚àÄ x, C (pure x))
    (ih2 : ‚àÄ x y, C (pure x) ‚Üí C y ‚Üí C (pure x * y)) : C x :=
  FreeSemigroup.recOnMul x ih1 ih2

@[to_additive (attr := simp)]
protected theorem map_pure (f : Œ± ‚Üí Œ≤) (x) : (f <$> pure x : FreeSemigroup Œ≤) = pure (f x) := rfl

@[to_additive (attr := simp)]
theorem map_mul' (f : Œ± ‚Üí Œ≤) (x y : FreeSemigroup Œ±) : f <$> (x * y) = f <$> x * f <$> y :=
  map_mul (map f) _ _

@[to_additive (attr := simp)]
theorem pure_bind (f : Œ± ‚Üí FreeSemigroup Œ≤) (x) : pure x >>= f = f x := rfl

@[to_additive (attr := simp)]
theorem mul_bind (f : Œ± ‚Üí FreeSemigroup Œ≤) (x y : FreeSemigroup Œ±) :
    x * y >>= f = (x >>= f) * (y >>= f) := map_mul (lift f) _ _

@[to_additive (attr := simp)]
theorem pure_seq {f : Œ± ‚Üí Œ≤} {x : FreeSemigroup Œ±} : pure f <*> x = f <$> x := rfl

@[to_additive (attr := simp)]
theorem mul_seq {f g : FreeSemigroup (Œ± ‚Üí Œ≤)} {x : FreeSemigroup Œ±} :
    f * g <*> x = (f <*> x) * (g <*> x) := mul_bind _ _ _

@[to_additive]
instance instLawfulMonad : LawfulMonad FreeSemigroup.{u} := LawfulMonad.mk'
  (pure_bind := fun _ _ ‚Ü¶ rfl)
  (bind_assoc := fun x g f ‚Ü¶
    recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by rw [mul_bind, mul_bind, mul_bind, ih1, ih2])
  (id_map := fun x ‚Ü¶ recOnPure x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by rw [map_mul', ih1, ih2])

/-- `FreeSemigroup` is traversable. -/
@[to_additive /-- `FreeAddSemigroup` is traversable. -/]
protected def traverse {m : Type u ‚Üí Type u} [Applicative m] {Œ± Œ≤ : Type u}
    (F : Œ± ‚Üí m Œ≤) (x : FreeSemigroup Œ±) : m (FreeSemigroup Œ≤) :=
  recOnPure x (fun x ‚Ü¶ pure <$> F x) fun _x _y ihx ihy ‚Ü¶ (¬∑ * ¬∑) <$> ihx <*> ihy

@[to_additive]
instance : Traversable FreeSemigroup := ‚ü®@FreeSemigroup.traverse‚ü©

variable {m : Type u ‚Üí Type u} [Applicative m] (F : Œ± ‚Üí m Œ≤)

@[to_additive (attr := simp)]
theorem traverse_pure (x) : traverse F (pure x : FreeSemigroup Œ±) = pure <$> F x := rfl

@[to_additive (attr := simp)]
theorem traverse_pure' : traverse F ‚àò pure = fun x ‚Ü¶ (pure <$> F x : m (FreeSemigroup Œ≤)) := rfl

section

variable [LawfulApplicative m]

@[to_additive (attr := simp)]
theorem traverse_mul (x y : FreeSemigroup Œ±) :
    traverse F (x * y) = (¬∑ * ¬∑) <$> traverse F x <*> traverse F y :=
  let ‚ü®x, L1‚ü© := x
  let ‚ü®y, L2‚ü© := y
  List.recOn L1 (fun _ ‚Ü¶ rfl)
    (fun hd tl ih x ‚Ü¶ show
        (¬∑ * ¬∑) <$> pure <$> F x <*> traverse F (mk hd tl * mk y L2) =
          (¬∑ * ¬∑) <$> ((¬∑ * ¬∑) <$> pure <$> F x <*> traverse F (mk hd tl)) <*> traverse F (mk y L2)
        by rw [ih]; simp only [Function.comp_def, (mul_assoc _ _ _).symm, functor_norm])
    x

@[to_additive (attr := simp)]
theorem traverse_mul' :
    Function.comp (traverse F) ‚àò (HMul.hMul : FreeSemigroup Œ± ‚Üí FreeSemigroup Œ± ‚Üí FreeSemigroup Œ±) =
      fun x y ‚Ü¶ (¬∑ * ¬∑) <$> traverse F x <*> traverse F y :=
  funext fun x ‚Ü¶ funext fun y ‚Ü¶ traverse_mul F x y

end

@[to_additive (attr := simp)]
theorem traverse_eq (x) : FreeSemigroup.traverse F x = traverse F x := rfl

@[to_additive]
instance : LawfulTraversable FreeSemigroup.{u} :=
  { instLawfulMonad with
    id_traverse := fun x ‚Ü¶
      FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, seq_pure, map_pure, map_pure]
    comp_traverse := fun f g x ‚Ü¶
      recOnPure x (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp_def])
        fun x y ih1 ih2 ‚Ü¶ by
          rw [traverse_mul, ih1, ih2, traverse_mul, Functor.Comp.map_mk]
          simp only [Function.comp_def, functor_norm, traverse_mul]
    naturality := fun Œ∑ Œ± Œ≤ f x ‚Ü¶
      recOnPure x (fun x ‚Ü¶ by simp only [traverse_pure, functor_norm, Function.comp])
          (fun x y ih1 ih2 ‚Ü¶ by simp only [traverse_mul, functor_norm, ih1, ih2])
    traverse_eq_map_id := fun f x ‚Ü¶
      FreeSemigroup.recOnMul x (fun _ ‚Ü¶ rfl) fun x y ih1 ih2 ‚Ü¶ by
        rw [traverse_mul, ih1, ih2, map_mul', map_pure, seq_pure, map_pure] }

end Category

@[to_additive]
instance [DecidableEq Œ±] : DecidableEq (FreeSemigroup Œ±) :=
  fun _ _ ‚Ü¶ decidable_of_iff' _ FreeSemigroup.ext_iff

end FreeSemigroup

namespace FreeMagma

variable {Œ± : Type u} {Œ≤ : Type v}

/-- The canonical multiplicative morphism from `FreeMagma Œ±` to `FreeSemigroup Œ±`. -/
@[to_additive /-- The canonical additive morphism from `FreeAddMagma Œ±` to `FreeAddSemigroup Œ±`. -/]
def toFreeSemigroup : FreeMagma Œ± ‚Üí‚Çô* FreeSemigroup Œ± := FreeMagma.lift FreeSemigroup.of

@[to_additive (attr := simp)]
theorem toFreeSemigroup_of (x : Œ±) : toFreeSemigroup (of x) = FreeSemigroup.of x := rfl

@[to_additive (attr := simp)]
theorem toFreeSemigroup_comp_of : @toFreeSemigroup Œ± ‚àò of = FreeSemigroup.of := rfl

@[to_additive]
theorem toFreeSemigroup_comp_map (f : Œ± ‚Üí Œ≤) :
    toFreeSemigroup.comp (map f) = (FreeSemigroup.map f).comp toFreeSemigroup := by ext1; rfl

@[to_additive]
theorem toFreeSemigroup_map (f : Œ± ‚Üí Œ≤) (x : FreeMagma Œ±) :
    toFreeSemigroup (map f x) = FreeSemigroup.map f (toFreeSemigroup x) :=
  DFunLike.congr_fun (toFreeSemigroup_comp_map f) x

@[to_additive (attr := simp)]
theorem length_toFreeSemigroup (x : FreeMagma Œ±) : (toFreeSemigroup x).length = x.length :=
  FreeMagma.recOnMul x (fun _ ‚Ü¶ rfl) fun x y hx hy ‚Ü¶ by
    rw [map_mul, FreeSemigroup.length_mul, hx, hy]; rfl

end FreeMagma

/-- Isomorphism between `Magma.AssocQuotient (FreeMagma Œ±)` and `FreeSemigroup Œ±`. -/
