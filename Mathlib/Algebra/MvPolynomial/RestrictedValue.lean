/-- The ring of integer-valued polynomials is generated by binomial coefficients in variables. -/
lemma integerValued_iff :
    restrictedValue σ ℤ ℚ =
      Subring.closure {Ring.choose (X i : MvPolynomial σ ℚ) n | (i : σ) (n : ℕ)} := by
  sorry
