import Mathlib.Algebra.Group.Subgroup.Pointwise
import Mathlib.Algebra.GroupWithZero.Units.Lemmas
import Mathlib.Algebra.GroupWithZero.WithZero

/-! # The range of a MonoidWithZeroHom
Given a `MonoidWithZeroHom` `f : A έΗΤ B` whose codomain `B` is a `MonoidWithZero`, we define the
type `MonoidWithZeroHom.valueMonoid` as the submonoid of `B╦μ` generated by the invertible elements
in the range of `f`. For example, if `A = έΕΧ`, `f` is the natural cast to `B` where `B` is
* `έΕζέΚξ0`, then `MonoidWithZero.valueMonoid` are the positive natural numbers in `έΕζέΚξ0`;
* `WithZero έΕν`, then `MonoidWithZero.valueMonoid = {1}`.


`MonoidWithZeroHom.valueMonoidέΓΑ` is the `MonoidWithZero` obtained by
adjoining `0` to the previous type.

Likewise, `MonoidWithZeroHom.valueGroup` is the *subgroup* of `B╦μ` generated by the invertible
elements in `range f` and ``MonoidWithZeroHom.valueGroupέΓΑ` adds a `0` to the previous group.

When `B` is commutative, then both `MonoidWithZeroHom.valueGroup f` and
`MonoidWithZeroHom.valueGroupέΓΑ f` are also commutative and the former can be described more
explicitly (see `MonoidWithZeroHom.mem_valueGroup_iff_of_comm`).

## Main Results
* `valueMonoid f` is the smallest submonoid of `B╦μ` containing the range of `f`;
* `valueMonoidέΓΑ f` is the smallest submonoid with `0` containing the range of `f`;
* `valueGroup f` is the smallest subgroup of `B╦μ` containing the range of `f`;
* `valueMonoidέΓΑ f` is the smallest subgroup with `0` containing the range of `f`;
* When `B` is a group with zero, rather than merely a monoid with zero, the above definitions
all coincide: see `valueMonoid_eq_valueGroup` for an equality as submonoids and
`valueMonoid_eq_valueGroup'` for an equality as subsets.
* When `B` is a *commutative* group with zero, `MonoidWithZeroHom.valueGroup` can be
explicitly described as the elements that are ratios of terms in `range f`, see
`MonoidWithZeroHom.mem_valueGroup_iff_of_comm`.

## Implementation details
`MonoidWithZeroHom.valueMonoid` is defined explicitly in terms of its carrier, by proving the
required properties; that it coincides with the submonoid generated by the closure is proven in
`MonoidWithZeroHom.valueMonoid_eq_closure`, but using the latter as definition yields to unwanted
unfolding.
-/

namespace MonoidWithZeroHom

open Set Subgroup Submonoid

variable {A B F : Type*} [FunLike F A B] (f : F)

section MonoidWithZero

variable [MonoidWithZero A] [MonoidWithZero B] [MonoidWithZeroHomClass F A B]

/-- For a morphism of monoids with zero `f`, this is a smallest submonoid of the invertible
elements in the codomain containing the range of `f`. -/
def valueMonoid : Submonoid B╦μ where
  carrier := (έΗΣ)έΒ╗┬╣' (range f)
  mul_mem' hb hb' := by
    obtain έθρy, hyέθσ := hb
    obtain έθρy', hy'έθσ := hb'
    use y * y'
    rw [map_mul, hy, hy', @Units.val_mul]
  one_mem' := έθρ1, by simpέθσ

lemma one_mem_valueMonoid : 1 έΙΙ valueMonoid f := έθρ1, map_one ..έθσ

lemma coe_one : (έθρ(1 : B╦μ), (one_mem_valueMonoid f)έθσ : valueMonoid f) = 1 := rfl

lemma mem_valueMonoid_iff {b : B╦μ} : b έΙΙ valueMonoid f έΗΦ b έΙΙ (έΗΣ)έΒ╗┬╣' (range f) := Iff.rfl

lemma valueMonoid_eq_closure : valueMonoid f = Submonoid.closure ((έΗΣ)έΒ╗┬╣' (range f)) :=
  (valueMonoid f).closure_eq.symm

/-- For a morphism of monoids with zero `f`, this is the smallest subgroup of the invertible
elements in the codomain containing the range of `f`. -/
def valueGroup : Subgroup B╦μ := closure (valueMonoid f)

lemma valueGroup_def : valueGroup f = Subgroup.closure (valueMonoid f) := rfl

/-- For a morphism of monoids with zero `f`, this is the smallest submonoid with zero of the
codomain containing the range of `f`. -/
abbrev valueMonoidέΓΑ := WithZero (valueMonoid f)

/-- For a morphism of monoids with zero `f`, this is a smallest subgroup with zero of the
codomain containing the range of `f`. -/
abbrev valueGroupέΓΑ := WithZero (valueGroup f)

lemma mem_valueMonoid {b : B╦μ} (hb : b.val έΙΙ range f) : b έΙΙ valueMonoid f := by
  rcases hb with έθρc, _έθσ
  simp only [mem_valueMonoid_iff, mem_preimage, mem_range]
  use c

lemma mem_valueGroup {b : B╦μ} (hb : b.1 έΙΙ range f) : b έΙΙ valueGroup f := by
  suffices b έΙΙ valueMonoid f from Subgroup.mem_closure.mpr fun _ a έΗο a this
  exact mem_valueMonoid _ hb

lemma inv_mem_valueGroup {b : B╦μ} (hb : b.1 έΙΙ range f) : bέΒ╗┬╣ έΙΙ valueGroup f :=
  Subgroup.inv_mem _ (mem_valueGroup f hb)

end MonoidWithZero

noncomputable section GroupWithZero

variable [GroupWithZero A] [GroupWithZero B] [MonoidWithZeroHomClass F A B] {f}

/- When the *domain* is itself a group with zero, the `valueMonoid` and the `valueGroup` coincide.-/
lemma valueMonoid_eq_valueGroup : (valueMonoid f) = (valueGroup f).toSubmonoid := by
  rw [valueGroup_def, Subgroup.closure_toSubmonoid, Eq.comm]
  apply Submonoid.closure_eq_of_le
  ┬╖ simp only [union_subset_iff, subset_refl, true_and]
    intro _ έθρy, hyέθσ
    use yέΒ╗┬╣
    simp [hy]
  ┬╖ simp [Submonoid.closure_union]

variable (f) in
lemma valueMonoid_eq_valueGroup' : (valueMonoid f : Set B╦μ) = valueGroup f := by
  rw [valueMonoid_eq_valueGroup, coe_toSubmonoid]

lemma valueGroup_eq_range : Units.val '' (valueGroup f) = (range f \ {0}) := by
  ext x
  refine έθρfun h έΗο ?_, fun h έΗο ?_έθσ
  ┬╖ obtain έθρy, έθρhy, rflέθσέθσ := h
    simp only [mem_diff, mem_range, mem_singleton_iff, Units.ne_zero, not_false_eq_true, and_true]
    obtain έθρa, _έθσ := (valueMonoid_eq_valueGroup' f).symm έΨ╕ hy
    use a
  ┬╖ simp only [mem_diff, mem_range, mem_singleton_iff] at h
    obtain έθρέθρy, hyέθσ, hxέΓΑέθσ := h
    refine έθρUnits.mk0 x hxέΓΑ, ?_, rflέθσ
    simpa [έΗΡ valueMonoid_eq_valueGroup', Units.val_mk0, mem_range] using έθρy, hyέθσ


end GroupWithZero
section CommGroupWithZero
--
variable [MonoidWithZero A] [CommGroupWithZero B] [MonoidWithZeroHomClass F A B]

theorem mem_valueGroup_iff_of_comm {y : B╦μ} :
    y έΙΙ (valueGroup f) έΗΦ έΙΔ a, f a έΚι 0 έΙπ έΙΔ x, f a * y = f x := by
  refine έθρfun hy έΗο ?_, fun έθρa, ha, έθρx, hyέθσέθσ έΗο ?_έθσ
  ┬╖ simp only [valueGroup, valueMonoid, Submonoid.coe_set_mk, Subsemigroup.coe_set_mk] at hy
    induction hy using Subgroup.closure_induction with
    | mem _ h =>
      obtain έθρa, haέθσ := h
      exact έθρa, ha.symm έΨ╕ Units.ne_zero _, έθρa * a, by simp [έΗΡ ha]έθσέθσ
    | one => exact έθρ1, by simp, 1, by simpέθσ
    | mul c d hc hd hcy hdy =>
      obtain έθρu, hu, a, haέθσ := hcy
      obtain έθρv, hv, b, hbέθσ := hdy
      refine έθρu * v, by simp [hu, hv], a * b, ?_έθσ
      simpa [map_mul, Units.val_mul, έΗΡ hb, έΗΡ ha] using mul_mul_mul_comm ..
    | inv c hc hcy  =>
      obtain έθρu, hu, a, haέθσ := hcy
      exact έθρa, by simp [έΗΡ ha, hu], u, by simp [έΗΡ ha]έθσ
  ┬╖ have hv : f x έΚι 0 := by
      simp only [έΗΡ hy, ne_eq, mul_eq_zero, ha, Units.ne_zero, or_self, not_false_eq_true]
    let v := (Ne.isUnit hv).unit
    have hvέΓΑ : f x = έΗΣv := IsUnit.unit_spec (Ne.isUnit hv)
    let u := (Ne.isUnit ha).unit
    have haέΓΑ : f a = έΗΣu := IsUnit.unit_spec (Ne.isUnit ha)
    rw_mod_cast [hvέΓΑ, haέΓΑ, Eq.comm, έΗΡ inv_mul_eq_iff_eq_mul] at hy
    rw [έΗΡ hy]
    apply Subgroup.mul_mem
    ┬╖ apply inv_mem_valueGroup
      use a
    ┬╖ apply mem_valueGroup
      use x

theorem mem_valueGroup_iff_of_comm' {y : B╦μ} :
    y έΙΙ (valueGroup f) έΗΦ έΙΔ a, f a έΚι 0 έΙπ έΙΔ x, y = f x / f a := by
  rw [mem_valueGroup_iff_of_comm]
  refine exists_congr fun r έΗο and_congr_right fun hr έΗο exists_congr fun y έΗο ?_
  rw [eq_div_iff hr, mul_comm]

instance : CommGroupWithZero (valueGroupέΓΑ f) where
  mul_comm _ _ := mul_comm ..


end CommGroupWithZero

