/- /-- The map sending a pair of nonzero `r s : A` to the element -/
def mk (r s : A) (hr : f r έΚι 0) (hs : f s έΚι 0) : ValueGroupέΓΑ f :=
    (έθρ.mk0 _ hr * (.mk0 _ hs)έΒ╗┬╣, mul_mem (mem_valueGroup _ (by simp))
    (inv_mem (mem_valueGroup _ (by simp)))έθσ : valueGroup f) -/

/-- The map sending a pair of nonzero `r s : A` to the element `(v r)έΒ╗┬╣ * (v s)`
of `ValueGroupέΓΑ v`. -/
def mk (r s : A) (hr : f r έΚι 0) (hs : f s έΚι 0) : ValueGroupέΓΑ f :=
    (έθρ(.mk0 _ hr)έΒ╗┬╣ * (.mk0 _ hs), mul_mem (inv_mem (mem_valueGroup _ (by simp)))
    (mem_valueGroup _ (by simp))έθσ : valueGroup f)

theorem zero_or_exists_mk (x : ValueGroupέΓΑ f) :
    x = 0 έΙρ έΙΔ r s hr hs, x = .mk f r s hr hs := by
  obtain _ | έθρx, hxέθσ := x
  ┬╖ left; rfl
  ┬╖ rw [mem_valueGroup_iff_of_comm'] at hx
    obtain έθρr, hr, s, hs, hrsέθσ := hx
    exact .inr έθρr, s, hr, hs, Option.some_inj.mpr <| by
      simp only [Subtype.mk.injEq]
      rw [eq_inv_mul_iff_mul_eq]
      simp [έΗΡ hrs, mul_comm]έθσ

theorem zero_or_exists_mk' (x : ValueGroupέΓΑ f) :
    x = 0 έΙρ έΙΔ d : {xy : A ├Ω A // f xy.1 έΚι 0 έΙπ f xy.2 έΚι 0}, x = .mk f d.1.1 d.1.2 d.2.1 d.2.2 :=
  x.zero_or_exists_mk.imp _root_.id fun έθρr, s, hr, hs, hxέθσ έΗο έθρέθρ(r, s), έθρhr, hsέθσέθσ, hxέθσ

