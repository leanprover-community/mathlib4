@[simp] theorem mk_ne_zero {hr : f r έΚι 0} {hs : f s έΚι 0} : mk f r s hr hs έΚι 0 := by simp [mk]

@[simp] theorem mk_inj {hrέΓΒ : f rέΓΒ έΚι 0} {hsέΓΒ : f sέΓΒ έΚι 0} {hrέΓΓ : f rέΓΓ έΚι 0} {hsέΓΓ : f sέΓΓ έΚι 0} :
    mk f rέΓΒ sέΓΒ hrέΓΒ hsέΓΒ = mk f rέΓΓ sέΓΓ hrέΓΓ hsέΓΓ έΗΦ f (rέΓΒ * sέΓΓ) = f (rέΓΓ * sέΓΒ) := by
