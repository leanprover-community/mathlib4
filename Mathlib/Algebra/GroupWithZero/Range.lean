    mk f rέΓΒ sέΓΒ hrέΓΒ hsέΓΒ * mk f rέΓΓ sέΓΓ hrέΓΓ hsέΓΓ =
      mk f (rέΓΒ * rέΓΓ) (sέΓΒ * sέΓΓ) (by simp_all) (by simp_all) := by
  refine Option.some_inj.mpr <| ?_
