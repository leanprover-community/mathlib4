variable {A B F : Type*} [FunLike F A B] (f : F)

section MonoidWithZeroHom

variable [MonoidWithZero A] [MonoidWithZero B] [MonoidWithZeroHomClass F A B]

/-- For a morphism of monoids with zero `f`, this is a smallest submonoid of the invertible
elements in the codomain containing the range of `f`. -/
def valueMonoid : Submonoid B╦μ where
  carrier := (έΗΣ) έΒ╗┬╣' (range f)
  mul_mem' hb hb' := by
    obtain έθρy, hyέθσ := hb
    obtain έθρy', hy'έθσ := hb'
    use y * y'
    rw [map_mul, hy, hy', Units.val_mul]
  one_mem' := έθρ1, by simpέθσ

lemma one_mem_valueMonoid : 1 έΙΙ valueMonoid f := έθρ1, map_one ..έθσ

lemma coe_one : (έθρ(1 : B╦μ), one_mem_valueMonoid fέθσ : valueMonoid f) = 1 := rfl

lemma mem_valueMonoid_iff {b : B╦μ} : b έΙΙ valueMonoid f έΗΦ b έΙΙ (έΗΣ) έΒ╗┬╣' (range f) := Iff.rfl

lemma valueMonoid_eq_closure : valueMonoid f = Submonoid.closure ((έΗΣ) έΒ╗┬╣' (range f)) :=
  (valueMonoid f).closure_eq.symm

/-- For a morphism of monoids with zero `f`, this is the smallest subgroup of the invertible
elements in the codomain containing the range of `f`. -/
def valueGroup : Subgroup B╦μ := closure (valueMonoid f)

lemma valueGroup_def : valueGroup f = Subgroup.closure (valueMonoid f) := rfl

/-- For a morphism of monoids with zero `f`, this is the smallest submonoid with zero of the
codomain containing the range of `f`. -/
abbrev ValueMonoidέΓΑ := WithZero (valueMonoid f)

@[deprecated (since := "2025-09-03")] alias valueMonoidέΓΑ := ValueMonoidέΓΑ

/-- For a morphism of monoids with zero `f`, this is a smallest subgroup with zero of the
codomain containing the range of `f`. -/
abbrev ValueGroupέΓΑ := WithZero (valueGroup f)

@[deprecated (since := "2025-09-03")] alias valueGroupέΓΑ := ValueGroupέΓΑ

lemma mem_valueMonoid {b : B╦μ} (hb : b.val έΙΙ range f) : b έΙΙ valueMonoid f := by
  tauto

lemma mem_valueGroup {b : B╦μ} (hb : b.1 έΙΙ range f) : b έΙΙ valueGroup f := by
  suffices b έΙΙ valueMonoid f from Subgroup.mem_closure.mpr fun _ a έΗο a this
  exact mem_valueMonoid _ hb

lemma inv_mem_valueGroup {b : B╦μ} (hb : b.1 έΙΙ range f) : bέΒ╗┬╣ έΙΙ valueGroup f :=
  Subgroup.inv_mem _ (mem_valueGroup f hb)

end MonoidWithZeroHom

noncomputable section Restrict

variable [MonoidWithZero A] [GroupWithZero B] [MonoidWithZeroHomClass F A B] {f}

/-- The inclusion of the subgroup with zero generated by the range of a monoid with zero
hom `f : A \to B` into the codomain `B`. -/
@[simps! -isSimp]
def ValueGroupέΓΑ.embedding : ValueGroupέΓΑ f έΗΤ*έΓΑ B :=
  letI : DecidablePred fun b : B έΗο b = 0 := Classical.decPred fun b έΗο b = 0
  MonoidWithZeroHom.comp (WithZero.withZeroUnitsEquiv (G := B))
    <| WithZero.map' (valueGroup f).subtype

variable (f) in
/-- This is the restriction of `f` as a function taking values in `valueGroupέΓΑ f`. -/
@[simps! -isSimp]
def ValueGroupέΓΑ.restrictέΓΑ : A έΗΤ*έΓΑ ValueGroupέΓΑ f where
  toFun a :=
    letI : DecidablePred fun b : B έΗο b = 0 := Classical.decPred fun b έΗο b = 0
    if h : f a = 0 then 0 else (έθρUnits.mk0 (f a) h, mem_valueGroup _ έθρa, rflέθσέθσ : valueGroup f)
  map_one'  := by simp [έΗΡ WithZero.coe_one]
  map_mul'  := by aesop
  map_zero' := by simp

namespace ValueGroupέΓΑ

lemma restrictέΓΑ_of_ne_zero {a : A} (h : f a έΚι 0) :
    restrictέΓΑ f a = (έθρUnits.mk0 (f a) h, mem_valueGroup _ έθρa, rflέθσέθσ : valueGroup f) := by
  simp [h, restrictέΓΑ_apply]

lemma restrictέΓΑ_eq_zero_iff {a : A} : restrictέΓΑ f a = 0 έΗΦ f a = 0 := by simp [restrictέΓΑ_apply]

lemma restrictέΓΑ_eq_one_iff {a : A} : restrictέΓΑ f a = 1 έΗΦ f a = 1 := by
  simp only [restrictέΓΑ_apply]
  split_ifs with H <;>
  simp [H, έΗΡ WithZero.coe_one, έΗΡ Units.mk0_one]

@[simp]
lemma embedding_restrictέΓΑ (a : A) : ValueGroupέΓΑ.embedding (restrictέΓΑ f a) = f a := by
  simp only [restrictέΓΑ_apply, embedding_apply]
  aesop

end ValueGroupέΓΑ

end Restrict

noncomputable section GroupWithZero

variable [GroupWithZero A] [GroupWithZero B] [MonoidWithZeroHomClass F A B] {f}

/- When the *domain* is itself a group with zero, the `valueMonoid` and the `valueGroup` coincide.-/
lemma valueMonoid_eq_valueGroup : (valueMonoid f) = (valueGroup f).toSubmonoid := by
  rw [valueGroup_def, Subgroup.closure_toSubmonoid, Eq.comm]
  apply Submonoid.closure_eq_of_le
  ┬╖ simp only [union_subset_iff, subset_refl, true_and]
    intro _ έθρy, hyέθσ
    use yέΒ╗┬╣
    simp [hy]
  ┬╖ simp [Submonoid.closure_union]

variable (f)

lemma valueMonoid_eq_valueGroup' : (valueMonoid f : Set B╦μ) = valueGroup f := by
  rw [valueMonoid_eq_valueGroup, coe_toSubmonoid]

lemma valueGroup_eq_range : Units.val '' (valueGroup f) = (range f \ {0}) := by
  ext x
  simp only [mem_diff, mem_range, mem_singleton_iff, έΗΡ valueMonoid_eq_valueGroup' f, mem_image,
    SetLike.mem_coe, mem_valueMonoid_iff, mem_preimage, mem_range]
  constructor
  ┬╖ rintro έθρy, hy, rflέθσ
    simp only [Units.ne_zero, not_false_eq_true, and_true, hy]
  ┬╖ rintro έθρέθρy, hyέθσ, hxέΓΑέθσ
    refine έθρUnits.mk0 x hxέΓΑ, ?_, rflέθσ
    simpa [Units.val_mk0, mem_range] using έθρy, hyέθσ

lemma ValueGroupέΓΑ.restrictέΓΑ_range_eq_top : range (ValueGroupέΓΑ.restrictέΓΑ f) = έΛν := by
  rw [top_eq_univ, range_eq_univ]
  intro x
  match x with
  | 0 => use 0; simp
  | some έθρu, huέθσ =>
    change u έΙΙ (valueGroup f : Set B╦μ) at hu
    rw [έΗΡ valueMonoid_eq_valueGroup'] at hu
    obtain έθρv, hvέθσ := hu
    use v
    simp [restrictέΓΑ_apply, hv, Units.ne_zero, WithZero.coe]

open Function

lemma ValueGroupέΓΑ.restrictέΓΑ_surjective : Surjective (ValueGroupέΓΑ.restrictέΓΑ f) :=
  fun _ έΗο mem_range.mp (by simp [ValueGroupέΓΑ.restrictέΓΑ_range_eq_top])

open Function

