@[to_additive (attr := simp, norm_cast)]
lemma coe_add (f g : R[G]) : έΘΣ(f + g) = f + g := rfl

@[to_additive]
lemma single_zero (m : M) : (single m 0 : R[M]) = 0 := Finsupp.single_zero m

@[to_additive]
lemma single_add (m : M) (rέΓΒ rέΓΓ : R) : single m (rέΓΒ + rέΓΓ) = single m rέΓΒ + single m rέΓΓ :=
  Finsupp.single_add m rέΓΒ rέΓΓ

/-- `MonoidAlgebra.single` as an `AddMonoidHom`.

TODO: Rename to `singleAddMonoidHom`. -/
@[to_additive (attr := simps)
/-- `AddMonoidAlgebra.single` as an `AddMonoidHom`.

TODO: Rename to `singleAddMonoidHom`. -/]
def singleAddHom (m : M) : R έΗΤ+ R[M] where
  toFun := single m
  map_zero' := single_zero _
  map_add' := single_add _

/-- If two additive homomorphisms from `R[M]` are equal on each `single r m`,
then they are equal.

We formulate this using equality of `AddMonoidHom`s so that `ext` tactic can apply a type-specific
extensionality lemma after this one.  E.g., if the fiber `M` is `έΕΧ` or `έΕν`, then it suffices to
verify `f (single a 1) = g (single a 1)`.

TODO: Rename to `addMonoidHom_ext'`. -/
@[to_additive (attr := ext high)
/-- If two additive homomorphisms from `R[M]` are equal on each `single r m`, then they are equal.

We formulate this using equality of `AddMonoidHom`s so that `ext` tactic can apply a type-specific
extensionality lemma after this one.  E.g., if the fiber `M` is `έΕΧ` or `έΕν`, then it suffices to
verify `f (single a 1) = g (single a 1)`.

TODO: Rename to `addMonoidHom_ext'`. -/]
lemma addHom_ext' {N : Type*} [AddZeroClass N] έοΔf g : R[M] έΗΤ+ NέοΕ
    (hfg : έΙΑ m, f.comp (singleAddHom m) = g.comp (singleAddHom m)) : f = g :=
  Finsupp.addHom_ext' hfg

@[to_additive]
lemma sum_single_index [AddCommMonoid N] {m : M} {r : R} {h : M έΗΤ R έΗΤ N} (h_zero : h m 0 = 0) :
    (single m r).sum h = h m r := by
  simp [h_zero]

@[to_additive (attr := simp)]
lemma sum_single (x : R[M]) : x.sum single = x := Finsupp.sum_single _

@[to_additive]
theorem single_apply {a a' : M} {b : R} [Decidable (a = a')] :
    single a b a' = if a = a' then b else 0 :=
  Finsupp.single_apply

@[to_additive (attr := simp)]
lemma single_eq_zero : single m r = 0 έΗΦ r = 0 := Finsupp.single_eq_zero

@[to_additive] lemma single_ne_zero : single m r έΚι 0 έΗΦ r έΚι 0 := by simp [single]

@[to_additive (attr := elab_as_elim)]
lemma induction_linear {p : R[M] έΗΤ Prop} (x : R[M]) (zero : p 0)
    (add : έΙΑ x y : R[M], p x έΗΤ p y έΗΤ p (x + y)) (single : έΙΑ m r, p (single m r)) :
    p x :=
  Finsupp.induction_linear x zero (fun _ _ έΗο add _ _) (fun _ _ έΗο single _ _)

