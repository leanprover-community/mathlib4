section Semiring
variable [Semiring R] {x y : R[M]} {r rέΓΒ rέΓΓ : R} {m m' mέΓΒ mέΓΓ : M}

/-- Construct an element of the monoid algebra `R[M]` from its coefficients `M έΗΤέΓΑ R`. -/
@[to_additive
/-- Construct an element of the additive monoid algebra `R[M]` from its coefficients `M έΗΤέΓΑ R`. -/]
def ofCoeff (x : M έΗΤέΓΑ R) : R[M] := x

/-- The coefficients `M έΗΤέΓΑ R` of an element of the monoid algebra `R[M]`. -/
@[to_additive
/-- The coefficients `M έΗΤέΓΑ R` of an element of the additive monoid algebra `R[M]`. -/]
def coeff (x : R[M]) : M έΗΤέΓΑ R := x

@[to_additive (attr := simp)] lemma coeff_ofCoeff (x : M έΗΤέΓΑ R) : coeff (ofCoeff x) = x := rfl
@[to_additive (attr := simp)] lemma ofCoeff_coeff (x : R[M]) : ofCoeff x.coeff = x := rfl

/-- `MonoidAlgebra.coeff` as an equiv. -/
@[to_additive (attr := simps apply symm_apply)
/-- `AddMonoidAlgebra.coeff` as an equiv. -/]
def coeffEquiv : R[M] έΚΔ (M έΗΤέΓΑ R) where
  toFun := coeff
  invFun := ofCoeff
  left_inv _ := rfl
  right_inv _ := rfl

@[to_additive] lemma ┬τforall┬╗ {P : R[M] έΗΤ Prop} : (έΙΑ p, P p) έΗΦ έΙΑ q, P (ofCoeff q) :=
  coeffEquiv.forall_congr_left

@[to_additive] lemma ┬τexists┬╗ {P : R[M] έΗΤ Prop} : (έΙΔ p, P p) έΗΦ έΙΔ q, P (ofCoeff q) :=
  coeffEquiv.exists_congr_left

@[to_additive]
lemma coeff_injective : (coeff : R[M] έΗΤ M έΗΤέΓΑ R).Injective := coeffEquiv.injective

@[to_additive]
lemma ofCoeff_injective : (ofCoeff : (M έΗΤέΓΑ R) έΗΤ R[M]).Injective := coeffEquiv.symm.injective

@[to_additive (attr := simp)]
lemma coeff_inj : x.coeff = y.coeff έΗΦ x = y := coeff_injective.eq_iff

@[to_additive]
lemma ofCoeff_inj {x y : M έΗΤέΓΑ R} : ofCoeff x = ofCoeff y έΗΦ x = y := ofCoeff_injective.eq_iff

@[to_additive] instance inhabited : Inhabited R[M] :=
  inferInstanceAs <| Inhabited <| M έΗΤέΓΑ R

@[to_additive] instance nontrivial [Nontrivial R] [Nonempty M] : Nontrivial R[M] :=
  inferInstanceAs <| Nontrivial <| M έΗΤέΓΑ R

@[to_additive] instance unique [Subsingleton R] : Unique R[M] :=
  inferInstanceAs <| Unique <| M έΗΤέΓΑ R

@[to_additive] instance instDecidableEq [DecidableEq R] [DecidableEq M] : DecidableEq R[M] :=
  inferInstanceAs <| DecidableEq <| M έΗΤέΓΑ R

@[to_additive] instance : Zero R[M] :=
  inferInstanceAs <| Zero <| M έΗΤέΓΑ R

@[to_additive (dont_translate := A) smulZeroClass]
instance smulZeroClass {A : Type*} [SMulZeroClass A R] : SMulZeroClass A R[M] :=
  inferInstanceAs <| SMulZeroClass A (M έΗΤέΓΑ R)

@[to_additive] instance addCommMonoid : AddCommMonoid R[M] :=
  fast_instance% { (inferInstance : AddCommMonoid <| M έΗΤέΓΑ R) with nsmul := SMul.smul }

-- Ensure that the different smul instances do not create a diamond.
example : (smulZeroClass (A := έΕΧ) (R := R) (M := M)).toSMul = addCommMonoid.toNSMul := by
  with_reducible_and_instances rfl

@[to_additive] instance instIsCancelAdd [IsCancelAdd R] : IsCancelAdd R[M] :=
  inferInstanceAs <| IsCancelAdd <| M έΗΤέΓΑ R

-- TODO: Replace this with `coeff`. See https://github.com/leanprover-community/mathlib4/pull/36746
#adaptation_note /-- Since v4.29.0-rc7,
this is needed or we get errors in UniversalFactorizationRing.lean -/
set_option backward.inferInstanceAs.wrap false in
@[to_additive] instance instCoeFun : CoeFun R[M] fun _ έΗο M έΗΤ R :=
  inferInstanceAs <| CoeFun (M έΗΤέΓΑ R) fun _ έΗο M έΗΤ R

/-- A copy of `Finsupp.ext` for `MonoidAlgebra`. -/
@[to_additive (attr := ext) /-- A copy of `Finsupp.ext` for `AddMonoidAlgebra`. -/]
lemma ext έοΔf g : R[M]έοΕ (hfg : έΙΑ m, f m = g m) : f = g := Finsupp.ext hfg

/-- `MonoidAlgebra.coeff` as an `AddEquiv`. -/
@[to_additive (attr := simps! apply symm_apply)
/-- `AddMonoidAlgebra.coeff` as an `AddEquiv`. -/]
def coeffAddEquiv : R[M] έΚΔ+ (M έΗΤέΓΑ R) := coeffEquiv.addEquiv

@[to_additive (attr := simp)] lemma coeff_zero : coeff (0 : R[M]) = 0 := rfl
@[to_additive (attr := simp)] lemma ofCoeff_zero : (ofCoeff 0 : R[M]) = 0 := rfl
@[to_additive (attr := simp)] lemma coeff_eq_zero : coeff x = 0 έΗΦ x = 0 := coeff_inj
@[to_additive (attr := simp)] lemma ofCoeff_eq_zero {x : M έΗΤέΓΑ R} : ofCoeff x = 0 έΗΦ x = 0 :=
  ofCoeff_inj

@[to_additive (attr := simp)]
lemma coeff_add (x y : R[M]) : coeff (x + y) = coeff x + coeff y := rfl

@[to_additive (attr := simp)]
lemma ofCoeff_add (x y : M έΗΤέΓΑ R) : ofCoeff (x + y) = ofCoeff x + ofCoeff y := rfl

@[to_additive (attr := simp)]
lemma coeff_sum (s : Finset ╬╣) (f : ╬╣ έΗΤ R[M]) :
    coeff (έΙΣ i έΙΙ s, f i) = έΙΣ i έΙΙ s, coeff (f i) := map_sum coeffAddEquiv ..

@[to_additive (attr := simp)]
lemma ofCoeff_sum (s : Finset ╬╣) (f : ╬╣ έΗΤ M έΗΤέΓΑ R) :
    ofCoeff (έΙΣ i έΙΙ s, f i) = έΙΣ i έΙΙ s, ofCoeff (f i) := map_sum coeffAddEquiv.symm ..

@[to_additive (attr := simp)]
lemma coeff_finsuppSum [AddCommMonoid N] (f : ╬╣ έΗΤέΓΑ N) (g : ╬╣ έΗΤ N έΗΤ R[M]) :
    coeff (f.sum g) = f.sum (fun i n έΗο coeff (g i n)) := map_finsuppSum coeffAddEquiv ..

@[to_additive (attr := simp)]
lemma ofCoeff_finsuppSum [AddCommMonoid N] (f : ╬╣ έΗΤέΓΑ N) (g : ╬╣ έΗΤ N έΗΤ M έΗΤέΓΑ R) :
    ofCoeff (f.sum g) = f.sum (fun i n έΗο ofCoeff (g i n)) := map_finsuppSum coeffAddEquiv.symm ..

-- TODO: This definition is very leaky, and we later have frequent problems conflating the two
-- versions of `single`. Perhaps someone wants to try making this a `def` rather than an `abbrev`?
-- In Mathlib 3 this was locally reducible.
/-- `MonoidAlgebra.single m r` for `m : M`, `r : R` is the element `rm : R[M]`. -/
@[to_additive
/-- `AddMonoidAlgebra.single m r` for `m : M`, `r : R` is the element `rm : R[M]`. -/]
abbrev single (m : M) (r : R) : R[M] := Finsupp.single m r

/-- Remove a term from an element of the monoid algebra. -/
@[to_additive /-- Remove a term from an element of the additive monoid algebra. -/]
def erase (m : M) (x : R[M]) : R[M] := .ofCoeff <| .erase m x.coeff

@[to_additive (attr := simp)]
lemma coeff_erase (m : M) (x : R[M]) : (x.erase m).coeff = x.coeff.erase m := rfl

@[to_additive (attr := simp)]
lemma ofCoeff_erase (m : M) (x : M έΗΤέΓΑ R) : ofCoeff (x.erase m) = (ofCoeff x).erase m := rfl

@[to_additive (attr := simp)]
lemma erase_zero (m : M) : erase m (0 : R[M]) = 0 := by simp [erase]

@[to_additive (attr := simp)]
lemma erase_single (m : M) (r : R) : erase m (single m r) = 0 := by
  simp [erase, ofCoeff, coeff]; rfl

/-- Replace the `m`-th coefficient of an element `x` of the monoid algebra by a given value `r : R`.
If `r = 0`, this is equal to `x.erase m`. -/
@[to_additive
/-- Replace the `m`-th coefficient of an element `x` of the monoid algebra by a given value `r : R`.
If `r = 0`, this is equal to `x.erase m`. -/]
def update (m : M) (r : R) (x : R[M]) : R[M] :=
  ofCoeff (x.coeff.update m r)

@[to_additive (attr := simp)]
lemma coeff_update (m : M) (r : R) (x : R[M]) :
    (x.update m r).coeff = x.coeff.update m r := rfl

@[to_additive (attr := simp)]
lemma ofCoeff_update (m : M) (r : R) (x : M έΗΤέΓΑ R) :
    ofCoeff (x.update m r) = (ofCoeff x).update m r := rfl

section SMul

/-! ### Basic scalar multiplication instances

This section collects instances needed for the algebraic structure of `Polynomial`,
which is defined in terms of `MonoidAlgebra`.
Further results on scalar multiplication can be found in
`Mathlib/Algebra/MonoidAlgebra/Module.lean`.
-/

variable {A : Type*} [SMulZeroClass A R]

@[to_additive (dont_translate := A) (attr := simp) coeff_smul]
lemma coeff_smul (a : A) (x : R[M]) : coeff (a έΑλ x) = a έΑλ coeff x := rfl

@[to_additive (dont_translate := A) (attr := simp) ofCoeff_smul]
lemma ofCoeff_smul (a : A) (x : M έΗΤέΓΑ R) : ofCoeff (a έΑλ x) = a έΑλ ofCoeff x := rfl

@[to_additive (attr := simp) (dont_translate := A) smul_apply]
lemma smul_apply (a : A) (x : R[M]) (m : M) : (a έΑλ x) m = a έΑλ x m := rfl

@[to_additive (attr := simp) (dont_translate := A) smul_single]
lemma smul_single (a : A) (m : M) (r : R) : a έΑλ single m r = single m (a έΑλ r) := by
  ext
  simp [single, έΗΡ Finsupp.smul_single]

@[to_additive (dont_translate := R) smul_single']
lemma smul_single' (r' : R) (m : M) (r : R) : r' έΑλ single m r = single m (r' * r) := smul_single ..

@[to_additive (dont_translate := N) distribSMul]
instance distribSMul [DistribSMul N R] : DistribSMul N R[M] :=
  inferInstanceAs <| DistribSMul N (M έΗΤέΓΑ R)

@[to_additive (dont_translate := N) isScalarTower]
instance isScalarTower [SMulZeroClass N R] [SMulZeroClass O R] [SMul N O] [IsScalarTower N O R] :
    IsScalarTower N O R[M] :=
  inferInstanceAs <| IsScalarTower N O (M έΗΤέΓΑ R)

@[to_additive (dont_translate := N) smulCommClass]
instance smulCommClass [SMulZeroClass N R] [SMulZeroClass O R] [SMulCommClass N O R] :
    SMulCommClass N O R[M] :=
  inferInstanceAs <| SMulCommClass N O (M έΗΤέΓΑ R)

@[to_additive (dont_translate := N) isCentralScalar]
instance isCentralScalar [SMulZeroClass N R] [SMulZeroClass Nά╡Ρά╡Τά╡Ψ R] [IsCentralScalar N R] :
    IsCentralScalar N R[M] :=
