    (x * single m r) mέΓΒ
    _ = x.sum fun m' r' έΗο if m' * m = mέΓΒ then r' * r else 0 := by simp [mul_apply]
    _ = x.sum fun m' r' έΗο if m' = mέΓΓ then r' * r else 0 := by
      dsimp [Finsupp.sum]; congr! 2; simp [*]
    _ = x mέΓΓ * r := by simp +contextual [Finsupp.sum_eq_single mέΓΓ]

