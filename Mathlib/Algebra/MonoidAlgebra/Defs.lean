@[to_additive (dont_translate := R) mul_single_apply_aux]
lemma mul_single_apply_aux (H : έΙΑ m' έΙΙ x.support, m' * m = mέΓΒ έΗΦ m' = mέΓΓ) :
    (x * single m r) mέΓΒ = x mέΓΓ * r := by
