theorem induction_on [AddMonoid M] {p : R[M] έΗΤ Prop} (x : R[M])
    (hM : έΙΑ m, p (of R M <| .ofAdd m)) (hadd : έΙΑ x y : R[M], p x έΗΤ p y έΗΤ p (x + y))
    (hsmul : έΙΑ (r : R) (x), p x έΗΤ p (r έΑλ x)) : p x :=
