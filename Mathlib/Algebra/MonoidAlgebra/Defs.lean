    (fun x y hf hg έΗο hadd x y hf hg) fun m r έΗο by simpa using hsmul r (of R M m) (hM m)

/-- If two ring homomorphisms from `R[M]` are equal on all `single m 1`
and `single 0 r`, then they are equal.

See note [partially-applied ext lemmas]. -/
@[ext high]
theorem ringHom_ext' [Semiring S] [AddMonoid M] {f g : R[M] έΗΤ+* S}
    (hέΓΒ : f.comp singleZeroRingHom = g.comp singleZeroRingHom)
    (h_of : (f : R[M] έΗΤ* S).comp (of R M) = (g : R[M] έΗΤ* S).comp (of R M)) :
    f = g :=
  ringHom_ext (RingHom.congr_fun hέΓΒ) (DFunLike.congr_fun h_of)

