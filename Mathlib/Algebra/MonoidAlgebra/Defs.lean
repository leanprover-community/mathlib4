lemma single_mul_single (mέΓΒ mέΓΓ : M) (rέΓΒ rέΓΓ : R) :
    single mέΓΒ rέΓΒ * single mέΓΓ rέΓΓ = single (mέΓΒ * mέΓΓ) (rέΓΒ * rέΓΓ) := by simp [mul_def]

