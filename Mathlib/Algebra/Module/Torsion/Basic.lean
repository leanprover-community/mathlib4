    [‚ąÄ n : ‚Ąē, Decidable (p ^ n ‚ÄĘ x = 0)] : p ^ pOrder hM x ‚ÄĘ x = 0 :=
  Nat.find_spec <| (isTorsion'_powers_iff p).mp hM x

