    exact ‚ü®n, Nat.pos_of_ne_zero (nonZeroDivisors.coe_ne_zero _), hn‚ü©

theorem isTorsion_iff_isTorsion_int [AddCommGroup M] :
    AddMonoid.IsTorsion M ‚ÜĒ Module.IsTorsion ‚Ą§ M := by
  refine ‚ü®fun h x => ?_, fun h x => ?_‚ü©
  ¬∑ obtain ‚ü®n, h0, hn‚ü© := (h x).exists_nsmul_eq_zero
    exact
      ‚ü®‚ü®n, mem_nonZeroDivisors_of_ne_zero <| ne_of_gt <| Int.natCast_pos.mpr h0‚ü©,
        (natCast_zsmul _ _).trans hn‚ü©
  ¬∑ rw [isOfFinAddOrder_iff_nsmul_eq_zero]
    obtain ‚ü®n, hn‚ü© := @h x
    exact ‚ü®_, Int.natAbs_pos.2 (nonZeroDivisors.coe_ne_zero n), natAbs_nsmul_eq_zero.2 hn‚ü©

end AddMonoid

namespace AddSubgroup

variable (A : Type*) [AddCommGroup A] (n : ‚Ą§)

/-- The additive `n`-torsion subgroup for an integer `n`, denoted as `A[n]`. -/
@[reducible]
def torsionBy : AddSubgroup A :=
  (Submodule.torsionBy ‚Ą§ A n).toAddSubgroup

@[inherit_doc torsionBy]
scoped syntax:max (name := torsionByStx) (priority := high) term noWs "[" term "]" : term

macro_rules | `($A[$n]) => `(torsionBy $A $n)

/-- Unexpander for `torsionBy`. -/
@[scoped app_unexpander torsionBy]
def torsionByUnexpander : Lean.PrettyPrinter.Unexpander
  | `($_ $A $n) => `($A[$n])
  | _ => throw ()

lemma torsionBy.neg : A[-n] = A[n] := by
  ext a
  simp

variable {A} {n : ‚Ąē}

@[simp]
lemma torsionBy.nsmul (x : A[n]) : n ‚ÄĘ x = 0 :=
  Nat.cast_smul_eq_nsmul ‚Ą§ n x ‚Ėł Submodule.smul_torsionBy ..

lemma torsionBy.nsmul_iff {x : A} :
    x ‚ąą A[n] ‚ÜĒ n ‚ÄĘ x = 0 :=
  Nat.cast_smul_eq_nsmul ‚Ą§ n x ‚Ėł Submodule.mem_torsionBy_iff ..

lemma torsionBy.mod_self_nsmul (s : ‚Ąē) (x : A[n]) :
    s ‚ÄĘ x = (s % n) ‚ÄĘ x :=
  nsmul_eq_mod_nsmul s (torsionBy.nsmul x)

lemma torsionBy.mod_self_nsmul' (s : ‚Ąē) {x : A} (h : x ‚ąą A[n]) :
    s ‚ÄĘ x = (s % n) ‚ÄĘ x :=
  nsmul_eq_mod_nsmul s (torsionBy.nsmul_iff.mp h)

/-- For a natural number `n`, the `n`-torsion subgroup of `A` is a `ZMod n` module. -/
def torsionBy.zmodModule : Module (ZMod n) A[n] :=
  AddCommGroup.zmodModule torsionBy.nsmul

end AddSubgroup

section InfiniteRange

@[simp]
lemma infinite_range_add_smul_iff
    [AddCommGroup M] [Ring R] [Module R M] [Infinite R] [NoZeroSMulDivisors R M] (x y : M) :
    (Set.range <| fun r : R ‚Ü¶ x + r ‚ÄĘ y).Infinite ‚ÜĒ y ‚Č† 0 := by
  refine ‚ü®fun h hy ‚Ü¶ by simp [hy] at h, fun h ‚Ü¶ Set.infinite_range_of_injective fun r s hrs ‚Ü¶ ?_‚ü©
  rw [add_right_inj] at hrs
  exact smul_left_injective _ h hrs

@[simp]
lemma infinite_range_add_nsmul_iff [AddCommGroup M] [NoZeroSMulDivisors ‚Ą§ M] (x y : M) :
    (Set.range <| fun n : ‚Ąē ‚Ü¶ x + n ‚ÄĘ y).Infinite ‚ÜĒ y ‚Č† 0 := by
  refine ‚ü®fun h hy ‚Ü¶ by simp [hy] at h, fun h ‚Ü¶ Set.infinite_range_of_injective fun r s hrs ‚Ü¶ ?_‚ü©
  rw [add_right_inj, ‚Üź natCast_zsmul, ‚Üź natCast_zsmul] at hrs
  simpa using smul_left_injective _ h hrs

end InfiniteRange
