theorem isTorsion'_powers_iff (p : R) :
    IsTorsion' M (Submonoid.powers p) ‚ÜĒ ‚ąÄ x : M, ‚ąÉ n : ‚Ąē, p ^ n ‚ÄĘ x = 0 := by
  constructor
