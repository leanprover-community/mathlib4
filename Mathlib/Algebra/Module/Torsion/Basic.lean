section Coprime

variable {őĻ : Type*} {p : őĻ ‚Üí Ideal R} {S : Finset őĻ}

theorem iSup_torsionBySet_ideal_eq_torsionBySet_iInf
    (hp : (S : Set őĻ).Pairwise fun i j => p i ‚äĒ p j = ‚ä§) :
    ‚®Ü i ‚ąą S, torsionBySet R M (p i) = torsionBySet R M ‚ÜĎ(‚®Ö i ‚ąą S, p i) := by
  rcases S.eq_empty_or_nonempty with h | h
  ¬∑ simp [h]
  apply le_antisymm
  ¬∑ apply iSup_le _
    intro i
    apply iSup_le _
    intro is
    apply torsionBySet_le_torsionBySet_of_subset
    exact (iInf_le (fun i => ‚®Ö _ : i ‚ąą S, p i) i).trans (iInf_le _ is)
  ¬∑ intro x hx
    rw [mem_iSup_finset_iff_exists_sum]
    obtain ‚ü®őľ, hőľ‚ü© :=
      (mem_iSup_finset_iff_exists_sum _ _).mp
        ((Ideal.eq_top_iff_one _).mp <| (Ideal.iSup_iInf_eq_top_iff_pairwise h _).mpr hp)
    refine ‚ü®fun i => ‚ü®(őľ i : R) ‚ÄĘ x, ?_‚ü©, ?_‚ü©
    ¬∑ rw [mem_torsionBySet_iff] at hx ‚äĘ
      rintro ‚ü®a, ha‚ü©
      rw [smul_smul]
      suffices a * őľ i ‚ąą ‚®Ö i ‚ąą S, p i from hx ‚ü®_, this‚ü©
      rw [mem_iInf]
      intro j
      rw [mem_iInf]
      intro hj
      by_cases ij : j = i
      ¬∑ rw [ij]
        exact Ideal.mul_mem_right _ _ ha
      ¬∑ have := coe_mem (őľ i)
        simp only [mem_iInf] at this
        exact Ideal.mul_mem_left _ _ (this j hj ij)
    ¬∑ rw [‚Üź Finset.sum_smul, hőľ, one_smul]

theorem supIndep_torsionBySet_ideal (hp : (S : Set őĻ).Pairwise fun i j => p i ‚äĒ p j = ‚ä§) :
    S.SupIndep fun i => torsionBySet R M <| p i :=
  fun T hT i hi hiT => by
  rw [disjoint_iff, Finset.sup_eq_iSup,
    iSup_torsionBySet_ideal_eq_torsionBySet_iInf fun i hi j hj ij => hp (hT hi) (hT hj) ij]
  have := GaloisConnection.u_inf
    (b‚āĀ := OrderDual.toDual (p i)) (b‚āā := OrderDual.toDual (‚®Ö i ‚ąą T, p i)) (torsion_gc R M)
  dsimp at this ‚äĘ
  rw [‚Üź this, Ideal.sup_iInf_eq_top, top_coe, torsionBySet_univ]
  intro j hj; apply hp hi (hT hj); rintro rfl; exact hiT hj

variable {q : őĻ ‚Üí R}

open scoped Function -- required for scoped `on` notation

theorem iSup_torsionBy_eq_torsionBy_prod (hq : (S : Set őĻ).Pairwise <| (IsCoprime on q)) :
    ‚®Ü i ‚ąą S, torsionBy R M (q i) = torsionBy R M (‚ąŹ i ‚ąą S, q i) := by
  rw [‚Üź torsionBySet_span_singleton_eq, Ideal.submodule_span_eq, ‚Üź
    Ideal.finset_inf_span_singleton _ _ hq, Finset.inf_eq_iInf, ‚Üź
    iSup_torsionBySet_ideal_eq_torsionBySet_iInf]
  ¬∑ congr
    ext : 1
    congr
    ext : 1
    exact (torsionBySet_span_singleton_eq _).symm
  exact fun i hi j hj ij => (Ideal.sup_eq_top_iff_isCoprime _ _).mpr (hq hi hj ij)

theorem supIndep_torsionBy (hq : (S : Set őĻ).Pairwise <| (IsCoprime on q)) :
    S.SupIndep fun i => torsionBy R M <| q i := by
  convert supIndep_torsionBySet_ideal (M := M) fun i hi j hj ij =>
      (Ideal.sup_eq_top_iff_isCoprime (q i) _).mpr <| hq hi hj ij
  exact (torsionBySet_span_singleton_eq (R := R) (M := M) _).symm

end Coprime

