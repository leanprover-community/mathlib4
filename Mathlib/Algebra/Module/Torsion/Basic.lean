variable [CommSemiring R] [AddCommMonoid M] [Module R M] [‚ąÄ x : M, Decidable (x = 0)]

theorem exists_isTorsionBy {p : R} (hM : IsTorsion' M <| Submonoid.powers p) (d : ‚Ąē) (hd : d ‚Č† 0)
    (s : Fin d ‚Üí M) (hs : span R (Set.range s) = ‚ä§) :
    ‚ąÉ j : Fin d, Module.IsTorsionBy R M (p ^ pOrder hM (s j)) := by
  let oj := List.argmax (fun i => pOrder hM <| s i) (List.finRange d)
  have hoj : oj.isSome :=
    Option.ne_none_iff_isSome.mp fun eq_none =>
      hd <| List.finRange_eq_nil.mp <| List.argmax_eq_none.mp eq_none
  use Option.get _ hoj
  rw [isTorsionBy_iff_torsionBy_eq_top, eq_top_iff, ‚Üź hs, Submodule.span_le,
    Set.range_subset_iff]
  intro i; change (p ^ pOrder hM (s (Option.get oj hoj))) ‚ÄĘ s i = 0
  have : pOrder hM (s i) ‚Č§ pOrder hM (s <| Option.get _ hoj) :=
    List.le_of_mem_argmax (List.mem_finRange i) (Option.get_mem hoj)
  rw [‚Üź Nat.sub_add_cancel this, pow_add, mul_smul, pow_pOrder_smul, smul_zero]

