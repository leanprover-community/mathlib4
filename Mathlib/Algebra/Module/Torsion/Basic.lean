namespace Submodule

variable [CommRing R] [AddCommGroup M] [Module R M]
variable {őĻ : Type*} [DecidableEq őĻ] {S : Finset őĻ}

/-- If the `p i` are pairwise coprime, a `‚®Ö i, p i`-torsion module is the internal direct sum of
its `p i`-torsion submodules. -/
theorem torsionBySet_isInternal {p : őĻ ‚Üí Ideal R}
    (hp : (S : Set őĻ).Pairwise fun i j => p i ‚äĒ p j = ‚ä§)
    (hM : Module.IsTorsionBySet R M (‚®Ö i ‚ąą S, p i : Ideal R)) :
