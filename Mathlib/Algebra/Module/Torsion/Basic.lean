namespace Module

variable [Semiring R] [AddCommMonoid M] [Module R M] (s : Set R) (a : R)

theorem isTorsionBySet_of_subset {s t : Set R} (h : s ‚äÜ t)
    (ht : IsTorsionBySet R M t) : IsTorsionBySet R M s :=
  fun m r ‚Ü¶ @ht m ‚ü®r, h r.2‚ü©

@[simp]
theorem isTorsionBySet_singleton_iff : IsTorsionBySet R M {a} ‚ÜĒ IsTorsionBy R M a := by
  refine ‚ü®fun h x => @h _ ‚ü®_, Set.mem_singleton _‚ü©, fun h x => ?_‚ü©
  rintro ‚ü®b, rfl : b = a‚ü©; exact @h _

theorem isTorsionBySet_iff_is_torsion_by_span :
    IsTorsionBySet R M s ‚ÜĒ IsTorsionBySet R M (Ideal.span s) := by
  simpa only [isTorsionBySet_iff_subset_annihilator] using Ideal.span_le.symm

theorem isTorsionBySet_span_singleton_iff : IsTorsionBySet R M (R ‚ąô a) ‚ÜĒ IsTorsionBy R M a :=
  (isTorsionBySet_iff_is_torsion_by_span _).symm.trans <| isTorsionBySet_singleton_iff _

end Module

