module

public import Mathlib.AlgebraicTopology.SimplicialSet.Basic
public import Mathlib.CategoryTheory.Subfunctor.OfSection

/-!
# Subcomplexes of a simplicial set

Given a simplicial set `X`, this file defines the type `X.Subcomplex`
of subcomplexes of `X` as an abbreviation for `Subfunctor X`.
It also introduces a coercion from `X.Subcomplex` to `SSet`.

-/

@[expose] public section

universe u

open CategoryTheory Simplicial Limits

namespace SSet

-- Note: this could be obtained as `inferInstanceAs (Balanced (_ ‚•§ _))`
-- by importing `Mathlib.CategoryTheory.Adhesive.Basic`, but we give a
-- different proof so as to reduce imports
instance : Balanced SSet.{u} where
  isIso_of_mono_of_epi f _ _ := by
    rw [NatTrans.isIso_iff_isIso_app]
    intro
    rw [isIso_iff_bijective]
    constructor
    ¬∑ rw [‚Üź mono_iff_injective]
      infer_instance
    ¬∑ rw [‚Üź epi_iff_surjective]
      infer_instance

variable (X Y : SSet.{u})

/-- The complete lattice of subcomplexes of a simplicial set. -/
abbrev Subcomplex := Subfunctor X

variable {X Y}

namespace Subcomplex

/-- The underlying simplicial set of a subcomplex. -/
abbrev toSSet (A : X.Subcomplex) : SSet.{u} := A.toFunctor

instance : CoeOut X.Subcomplex SSet.{u} where
  coe := fun S ‚Ü¶ S.toSSet

instance {X : SSet.{u}} (n : SimplexCategoryŠĶíŠĶĖ) (A : X.Subcomplex)
    [DecidableEq (X.obj n)] :
    DecidableEq ((A : SSet).obj n) :=
  inferInstanceAs (DecidableEq (A.obj n))

/-- If `A : Subcomplex X`, this is the inclusion `A ‚ü∂ X` in the category `SSet`. -/
abbrev őĻ (A : Subcomplex X) : Quiver.Hom (V := SSet) A X := Subfunctor.őĻ A

instance (A : X.Subcomplex) : Mono A.őĻ :=
  inferInstanceAs (Mono (Subfunctor.őĻ A))

section

variable {S‚āĀ S‚āā : X.Subcomplex} (h : S‚āĀ ‚Č§ S‚āā)

/-- Given an inequality `S‚āĀ ‚Č§ S‚āā` between subcomplexes of a simplicial set,
this is the induced morphism in the category `SSet`. -/
abbrev homOfLE : (S‚āĀ : SSet.{u}) ‚ü∂ (S‚āā : SSet.{u}) := Subfunctor.homOfLe h

@[reassoc]
lemma homOfLE_comp {S‚āÉ : X.Subcomplex} (h' : S‚āā ‚Č§ S‚āÉ) :
    homOfLE h ‚Čę homOfLE h' = homOfLE (h.trans h') := rfl

variable (S‚āĀ) in
@[simp]
lemma homOfLE_refl : homOfLE (by rfl : S‚āĀ ‚Č§ S‚āĀ) = ūĚüô _ := rfl

@[simp]
lemma homOfLE_app_val (őĒ : SimplexCategoryŠĶíŠĶĖ) (x : S‚āĀ.obj őĒ) :
    dsimp% ((homOfLE h).app őĒ x).val = x.val := rfl

@[simp, reassoc]
lemma homOfLE_őĻ : homOfLE h ‚Čę S‚āā.őĻ = S‚āĀ.őĻ := rfl

instance mono_homOfLE : Mono (homOfLE h) := mono_of_mono_fac (homOfLE_őĻ h)

/-- This is the isomorphism of simplicial sets corresponding to
an equality of subcomplexes. -/
@[simps]
protected def eqToIso (h : S‚āĀ = S‚āā) : (S‚āĀ : SSet.{u}) ‚ČÖ S‚āā where
  hom := homOfLE h.le
  inv := homOfLE h.symm.le

end

/-- The functor which sends `A : X.Subcomplex` to `A.toSSet`. -/
@[simps]
def toSSetFunctor : X.Subcomplex ‚•§ SSet.{u} where
  obj A := A
  map h := homOfLE (leOfHom h)

section

variable (X)

/-- If `X : SSet`, this is the isomorphism of simplicial sets
from `‚ä§ : X.Subcomplex` to `X`. -/
@[simps! inv_app_hom_apply]
def topIso : ((‚ä§ : X.Subcomplex) : SSet) ‚ČÖ X :=
  NatIso.ofComponents (fun n ‚Ü¶ (Equiv.Set.univ (X.obj n)).toIso)

@[simp]
lemma topIso_hom : (topIso X).hom = Subcomplex.őĻ _ := rfl

@[reassoc (attr := simp)]
lemma topIso_inv_őĻ : (topIso X).inv ‚Čę Subfunctor.őĻ _ = ūĚüô _ := rfl

end

instance : Subsingleton (((‚ä• : X.Subcomplex) : SSet.{u}) ‚ü∂ Y) where
  allEq _ _ := by ext _ ‚ü®_, h‚ü©; tauto

instance : Unique (((‚ä• : X.Subcomplex) : SSet.{u}) ‚ü∂ Y) where
  default :=
    { app _ := TypeCat.ofHom fun ‚ü®_, h‚ü© ‚Ü¶ by tauto
      naturality _ _ _ := by ext ‚ü®_, h‚ü©; tauto }
  uniq := by subsingleton

/-- If `X` is a simplicial set, then the empty subcomplex of `X` is an initial
object in `SSet`. -/
def isInitialBot : IsInitial ((‚ä• : X.Subcomplex) : SSet.{u}) :=
  IsInitial.ofUnique _

/-- The subcomplex of a simplicial set that is generated by a simplex. -/
abbrev ofSimplex {n : ‚Ąē} (x : X _‚¶čn‚¶Ć) : X.Subcomplex := Subfunctor.ofSection x

@[simp]
lemma ofSimplex_őĻ (x : X _‚¶č0‚¶Ć) : (ofSimplex x).őĻ = SSet.const x := by
  ext n ‚ü®_, ‚ü®u‚ü©, rfl‚ü©
  obtain rfl := Subsingleton.elim u (SimplexCategory.const _ _ 0)
  rfl

lemma mem_ofSimplex_obj {n : ‚Ąē} (x : X _‚¶čn‚¶Ć) :
    x ‚ąą (ofSimplex x).obj _ :=
  Subfunctor.mem_ofSection_obj x

lemma ofSimplex_le_iff {n : ‚Ąē} (x : X _‚¶čn‚¶Ć) (A : X.Subcomplex) :
    ofSimplex x ‚Č§ A ‚ÜĒ x ‚ąą A.obj _ :=
  Subfunctor.ofSection_le_iff _ _

lemma mem_ofSimplex_obj_iff {n : ‚Ąē} (x : X _‚¶čn‚¶Ć) {m : SimplexCategoryŠĶíŠĶĖ} (y : X.obj m) :
    y ‚ąą (ofSimplex x).obj m ‚ÜĒ ‚ąÉ (f : m.unop ‚ü∂ ‚¶čn‚¶Ć), X.map f.op x = y := by
  dsimp [ofSimplex, Subfunctor.ofSection]
  aesop

section

variable (f : X ‚ü∂ Y)

/-- The range of a morphism of simplicial sets, as a subcomplex. -/
abbrev range : Y.Subcomplex := Subfunctor.range f

/-- The morphism `X ‚ü∂ Subcomplex.range f` induced by `f : X ‚ü∂ Y`. -/
abbrev toRange : X ‚ü∂ Subcomplex.range f := Subfunctor.toRange f

@[simp, reassoc]
lemma toRange_őĻ : toRange f ‚Čę (Subcomplex.range f).őĻ = f := rfl

@[simp]
lemma toRange_app_val {őĒ : SimplexCategoryŠĶíŠĶĖ} (x : X.obj őĒ) :
    dsimp% ((toRange f).app őĒ x).val = f.app őĒ x := rfl

instance : Epi (toRange f) :=
  inferInstanceAs (Epi (Subfunctor.toRange f))

instance [Mono f] : Mono (toRange f) :=
  mono_of_mono_fac (toRange_őĻ f)

instance [Mono f] : IsIso (toRange f) :=
  isIso_of_mono_of_epi _

lemma range_eq_top_iff : Subcomplex.range f = ‚ä§ ‚ÜĒ Epi f := by
  rw [NatTrans.epi_iff_epi_app, Subfunctor.ext_iff, funext_iff]
  simp only [epi_iff_surjective, Subfunctor.range_obj, Subfunctor.top_obj,
    Set.top_eq_univ, Set.range_eq_univ]

lemma range_eq_top [Epi f] : Subcomplex.range f = ‚ä§ := by
  rwa [range_eq_top_iff]

end

section

variable (f : X ‚ü∂ Y) {B : Y.Subcomplex} (hf : range f ‚Č§ B)

/-- Given a morphism of simplicial sets `f : X ‚ü∂ Y` whose
range is `‚Č§ B` for some `B : Y.Subcomplex`, this is the
induced morphism `X ‚ü∂ B`. -/
def lift : X ‚ü∂ B := Subfunctor.lift f hf

@[reassoc (attr := simp)]
lemma lift_őĻ : lift f hf ‚Čę B.őĻ = f := rfl

@[simp]
lemma lift_app_coe {n : SimplexCategoryŠĶíŠĶĖ} (x : X.obj n) :
    dsimp% ((lift f hf).app _ x).1 = f.app _ x := rfl

end

section

/-- The preimage of a subcomplex by a morphism of simplicial sets. -/
@[simps]
def preimage (A : X.Subcomplex) (p : Y ‚ü∂ X) : Y.Subcomplex where
  obj n := p.app n ‚ĀĽ¬Ļ' (A.obj n)
  map f := (Set.preimage_mono (A.map f)).trans (by simp [Set.preimage_preimage])

@[simp]
lemma preimage_max (A B : X.Subcomplex) (p : Y ‚ü∂ X) :
    (A ‚äĒ B).preimage p = A.preimage p ‚äĒ B.preimage p := rfl

@[simp]
lemma preimage_min (A B : X.Subcomplex) (p : Y ‚ü∂ X) :
    (A ‚äď B).preimage p = A.preimage p ‚äď B.preimage p := rfl

@[simp]
lemma preimage_iSup {őĻ : Type*} (A : őĻ ‚Üí X.Subcomplex) (p : Y ‚ü∂ X) :
    (‚®Ü i, A i).preimage p = ‚®Ü i, (A i).preimage p := by aesop

@[simp]
lemma preimage_iInf {őĻ : Type*} (A : őĻ ‚Üí X.Subcomplex) (p : Y ‚ü∂ X) :
    (‚®Ö i, A i).preimage p = ‚®Ö i, (A i).preimage p := by aesop

end

section

variable (A : X.Subcomplex) (f : X ‚ü∂ Y)

/-- The image of a subcomplex by a morphism of simplicial sets. -/
@[simps!]
def image : Y.Subcomplex := Subfunctor.image A f

lemma image_le_iff (Z : Y.Subcomplex) :
    A.image f ‚Č§ Z ‚ÜĒ A ‚Č§ Z.preimage f := by
  simp [Subfunctor.le_def]

lemma image_top : (‚ä§ : X.Subcomplex).image f = range f := by aesop

@[simp]
lemma image_id : A.image (ūĚüô _) = A := by aesop

lemma image_comp {Z : SSet.{u}} (g : Y ‚ü∂ Z) :
    A.image (f ‚Čę g) = (A.image f).image g := by aesop

lemma range_comp {Z : SSet.{u}} (g : Y ‚ü∂ Z) :
    Subcomplex.range (f ‚Čę g) = (Subcomplex.range f).image g := by aesop

lemma image_eq_range : A.image f = range (A.őĻ ‚Čę f) := by aesop

lemma image_iSup {őĻ : Type*} (S : őĻ ‚Üí X.Subcomplex) (f : X ‚ü∂ Y) :
    image (‚®Ü i, S i) f = ‚®Ü i, (S i).image f := by
  aesop

@[simp]
lemma preimage_range : (range f).preimage f = ‚ä§ :=
  le_antisymm (by simp) (by rw [‚Üź image_le_iff, image_top])

@[simp]
lemma image_le_range : A.image f ‚Č§ range f := by
  simp [image_le_iff, preimage_range, le_top]

@[simp]
lemma image_ofSimplex {n : ‚Ąē} (x : X _‚¶čn‚¶Ć) (f : X ‚ü∂ Y) :
    (ofSimplex x).image f = ofSimplex (f.app _ x) := by
  apply le_antisymm
  ¬∑ rw [image_le_iff, ofSimplex_le_iff, preimage_obj, Set.mem_preimage]
    apply mem_ofSimplex_obj
  ¬∑ rw [ofSimplex_le_iff]
    exact ‚ü®x, mem_ofSimplex_obj _, rfl‚ü©

/-- Given a morphism of simplicial sets `f : X ‚ü∂ Y` and a subcomplex `A` of `X`,
this is the induced morphism from `A` to `A.image f`. -/
@[simps! +dsimpLhs]
def toImage : (A : SSet) ‚ü∂ (A.image f : SSet) :=
  (A.image f).lift (A.őĻ ‚Čę f) (by rw [image_eq_range])

@[reassoc (attr := simp)]
lemma toImage_őĻ : A.toImage f ‚Čę (A.image f).őĻ = A.őĻ ‚Čę f := rfl

instance : Epi (A.toImage f) := by
  rw [‚Üź range_eq_top_iff]
  apply le_antisymm (by simp)
  rintro m ‚ü®_, ‚ü®y, hy, rfl‚ü©‚ü© _
  exact ‚ü®‚ü®y, hy‚ü©, rfl‚ü©

lemma image_monotone : Monotone (fun (S : X.Subcomplex) ‚Ü¶ S.image f) := by
  intro S T h
  rw [image_le_iff]
  exact h.trans (by rw [‚Üź image_le_iff])

end

lemma preimage_eq_top_iff (B : X.Subcomplex) (f : Y ‚ü∂ X) :
    B.preimage f = ‚ä§ ‚ÜĒ range f ‚Č§ B := by
  rw [‚Üź image_top, image_le_iff, top_le_iff]

@[simp]
lemma image_preimage_le (B : X.Subcomplex) (f : Y ‚ü∂ X) :
    (B.preimage f).image f ‚Č§ B := by
  rw [image_le_iff]

/-- Given a morphism of simplicial sets `p : Y ‚ü∂ X` and
`A : X.Subcomplex`, this is the induced morphism
`(A.preimage p : SSet) ‚ü∂ (A : SSet)`. -/
@[simps! +dsimpLhs]
def fromPreimage (A : X.Subcomplex) (p : Y ‚ü∂ X) :
    (A.preimage p : SSet) ‚ü∂ (A : SSet) :=
  lift (Subcomplex.őĻ _ ‚Čę p) (by simp [range_comp])

@[reassoc (attr := simp)]
lemma fromPreimage_őĻ (A : X.Subcomplex) (p : Y ‚ü∂ X) :
    A.fromPreimage p ‚Čę A.őĻ = (A.preimage p).őĻ ‚Čę p := rfl

end Subcomplex

end SSet
