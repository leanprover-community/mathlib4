/-- For a preorder `P`, `Cofinal P` is the type of subsets of `P`
  containing arbitrarily large elements. They are the dense sets in
  the topology whose open sets are terminal segments. -/
structure Cofinal (P) [Preorder P] where
  /-- The carrier of a `Cofinal` is the underlying set. -/
  carrier : Set P
  /-- The `Cofinal` contains arbitrarily large elements. -/
  isCofinal : IsCofinal carrier

namespace Cofinal

variable [Preorder P]

instance : Inhabited (Cofinal P) :=
  ‚ü®_, .univ‚ü©

instance : Membership P (Cofinal P) :=
  ‚ü®fun D x ‚Ü¶ x ‚ąą D.carrier‚ü©

variable (D : Cofinal P) (x : P)

/-- A (noncomputable) element of a cofinal set lying above a given element. -/
noncomputable def above : P :=
  Classical.choose <| D.isCofinal x

theorem above_mem : D.above x ‚ąą D :=
  (Classical.choose_spec <| D.isCofinal x).1

theorem le_above : x ‚Č§ D.above x :=
  (Classical.choose_spec <| D.isCofinal x).2

end Cofinal

section IdealOfCofinals

variable [Preorder P] (p : P) {őĻ : Type*} [Encodable őĻ] (ūĚíü : őĻ ‚Üí Cofinal P)

/-- Given a starting point, and a countable family of cofinal sets,
  this is an increasing sequence that intersects each cofinal set. -/
noncomputable def sequenceOfCofinals : ‚Ąē ‚Üí P
  | 0 => p
  | n + 1 =>
    match Encodable.decode n with
    | none => sequenceOfCofinals n
    | some i => (ūĚíü i).above (sequenceOfCofinals n)

theorem sequenceOfCofinals.monotone : Monotone (sequenceOfCofinals p ūĚíü) := by
  apply monotone_nat_of_le_succ
  intro n
  dsimp only [sequenceOfCofinals, Nat.add]
  cases (Encodable.decode n : Option őĻ)
  ¬∑ rfl
  ¬∑ apply Cofinal.le_above

theorem sequenceOfCofinals.encode_mem (i : őĻ) :
    sequenceOfCofinals p ūĚíü (Encodable.encode i + 1) ‚ąą ūĚíü i := by
  dsimp only [sequenceOfCofinals, Nat.add]
  rw [Encodable.encodek]
  apply Cofinal.above_mem

/-- Given an element `p : P` and a family `ūĚíü` of cofinal subsets of a preorder `P`,
  indexed by a countable type, `idealOfCofinals p ūĚíü` is an ideal in `P` which
  - contains `p`, according to `mem_idealOfCofinals p ūĚíü`, and
  - intersects every set in `ūĚíü`, according to `cofinal_meets_idealOfCofinals p ūĚíü`.

  This proves the Rasiowa‚ÄďSikorski lemma. -/
def idealOfCofinals : Ideal P where
  carrier := { x : P | ‚ąÉ n, x ‚Č§ sequenceOfCofinals p ūĚíü n }
  lower' := fun _ _ hxy ‚ü®n, hn‚ü© ‚Ü¶ ‚ü®n, le_trans hxy hn‚ü©
  nonempty' := ‚ü®p, 0, le_rfl‚ü©
  directed' := fun _ ‚ü®n, hn‚ü© _ ‚ü®m, hm‚ü© ‚Ü¶
    ‚ü®_, ‚ü®max n m, le_rfl‚ü©, le_trans hn <| sequenceOfCofinals.monotone p ūĚíü (le_max_left _ _),
      le_trans hm <| sequenceOfCofinals.monotone p ūĚíü (le_max_right _ _)‚ü©

theorem mem_idealOfCofinals : p ‚ąą idealOfCofinals p ūĚíü :=
  ‚ü®0, le_rfl‚ü©

/-- `idealOfCofinals p ūĚíü` is `ūĚíü`-generic. -/
theorem cofinal_meets_idealOfCofinals (i : őĻ) : ‚ąÉ x : P, x ‚ąą ūĚíü i ‚ąß x ‚ąą idealOfCofinals p ūĚíü :=
  ‚ü®_, sequenceOfCofinals.encode_mem p ūĚíü i, _, le_rfl‚ü©

end IdealOfCofinals

