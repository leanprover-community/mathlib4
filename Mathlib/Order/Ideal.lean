/-- A proper ideal is one that is not `Set.univ` (note `Set.univ` might not be an ideal). -/
@[mk_iff]
class IsProper (I : Ideal P) : Prop where
  /-- This ideal is not `Set.univ`. -/
  ne_univ : (I : Set P) ‚Č† univ

/-- A proper filter is one that is not `Set.univ` (note `Set.univ` might not be a filter). -/
@[to_dual existing, mk_iff]
class _root_.Order.PFilter.IsProper (F : PFilter P) : Prop where
  /-- This filter is not `Set.univ`. -/
  ne_univ : (F : Set P) ‚Č† univ

@[to_dual]
theorem isProper_of_notMem {I : Ideal P} {p : P} (notMem : p ‚ąČ I) : IsProper I :=
  ‚ü®fun hp ‚Ü¶ by
    have := mem_univ p
    rw [‚Üź hp] at this
    exact notMem this‚ü©

/-- An ideal is maximal if it is maximal among proper ideals.

Note that `IsCoatom` is less general because ideals only have a top element when `P` is directed
and nonempty. -/
@[mk_iff]
class IsMaximal (I : Ideal P) : Prop extends IsProper I where
  /-- This ideal is maximal among proper ideals. -/
  maximal_proper : ‚ąÄ ‚¶ÉJ : Ideal P‚¶Ą, I < J ‚Üí (J : Set P) = univ

/-- A filter is a ultrafilter if it is maximal among proper filters (which is minimal over the
reversed inclusion order).

Note that `IsAtom` is less general because filters only have a bottom element when `P` is codirected
and nonempty. -/
@[to_dual existing Ideal.IsMaximal, mk_iff]
class _root_.Order.PFilter.IsUltra (F : PFilter P) : Prop extends F.IsProper where
  /-- This filter is maximal (minimal over reversed inclusion order) among proper filter. -/
  minimal_proper : ‚ąÄ ‚¶ÉG : PFilter P‚¶Ą, G < F ‚Üí (G : Set P) = univ

@[to_dual]
theorem inter_nonempty [IsCodirectedOrder P] (I J : Ideal P) : (I ‚ą© J : Set P).Nonempty := by
  obtain ‚ü®a, ha‚ü© := I.nonempty
  obtain ‚ü®b, hb‚ü© := J.nonempty
  obtain ‚ü®c, hac, hbc‚ü© := exists_le_le a b
  exact ‚ü®c, I.lower hac ha, J.lower hbc hb‚ü©

end

