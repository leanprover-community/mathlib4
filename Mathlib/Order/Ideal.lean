/-- A specific witness of `Ideal.directed` when `P` has joins. -/
@[to_dual /-- A specific witness of `PFilter.directed` when `P` has meets. -/]
theorem sup_mem (hx : x ‚ąą s) (hy : y ‚ąą s) : x ‚äĒ y ‚ąą s :=
  let ‚ü®_, hz, hx, hy‚ü© := s.directed x hx y hy
