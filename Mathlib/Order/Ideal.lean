variable [SemilatticeSup P] [IsCodirectedOrder P] {x : P} {I J s t : Ideal P}

/-- The infimum of two ideals of a co-directed order is their intersection. -/
@[to_dual /-- The supremum of two filters of a directed order is their intersection. -/]
instance : SemilatticeInf (Ideal P) where
  inf I J :=
    { toLowerSet := I.toLowerSet ‚äď J.toLowerSet
      nonempty' := inter_nonempty I J
      directed' := fun x hx y hy ‚Ü¶ ‚ü®x ‚äĒ y, ‚ü®sup_mem hx.1 hy.1, sup_mem hx.2 hy.2‚ü©, by simp‚ü© }
  inf_le_left _ _ := inter_subset_left
  inf_le_right _ _ := inter_subset_right
  le_inf _ _ _ := subset_inter

/-- The supremum of two ideals of a co-directed order is the union of the down sets of the pointwise
supremum of `I` and `J`. -/
@[to_dual /-- The infimum of two filters of a directed order is the union of the down sets of the
pointwise infimum of `I` and `J`. -/]
instance : SemilatticeSup (Ideal P) where
  sup I J :=
    { carrier := { x | ‚ąÉ i ‚ąą I, ‚ąÉ j ‚ąą J, x ‚Č§ i ‚äĒ j }
      nonempty' := by
        obtain ‚ü®w, h‚ü© := inter_nonempty I J
        exact ‚ü®w, w, h.1, w, h.2, le_sup_left‚ü©
      directed' := fun x ‚ü®xi, _, xj, _, _‚ü© y ‚ü®yi, _, yj, _, _‚ü© ‚Ü¶
        ‚ü®x ‚äĒ y, ‚ü®xi ‚äĒ yi, sup_mem ‚ÄĻ_‚Äļ ‚ÄĻ_‚Äļ, xj ‚äĒ yj, sup_mem ‚ÄĻ_‚Äļ ‚ÄĻ_‚Äļ,
            sup_le
              (calc
                x ‚Č§ xi ‚äĒ xj := ‚ÄĻ_‚Äļ
                _ ‚Č§ xi ‚äĒ yi ‚äĒ (xj ‚äĒ yj) := sup_le_sup le_sup_left le_sup_left)
              (calc
                y ‚Č§ yi ‚äĒ yj := ‚ÄĻ_‚Äļ
                _ ‚Č§ xi ‚äĒ yi ‚äĒ (xj ‚äĒ yj) := sup_le_sup le_sup_right le_sup_right)‚ü©,
          le_sup_left, le_sup_right‚ü©
      lower' := fun _ _ h ‚ü®yi, hi, yj, hj, hxy‚ü© ‚Ü¶ ‚ü®yi, hi, yj, hj, h.trans hxy‚ü© }
  le_sup_left _ J i hi :=
    let ‚ü®w, hw‚ü© := J.nonempty
    ‚ü®i, hi, w, hw, le_sup_left‚ü©
  le_sup_right I _ j hj :=
    let ‚ü®w, hw‚ü© := I.nonempty
    ‚ü®w, hw, j, hj, le_sup_right‚ü©
