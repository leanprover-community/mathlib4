section Preorder

variable [Preorder P]

section

variable {I : Ideal P} {x y : P}

/-- The smallest ideal containing a given element. -/
@[to_dual (attr := simps!) /-- The smallest filter containing a given element. -/]
def principal (p : P) : Ideal P where
  toLowerSet := LowerSet.Iic p
  nonempty' := nonempty_Iic
  directed' _ hx _ hy := ⟨p, le_rfl, hx, hy⟩

@[to_dual]
instance [Inhabited P] : Inhabited (Ideal P) :=
  ⟨Ideal.principal default⟩

@[to_dual (attr := simp) le_principal_iff]
theorem principal_le_iff : principal x ≤ I ↔ x ∈ I :=
  ⟨fun h ↦ h le_rfl, fun hx _ hy ↦ I.lower hy hx⟩

@[deprecated (since := "2026-04-23")] alias _root_.Order.PFilter.principal_le_iff :=
  PFilter.le_principal_iff

@[to_dual (attr := simp)]
theorem mem_principal : x ∈ principal y ↔ x ≤ y :=
  Iff.rfl

@[to_dual]
lemma mem_principal_self : x ∈ principal x :=
  mem_principal.2 (le_refl x)

@[deprecated "use `simp` instead" (since := "2026-04-23")]
theorem principal_le_principal_iff : PFilter.principal y ≥ PFilter.principal x ↔ x ≤ y := by simp

@[to_dual]
theorem monotone_principal : Monotone (principal (P := P)) := fun _ _ => by simp

@[deprecated (since := "2026-04-23")] alias _root_.Order.PFilter.antitone_principal :=
  PFilter.monotone_principal

end

