/-- There is a bottom ideal when `P` has a bottom element. -/
@[to_dual /-- There is a top filter when `P` has a top element. -/]
instance : OrderBot (Ideal P) where
  bot := principal ⊥
  bot_le := by simp

@[to_dual (attr := simp)]
theorem principal_bot : principal (⊥ : P) = ⊥ :=
  rfl

