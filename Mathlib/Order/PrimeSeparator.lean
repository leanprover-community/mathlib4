/-!
# Separating prime filters and ideals

In a bounded distributive lattice, if $F$ is a filter, $I$ is an ideal, and $F$ and $I$ are
disjoint, then there exists a prime ideal $J$ containing $I$ with $J$ still disjoint from $F$.
This theorem is a crucial ingredient to [Stone's][Sto1938] duality for bounded distributive
lattices. The construction of the separator relies on Zorn's lemma.

## Tags

ideal, filter, prime, distributive lattice

## References

* [M. H. Stone, Topological representations of distributive lattices and Brouwerian logics
  (1938)][Sto1938]
-/

public section


universe u
variable {╬▒ : Type*}

open Order Ideal Set

variable [DistribLattice ╬▒] [BoundedOrder ╬▒]

variable {F : PFilter ╬▒} {I : Ideal ╬▒}

namespace DistribLattice


lemma mem_ideal_sup_principal (a b : ╬▒) (J : Ideal ╬▒) : b έΙΙ J έΛΦ principal a έΗΦ έΙΔ j έΙΙ J, b έΚν j έΛΦ a :=
  έθρfun έθρj, έθρjJ, _, ha', bja'έθσέθσ => έθρj, jJ, le_trans bja' (sup_le_sup_left ha' j)έθσ,
    fun έθρj, hj, hbjaέθσ => έθρj, hj, a, le_refl a, hbjaέθσέθσ

set_option linter.style.whitespace false in -- manual alignment is not recognised
theorem prime_ideal_of_disjoint_filter_ideal (hFI : Disjoint (F : Set ╬▒) (I : Set ╬▒)) :
    έΙΔ J : Ideal ╬▒, (IsPrime J) έΙπ I έΚν J έΙπ Disjoint (F : Set ╬▒) J := by
  -- Let S be the set of ideals containing I and disjoint from F.
  set S : Set (Set ╬▒) := { J : Set ╬▒ | IsIdeal J έΙπ I έΚν J έΙπ Disjoint (F : Set ╬▒) J }
  -- Then I is in S...
  have IinS : έΗΣI έΙΙ S := by
    refine έθρOrder.Ideal.isIdeal I, by trivialέθσ
  -- ...and S contains upper bounds for any non-empty chains.
  have chainub : έΙΑ c έΛΗ S, IsChain (┬╖ έΛΗ ┬╖) c έΗΤ c.Nonempty έΗΤ έΙΔ ub έΙΙ S, έΙΑ s έΙΙ c, s έΛΗ ub := by
    intro c hcS hcC hcNe
    use sUnion c
    refine έθρ?_, fun s hs έΗο le_sSup hsέθσ
    simp only [le_eq_subset, mem_setOf_eq, disjoint_sUnion_right, S]
    let έθρJ, hJέθσ := hcNe
    refine έθρOrder.isIdeal_sUnion_of_isChain (fun _ hJ έΗο (hcS hJ).1) hcC hcNe,
            έθρle_trans (hcS hJ).2.1 (le_sSup hJ), fun J hJ έΗο (hcS hJ).2.2έθσέθσ
  -- Thus, by Zorn's lemma, we can pick a maximal ideal J in S.
  obtain έθρJset, _, hmaxέθσ := zorn_subset_nonempty S chainub I IinS
  obtain έθρJidl, IJ, JFέθσ := hmax.prop
  set J := IsIdeal.toIdeal Jidl
  use J
  have IJ' : I έΚν J := IJ
  clear chainub IinS
  -- By construction, J contains I and is disjoint from F. It remains to prove that J is prime.
  refine έθρ?_, έθρIJ, JFέθσέθσ
  -- First note that J is proper: έΛν έΙΙ F so έΛν έΙΚ J because F and J are disjoint.
  have Jpr : IsProper J := isProper_of_notMem (Set.disjoint_left.1 JF F.top_mem)
  -- Suppose that aέΓΒ έΙΚ J, aέΓΓ έΙΚ J. We need to prove that aέΓΒ έΛΦ aέΓΓ έΙΚ J.
  rw [isPrime_iff_mem_or_mem]
  intro aέΓΒ aέΓΓ
  contrapose!
  intro έθρhaέΓΒ, haέΓΓέθσ
  -- Consider the ideals JέΓΒ, JέΓΓ generated by J έΙς {aέΓΒ} and J έΙς {aέΓΓ}, respectively.
  let JέΓΒ := J έΛΦ principal aέΓΒ
  let JέΓΓ := J έΛΦ principal aέΓΓ
  -- For each i, Jά╡λ is an ideal that contains aά╡λ, and is not equal to J.
  have aέΓΒJέΓΒ : aέΓΒ έΙΙ JέΓΒ := mem_of_subset_of_mem (le_sup_right : _ έΚν J έΛΦ _) mem_principal_self
  have aέΓΓJέΓΓ : aέΓΓ έΙΙ JέΓΓ := mem_of_subset_of_mem (le_sup_right : _ έΚν J έΛΦ _) mem_principal_self
  have JέΓΒJ : έΗΣJέΓΒ έΚι Jset := ne_of_mem_of_not_mem' aέΓΒJέΓΒ haέΓΒ
  have JέΓΓJ : έΗΣJέΓΓ έΚι Jset := ne_of_mem_of_not_mem' aέΓΓJέΓΓ haέΓΓ
  -- Therefore, since J is maximal, we must have Jά╡λ έΙΚ S.
  have JέΓΒS : έΗΣJέΓΒ έΙΚ S := fun h => JέΓΒJ (hmax.eq_of_le h (le_sup_left : J έΚν JέΓΒ)).symm
  have JέΓΓS : έΗΣJέΓΓ έΙΚ S := fun h => JέΓΓJ (hmax.eq_of_le h (le_sup_left : J έΚν JέΓΓ)).symm
  -- Since Jά╡λ is an ideal that contains I, we have that Jά╡λ is not disjoint from F.
  have JέΓΒF : ┬υ (Disjoint (F : Set ╬▒) JέΓΒ) := by
    intro hdis
    apply JέΓΒS
    simp only [le_eq_subset, mem_setOf_eq, SetLike.coe_subset_coe, S]
    exact έθρJέΓΒ.isIdeal, le_trans IJ' le_sup_left, hdisέθσ
  have JέΓΓF : ┬υ (Disjoint (F : Set ╬▒) JέΓΓ) := by
    intro hdis
    apply JέΓΓS
    simp only [le_eq_subset, mem_setOf_eq, SetLike.coe_subset_coe, S]
    exact έθρJέΓΓ.isIdeal, le_trans IJ' le_sup_left, hdisέθσ
  -- Thus, pick cά╡λ έΙΙ F έΙσ Jά╡λ.
  let έθρcέΓΒ, έθρcέΓΒF, cέΓΒJέΓΒέθσέθσ := Set.not_disjoint_iff.1 JέΓΒF
  let έθρcέΓΓ, έθρcέΓΓF, cέΓΓJέΓΓέθσέθσ := Set.not_disjoint_iff.1 JέΓΓF
  -- Using the definition of Jά╡λ, we can pick bά╡λ έΙΙ J such that cά╡λ έΚν bά╡λ έΛΦ aά╡λ.
  let έθρbέΓΒ, έθρbέΓΒJ, cbaέΓΒέθσέθσ := (mem_ideal_sup_principal aέΓΒ cέΓΒ J).1 cέΓΒJέΓΒ
  let έθρbέΓΓ, έθρbέΓΓJ, cbaέΓΓέθσέθσ := (mem_ideal_sup_principal aέΓΓ cέΓΓ J).1 cέΓΓJέΓΓ
  -- Since J is an ideal, we have b := bέΓΒ έΛΦ bέΓΓ έΙΙ J.
  let b := bέΓΒ έΛΦ bέΓΓ
  have bJ : b έΙΙ J := sup_mem bέΓΒJ bέΓΓJ
  -- We now prove a key inequality, using crucially that the lattice is distributive.
  have ineq : cέΓΒ έΛΥ cέΓΓ έΚν b έΛΦ (aέΓΒ έΛΥ aέΓΓ) :=
  calc
    cέΓΒ έΛΥ cέΓΓ έΚν (bέΓΒ έΛΦ aέΓΒ) έΛΥ (bέΓΓ έΛΦ aέΓΓ) := inf_le_inf cbaέΓΒ cbaέΓΓ
    _       έΚν (b έΛΦ aέΓΒ) έΛΥ (b έΛΦ aέΓΓ) := by gcongr; exacts [le_sup_left, le_sup_right]
    _       = b έΛΦ (aέΓΒ έΛΥ aέΓΓ) := (sup_inf_left b aέΓΒ aέΓΓ).symm
  -- Note that cέΓΒ έΛΥ cέΓΓ έΙΙ F, since cέΓΒ and cέΓΓ are both in F and F is a filter.
  -- Since F is an upper set, it now follows that b έΛΦ (aέΓΒ έΛΥ aέΓΓ) έΙΙ F.
  have baέΓΒaέΓΓF : b έΛΦ (aέΓΒ έΛΥ aέΓΓ) έΙΙ F := PFilter.mem_of_le ineq (PFilter.inf_mem cέΓΒF cέΓΓF)
  -- Now, if we would have aέΓΒ έΛΥ aέΓΓ έΙΙ J, then, since J is an ideal and b έΙΙ J, we would also get
  -- b έΛΦ (aέΓΒ έΛΥ aέΓΓ) έΙΙ J. But this contradicts that J is disjoint from F.
  contrapose JF with haέΓΒaέΓΓ
  rw [Set.not_disjoint_iff]
  use b έΛΦ (aέΓΒ έΛΥ aέΓΓ)
  exact έθρbaέΓΒaέΓΓF, sup_mem bJ haέΓΒaέΓΓέθσ

