scoped[Pointwise] attribute [instance] smul_filter.instNeBot vadd_filter.instNeBot

@[to_additive (attr := gcongr)]
theorem smul_filter_le_smul_filter (hf : f‚āĀ ‚Č§ f‚āā) : a ‚ÄĘ f‚āĀ ‚Č§ a ‚ÄĘ f‚āā :=
  map_mono hf

@[to_additive]
instance covariant_smul_filter : CovariantClass őĪ (Filter ő≤) (¬∑ ‚ÄĘ ¬∑) (¬∑ ‚Č§ ¬∑) :=
  ‚ü®fun _ => @map_mono ő≤ ő≤ _‚ü©

end SMul

@[to_additive]
instance smulCommClass_filter [SMul őĪ ő≥] [SMul ő≤ ő≥] [SMulCommClass őĪ ő≤ ő≥] :
    SMulCommClass őĪ ő≤ (Filter ő≥) :=
  ‚ü®fun _ _ _ => map_comm (funext <| smul_comm _ _) _‚ü©

@[to_additive]
instance smulCommClass_filter' [SMul őĪ ő≥] [SMul ő≤ ő≥] [SMulCommClass őĪ ő≤ ő≥] :
    SMulCommClass őĪ (Filter ő≤) (Filter ő≥) :=
  ‚ü®fun a _ _ => map_map‚āā_distrib_right <| smul_comm a‚ü©

@[to_additive]
instance smulCommClass_filter'' [SMul őĪ ő≥] [SMul ő≤ ő≥] [SMulCommClass őĪ ő≤ ő≥] :
    SMulCommClass (Filter őĪ) ő≤ (Filter ő≥) :=
  haveI := SMulCommClass.symm őĪ ő≤ ő≥
  SMulCommClass.symm _ _ _

@[to_additive]
instance smulCommClass [SMul őĪ ő≥] [SMul ő≤ ő≥] [SMulCommClass őĪ ő≤ ő≥] :
    SMulCommClass (Filter őĪ) (Filter ő≤) (Filter ő≥) :=
  ‚ü®fun _ _ _ => map‚āā_left_comm smul_comm‚ü©

@[to_additive]
instance isScalarTower [SMul őĪ ő≤] [SMul őĪ ő≥] [SMul ő≤ ő≥] [IsScalarTower őĪ ő≤ ő≥] :
    IsScalarTower őĪ ő≤ (Filter ő≥) :=
  ‚ü®fun a b f => by simp only [‚Üź Filter.map_smul, map_map, smul_assoc]; rfl‚ü©

@[to_additive]
instance isScalarTower' [SMul őĪ ő≤] [SMul őĪ ő≥] [SMul ő≤ ő≥] [IsScalarTower őĪ ő≤ ő≥] :
    IsScalarTower őĪ (Filter ő≤) (Filter ő≥) :=
  ‚ü®fun a f g => by
    refine (map_map‚āā_distrib_left fun _ _ => ?_).symm
    exact (smul_assoc a _ _).symm‚ü©

@[to_additive]
instance isScalarTower'' [SMul őĪ ő≤] [SMul őĪ ő≥] [SMul ő≤ ő≥] [IsScalarTower őĪ ő≤ ő≥] :
    IsScalarTower (Filter őĪ) (Filter ő≤) (Filter ő≥) :=
  ‚ü®fun _ _ _ => map‚āā_assoc smul_assoc‚ü©

@[to_additive]
instance isCentralScalar [SMul őĪ ő≤] [SMul őĪŠĶźŠĶíŠĶĖ ő≤] [IsCentralScalar őĪ ő≤] :
    IsCentralScalar őĪ (Filter ő≤) :=
  ‚ü®fun _ f => (congr_arg fun m => map m f) <| funext fun _ => op_smul_eq_smul _ _‚ü©

/-- A multiplicative action of a monoid `őĪ` on a type `ő≤` gives a multiplicative action of
`Filter őĪ` on `Filter ő≤`. -/
@[to_additive /-- An additive action of an additive monoid `őĪ` on a type `ő≤` gives an additive
action of `Filter őĪ` on `Filter ő≤`. -/]
protected def mulAction [Monoid őĪ] [MulAction őĪ ő≤] : MulAction (Filter őĪ) (Filter ő≤) where
  one_smul f := map‚āā_pure_left.trans <| by simp_rw [one_smul, map_id']
  mul_smul _ _ _ := map‚āā_assoc mul_smul

/-- A multiplicative action of a monoid on a type `ő≤` gives a multiplicative action on `Filter ő≤`.
-/
@[to_additive /-- An additive action of an additive monoid on a type `ő≤` gives an additive action on
`Filter ő≤`. -/]
protected def mulActionFilter [Monoid őĪ] [MulAction őĪ ő≤] : MulAction őĪ (Filter ő≤) where
  mul_smul a b f := by simp only [‚Üź Filter.map_smul, map_map, Function.comp_def, ‚Üź mul_smul]
  one_smul f := by simp only [‚Üź Filter.map_smul, one_smul, map_id']

scoped[Pointwise] attribute [instance] Filter.mulAction Filter.addAction Filter.mulActionFilter
  Filter.addActionFilter

/-- A distributive multiplicative action of a monoid on an additive monoid `ő≤` gives a distributive
multiplicative action on `Filter ő≤`. -/
protected def distribMulActionFilter [Monoid őĪ] [AddMonoid ő≤] [DistribMulAction őĪ ő≤] :
    DistribMulAction őĪ (Filter ő≤) where
  smul_add _ _ _ := map_map‚āā_distrib <| smul_add _
  smul_zero _ := (map_pure _ _).trans <| by rw [smul_zero, pure_zero]

/-- A multiplicative action of a monoid on a monoid `ő≤` gives a multiplicative action on `Set ő≤`. -/
protected noncomputable def mulDistribMulActionFilter
    [Monoid őĪ] [Monoid ő≤] [MulDistribMulAction őĪ ő≤] : MulDistribMulAction őĪ (Set ő≤) where
  smul_mul _ _ _ := image_image2_distrib <| smul_mul' _
  smul_one _ := image_singleton.trans <| by rw [smul_one, singleton_one]

scoped[Pointwise]
  attribute [instance] Filter.distribMulActionFilter Filter.mulDistribMulActionFilter

section SMulWithZero

variable [Zero őĪ] [Zero ő≤] [SMulWithZero őĪ ő≤] {f : Filter őĪ} {g : Filter ő≤}

/-!
Note that we have neither `SMulWithZero őĪ (Filter ő≤)` nor `SMulWithZero (Filter őĪ) (Filter ő≤)`
because `0 * ‚ä• ‚Č† 0`.
-/

theorem NeBot.smul_zero_nonneg (hf : f.NeBot) : 0 ‚Č§ f ‚ÄĘ (0 : Filter ő≤) :=
  le_smul_iff.2 fun _ h‚āĀ _ h‚āā =>
    let ‚ü®_, ha‚ü© := hf.nonempty_of_mem h‚āĀ
    ‚ü®_, ha, _, h‚āā, smul_zero _‚ü©

theorem NeBot.zero_smul_nonneg (hg : g.NeBot) : 0 ‚Č§ (0 : Filter őĪ) ‚ÄĘ g :=
  le_smul_iff.2 fun _ h‚āĀ _ h‚āā =>
    let ‚ü®_, hb‚ü© := hg.nonempty_of_mem h‚āā
    ‚ü®_, h‚āĀ, _, hb, zero_smul _ _‚ü©

theorem zero_smul_filter_nonpos : (0 : őĪ) ‚ÄĘ g ‚Č§ 0 := by
  refine fun s hs => mem_smul_filter.2 ?_
  convert @univ_mem _ g
  refine eq_univ_iff_forall.2 fun a => ?_
  rwa [mem_preimage, zero_smul]

theorem zero_smul_filter (hg : g.NeBot) : (0 : őĪ) ‚ÄĘ g = 0 :=
  zero_smul_filter_nonpos.antisymm <|
    le_map_iff.2 fun s hs => by
      simp_rw [zero_smul, (hg.nonempty_of_mem hs).image_const]
      exact zero_mem_zero

end SMulWithZero

section Cancel

@[to_additive]
theorem _root_.IsUnit.smul_tendsto_smul_iff [Monoid ő≥] [MulAction ő≥ ő≤] {m : őĪ ‚Üí ő≤} {c : ő≥}
    {f : Filter őĪ} {g : Filter ő≤} (hc : IsUnit c) :
    Tendsto (c ‚ÄĘ m) f (c ‚ÄĘ g) ‚ÜĒ Tendsto m f g := by
  rcases hc.exists_left_inv with ‚ü®d, hd‚ü©
  refine ‚ü®fun H ‚Ü¶ ?_, fun H ‚Ü¶ tendsto_map.comp H‚ü©
  simpa [Function.comp_def, smul_smul, hd] using (tendsto_map (f := (d ‚ÄĘ ¬∑))).comp H

@[to_additive (attr := simp)]
theorem smul_tendsto_smul_iff [Group ő≥] [MulAction ő≥ ő≤] {m : őĪ ‚Üí ő≤} {c : ő≥} {f : Filter őĪ}
    {g : Filter ő≤} : Tendsto (c ‚ÄĘ m) f (c ‚ÄĘ g) ‚ÜĒ Tendsto m f g :=
  Group.isUnit _ |>.smul_tendsto_smul_iff

theorem smul_tendsto_smul_iff‚āÄ [GroupWithZero ő≥] [MulAction ő≥ ő≤] {m : őĪ ‚Üí ő≤} {c : ő≥} {f : Filter őĪ}
    {g : Filter ő≤} (hc : c ‚Č† 0) : Tendsto (c ‚ÄĘ m) f (c ‚ÄĘ g) ‚ÜĒ Tendsto m f g :=
  hc.isUnit.smul_tendsto_smul_iff

end Cancel

