@[to_additive (attr := simp)]
lemma inv_atTop {G : Type*} [CommGroup G] [PartialOrder G] [IsOrderedMonoid G] :
    (atTop : Filter G)‚ĀĽ¬Ļ = atBot := by
  -- Show (atTop)‚ĀĽ¬Ļ ‚Č§ atBot: suffices ‚ąÄ a, Iic a ‚ąą (atTop)‚ĀĽ¬Ļ
  have h1 : (atTop : Filter G)‚ĀĽ¬Ļ ‚Č§ atBot := le_iInf fun a =>
    le_principal_iff.mpr <| Filter.mem_inv.mpr <| mem_of_superset (Ici_mem_atTop a‚ĀĽ¬Ļ)
      fun b (hb : a‚ĀĽ¬Ļ ‚Č§ b) => show b‚ĀĽ¬Ļ ‚Č§ a from inv_le'.mp hb
  -- Show atBot ‚Č§ (atTop)‚ĀĽ¬Ļ: from (atBot)‚ĀĽ¬Ļ ‚Č§ atTop and monotonicity of ‚ĀĽ¬Ļ
  have h2 : (atBot : Filter G)‚ĀĽ¬Ļ ‚Č§ atTop := le_iInf fun a =>
    le_principal_iff.mpr <| Filter.mem_inv.mpr <| mem_of_superset (Iic_mem_atBot a‚ĀĽ¬Ļ)
      fun b (hb : b ‚Č§ a‚ĀĽ¬Ļ) => show a ‚Č§ b‚ĀĽ¬Ļ from le_inv'.mp hb
  exact h1.antisymm (inv_inv (atBot : Filter G) ‚Ėł Filter.inv_le_inv h2)

