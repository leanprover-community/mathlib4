section SMul

variable [SMul őĪ ő≤] {f f‚āĀ f‚āā : Filter ő≤} {s : Set ő≤} {a : őĪ}

/-- `a ‚ÄĘ f` is the map of `f` under `a ‚ÄĘ` in scope `Pointwise`. -/
@[to_additive /-- `a +ŠĶ• f` is the map of `f` under `a +ŠĶ•` in scope `Pointwise`. -/]
protected def instSMulFilter : SMul őĪ (Filter ő≤) :=
  ‚ü®fun a => map (a ‚ÄĘ ¬∑)‚ü©

scoped[Pointwise] attribute [instance] Filter.instSMulFilter Filter.instVAddFilter

@[to_additive (attr := simp)]
protected theorem map_smul : map (fun b => a ‚ÄĘ b) f = a ‚ÄĘ f :=
  rfl

@[to_additive]
theorem mem_smul_filter : s ‚ąą a ‚ÄĘ f ‚ÜĒ (a ‚ÄĘ ¬∑) ‚ĀĽ¬Ļ' s ‚ąą f := Iff.rfl

@[to_additive]
theorem smul_set_mem_smul_filter : s ‚ąą f ‚Üí a ‚ÄĘ s ‚ąą a ‚ÄĘ f :=
  image_mem_map

@[to_additive (attr := simp)]
theorem smul_filter_bot : a ‚ÄĘ (‚ä• : Filter ő≤) = ‚ä• :=
  map_bot

@[to_additive (attr := simp)]
theorem smul_filter_eq_bot_iff : a ‚ÄĘ f = ‚ä• ‚ÜĒ f = ‚ä• :=
  map_eq_bot_iff

@[to_additive (attr := simp)]
theorem smul_filter_neBot_iff : (a ‚ÄĘ f).NeBot ‚ÜĒ f.NeBot :=
  map_neBot_iff _

@[to_additive]
theorem NeBot.smul_filter : f.NeBot ‚Üí (a ‚ÄĘ f).NeBot := fun h => h.map _

@[to_additive]
