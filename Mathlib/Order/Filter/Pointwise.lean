lemma vsub.instNeBot [NeBot f] [NeBot g] : NeBot (f -ŠĶ• g) := .vsub ‚ÄĻ_‚Äļ ‚ÄĻ_‚Äļ

scoped[Pointwise] attribute [instance] vsub.instNeBot

@[simp]
theorem pure_vsub : (pure a : Filter ő≤) -ŠĶ• g = g.map (a -ŠĶ• ¬∑) :=
  map‚āā_pure_left

@[simp]
theorem vsub_pure : f -ŠĶ• pure b = f.map (¬∑ -ŠĶ• b) :=
  map‚āā_pure_right

theorem pure_vsub_pure : (pure a : Filter ő≤) -ŠĶ• pure b = (pure (a -ŠĶ• b) : Filter őĪ) := by simp

@[gcongr]
theorem vsub_le_vsub : f‚āĀ ‚Č§ f‚āā ‚Üí g‚āĀ ‚Č§ g‚āā ‚Üí f‚āĀ -ŠĶ• g‚āĀ ‚Č§ f‚āā -ŠĶ• g‚āā :=
  map‚āā_mono

theorem vsub_le_vsub_left : g‚āĀ ‚Č§ g‚āā ‚Üí f -ŠĶ• g‚āĀ ‚Č§ f -ŠĶ• g‚āā :=
  map‚āā_mono_left

theorem vsub_le_vsub_right : f‚āĀ ‚Č§ f‚āā ‚Üí f‚āĀ -ŠĶ• g ‚Č§ f‚āā -ŠĶ• g :=
  map‚āā_mono_right

@[simp]
theorem le_vsub_iff : h ‚Č§ f -ŠĶ• g ‚ÜĒ ‚ąÄ ‚¶És‚¶Ą, s ‚ąą f ‚Üí ‚ąÄ ‚¶Ét‚¶Ą, t ‚ąą g ‚Üí s -ŠĶ• t ‚ąą h :=
  le_map‚āā_iff

end Vsub

