      obtain ‚ü®a, b, rfl, rfl, hab‚ü© := Filter.mul_eq_one_iff.1 h
      rw [inv_pure, inv_eq_of_mul_eq_one_right hab]
    div_eq_mul_inv := fun _ _ => map_map‚āā_distrib_right div_eq_mul_inv }

@[to_additive]
theorem isUnit_iff : IsUnit f ‚ÜĒ ‚ąÉ a, f = pure a ‚ąß IsUnit a := by
