@[to_additive]
protected theorem mul_eq_one_iff : f * g = 1 ‚ÜĒ ‚ąÉ a b, f = pure a ‚ąß g = pure b ‚ąß a * b = 1 := by
  refine ‚ü®fun hfg => ?_, ?_‚ü©
  ¬∑ obtain ‚ü®t‚āĀ, h‚āĀ, t‚āā, h‚āā, h‚ü© : (1 : Set őĪ) ‚ąą f * g := hfg.symm ‚Ėł one_mem_one
    have hfg : (f * g).NeBot := hfg.symm.subst one_neBot
    rw [(hfg.nonempty_of_mem <| mul_mem_mul h‚āĀ h‚āā).subset_one_iff, Set.mul_eq_one_iff] at h
    obtain ‚ü®a, b, rfl, rfl, h‚ü© := h
    refine ‚ü®a, b, ?_, ?_, h‚ü©
    ¬∑ rwa [‚Üź hfg.of_mul_left.le_pure_iff, le_pure_iff]
    ¬∑ rwa [‚Üź hfg.of_mul_right.le_pure_iff, le_pure_iff]
  ¬∑ rintro ‚ü®a, b, rfl, rfl, h‚ü©
    rw [pure_mul_pure, h, pure_one]

