theorem inv_le_iff_le_inv : f‚ĀĽ¬Ļ ‚Č§ g ‚ÜĒ f ‚Č§ g‚ĀĽ¬Ļ := by rw [‚Üź Filter.inv_le_inv_iff, inv_inv]

