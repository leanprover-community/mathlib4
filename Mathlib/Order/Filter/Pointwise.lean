  rfl

theorem mem_vsub {s : Set őĪ} : s ‚ąą f -ŠĶ• g ‚ÜĒ ‚ąÉ t‚āĀ ‚ąą f, ‚ąÉ t‚āā ‚ąą g, t‚āĀ -ŠĶ• t‚āā ‚äÜ s :=
  Iff.rfl

theorem vsub_mem_vsub : s ‚ąą f ‚Üí t ‚ąą g ‚Üí s -ŠĶ• t ‚ąą f -ŠĶ• g :=
  image2_mem_map‚āā

@[simp]
theorem bot_vsub : (‚ä• : Filter ő≤) -ŠĶ• g = ‚ä• :=
  map‚āā_bot_left

@[simp]
theorem vsub_bot : f -ŠĶ• (‚ä• : Filter ő≤) = ‚ä• :=
  map‚āā_bot_right

@[simp]
theorem vsub_eq_bot_iff : f -ŠĶ• g = ‚ä• ‚ÜĒ f = ‚ä• ‚ą® g = ‚ä• :=
  map‚āā_eq_bot_iff

@[simp]
theorem vsub_neBot_iff : (f -ŠĶ• g : Filter őĪ).NeBot ‚ÜĒ f.NeBot ‚ąß g.NeBot :=
  map‚āā_neBot_iff

protected theorem NeBot.vsub : NeBot f ‚Üí NeBot g ‚Üí NeBot (f -ŠĶ• g) :=
  NeBot.map‚āā

theorem NeBot.of_vsub_left : (f -ŠĶ• g : Filter őĪ).NeBot ‚Üí f.NeBot :=
  NeBot.of_map‚āā_left

theorem NeBot.of_vsub_right : (f -ŠĶ• g : Filter őĪ).NeBot ‚Üí g.NeBot :=
