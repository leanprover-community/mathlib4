module

public import Mathlib.Data.Fintype.Sigma
public import Mathlib.Data.Fintype.Sum
public import Mathlib.Order.ModularLattice
public import Mathlib.Tactic.DeriveFintype
public import Mathlib.Tactic.Order

/-!
## Free Modular Lattice On Three Generators

In this file we define `FreeModLatThree`, the free modular lattice on three generators,
and prove the universal property.
-/

@[expose] public section

/--
The free modular lattice on three generators, defined as an inductive type.
It is generated by `gen`, `cycle gen`, and `cycle (cycle gen)`.
-/
inductive FreeModLatThree where
  /--
  `top i j k` is an element of the sublattice generated by
  `gen ⊔ cycle gen`, `gen ⊔ cycle (cycle gen)`, and `cycle gen ⊔ cycle (cycle gen)`.

  Note that you should **not** use this definition directly, as it is
  an implementation detail of `FreeModLatThree`.
  -/
  | top (i j k : Bool)
  /--
  `parti bot top` is an element of the sublattice generated by
  `gen` and `gen ⊓ (cycle gen ⊔ cycle (cycle gen)) ⊔ (cycle gen ⊓ cycle (cycle gen))`.

  Note that you should **not** use this definition directly, as it is
  an implementation detail of `FreeModLatThree`.
  -/
  | parti (bot top : Bool)
  /--
  `partj bot top` is an element of the sublattice generated by
  `cycle gen` and `cycle gen ⊓ (gen ⊔ cycle (cycle gen)) ⊔ (gen ⊓ cycle (cycle gen))`.

  Note that you should **not** use this definition directly, as it is
  an implementation detail of `FreeModLatThree`.
  -/
  | partj (bot top : Bool)
  /--
  `partk bot top` is an element of the sublattice generated by
  `cycle (cycle gen)` and `cycle (cycle gen) ⊓ (gen ⊔ cycle gen) ⊔ (gen ⊓ cycle gen)`.

  Note that you should **not** use this definition directly, as it is
  an implementation detail of `FreeModLatThree`.
  -/
  | partk (bot top : Bool)
  /--
  `bot i j k` is an element of the sublattice generated by
  `gen ⊓ cycle gen`, `gen ⊓ cycle (cycle gen)`, and `cycle gen ⊓ cycle (cycle gen)`.

  Note that you should **not** use this definition directly, as it is
  an implementation detail of `FreeModLatThree`.
  -/
  | bot (i j k : Bool)
deriving Fintype, DecidableEq

namespace FreeModLatThree

theorem card_eq_28 : Fintype.card FreeModLatThree = 28 := rfl

/--
One of the generators of `FreeModLatThree`.
The other two generators are `cycle gen` and `cycle (cycle gen)`.
-/
def gen : FreeModLatThree := .parti false true

/-- The boolean less-than-or-equal relation on `FreeModLatThree`. Prefer using `≤` instead. -/
def ble (x y : FreeModLatThree) : Bool :=
  match x, y with
  | .bot _ _ _, .top _ _ _ => true
  | .top xi xj xk, .top yi yj yk => xi ≤ yi && xj ≤ yj && xk ≤ yk
  | .parti xbot xtop, .parti ybot ytop => xbot ≤ ybot && xtop ≤ ytop
  | .partj xbot xtop, .partj ybot ytop => xbot ≤ ybot && xtop ≤ ytop
  | .partk xbot xtop, .partk ybot ytop => xbot ≤ ybot && xtop ≤ ytop
  | .bot xi xj xk, .bot yi yj yk => xi ≤ yi && xj ≤ yj && xk ≤ yk
  | .parti _ xtop, .top yi _ _ => xtop ≤ yi
  | .partj _ xtop, .top _ yj _ => xtop ≤ yj
  | .partk _ xtop, .top _ _ yk => xtop ≤ yk
  | .bot xi _ _, .parti ybot _ => xi ≤ ybot
  | .bot _ xj _, .partj ybot _ => xj ≤ ybot
  | .bot _ _ xk, .partk ybot _ => xk ≤ ybot
  | _, _ => false

/-- The boolean less-than relation on `FreeModLatThree`. Prefer using `<` instead. -/
def blt (x y : FreeModLatThree) : Bool :=
  ble x y && x != y

instance : LE FreeModLatThree where
  le x y := ble x y = true

instance : LT FreeModLatThree where
  lt x y := blt x y = true

instance : DecidableLE FreeModLatThree :=
  inferInstanceAs (DecidableRel fun x y => ble x y = true)

instance : DecidableLT FreeModLatThree :=
  inferInstanceAs (DecidableRel fun x y => blt x y = true)

theorem le_def (x y : FreeModLatThree) : x ≤ y ↔ ble x y = true := .rfl
theorem lt_def (x y : FreeModLatThree) : x < y ↔ blt x y = true := .rfl

instance : PartialOrder FreeModLatThree where
  le_refl := by decide
  le_trans := by grind [cases FreeModLatThree, le_def, ble]
  le_antisymm := by grind [cases FreeModLatThree, le_def, ble]
  lt_iff_le_not_ge := by decide

/--
The infimum of `a` and `b`, which is the greatest lower bound of `a` and `b`.
Prefer writing `a ⊓ b` instead.
-/
def inf (x y : FreeModLatThree) : FreeModLatThree :=
  match x, y with
  | .top xi xj xk, .top yi yj yk => .top (xi && yi) (xj && yj) (xk && yk)
  | .parti xbot xtop, .parti ybot ytop => .parti (xbot && ybot) (xtop && ytop)
  | .partj xbot xtop, .partj ybot ytop => .partj (xbot && ybot) (xtop && ytop)
  | .partk xbot xtop, .partk ybot ytop => .partk (xbot && ybot) (xtop && ytop)
  | .bot xi xj xk, .bot yi yj yk => .bot (xi && yi) (xj && yj) (xk && yk)
  | .bot _ _ _, .top _ _ _ => x
  | .top _ _ _, .bot _ _ _ => y
  | .top xi _ _, .parti ybot ytop => .parti ybot (xi && ytop)
  | .top _ xj _, .partj ybot ytop => .partj ybot (xj && ytop)
  | .top _ _ xk, .partk ybot ytop => .partk ybot (xk && ytop)
  | .parti xbot xtop, .top yi _ _ => .parti xbot (xtop && yi)
  | .partj xbot xtop, .top _ yj _ => .partj xbot (xtop && yj)
  | .partk xbot xtop, .top _ _ yk => .partk xbot (xtop && yk)
  | .bot xi xj xk, .parti ybot _ => .bot (xi && ybot) xj xk
  | .bot xi xj xk, .partj ybot _ => .bot xi (xj && ybot) xk
  | .bot xi xj xk, .partk ybot _ => .bot xi xj (xk && ybot)
  | .parti xbot _, .bot yi yj yk => .bot (xbot && yi) yj yk
  | .partj xbot _, .bot yi yj yk => .bot yi (xbot && yj) yk
  | .partk xbot _, .bot yi yj yk => .bot yi yj (xbot && yk)
  | .parti xbot _, .partj ybot _ => .bot xbot ybot true
  | .partj xbot _, .parti ybot _ => .bot ybot xbot true
  | .parti xbot _, .partk ybot _ => .bot xbot true ybot
  | .partk xbot _, .parti ybot _ => .bot ybot true xbot
  | .partj xbot _, .partk ybot _ => .bot true xbot ybot
  | .partk xbot _, .partj ybot _ => .bot true ybot xbot

/--
The supremum of `a` and `b`, which is the least upper bound of `a` and `b`.
Prefer writing `a ⊔ b` instead.
-/
def sup (x y : FreeModLatThree) : FreeModLatThree :=
  match x, y with
  | .top xi xj xk, .top yi yj yk => .top (xi || yi) (xj || yj) (xk || yk)
  | .parti xbot xtop, .parti ybot ytop => .parti (xbot || ybot) (xtop || ytop)
  | .partj xbot xtop, .partj ybot ytop => .partj (xbot || ybot) (xtop || ytop)
  | .partk xbot xtop, .partk ybot ytop => .partk (xbot || ybot) (xtop || ytop)
  | .bot xi xj xk, .bot yi yj yk => .bot (xi || yi) (xj || yj) (xk || yk)
  | .top _ _ _, .bot _ _ _ => x
  | .bot _ _ _, .top _ _ _ => y
  | .top xi xj xk, .parti _ ytop => .top (xi || ytop) xj xk
  | .top xi xj xk, .partj _ ytop => .top xi (xj || ytop) xk
  | .top xi xj xk, .partk _ ytop => .top xi xj (xk || ytop)
  | .parti _ xtop, .top yi yj yk => .top (xtop || yi) yj yk
  | .partj _ xtop, .top yi yj yk => .top yi (xtop || yj) yk
  | .partk _ xtop, .top yi yj yk => .top yi yj (xtop || yk)
  | .bot xi _ _, .parti ybot ytop => .parti (xi || ybot) ytop
  | .bot _ xj _, .partj ybot ytop => .partj (xj || ybot) ytop
  | .bot _ _ xk, .partk ybot ytop => .partk (xk || ybot) ytop
  | .parti xbot xtop, .bot yi _ _ => .parti (xbot || yi) xtop
  | .partj xbot xtop, .bot _ yj _ => .partj (xbot || yj) xtop
  | .partk xbot xtop, .bot _ _ yk => .partk (xbot || yk) xtop
  | .parti _ xtop, .partj _ ytop => .top xtop ytop false
  | .partj _ xtop, .parti _ ytop => .top ytop xtop false
  | .parti _ xtop, .partk _ ytop => .top xtop false ytop
  | .partk _ xtop, .parti _ ytop => .top ytop false xtop
  | .partj _ xtop, .partk _ ytop => .top false xtop ytop
  | .partk _ xtop, .partj _ ytop => .top false ytop xtop

instance : Lattice FreeModLatThree where
  inf := inf
  inf_le_left := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, inf]
  inf_le_right := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, inf]
  le_inf := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, inf]
  sup := sup
  le_sup_left := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, sup]
  le_sup_right := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, sup]
  sup_le := by grind [cases FreeModLatThree, le_def, ble, Bool.le_iff_imp, sup]

@[grind norm]
theorem inf_def : min = inf := rfl
theorem sup_def : max = sup := rfl

instance : BoundedOrder FreeModLatThree where
  bot := .bot false false false
  bot_le := by decide
  top := .top true true true
  le_top := by decide

instance : IsModularLattice FreeModLatThree where
  sup_inf_le_assoc_of_le := by decide +kernel

/--
The unique order reversing equivalence on `FreeModLatThree` which preserves the three generators.
-/
def flip (x : FreeModLatThree) : FreeModLatThree :=
  match x with
  | .top xi xj xk => .bot (!xi) (!xj) (!xk)
  | .parti xbot xtop => .parti (!xtop) (!xbot)
  | .partj xbot xtop => .partj (!xtop) (!xbot)
  | .partk xbot xtop => .partk (!xtop) (!xbot)
  | .bot xi xj xk => .top (!xi) (!xj) (!xk)

@[simp]
theorem flip_gen : flip gen = gen := rfl

@[simp]
theorem flip_flip (x : FreeModLatThree) : flip (flip x) = x := by
  decide +revert

@[simp]
theorem flip_le_flip {x y : FreeModLatThree} : flip x ≤ flip y ↔ y ≤ x := by
  decide +revert

/-- `FreeModLatThree.flip`, as an `OrderIso` between `FreeModLatThree` and `FreeModLatThreeᵒᵈ`. -/
@[simps]
def flipOrderIso : FreeModLatThree ≃o FreeModLatThreeᵒᵈ where
  toFun x := OrderDual.toDual (flip x)
  invFun x := flip (OrderDual.ofDual x)
  left_inv _ := by simp
  right_inv _ := by simp
  map_rel_iff' := by simp

@[simp] theorem flip_top : flip ⊤ = ⊥ := rfl
@[simp] theorem flip_bot : flip ⊥ = ⊤ := rfl
@[simp] theorem flip_inf (x y : FreeModLatThree) : flip (x ⊓ y) = flip x ⊔ flip y :=
  OrderDual.toDual_inj.1 (map_inf flipOrderIso x y)
@[simp] theorem flip_sup (x y : FreeModLatThree) : flip (x ⊔ y) = flip x ⊓ flip y :=
  OrderDual.toDual_inj.1 (map_sup flipOrderIso x y)

/-- Order isomorphism which swaps the generators `gen` and `cycle gen`. -/
def swap (x : FreeModLatThree) : FreeModLatThree :=
  match x with
  | .top xi xj xk => .top xj xi xk
  | .parti xbot xtop => .partj xbot xtop
  | .partj xbot xtop => .parti xbot xtop
  | .partk xbot xtop => .partk xbot xtop
  | .bot xi xj xk => .bot xj xi xk

@[simp]
theorem flip_swap (x : FreeModLatThree) : flip (swap x) = swap (flip x) := by
  decide +revert

@[simp]
theorem swap_swap (x : FreeModLatThree) : swap (swap x) = x := by
  decide +revert

@[simp]
theorem swap_le_swap {x y : FreeModLatThree} : swap x ≤ swap y ↔ x ≤ y := by
  decide +revert

/-- `FreeModLatThree.swap`, as an `OrderIso`. -/
@[simps]
def swapOrderIso : FreeModLatThree ≃o FreeModLatThree where
  toFun := swap
  invFun := swap
  left_inv _ := by simp
  right_inv _ := by simp
  map_rel_iff' := by simp

@[simp] theorem swap_top : swap ⊤ = ⊤ := rfl
@[simp] theorem swap_bot : swap ⊥ = ⊥ := rfl
@[simp] theorem swap_inf (x y : FreeModLatThree) : swap (x ⊓ y) = swap x ⊓ swap y :=
  map_inf swapOrderIso x y
@[simp] theorem swap_sup (x y : FreeModLatThree) : swap (x ⊔ y) = swap x ⊔ swap y :=
  map_sup swapOrderIso x y

/-- Permute the three generators in a 3-cycle. The generators are
`gen`, `cycle gen`, and `cycle (cycle gen)`, and `∀ x, cycle (cycle (cycle x)) = x`. -/
def cycle (x : FreeModLatThree) : FreeModLatThree :=
  match x with
  | .top xi xj xk => .top xk xi xj
  | .parti xbot xtop => .partj xbot xtop
  | .partj xbot xtop => .partk xbot xtop
  | .partk xbot xtop => .parti xbot xtop
  | .bot xi xj xk => .bot xk xi xj

@[simp]
theorem flip_cycle (x : FreeModLatThree) : flip (cycle x) = cycle (flip x) := by
  decide +revert

theorem swap_cycle (x : FreeModLatThree) : swap (cycle x) = cycle (cycle (swap x)) := by
  decide +revert

@[simp]
theorem cycle_swap (x : FreeModLatThree) : cycle (swap x) = swap (cycle (cycle x)) := by
  decide +revert

@[simp]
theorem cycle_cycle_cycle (x : FreeModLatThree) : cycle (cycle (cycle x)) = x := by
  decide +revert

@[simp]
theorem cycle_le_cycle {x y : FreeModLatThree} : cycle x ≤ cycle y ↔ x ≤ y := by
  decide +revert

/-- `FreeModLatThree.cycle`, as an `OrderIso`. -/
@[simps]
def cycleOrderIso : FreeModLatThree ≃o FreeModLatThree where
  toFun := cycle
  invFun := cycle ∘ cycle
  left_inv _ := by simp
  right_inv _ := by simp
  map_rel_iff' := by simp

@[simp] theorem cycle_top : cycle ⊤ = ⊤ := rfl
@[simp] theorem cycle_bot : cycle ⊥ = ⊥ := rfl
@[simp] theorem cycle_inf (x y : FreeModLatThree) : cycle (x ⊓ y) = cycle x ⊓ cycle y :=
  map_inf cycleOrderIso x y
@[simp] theorem cycle_sup (x y : FreeModLatThree) : cycle (x ⊔ y) = cycle x ⊔ cycle y :=
  map_sup cycleOrderIso x y

@[simp] theorem swap_gen : swap gen = cycle gen := rfl
@[simp] theorem swap_cycle_gen : swap (cycle gen) = gen := rfl
@[simp] theorem swap_cycle_cycle_gen : swap (cycle (cycle gen)) = cycle (cycle gen) := rfl

section lift

/-- Given elements `i`, `j`, `k` in a modular lattice `α`, construct the unique lattice homomorphism
sending the three generators of `FreeModLatThree` to `i`, `j`, and `k`. Prefer using
`liftEquiv` instead. -/
def liftFun {α : Type*} [Lattice α] [IsModularLattice α] (i j k : α) (x : FreeModLatThree) : α :=
  match x with
  | .top true true true => i ⊔ j ⊔ k
  | .top false true true => j ⊔ k
  | .top true false true => i ⊔ k
  | .top true true false => i ⊔ j
  | .top true false false => (i ⊔ j) ⊓ (i ⊔ k)
  | .top false true false => (i ⊔ j) ⊓ (j ⊔ k)
  | .top false false true => (i ⊔ k) ⊓ (j ⊔ k)
  | .top false false false => (i ⊔ j) ⊓ (i ⊔ k) ⊓ (j ⊔ k)
  | .parti true true => i ⊔ (j ⊓ k)
  | .parti false true => i
  | .parti true false => i ⊓ (j ⊔ k) ⊔ (j ⊓ k)
  | .parti false false => i ⊓ (j ⊔ k)
  | .partj true true => j ⊔ (i ⊓ k)
  | .partj false true => j
  | .partj true false => j ⊓ (i ⊔ k) ⊔ (i ⊓ k)
  | .partj false false => j ⊓ (i ⊔ k)
  | .partk true true => k ⊔ (i ⊓ j)
  | .partk false true => k
  | .partk true false => k ⊓ (i ⊔ j) ⊔ (i ⊓ j)
  | .partk false false => k ⊓ (i ⊔ j)
  | .bot true true true => (i ⊓ j) ⊔ (i ⊓ k) ⊔ (j ⊓ k)
  | .bot false true true => (i ⊓ j) ⊔ (i ⊓ k)
  | .bot true false true => (i ⊓ j) ⊔ (j ⊓ k)
  | .bot true true false => (i ⊓ k) ⊔ (j ⊓ k)
  | .bot true false false => j ⊓ k
  | .bot false true false => i ⊓ k
  | .bot false false true => i ⊓ j
  | .bot false false false => i ⊓ j ⊓ k

variable {α : Type*} [Lattice α] [IsModularLattice α]

theorem toDual_liftFun (i j k : α) (x : FreeModLatThree) :
    OrderDual.toDual (liftFun i j k x) =
      liftFun (OrderDual.toDual i) (OrderDual.toDual j) (OrderDual.toDual k) (flip x) := by
  have hd (x y z : αᵒᵈ) : x ⊓ (y ⊔ z) ⊔ (y ⊓ z) = (x ⊔ (y ⊓ z)) ⊓ (y ⊔ z) := by
    rw [sup_comm, ← sup_inf_assoc_of_le x inf_le_sup, sup_comm]
  casesm* FreeModLatThree, Bool <;> simp [flip, liftFun] <;> simp [hd]

private theorem liftFun_swap (i j k : α) (x : FreeModLatThree) :
    liftFun i j k (swap x) = liftFun j i k x := by
  casesm* FreeModLatThree, Bool <;> simp only [swap, liftFun] <;> order

private theorem liftFun_cycle (i j k : α) (x : FreeModLatThree) :
    liftFun i j k (cycle x) = liftFun j k i x := by
  casesm* FreeModLatThree, Bool <;> simp only [cycle, liftFun] <;> order

private theorem liftFun_inf_bot (i j k : α) (xi xj xk yi yj yk : Bool) :
    liftFun i j k (bot xi xj xk ⊓ bot yi yj yk) =
      liftFun i j k (bot xi xj xk) ⊓ liftFun i j k (bot yi yj yk) := by
  casesm* Bool <;> simp only [inf_def, inf, liftFun, Bool.false_and, Bool.true_and] <;> order

private theorem liftFun_inf_top (i j k : α) (xi xj xk yi yj yk : Bool) :
    liftFun i j k (top xi xj xk ⊓ top yi yj yk) =
      liftFun i j k (top xi xj xk) ⊓ liftFun i j k (top yi yj yk) := by
  casesm* Bool <;> simp only [inf_def, inf, liftFun, Bool.false_and, Bool.true_and] <;> order

private theorem liftFun_inf_parti (i j k : α) (xbot xtop ybot ytop : Bool) :
    liftFun i j k (parti xbot xtop ⊓ parti ybot ytop) =
      liftFun i j k (parti xbot xtop) ⊓ liftFun i j k (parti ybot ytop) := by
  casesm* Bool <;> simp only [inf_def, inf, liftFun, Bool.false_and, Bool.true_and] <;> order

private theorem liftFun_inf_bot_top (i j k : α) (xi xj xk yi yj yk : Bool) :
    liftFun i j k (bot xi xj xk ⊓ top yi yj yk) =
      liftFun i j k (bot xi xj xk) ⊓ liftFun i j k (top yi yj yk) := by
  have ii₁ : bot xi xj xk ≤ bot true true true := by simp [le_def, ble]
  have ii₂ : top false false false ≤ top yi yj yk := by simp [le_def, ble]
  have ii₃ : bot true true true ≤ top false false false := by simp [le_def, ble]
  rw [inf_eq_left.2 (ii₁.trans (ii₃.trans ii₂)), eq_comm, inf_eq_left]
  rw [← inf_eq_left] at ii₁ ii₂
  calc liftFun i j k (bot xi xj xk)
    _ ≤ liftFun i j k (bot true true true) := by
      rw [← inf_eq_left, ← liftFun_inf_bot, ii₁]
    _ ≤ liftFun i j k (top false false false) := by
      rw [liftFun, liftFun]
      order
    _ ≤ liftFun i j k (top yi yj yk) := by
      rw [← inf_eq_left, ← liftFun_inf_top, ii₂]

private theorem liftFun_inf_bot_parti (i j k : α) (xi xj xk ybot ytop : Bool) :
    liftFun i j k (bot xi xj xk ⊓ parti ybot ytop) =
      liftFun i j k (bot xi xj xk) ⊓ liftFun i j k (parti ybot ytop) := by
  wlog h : xi = true ∧ xj = true ∧ xk = true generalizing xi xj xk ytop ybot with ih
  · specialize ih true true true ybot ytop ⟨rfl, rfl, rfl⟩
    have ii₁ : bot true true true ⊓ parti ybot ytop = bot ybot true true := by
      simp [inf_def, inf]
    have ii₂ : bot xi xj xk ⊓ parti ybot ytop = bot xi xj xk ⊓ bot ybot true true := by
      simp [inf_def, inf]
    have ii₃ : bot xi xj xk ⊓ bot true true true = bot xi xj xk := by
      simp [inf_def, inf]
    rw [ii₂, liftFun_inf_bot, ← ii₁, ih, ← inf_assoc, ← liftFun_inf_bot, ii₃]
  rcases h with ⟨rfl, rfl, rfl⟩
  cases ybot <;> cases ytop <;> (
    simp only [inf_def, inf, Bool.true_and, liftFun]
    rw [sup_inf_assoc_of_le (j ⊓ k) (by order)]
    order)

private theorem liftFun_inf_top_parti (i j k : α) (xi xj xk ybot ytop : Bool) :
    liftFun i j k (top xi xj xk ⊓ parti ybot ytop) =
      liftFun i j k (top xi xj xk) ⊓ liftFun i j k (parti ybot ytop) := by
  wlog h : ybot = true generalizing xi xj xk ytop ybot with ih
  · specialize ih xi xj xk true ytop rfl
    have ii₁ : top xi xj xk ⊓ parti ybot ytop = parti ybot true ⊓ parti true (xi && ytop) := by
      simp [inf_def, inf]
    have ii₂ : top xi xj xk ⊓ parti true ytop = parti true (xi && ytop) := by
      simp [inf_def, inf]
    have ii₃ : parti true ytop ⊓ parti ybot true = parti ybot ytop := by
      simp [inf_def, inf]
    rw [ii₁, liftFun_inf_parti, ← ii₂, ih, inf_rotate', ← liftFun_inf_parti, ii₃]
  rcases h with rfl
  have hd : i ⊓ (j ⊔ k) ⊔ (j ⊓ k) = (i ⊔ (j ⊓ k)) ⊓ (j ⊔ k) := by
    rw [sup_comm, ← sup_inf_assoc_of_le i inf_le_sup, sup_comm]
  casesm* Bool <;> simp only [inf_def, inf, Bool.false_and, Bool.true_and, liftFun] <;> order

private theorem liftFun_inf_parti_partj (i j k : α) (xbot xtop ybot ytop : Bool) :
    liftFun i j k (parti xbot xtop ⊓ partj ybot ytop) =
      liftFun i j k (parti xbot xtop) ⊓ liftFun i j k (partj ybot ytop) := by
  cases xbot with
  | false =>
    cases ybot with
    | false =>
      cases xtop <;> cases ytop <;> simp only [inf_def, inf, liftFun] <;> order
    | true =>
      cases xtop <;> cases ytop <;> simp only [inf_def, inf, liftFun] <;>
        rw [← inf_sup_assoc_of_le _ (by order)] <;> order
  | true =>
    cases ybot with
    | false =>
      cases xtop <;> cases ytop <;> (
        simp only [inf_def, inf, liftFun]
        conv_rhs => rw [← sup_comm (j ⊓ k), sup_inf_assoc_of_le _ (by order)]
        order)
    | true =>
      cases xtop <;> cases ytop <;> (
        simp only [inf_def, inf, liftFun]
        conv_rhs =>
          rw [← inf_sup_assoc_of_le _ (by order), ← sup_comm (j ⊓ k),
            sup_inf_assoc_of_le _ (by order)]
        order)

private theorem liftFun_inf (i j k : α) (x y : FreeModLatThree) :
    liftFun i j k (x ⊓ y) = liftFun i j k x ⊓ liftFun i j k y := by
  have hi (i j k : α) (xtop ytop : Bool) (y : FreeModLatThree) :
      liftFun i j k (parti xtop ytop ⊓ y) = liftFun i j k (parti xtop ytop) ⊓ liftFun i j k y := by
    cases y with
    | top => rw [inf_comm, liftFun_inf_top_parti, inf_comm]
    | parti => rw [liftFun_inf_parti]
    | partj => rw [liftFun_inf_parti_partj]
    | partk =>
      rw [← liftFun_cycle k i j, ← liftFun_cycle k i j, ← liftFun_cycle k i j]
      simp_rw [← cycleOrderIso_apply, map_inf, cycleOrderIso_apply, cycle]
      rw [inf_comm, liftFun_inf_parti_partj, inf_comm]
    | bot => rw [inf_comm, liftFun_inf_bot_parti, inf_comm]
  cases x with
  | top =>
    cases y with
    | top => rw [liftFun_inf_top]
    | parti => rw [liftFun_inf_top_parti]
    | partj =>
      rw [← liftFun_swap j i k, ← liftFun_swap j i k, ← liftFun_swap j i k]
      simp_rw [← swapOrderIso_apply, map_inf, swapOrderIso_apply, swap, liftFun_inf_top_parti]
    | partk =>
      rw [← liftFun_cycle k i j, ← liftFun_cycle k i j, ← liftFun_cycle k i j]
      simp_rw [← cycleOrderIso_apply, map_inf, cycleOrderIso_apply, cycle, liftFun_inf_top_parti]
    | bot => rw [inf_comm, liftFun_inf_bot_top, inf_comm]
  | parti => exact hi i j k _ _ _
  | partj =>
    rw [← liftFun_swap j i k, ← liftFun_swap j i k, ← liftFun_swap j i k]
    simp_rw [← swapOrderIso_apply, map_inf, swapOrderIso_apply, swap]
    exact hi j i k _ _ _
  | partk =>
    rw [← liftFun_cycle k i j, ← liftFun_cycle k i j, ← liftFun_cycle k i j]
    simp_rw [← cycleOrderIso_apply, map_inf, cycleOrderIso_apply, cycle]
    exact hi k i j _ _ _
  | bot =>
    cases y with
    | top => rw [liftFun_inf_bot_top]
    | parti => rw [liftFun_inf_bot_parti]
    | partj =>
      rw [← liftFun_swap j i k, ← liftFun_swap j i k, ← liftFun_swap j i k]
      simp_rw [← swapOrderIso_apply, map_inf, swapOrderIso_apply, swap, liftFun_inf_bot_parti]
    | partk =>
      rw [← liftFun_cycle k i j, ← liftFun_cycle k i j, ← liftFun_cycle k i j]
      simp_rw [← cycleOrderIso_apply, map_inf, cycleOrderIso_apply, cycle, liftFun_inf_bot_parti]
    | bot => rw [liftFun_inf_bot]

@[inherit_doc liftFun]
def lift (i j k : α) : LatticeHom FreeModLatThree α where
  toFun := liftFun i j k
  map_inf' := by exact liftFun_inf i j k
  map_sup' := by
    intro a b
    rw [← OrderDual.toDual_inj, toDual_sup, toDual_liftFun,
      toDual_liftFun, toDual_liftFun, ← liftFun_inf]
    congr
    rw [← OrderDual.toDual_inj, ← flipOrderIso_apply, map_sup,
      flipOrderIso_apply, flipOrderIso_apply, toDual_inf]

set_option linter.style.whitespace false in
@[simp ←]
theorem coe_lift (i j k : α) : lift i j k = liftFun i j k := rfl

/-- The equivalence expressing the universal property of `FreeModLatThree`. -/
def liftEquiv : α × α × α ≃ LatticeHom FreeModLatThree α where
  toFun x := lift x.1 x.2.1 x.2.2
  invFun f := (f gen, f (cycle gen), f (cycle (cycle gen)))
  left_inv := by
    intro x
    ext <;> rfl
  right_inv := by
    intro f
    ext x
    casesm* FreeModLatThree, Bool <;> (
      simp only [coe_lift, liftFun, ← map_sup, ← map_inf]
      refine congrArg f ?_
      rfl)

theorem coe_liftEquiv (x : α × α × α) :
    liftEquiv x = lift x.1 x.2.1 x.2.2 := rfl

set_option linter.style.whitespace false in
@[simp ←]
theorem coe_liftEquiv' (i j k : α) :
    liftEquiv (i, j, k) = lift i j k := rfl

@[simp]
theorem liftEquiv_apply_gen (x : α × α × α) : liftEquiv x gen = x.1 := rfl

@[simp]
theorem liftEquiv_apply_cycle (i j k : α) (x : FreeModLatThree) :
    liftEquiv (i, j, k) (cycle x) = liftEquiv (j, k, i) x := liftFun_cycle i j k x

@[simp]
theorem liftEquiv_apply_swap (i j k : α) (x : FreeModLatThree) :
    liftEquiv (i, j, k) (swap x) = liftEquiv (j, i, k) x := liftFun_swap i j k x

theorem toDual_liftEquiv_apply (i j k : α) (x : FreeModLatThree) :
    OrderDual.toDual (liftEquiv (i, j, k) x) =
      liftEquiv (OrderDual.toDual i, OrderDual.toDual j, OrderDual.toDual k) (flip x) :=
    toDual_liftFun i j k x

theorem liftEquiv_symm_apply (f : LatticeHom FreeModLatThree α) :
    liftEquiv.symm f = (f gen, f (cycle gen), f (cycle (cycle gen))) := rfl

end lift

end FreeModLatThree
