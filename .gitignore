# macOS leaves these files everywhere:
.DS_Store
# Created by `lake exe cache get` if no home directory is available
.cache
# `lake` stores its files here:
.lake
# Python bytecode cache directories
**/__pycache__/
# Progress file from scripts/rm_set_option.py
scripts/.rm_set_option_progress.jsonl
# Output directory for `lake exe no_expose`
scripts/.no_expose/
# Legacy output directory from the predecessor expose-report pipeline; left
# here so existing local checkouts don't see noisy untracked files after upgrade.
scripts/.expose_report/
