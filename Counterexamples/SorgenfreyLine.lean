/-- Ring homomorphism between the Sorgenfrey line and the standard real line. -/
def toReal : ‚ĄĚ‚āó ‚ČÉ+* ‚ĄĚ :=
  RingEquiv.refl ‚ĄĚ

instance : TopologicalSpace ‚ĄĚ‚āó :=
  TopologicalSpace.generateFrom {s : Set ‚ĄĚ‚āó | ‚ąÉ a b : ‚ĄĚ‚āó, Ico a b = s}

theorem isOpen_Ico (a b : ‚ĄĚ‚āó) : IsOpen (Ico a b) :=
  TopologicalSpace.GenerateOpen.basic _ ‚ü®a, b, rfl‚ü©

theorem isOpen_Ici (a : ‚ĄĚ‚āó) : IsOpen (Ici a) :=
  iUnion_Ico_right a ‚Ėł isOpen_iUnion (isOpen_Ico a)

theorem nhds_basis_Ico (a : ‚ĄĚ‚āó) : (ūĚďĚ a).HasBasis (a < ¬∑) (Ico a ¬∑) := by
  rw [TopologicalSpace.nhds_generateFrom]
  haveI : Nonempty { x // x ‚Č§ a } := Set.nonempty_Iic_subtype
  have : (‚®Ö x : { i // i ‚Č§ a }, ūĚďü (Ici ‚ÜĎx)) = ūĚďü (Ici a) := by
    refine (IsLeast.isGLB ?_).iInf_eq
    exact ‚ü®‚ü®‚ü®a, le_rfl‚ü©, rfl‚ü©, forall_mem_range.2 fun b => principal_mono.2 <| Ici_subset_Ici.2 b.2‚ü©
  simp only [mem_setOf_eq, iInf_and, iInf_exists, @iInf_comm _ (_ ‚ąą _), @iInf_comm _ (Set ‚ĄĚ‚āó),
    iInf_iInf_eq_right, mem_Ico]
  simp_rw [@iInf_comm _ ‚ĄĚ‚āó (_ ‚Č§ _), iInf_subtype', ‚Üź Ici_inter_Iio, ‚Üź inf_principal,
    ‚Üź inf_iInf, ‚Üź iInf_inf, this, iInf_subtype]
  suffices (‚®Ö x ‚ąą Ioi a, ūĚďü (Iio x)).HasBasis (a < ¬∑) Iio from this.principal_inf _
  refine hasBasis_biInf_principal ?_ nonempty_Ioi
  exact directedOn_iff_directed.2 <| Monotone.directed_ge fun x y hxy ‚Ü¶ Iio_subset_Iio hxy

theorem nhds_basis_Ico_rat (a : ‚ĄĚ‚āó) :
    (ūĚďĚ a).HasCountableBasis (fun r : ‚Ąö => a < r) fun r => Ico a r := by
  refine ‚ü®(nhds_basis_Ico a).to_hasBasis (fun b hb => ?_) fun r hr => ‚ü®_, hr, Subset.rfl‚ü©,
    Set.to_countable _‚ü©
  rcases exists_rat_btwn hb with ‚ü®r, har, hrb‚ü©
  exact ‚ü®r, har, Ico_subset_Ico_right hrb.le‚ü©

theorem nhds_basis_Ico_inv_pnat (a : ‚ĄĚ‚āó) :
    (ūĚďĚ a).HasBasis (fun _ : ‚Ąē+ => True) fun n => Ico a (a + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) := by
  refine (nhds_basis_Ico a).to_hasBasis (fun b hb => ?_) fun n hn =>
    ‚ü®_, lt_add_of_pos_right _ (inv_pos.2 <| Nat.cast_pos.2 n.pos), Subset.rfl‚ü©
  rcases exists_nat_one_div_lt (sub_pos.2 hb) with ‚ü®k, hk‚ü©
  rw [one_div] at hk
  rw [‚Üź Nat.cast_add_one] at hk
  exact ‚ü®k.succPNat, trivial, Ico_subset_Ico_right (le_sub_iff_add_le'.1 hk.le)‚ü©

theorem nhds_countable_basis_Ico_inv_pnat (a : ‚ĄĚ‚āó) :
    (ūĚďĚ a).HasCountableBasis (fun _ : ‚Ąē+ => True) fun n => Ico a (a + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) :=
  ‚ü®nhds_basis_Ico_inv_pnat a, Set.to_countable _‚ü©

theorem nhds_antitone_basis_Ico_inv_pnat (a : ‚ĄĚ‚āó) :
    (ūĚďĚ a).HasAntitoneBasis fun n : ‚Ąē+ => Ico a (a + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) :=
  ‚ü®nhds_basis_Ico_inv_pnat a, monotone_const.Ico <| Antitone.const_add
    (fun k _l hkl => inv_anti‚āÄ (Nat.cast_pos.2 k.2)
      (Nat.mono_cast <| Subtype.coe_le_coe.2 hkl)) _‚ü©

theorem isOpen_iff {s : Set ‚ĄĚ‚āó} : IsOpen s ‚ÜĒ ‚ąÄ x ‚ąą s, ‚ąÉ y > x, Ico x y ‚äÜ s :=
  isOpen_iff_mem_nhds.trans <| forall‚āā_congr fun x _ => (nhds_basis_Ico x).mem_iff

theorem isClosed_iff {s : Set ‚ĄĚ‚āó} : IsClosed s ‚ÜĒ ‚ąÄ x, x ‚ąČ s ‚Üí ‚ąÉ y > x, Disjoint (Ico x y) s := by
  simp only [‚Üź isOpen_compl_iff, isOpen_iff, mem_compl_iff, subset_compl_iff_disjoint_right]

theorem exists_Ico_disjoint_closed {a : ‚ĄĚ‚āó} {s : Set ‚ĄĚ‚āó} (hs : IsClosed s) (ha : a ‚ąČ s) :
    ‚ąÉ b > a, Disjoint (Ico a b) s :=
  isClosed_iff.1 hs a ha

@[simp]
theorem map_toReal_nhds (a : ‚ĄĚ‚āó) : map toReal (ūĚďĚ a) = ūĚďĚ[‚Č•] toReal a := by
  refine ((nhds_basis_Ico a).map _).eq_of_same_basis ?_
  simpa only [toReal.image_eq_preimage_symm] using nhdsGE_basis_Ico (toReal a)

theorem nhds_eq_map (a : ‚ĄĚ‚āó) : ūĚďĚ a = map toReal.symm (ūĚďĚ[‚Č•] (toReal a)) := by
  simp_rw [‚Üź map_toReal_nhds, map_map, Function.comp_def, toReal.symm_apply_apply, map_id']

theorem nhds_eq_comap (a : ‚ĄĚ‚āó) : ūĚďĚ a = comap toReal (ūĚďĚ[‚Č•] (toReal a)) := by
  rw [‚Üź map_toReal_nhds, comap_map toReal.injective]

@[continuity]
theorem continuous_toReal : Continuous toReal :=
  continuous_iff_continuousAt.2 fun x => by
    rw [ContinuousAt, Tendsto, map_toReal_nhds]
    exact inf_le_left

instance : OrderClosedTopology ‚ĄĚ‚āó :=
  ‚ü®isClosed_le_prod.preimage (continuous_toReal.prodMap continuous_toReal)‚ü©

instance : ContinuousAdd ‚ĄĚ‚āó := by
  refine ‚ü®continuous_iff_continuousAt.2 ?_‚ü©
  rintro ‚ü®x, y‚ü©
  rw [ContinuousAt, nhds_prod_eq, nhds_eq_comap (x + y), tendsto_comap_iff,
    nhds_eq_map, nhds_eq_map, prod_map_map_eq, ‚Üź nhdsWithin_prod_eq, Ici_prod_Ici]
  exact (continuous_add.tendsto _).inf (MapsTo.tendsto fun x hx => add_le_add hx.1 hx.2)

theorem isClopen_Ici (a : ‚ĄĚ‚āó) : IsClopen (Ici a) :=
  ‚ü®isClosed_Ici, isOpen_Ici a‚ü©

theorem isClopen_Iio (a : ‚ĄĚ‚āó) : IsClopen (Iio a) := by
  simpa only [compl_Ici] using (isClopen_Ici a).compl

theorem isClopen_Ico (a b : ‚ĄĚ‚āó) : IsClopen (Ico a b) :=
  (isClopen_Ici a).inter (isClopen_Iio b)

instance : TotallyDisconnectedSpace ‚ĄĚ‚āó :=
  ‚ü®fun _ _ hs x hx y hy =>
    le_antisymm (hs.subset_isClopen (isClopen_Ici x) ‚ü®x, hx, self_mem_Ici‚ü© hy)
      (hs.subset_isClopen (isClopen_Ici y) ‚ü®y, hy, self_mem_Ici‚ü© hx)‚ü©

instance : FirstCountableTopology ‚ĄĚ‚āó :=
  ‚ü®fun x => (nhds_basis_Ico_rat x).isCountablyGenerated‚ü©

/-- Sorgenfrey line is a completely normal topological space.
    (Hausdorff follows as TotallyDisconnectedSpace ‚Üí T‚āĀ) -/
instance : CompletelyNormalSpace ‚ĄĚ‚āó := by
  /-
  Let `s` and `t` be disjoint closed sets.
  For each `x ‚ąą s` we choose `X x` such that `Set.Ico x (X x)` is disjoint with `t`.
  Similarly, for each `y ‚ąą t` we choose `Y y` such that `Set.Ico y (Y y)` is disjoint with `s`.
  Then `‚čÉ x ‚ąą s, Ico x (X x)` and `‚čÉ y ‚ąą t, Ico y (Y y)` are
  disjoint open sets that include `s` and `t`.
  -/
  refine ‚ü®fun s t hd‚āĀ hd‚āā => ?_‚ü©
  choose! X hX hXd using fun x (hx : x ‚ąą s) =>
    exists_Ico_disjoint_closed isClosed_closure (disjoint_left.1 hd‚āā hx)
  choose! Y hY hYd using fun y (hy : y ‚ąą t) =>
    exists_Ico_disjoint_closed isClosed_closure (disjoint_right.1 hd‚āĀ hy)
  refine disjoint_of_disjoint_of_mem ?_
    (bUnion_mem_nhdsSet fun x hx => (isOpen_Ico x (X x)).mem_nhds <| left_mem_Ico.2 (hX x hx))
    (bUnion_mem_nhdsSet fun y hy => (isOpen_Ico y (Y y)).mem_nhds <| left_mem_Ico.2 (hY y hy))
  simp only [disjoint_iUnion_left, disjoint_iUnion_right, Ico_disjoint_Ico]
  intro y hy x hx
  rcases le_total x y with hle | hle
  ¬∑ calc
      min (X x) (Y y) ‚Č§ X x := min_le_left _ _
      _ ‚Č§ y := (not_lt.1 fun hyx => (hXd x hx).le_bot ‚ü®‚ü®hle, hyx‚ü©, subset_closure hy‚ü©)
      _ ‚Č§ max x y := le_max_right _ _
  ¬∑ calc
      min (X x) (Y y) ‚Č§ Y y := min_le_right _ _
      _ ‚Č§ x := (not_lt.1 fun hxy => (hYd y hy).le_bot ‚ü®‚ü®hle, hxy‚ü©, subset_closure hx‚ü©)
      _ ‚Č§ max x y := le_max_left _ _

theorem denseRange_ratCast : DenseRange ((‚ÜĎ) : ‚Ąö ‚Üí ‚ĄĚ‚āó) := by
  refine dense_iff_inter_open.2 ?_
  rintro U Uo ‚ü®x, hx‚ü©
  rcases isOpen_iff.1 Uo _ hx with ‚ü®y, hxy, hU‚ü©
  rcases exists_rat_btwn hxy with ‚ü®z, hxz, hzy‚ü©
  exact ‚ü®z, hU ‚ü®hxz.le, hzy‚ü©, mem_range_self _‚ü©

instance : SeparableSpace ‚ĄĚ‚āó :=
  ‚ü®‚ü®_, countable_range _, denseRange_ratCast‚ü©‚ü©

theorem isClosed_antidiagonal (c : ‚ĄĚ‚āó) : IsClosed {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = c} :=
  isClosed_singleton.preimage continuous_add

theorem isClopen_Ici_prod (x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó) : IsClopen (Ici x) :=
  (Ici_prod_eq x).symm ‚Ėł (isClopen_Ici _).prod (isClopen_Ici _)

theorem cardinal_antidiagonal (c : ‚ĄĚ‚āó) : #{x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = c} = ūĚĒ† := by
  rw [‚Üź Cardinal.mk_real]
  exact Equiv.cardinal_eq ‚ü®fun x ‚Ü¶ toReal x.1.1,
    fun x ‚Ü¶ ‚ü®(toReal.symm x, c - toReal.symm x), by simp‚ü©,
    fun ‚ü®x, hx‚ü© ‚Ü¶ by ext <;> simp [‚Üź hx.out], fun x ‚Ü¶ rfl‚ü©

/-- Any subset of an antidiagonal `{(x, y) : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó| x + y = c}` is a closed set. -/
theorem isClosed_of_subset_antidiagonal {s : Set (‚ĄĚ‚āó √ó ‚ĄĚ‚āó)} {c : ‚ĄĚ‚āó} (hs : ‚ąÄ x ‚ąą s, x.1 + x.2 = c) :
    IsClosed s := by
  rw [‚Üź closure_subset_iff_isClosed]
  rintro ‚ü®x, y‚ü© H
  obtain rfl : x + y = c := by
    change (x, y) ‚ąą {p : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | p.1 + p.2 = c}
    exact closure_minimal (hs : s ‚äÜ {x | x.1 + x.2 = c}) (isClosed_antidiagonal c) H
  rcases mem_closure_iff.1 H (Ici (x, y)) (isClopen_Ici_prod _).2 self_mem_Ici with
    ‚ü®‚ü®x', y'‚ü©, ‚ü®hx : x ‚Č§ x', hy : y ‚Č§ y'‚ü©, H‚ü©
  convert H
  ¬∑ refine hx.antisymm ?_
    rwa [‚Üź add_le_add_iff_right, hs _ H, add_le_add_iff_left]
  ¬∑ refine hy.antisymm ?_
    rwa [‚Üź add_le_add_iff_left, hs _ H, add_le_add_iff_right]

open Subtype in
instance (c : ‚ĄĚ‚āó) : DiscreteTopology {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = c} :=
  discreteTopology_iff_forall_isClosed.2 fun C ‚Ü¶ isClosed_induced_iff.2
    ‚ü®val '' C, isClosed_of_subset_antidiagonal <| coe_image_subset _ C,
