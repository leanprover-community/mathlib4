/-- The Sorgenfrey plane `‚ĄĚ‚āó √ó ‚ĄĚ‚āó` is not a normal space. -/
theorem not_normalSpace_prod : ¬¨NormalSpace (‚ĄĚ‚āó √ó ‚ĄĚ‚āó) :=
  (isClosed_antidiagonal 0).not_normal_of_continuum_le_mk (cardinal_antidiagonal _).ge

/-- An antidiagonal is a separable set but is not a separable space. -/
theorem isSeparable_antidiagonal (c : ‚ĄĚ‚āó) : IsSeparable {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = c} :=
  .of_separableSpace _

/-- An antidiagonal is a separable set but is not a separable space. -/
theorem not_separableSpace_antidiagonal (c : ‚ĄĚ‚āó) :
    ¬¨SeparableSpace {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = c} := by
  rw [separableSpace_iff_countable, ‚Üź Cardinal.mk_le_aleph0_iff, cardinal_antidiagonal, not_le]
  exact Cardinal.aleph0_lt_continuum

theorem nhds_prod_antitone_basis_inv_pnat (x y : ‚ĄĚ‚āó) :
    (ūĚďĚ (x, y)).HasAntitoneBasis fun n : ‚Ąē+ => Ico x (x + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) √óňĘ Ico y (y + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) := by
  rw [nhds_prod_eq]
  exact (nhds_antitone_basis_Ico_inv_pnat x).prod (nhds_antitone_basis_Ico_inv_pnat y)

set_option backward.isDefEq.respectTransparency false in
/-- The sets of rational and irrational points of the antidiagonal `{(x, y) | x + y = 0}` cannot be
separated by open neighborhoods. This implies that `‚ĄĚ‚āó √ó ‚ĄĚ‚āó` is not a normal space. -/
theorem not_separatedNhds_rat_irrational_antidiag :
    ¬¨SeparatedNhds {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = 0 ‚ąß ‚ąÉ r : ‚Ąö, ‚ÜĎr = x.1}
    {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = 0 ‚ąß Irrational (toReal x.1)} := by
  have h‚āÄ : ‚ąÄ {n : ‚Ąē+}, 0 < (n : ‚ĄĚ)‚ĀĽ¬Ļ := inv_pos.2 (Nat.cast_pos.2 (PNat.pos _))
  have h‚āÄ' : ‚ąÄ {n : ‚Ąē+} {x : ‚ĄĚ}, x < x + (n : ‚ĄĚ)‚ĀĽ¬Ļ := lt_add_of_pos_right _ h‚āÄ
  /- Let `S` be the set of points `(x, y)` on the line `x + y = 0` such that `x` is rational.
    Let `T` be the set of points `(x, y)` on the line `x + y = 0` such that `x` is irrational.
    These sets are closed, see `SorgenfreyLine.isClosed_of_subset_antidiagonal`, and disjoint. -/
  set S := {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = 0 ‚ąß ‚ąÉ r : ‚Ąö, ‚ÜĎr = x.1}
  set T := {x : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó | x.1 + x.2 = 0 ‚ąß Irrational (toReal x.1)}
  -- Consider disjoint open sets `U ‚äá S` and `V ‚äá T`.
  rintro ‚ü®U, V, Uo, Vo, SU, TV, UV‚ü©
  /- For each point `(x, -x) ‚ąą T`, choose a neighborhood
    `Ico x (x + k‚ĀĽ¬Ļ) √óňĘ Ico (-x) (-x + k‚ĀĽ¬Ļ) ‚äÜ V`. -/
  have : ‚ąÄ x : ‚ĄĚ‚āó, Irrational (toReal x) ‚Üí
      ‚ąÉ k : ‚Ąē+, Ico x (x + (k : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) √óňĘ Ico (-x) (-x + (k : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) ‚äÜ V := fun x hx ‚Ü¶ by
    have hV : V ‚ąą ūĚďĚ (x, -x) := Vo.mem_nhds (@TV (x, -x) ‚ü®add_neg_cancel x, hx‚ü©)
    exact (nhds_prod_antitone_basis_inv_pnat _ _).mem_iff.1 hV
  choose! k hkV using this
  /- Since the set of irrational numbers is a dense Gőī set in the usual topology of `‚ĄĚ`, there
    exists `N > 0` such that the set `C N = {x : ‚ĄĚ | Irrational x ‚ąß k x = N}` is dense in a nonempty
    interval. In other words, the closure of this set has a nonempty interior. -/
  set C : ‚Ąē+ ‚Üí Set ‚ĄĚ := fun n => closure {x | Irrational x ‚ąß k (toReal.symm x) = n}
  have H : {x : ‚ĄĚ | Irrational x} ‚äÜ ‚čÉ n, C n := fun x hx =>
    mem_iUnion.2 ‚ü®_, subset_closure ‚ü®hx, rfl‚ü©‚ü©
  have Hd : Dense (‚čÉ n, interior (C n)) :=
    IsGőī.setOf_irrational.dense_iUnion_interior_of_closed dense_irrational
      (fun _ => isClosed_closure) H
  obtain ‚ü®N, hN‚ü© : ‚ąÉ n : ‚Ąē+, (interior <| C n).Nonempty := nonempty_iUnion.mp Hd.nonempty
  /- Choose a rational number `r` in the interior of the closure of `C N`, then choose `n ‚Č• N > 0`
    such that `Ico r (r + n‚ĀĽ¬Ļ) √ó Ico (-r) (-r + n‚ĀĽ¬Ļ) ‚äÜ U`. -/
  rcases Rat.denseRange_cast.exists_mem_open isOpen_interior hN with ‚ü®r, hr‚ü©
  have hrU : ((r, -r) : ‚ĄĚ‚āó √ó ‚ĄĚ‚āó) ‚ąą U := @SU (r, -r) ‚ü®add_neg_cancel _, r, rfl‚ü©
  obtain ‚ü®n, hnN, hn‚ü© :
      ‚ąÉ n, N ‚Č§ n ‚ąß Ico (r : ‚ĄĚ‚āó) (r + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) √óňĘ Ico (-r : ‚ĄĚ‚āó) (-r + (n : ‚ĄĚ‚āó)‚ĀĽ¬Ļ) ‚äÜ U :=
    ((nhds_prod_antitone_basis_inv_pnat _ _).hasBasis_ge N).mem_iff.1 (Uo.mem_nhds hrU)
  /- Finally, choose `x ‚ąą Ioo (r : ‚ĄĚ) (r + n‚ĀĽ¬Ļ) ‚ą© C N`. Then `(x, -r)` belongs both to `U` and `V`,
    so they are not disjoint. This contradiction completes the proof. -/
  obtain ‚ü®x, hxn, hx_irr, rfl‚ü© :
      ‚ąÉ x : ‚ĄĚ, x ‚ąą Ioo (r : ‚ĄĚ) (r + (n : ‚ĄĚ)‚ĀĽ¬Ļ) ‚ąß Irrational x ‚ąß k (toReal.symm x) = N := by
    have : (r : ‚ĄĚ) ‚ąą closure (Ioo (r : ‚ĄĚ) (r + (n : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
      rw [closure_Ioo h‚āÄ'.ne, left_mem_Icc]
      exact h‚āÄ'.le
    rcases mem_closure_iff_nhds.1 this _ (mem_interior_iff_mem_nhds.1 hr) with ‚ü®x', hx', hx'őĶ‚ü©
    exact mem_closure_iff.1 hx' _ isOpen_Ioo hx'őĶ
  refine UV.le_bot (?_ : (toReal.symm x, -(r : ‚ĄĚ‚āó)) ‚ąą _)
  refine ‚ü®hn ‚ü®?_, ?_‚ü©, hkV (toReal.symm x) hx_irr ‚ü®?_, ?_‚ü©‚ü©
  ¬∑ exact Ioo_subset_Ico_self hxn
  ¬∑ exact left_mem_Ico.2 h‚āÄ'
  ¬∑ exact left_mem_Ico.2 h‚āÄ'
