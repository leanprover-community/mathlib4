/-! ## Sabidussi coset graph -/

section ClayworthSabidussi

/-- The group generated by the two G₂(2) generators. -/
private def cGroup := Subgroup.closure (Set.range clayworthGens)

private noncomputable instance : MulAction cGroup (Fin 4032) :=
  MulAction.compHom _ cGroup.subtype

private noncomputable instance : GraphAction cGroup (Fin 4032) clayworthGraph where
  adj_smul g u v h := closureGraphAction clayworthGens
    (fun i => by match i with | 0 => exact clayworthGen1_adj | 1 => exact clayworthGen2_adj)
    g.1 g.2 u v h

private noncomputable instance : MulAction.IsPretransitive cGroup (Fin 4032) where
  exists_smul_eq x y :=
    ⟨⟨_, cGroup.mul_mem (applyWord'_mem clayworthGens _)
        (cGroup.inv_mem (applyWord'_mem clayworthGens _))⟩, by
      change ((applyWord' clayworthGens (clayworthWitnessWords x)).symm.trans
        (applyWord' clayworthGens (clayworthWitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' clayworthGens (clayworthWitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (clayworthWitness_correct x).symm]
      exact clayworthWitness_correct y⟩

/-- **The Clayworth graph is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 4032 cosets of C₃.
`Clayworth ≃g Sab(G₂(2), C₃, D)` with `4032 = 12096/3` vertices, genus 505. -/
noncomputable def clayworthSabidussiIso :
    clayworthGraph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer cGroup (0 : Fin 4032))
      (connectionSet cGroup clayworthGraph 0) (connectionSet.isConnectionSet 0) :=
  sabidussiIso 0

end ClayworthSabidussi
