/-! ## Graph definition via connection set -/

private def meinhold1344AdjBool (u v : Fin 1344) : Bool :=
  u ≠ v &&
  (let w := (applyWord' meinhold1344Gens (meinhold1344WitnessWords u)).symm v
   w == (5 : Fin 1344) || w == (18 : Fin 1344) || w == (60 : Fin 1344) || w == (341 : Fin 1344) || w == (379 : Fin 1344) || w == (636 : Fin 1344) || w == (779 : Fin 1344) || w == (827 : Fin 1344) || w == (1201 : Fin 1344))

/-- The Meinhold-1344 graph: 1344 vertices, 9-regular, girth 6. -/
def meinhold1344Graph : SimpleGraph (Fin 1344) where
  Adj u v := meinhold1344AdjBool u v
  symm u v := by simp only [meinhold1344AdjBool]; revert u v; native_decide
  loopless := ⟨fun u => by simp only [meinhold1344AdjBool]; revert u; native_decide⟩

instance meinhold1344DecAdj : DecidableRel meinhold1344Graph.Adj :=
  fun u v => inferInstanceAs (Decidable (meinhold1344AdjBool u v))

theorem meinhold1344Gen1_adj : ∀ u v : Fin 1344,
    meinhold1344Graph.Adj u v ↔ meinhold1344Graph.Adj (meinhold1344Gens 0 u) (meinhold1344Gens 0 v) := by
  native_decide

theorem meinhold1344Gen2_adj : ∀ u v : Fin 1344,
    meinhold1344Graph.Adj u v ↔ meinhold1344Graph.Adj (meinhold1344Gens 1 u) (meinhold1344Gens 1 v) := by
  native_decide

/-! ## Sabidussi coset graph proof -/

private def m1344Group := Subgroup.closure (Set.range meinhold1344Gens)

private noncomputable instance : MulAction m1344Group (Fin 1344) :=
  MulAction.compHom _ m1344Group.subtype

private noncomputable instance : GraphAction m1344Group (Fin 1344) meinhold1344Graph where
  adj_smul g u v h := closureGraphAction meinhold1344Gens
    (fun i => by match i with | 0 => exact meinhold1344Gen1_adj | 1 => exact meinhold1344Gen2_adj)
    g.1 g.2 u v h

set_option maxRecDepth 2048 in
private noncomputable instance : MulAction.IsPretransitive m1344Group (Fin 1344) where
  exists_smul_eq x y :=
    ⟨⟨_, m1344Group.mul_mem (applyWord'_mem meinhold1344Gens _)
        (m1344Group.inv_mem (applyWord'_mem meinhold1344Gens _))⟩, by
      change ((applyWord' meinhold1344Gens (meinhold1344WitnessWords x)).symm.trans
        (applyWord' meinhold1344Gens (meinhold1344WitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' meinhold1344Gens (meinhold1344WitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (meinhold1344Witness_correct x).symm]
      exact meinhold1344Witness_correct y⟩

/-- **Meinhold-1344 is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 1344 cosets of C₃×C₃.
`Meinhold-1344 ≃g Sab(G₂(2), C₃×C₃, D)` with `1344 = 12096/9` vertices. -/
noncomputable def meinhold1344SabidussiIso :
    meinhold1344Graph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer m1344Group (0 : Fin 1344))
      (connectionSet m1344Group meinhold1344Graph 0) (connectionSet.isConnectionSet 0) :=
  sabidussiIso 0

