/-- G₂(2) generators acting on the 72 Meinhold blocks (orders 3 and 6). -/
def meinhold72Gens : Fin 2 → Equiv.Perm (Fin 72)
  | 0 => {
    toFun := fun v => meinhold72Gen1Fwd[v.val]'(by have := meinhold72Gen1Fwd_size; omega)
    invFun := fun v => meinhold72Gen1Rev[v.val]'(by have := meinhold72Gen1Rev_size; omega)
    left_inv := by intro v; revert v; native_decide
    right_inv := by intro v; revert v; native_decide }
  | 1 => {
    toFun := fun v => meinhold72Gen2Fwd[v.val]'(by have := meinhold72Gen2Fwd_size; omega)
    invFun := fun v => meinhold72Gen2Rev[v.val]'(by have := meinhold72Gen2Rev_size; omega)
    left_inv := by intro v; revert v; native_decide
    right_inv := by intro v; revert v; native_decide }

