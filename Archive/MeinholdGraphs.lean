private def mGroup := Subgroup.closure (Set.range meinhold72Gens)

private noncomputable instance : MulAction mGroup (Fin 72) :=
  MulAction.compHom _ mGroup.subtype

private noncomputable instance : GraphAction mGroup (Fin 72) meinhold72Graph where
  adj_smul g u v h := closureGraphAction meinhold72Gens
    (fun i => by match i with | 0 => exact meinhold72Gen1_adj | 1 => exact meinhold72Gen2_adj)
    g.1 g.2 u v h

set_option maxRecDepth 2048 in
private noncomputable instance : MulAction.IsPretransitive mGroup (Fin 72) where
  exists_smul_eq x y :=
    ⟨⟨_, mGroup.mul_mem (applyWord'_mem meinhold72Gens _)
        (mGroup.inv_mem (applyWord'_mem meinhold72Gens _))⟩, by
      change ((applyWord' meinhold72Gens (meinhold72WitnessWords x)).symm.trans
        (applyWord' meinhold72Gens (meinhold72WitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' meinhold72Gens (meinhold72WitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (meinhold72Witness_correct x).symm]
      exact meinhold72Witness_correct y⟩

/-- **Meinhold-72 is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 72 cosets of PSL(3,2).
`Meinhold-72 ≃g Sab(G₂(2), PSL(3,2), D)` with `72 = 12096/168` vertices. -/
noncomputable def meinhold72SabidussiIso :
    meinhold72Graph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer mGroup (0 : Fin 72))
      (connectionSet mGroup meinhold72Graph 0) (connectionSet.isConnectionSet 0) :=
  sabidussiIso 0

/-- Every Meinhold-72 edge lifts to a Clayworth edge: for adjacent blocks a, b
    there exist vertices in those fibers that are adjacent in Clayworth.
    Together with `meinholdBlockMap_adj`, this makes the block map a full
    graph-theoretic quotient map. -/
theorem meinholdBlockMap_lifts {a b : Fin 72}
    (h : meinhold72Graph.Adj a b) :
    ∃ v w : Fin 4032, meinholdBlockMap v = a ∧ meinholdBlockMap w = b ∧
      clayworthGraph.Adj v w := by
  revert h; revert a b; native_decide

/-- Each fiber of the block map has exactly 56 vertices. -/
theorem meinholdBlockMap_fiber_card (b : Fin 72) :
    (Finset.univ.filter fun v : Fin 4032 => meinholdBlockMap v = b).card = 56 := by
  revert b; native_decide

