/-- A block map from Clayworth to a 63-vertex quotient graph. This is one of three
    G₂(2)-invariant 63-block partitions. -/
private theorem clayworth63BlockMapData_size : clayworth63BlockMapData.size = 4032 := by
  native_decide

def clayworth63BlockMap : Fin 4032 → Fin 63 :=
  fun v => clayworth63BlockMapData[v.val]'(by have := clayworth63BlockMapData_size; omega)

/-- The 63-block quotient has degree 32: each block has exactly 32 adjacent blocks.
    Since the Langer graph is 6-regular (189 edges), and this quotient has
    32 × 63 / 2 = 1008 edges, the Langer graph is not this quotient.
    By Lorimer's theorem, all quotients of an arc-transitive graph arise from
    block systems. There are exactly three 63-block systems for Clayworth;
    their quotient degrees are 24, 32, 32 — none equals 6. -/
theorem clayworth63BlockMap_degree :
    ∀ b : Fin 63, ((Finset.univ.filter fun b' : Fin 63 =>
      b ≠ b' ∧ ∃ v w : Fin 4032, clayworth63BlockMap v = b ∧
        clayworth63BlockMap w = b' ∧ clayworthGraph.Adj v w).card = 32) := by
  native_decide
