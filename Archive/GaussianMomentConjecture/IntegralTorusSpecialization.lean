import Archive.GaussianMomentConjecture.IntegralSpecialization
import Mathlib.Data.Complex.Basic
import Mathlib.RingTheory.FiniteType

/-!
# Integral torus specialization for GMC(2)

An integral polynomial system holding at a complex torus point can be
specialized to a torus point over a finite field while preserving a chosen
nonvanishing polynomial seed.

The proof forms the finite-type `ℤ`-subalgebra of `ℂ` generated by the point's
coordinates, their inverses, and the inverse of the evaluated seed.  Thus all
coordinates and the seed value are units before applying
`GMC2.IntegralSpecialization.exists_preserving_units`.  Since the resulting
specialization is a ring homomorphism, every polynomial relation is preserved.
-/

open Finset

namespace GMC2.IntegralTorusSpecialization

open GMC2.IntegralSpecialization

universe u

/-- **Finite-field specialization of an integral complex torus point.**

If `seed` is nonzero at `z`, then the data specialize to a finite field of
prime characteristic: every coordinate remains a unit and nonzero, every
integral polynomial zero relation at `z` still vanishes, and the seed remains
nonzero.  The universal relation clause is intentionally stronger than a
preselected family: it permits choosing a relation after the residue
characteristic is known. -/
theorem exists_finite_field_torus_specialization
    {ι : Type u} [Fintype ι]
    (z : ι → ℂ) (hz : ∀ i, z i ≠ 0)
    (seed : MvPolynomial ι ℤ)
    (hseed : MvPolynomial.aeval z seed ≠ 0) :
    ∃ (A : Subalgebra ℤ ℂ) (D : GMC2.IntegralSpecialization.ResidueData A)
      (w : ι → D.ResidueField),
      D.p.Prime ∧
      CharP D.ResidueField D.p ∧
      Finite D.ResidueField ∧
      IsField D.ResidueField ∧
      (∀ i, IsUnit (w i)) ∧
      (∀ i, w i ≠ 0) ∧
      (∀ f : MvPolynomial ι ℤ,
        MvPolynomial.aeval z f = 0 → MvPolynomial.aeval w f = 0) ∧
      MvPolynomial.aeval w seed ≠ 0 := by
  classical
  let seedValue : ℂ := MvPolynomial.aeval z seed
  let gens : Finset ℂ :=
    (Finset.univ.image z ∪ Finset.univ.image fun i => (z i)⁻¹) ∪
      {seedValue⁻¹}
  let A : Subalgebra ℤ ℂ := Algebra.adjoin ℤ (gens : Set ℂ)
  letI : Algebra ℤ A := Ring.toIntAlgebra A
  letI : Algebra.FiniteType ℤ A :=
    Algebra.FiniteType.adjoin_of_finite gens.finite_toSet
  have hzMem : ∀ i, z i ∈ A := by
    intro i
    apply Algebra.subset_adjoin
    simp [gens]
  have hzInvMem : ∀ i, (z i)⁻¹ ∈ A := by
    intro i
    apply Algebra.subset_adjoin
    simp [gens]
  have hseedInvMem : seedValue⁻¹ ∈ A := by
    apply Algebra.subset_adjoin
    simp [gens]
  let coord : ι → A := fun i => ⟨z i, hzMem i⟩
  let coordInv : ι → A := fun i => ⟨(z i)⁻¹, hzInvMem i⟩
  let evalA : MvPolynomial ι ℤ →ₐ[ℤ] A := MvPolynomial.aeval coord
  have hcoeEval : ∀ f : MvPolynomial ι ℤ,
      ((evalA f : A) : ℂ) = MvPolynomial.aeval z f := by
    intro f
    simpa [evalA, coord] using
      MvPolynomial.comp_aeval_apply (f := coord) (Subalgebra.val A) f
  have hcoordUnit : ∀ i, IsUnit (coord i) := by
    intro i
    apply isUnit_iff_exists_inv.mpr
    refine ⟨coordInv i, ?_⟩
    apply Subtype.ext
    simp [coord, coordInv, hz i]
  let seedA : A := evalA seed
  let seedInvA : A := ⟨seedValue⁻¹, hseedInvMem⟩
  have hseedUnit : IsUnit seedA := by
    apply isUnit_iff_exists_inv.mpr
    refine ⟨seedInvA, ?_⟩
    apply Subtype.ext
    change ((seedA : A) : ℂ) * seedValue⁻¹ = 1
    rw [show ((seedA : A) : ℂ) = seedValue by
      simpa [seedA, seedValue] using hcoeEval seed]
    exact mul_inv_cancel₀ (by simpa [seedValue] using hseed)
  let units : Option ι → A
    | none => seedA
    | some i => coord i
  have hunits : ∀ o : Option ι, IsUnit (units o) := by
    intro o
    cases o with
    | none => exact hseedUnit
    | some i => exact hcoordUnit i
  obtain ⟨D, hunitD, hnonzeroD⟩ :=
    GMC2.IntegralSpecialization.exists_preserving_units
      (A := A) (Finset.univ : Finset (Option ι)) units
      (by intro o _; exact hunits o)
  letI : Algebra ℤ D.ResidueField := Ring.toIntAlgebra D.ResidueField
  let w : ι → D.ResidueField := fun i => D.map (coord i)
  have hmapEval : ∀ f : MvPolynomial ι ℤ,
      MvPolynomial.eval₂ (Int.castRingHom D.ResidueField) w f =
        D.map (evalA f) := by
    intro f
    have hcomp : D.map.comp (Int.castRingHom A) = Int.castRingHom D.ResidueField :=
      RingHom.ext_int _ _
    simpa [w, evalA, MvPolynomial.aeval_def, algebraMap_int_eq, hcomp] using
      (MvPolynomial.map_aeval coord D.map f).symm
  refine ⟨A, D, w, D.prime, D.charP, D.finiteResidue,
    @Field.toIsField D.ResidueField D.fieldStructure, ?_, ?_, ?_, ?_⟩
  · intro i
    simpa [w, units] using hunitD (some i) (Finset.mem_univ _)
  · intro i
    simpa [w, units] using hnonzeroD (some i) (Finset.mem_univ _)
  · intro f hf
    have hfA : evalA f = 0 := by
      apply Subtype.ext
      simpa [hcoeEval] using hf
    change MvPolynomial.eval₂ (Int.castRingHom D.ResidueField) w f = 0
    rw [hmapEval f, hfA, map_zero]
  · change MvPolynomial.eval₂ (Int.castRingHom D.ResidueField) w seed ≠ 0
    rw [hmapEval seed]
    simpa [seedA, units] using hnonzeroD none (Finset.mem_univ _)

end GMC2.IntegralTorusSpecialization

