    ∀ v : Fin 2016, applyWord' meinhold2016Gens (meinhold2016WitnessWords v) 0 = v := by
  native_decide

/-! ## Graph definition via connection set -/

private def meinhold2016AdjBool (u v : Fin 2016) : Bool :=
  u ≠ v &&
  (let w := (applyWord' meinhold2016Gens (meinhold2016WitnessWords u)).symm v
   w == (5 : Fin 2016) || w == (18 : Fin 2016) || w == (60 : Fin 2016) || w == (408 : Fin 2016) || w == (742 : Fin 2016) || w == (1412 : Fin 2016))

/-- The Meinhold-2016 graph: 2016 vertices, 6-regular, girth 8. -/
def meinhold2016Graph : SimpleGraph (Fin 2016) where
  Adj u v := meinhold2016AdjBool u v
  symm u v := by simp only [meinhold2016AdjBool]; revert u v; native_decide
  loopless := ⟨fun u => by simp only [meinhold2016AdjBool]; revert u; native_decide⟩

instance meinhold2016DecAdj : DecidableRel meinhold2016Graph.Adj :=
  fun u v => inferInstanceAs (Decidable (meinhold2016AdjBool u v))

theorem meinhold2016Gen1_adj : ∀ u v : Fin 2016,
    meinhold2016Graph.Adj u v ↔ meinhold2016Graph.Adj (meinhold2016Gens 0 u) (meinhold2016Gens 0 v) := by
  native_decide

theorem meinhold2016Gen2_adj : ∀ u v : Fin 2016,
    meinhold2016Graph.Adj u v ↔ meinhold2016Graph.Adj (meinhold2016Gens 1 u) (meinhold2016Gens 1 v) := by
  native_decide

/-! ## Sabidussi coset graph proof -/

private def m2016Group := Subgroup.closure (Set.range meinhold2016Gens)

private noncomputable instance : MulAction m2016Group (Fin 2016) :=
  MulAction.compHom _ m2016Group.subtype

private noncomputable instance : GraphAction m2016Group (Fin 2016) meinhold2016Graph where
  adj_smul g u v h := closureGraphAction meinhold2016Gens
    (fun i => by match i with | 0 => exact meinhold2016Gen1_adj | 1 => exact meinhold2016Gen2_adj)
    g.1 g.2 u v h

set_option maxRecDepth 2048 in
private noncomputable instance : MulAction.IsPretransitive m2016Group (Fin 2016) where
  exists_smul_eq x y :=
    ⟨⟨_, m2016Group.mul_mem (applyWord'_mem meinhold2016Gens _)
        (m2016Group.inv_mem (applyWord'_mem meinhold2016Gens _))⟩, by
      change ((applyWord' meinhold2016Gens (meinhold2016WitnessWords x)).symm.trans
        (applyWord' meinhold2016Gens (meinhold2016WitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' meinhold2016Gens (meinhold2016WitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (meinhold2016Witness_correct x).symm]
      exact meinhold2016Witness_correct y⟩

/-- **Meinhold-2016 is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 2016 cosets of C₆.
`Meinhold-2016 ≃g Sab(G₂(2), C₆, D)` with `2016 = 12096/6` vertices. -/
noncomputable def meinhold2016SabidussiIso :
    meinhold2016Graph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer m2016Group (0 : Fin 2016))
