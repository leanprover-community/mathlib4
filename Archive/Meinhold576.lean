/-! ## Graph definition via connection set -/

/-- The Meinhold-576 graph: 576 vertices, 7-regular, girth 6.
    Adjacency is defined from the Sabidussi connection set: u is adjacent to v
    iff the group element mapping 0 to u also maps some element of D to v. -/
def meinhold576Graph : SimpleGraph (Fin 576) where
  Adj u v :=
    u ≠ v ∧
    let σ_inv := (applyWord' meinhold576Gens (meinhold576WitnessWords u)).symm
    let w := σ_inv v
    w = (2 : Fin 576) ∨ w = 5 ∨ w = 17 ∨ w = 128 ∨ w = 137 ∨ w = 222 ∨ w = 275
  symm u v := by simp only; revert u v; native_decide
  loopless := ⟨fun u => by simp only; revert u; native_decide⟩

instance meinhold576DecAdj : DecidableRel meinhold576Graph.Adj :=
  fun u v => inferInstance

theorem meinhold576Gen1_adj : ∀ u v : Fin 576,
    meinhold576Graph.Adj u v ↔ meinhold576Graph.Adj (meinhold576Gens 0 u) (meinhold576Gens 0 v) := by
  native_decide

theorem meinhold576Gen2_adj : ∀ u v : Fin 576,
    meinhold576Graph.Adj u v ↔ meinhold576Graph.Adj (meinhold576Gens 1 u) (meinhold576Gens 1 v) := by
  native_decide

/-! ## Sabidussi coset graph proof -/

private def m576Group := Subgroup.closure (Set.range meinhold576Gens)

private noncomputable instance : MulAction m576Group (Fin 576) :=
  MulAction.compHom _ m576Group.subtype

private noncomputable instance : GraphAction m576Group (Fin 576) meinhold576Graph where
  adj_smul g u v h := closureGraphAction meinhold576Gens
    (fun i => by match i with | 0 => exact meinhold576Gen1_adj | 1 => exact meinhold576Gen2_adj)
    g.1 g.2 u v h

set_option maxRecDepth 2048 in
private noncomputable instance : MulAction.IsPretransitive m576Group (Fin 576) where
  exists_smul_eq x y :=
    ⟨⟨_, m576Group.mul_mem (applyWord'_mem meinhold576Gens _)
        (m576Group.inv_mem (applyWord'_mem meinhold576Gens _))⟩, by
      change ((applyWord' meinhold576Gens (meinhold576WitnessWords x)).symm.trans
        (applyWord' meinhold576Gens (meinhold576WitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' meinhold576Gens (meinhold576WitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (meinhold576Witness_correct x).symm]
      exact meinhold576Witness_correct y⟩

/-- **Meinhold-576 is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 576 cosets of C₇:C₃.
`Meinhold-576 ≃g Sab(G₂(2), C₇:C₃, D)` with `576 = 12096/21` vertices. -/
noncomputable def meinhold576SabidussiIso :
    meinhold576Graph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer m576Group (0 : Fin 576))
      (connectionSet m576Group meinhold576Graph 0) (connectionSet.isConnectionSet 0) :=
  sabidussiIso 0

