theorem meinhold576_triangleFree :
    ∀ u v w : Fin 576, meinhold576Graph.Adj u v → meinhold576Graph.Adj v w →
      meinhold576Graph.Adj u w → False := by
  native_decide

/-- Meinhold-576 has a 6-cycle (girth ≤ 6, combined with triangle-free gives girth ≥ 4). -/
theorem meinhold576_has_6cycle :
    ∃ a b c d e f : Fin 576,
      a ≠ d ∧ b ≠ e ∧ c ≠ f ∧
      meinhold576Graph.Adj a b ∧ meinhold576Graph.Adj b c ∧
      meinhold576Graph.Adj c d ∧ meinhold576Graph.Adj d e ∧
      meinhold576Graph.Adj e f ∧ meinhold576Graph.Adj f a := by
  exact ⟨0, 128, 386, 238, 114, 17,
    by native_decide, by native_decide, by native_decide,
    by native_decide, by native_decide, by native_decide,
    by native_decide, by native_decide, by native_decide⟩
