/-- The dual of the Klein quartic surface is 7-regular. -/
theorem kleinSurface_dual_regular :
    ∀ v : Fin 24,
      (Finset.univ.filter fun w => kleinSurface.toDualSimpleGraph.Adj v w).card = 7 := by
  sorry
