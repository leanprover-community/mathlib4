/-! ## Graph definition via connection set -/

private def meinhold504AdjBool (u v : Fin 504) : Bool :=
  u ≠ v &&
  (let w := (applyWord' meinhold504Gens (meinhold504WitnessWords u)).symm v
   w == (5 : Fin 504) || w == (18 : Fin 504) || w == (43 : Fin 504) || w == (56 : Fin 504) || w == (59 : Fin 504) || w == (126 : Fin 504) || w == (138 : Fin 504) || w == (143 : Fin 504) || w == (152 : Fin 504) || w == (154 : Fin 504) || w == (233 : Fin 504) || w == (242 : Fin 504) || w == (260 : Fin 504) || w == (263 : Fin 504) || w == (267 : Fin 504) || w == (279 : Fin 504) || w == (296 : Fin 504) || w == (302 : Fin 504) || w == (320 : Fin 504) || w == (332 : Fin 504) || w == (365 : Fin 504) || w == (396 : Fin 504) || w == (437 : Fin 504) || w == (499 : Fin 504))

/-- The Meinhold-504 graph: 504 vertices, 24-regular, girth 4. -/
def meinhold504Graph : SimpleGraph (Fin 504) where
  Adj u v := meinhold504AdjBool u v
  symm u v := by simp only [meinhold504AdjBool]; revert u v; native_decide
  loopless := ⟨fun u => by simp only [meinhold504AdjBool]; revert u; native_decide⟩

instance meinhold504DecAdj : DecidableRel meinhold504Graph.Adj :=
  fun u v => inferInstanceAs (Decidable (meinhold504AdjBool u v))

theorem meinhold504Gen1_adj : ∀ u v : Fin 504,
    meinhold504Graph.Adj u v ↔ meinhold504Graph.Adj (meinhold504Gens 0 u) (meinhold504Gens 0 v) := by
  native_decide

theorem meinhold504Gen2_adj : ∀ u v : Fin 504,
    meinhold504Graph.Adj u v ↔ meinhold504Graph.Adj (meinhold504Gens 1 u) (meinhold504Gens 1 v) := by
  native_decide

/-! ## Sabidussi coset graph proof -/

private def m504Group := Subgroup.closure (Set.range meinhold504Gens)

private noncomputable instance : MulAction m504Group (Fin 504) :=
  MulAction.compHom _ m504Group.subtype

private noncomputable instance : GraphAction m504Group (Fin 504) meinhold504Graph where
  adj_smul g u v h := closureGraphAction meinhold504Gens
    (fun i => by match i with | 0 => exact meinhold504Gen1_adj | 1 => exact meinhold504Gen2_adj)
    g.1 g.2 u v h

set_option maxRecDepth 2048 in
private noncomputable instance : MulAction.IsPretransitive m504Group (Fin 504) where
  exists_smul_eq x y :=
    ⟨⟨_, m504Group.mul_mem (applyWord'_mem meinhold504Gens _)
        (m504Group.inv_mem (applyWord'_mem meinhold504Gens _))⟩, by
      change ((applyWord' meinhold504Gens (meinhold504WitnessWords x)).symm.trans
        (applyWord' meinhold504Gens (meinhold504WitnessWords y))) x = y
      simp only [Equiv.trans_apply]
      rw [show (applyWord' meinhold504Gens (meinhold504WitnessWords x)).symm x = 0 from by
        rw [Equiv.symm_apply_eq]; exact (meinhold504Witness_correct x).symm]
      exact meinhold504Witness_correct y⟩

/-- **Meinhold-504 is a Sabidussi coset graph.**

G₂(2) acts vertex-transitively on the 504 cosets of S₄.
`Meinhold-504 ≃g Sab(G₂(2), S₄, D)` with `504 = 12096/24` vertices. -/
noncomputable def meinhold504SabidussiIso :
    meinhold504Graph ≃g SimpleGraph.cosetGraph (MulAction.stabilizer m504Group (0 : Fin 504))
      (connectionSet m504Group meinhold504Graph 0) (connectionSet.isConnectionSet 0) :=
  sabidussiIso 0

/-! ## Properties -/

/-- Meinhold-504 is connected. -/
theorem meinhold504_connected : meinhold504Graph.Connected := by native_decide

/-- Meinhold-504 has no triangles. -/
theorem meinhold504_triangleFree :
    ∀ u v w : Fin 504, meinhold504Graph.Adj u v → meinhold504Graph.Adj v w →
      meinhold504Graph.Adj u w → False := by
  native_decide

/-- Meinhold-504 has a 4-cycle (girth = 4). -/
theorem meinhold504_has_4cycle :
    ∃ a b c d : Fin 504,
      a ≠ c ∧ b ≠ d ∧
      meinhold504Graph.Adj a b ∧ meinhold504Graph.Adj b c ∧
      meinhold504Graph.Adj c d ∧ meinhold504Graph.Adj d a := by
  exact ⟨0, 5, 264, 138, by native_decide, by native_decide,
    by native_decide, by native_decide, by native_decide, by native_decide⟩
