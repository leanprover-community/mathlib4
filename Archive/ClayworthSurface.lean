/-! ## The CellularSurface instance -/

/-- The Clayworth Surface (G₂(2)/C₃) as a CellularSurface.
    4032 vertices, 6048 edges, 1008 faces of size 12, genus 505. -/
def clayworthSurface : CellularSurface where
  nV := 4032
  nE := 6048
  nF := 1008
  edge_src := arrayToFin₂ ClayworthSurface_edge_src_data ClayworthSurface_edge_src_size
  edge_tgt := arrayToFin₂ ClayworthSurface_edge_tgt_data ClayworthSurface_edge_tgt_size
  edge_ne := by native_decide
  face_len := fun _ => 12
  face_len_pos := fun _ => by norm_num
  face_edge := fun f i =>
    have := ClayworthSurface_face_edge_size
    ClayworthSurface_face_edge_data[f.val * 12 + i.val]'(by omega)
  face_dir := fun f i =>
    have := ClayworthSurface_face_dir_size
    ClayworthSurface_face_dir_data[f.val * 12 + i.val]'(by omega)
  face_inj := by native_decide
  face_closed := by native_decide

/-- Euler characteristic confirms genus 505. -/
theorem clayworthSurface_euler :
    (4032 : ℤ) - 6048 + 1008 = 2 - 2 * 505 := by norm_num
